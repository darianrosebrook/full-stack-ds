#!/usr/bin/env bash
# Pre-push gate — a CHANGE-SCOPED pre-flight for .github/workflows/ci.yml.
#
# CI is the AUTHORITATIVE full gate (it additionally runs e2e:rail + chromium
# and the other framework suites — it is a superset of this hook). This hook
# runs only the step-groups whose inputs are in the push diff, so a docs/
# scripts/spec-only push doesn't pay to regenerate every framework. It is
# conservative: an indeterminate range, a classifier failure, or PREPUSH_FULL=1
# all fall back to the FULL sequence. It can over-skip relative to CI but never
# silently skips a step whose input changed; CI is the backstop.
#
# Scoping logic: scripts/prepush-scope.mjs (pure, unit-tested in
# scripts/prepush-scope.test.mjs). Step-group order is fail-fast: install ->
# lint -> typecheck -> token build (once) -> token gates -> generate:check ->
# docs -> tests -> governed:rail (heaviest, last).
#
# Activate per clone:   git config core.hooksPath .githooks
# Emergency bypass:      git push --no-verify   (CI still runs)
# Force the full gate:   PREPUSH_FULL=1 git push
#
# Maintenance: when ci.yml changes its step LIST, update the step commands here
# AND scripts/prepush-scope.mjs's path->group mapping in lockstep.

set -euo pipefail

ROOT="$(git rev-parse --show-toplevel)"
cd "$ROOT"

ZERO="0000000000000000000000000000000000000000"

# Which commits are being pushed? Capture the tip + the remote sha from stdin.
PUSHING_COMMITS=false
TIP=""
REMOTE_SHA=""
while IFS=' ' read -r _local_ref local_sha _remote_ref remote_sha; do
  if [ -n "${local_sha:-}" ] && [ "$local_sha" != "$ZERO" ]; then
    PUSHING_COMMITS=true
    TIP="$local_sha"
    REMOTE_SHA="${remote_sha:-}"
    break
  fi
done

if [ "$PUSHING_COMMITS" = false ]; then
  echo "[pre-push] no commits to push; skipping gate"
  exit 0
fi

# --- determine the diff range (or fall back to FULL) ---
FULL=false
[ "${PREPUSH_FULL:-}" = "1" ] && FULL=true

BASE=""
if [ "$FULL" = false ]; then
  # Prefer the merge-base with origin/main (the full branch delta vs main);
  # fall back to the last-pushed remote sha; else FULL.
  if git rev-parse --verify --quiet origin/main >/dev/null 2>&1; then
    BASE="$(git merge-base origin/main "$TIP" 2>/dev/null || true)"
  fi
  if [ -z "$BASE" ] && [ -n "$REMOTE_SHA" ] && [ "$REMOTE_SHA" != "$ZERO" ]; then
    BASE="$REMOTE_SHA"
  fi
  [ -z "$BASE" ] && FULL=true
fi

CHANGED=""
if [ "$FULL" = false ]; then
  CHANGED="$(git diff --name-only "$BASE" "$TIP" || true)"
fi

# --- classify into RUN_* step-group flags (fail-safe to FULL on any error) ---
if [ "$FULL" = true ]; then
  FLAGS="$(node "$ROOT/scripts/prepush-scope.mjs" --full)" || FLAGS=""
else
  FLAGS="$(printf '%s\n' "$CHANGED" | node "$ROOT/scripts/prepush-scope.mjs")" \
    || FLAGS="$(node "$ROOT/scripts/prepush-scope.mjs" --full || true)"
fi
if [ -z "$FLAGS" ]; then
  echo "[pre-push] classifier produced no output — running FULL gate"
  FLAGS="$(node "$ROOT/scripts/prepush-scope.mjs" --full)"
fi
eval "$FLAGS"

if [ "$FULL" = true ]; then
  echo "[pre-push] $REASON"
else
  echo "[pre-push] range ${BASE:0:9}..${TIP:0:9} — $REASON"
fi
echo ""

# --- install: only when deps could have changed (or full) ---
NEED_INSTALL=false
if [ "$FULL" = true ]; then
  NEED_INSTALL=true
elif printf '%s\n' "$CHANGED" | grep -qE '(^|/)(pnpm-lock\.yaml|package\.json)$'; then
  NEED_INSTALL=true
fi
if [ "$NEED_INSTALL" = true ]; then
  echo "[pre-push] install — pnpm install --frozen-lockfile"
  pnpm install --frozen-lockfile
else
  echo "[pre-push] skip install (no package.json / lockfile change)"
fi

# --- fail-fast: lint + typecheck before the heavy token/rail work ---
if [ "${RUN_LINT:-false}" = true ]; then
  echo ""; echo "[pre-push] lint — pnpm run lint"; pnpm run lint
else echo "[pre-push] skip lint"; fi

if [ "${RUN_TYPECHECK:-false}" = true ]; then
  echo ""; echo "[pre-push] typecheck (root + codegen)"; pnpm run typecheck
  echo "[pre-push] typecheck:vue"; pnpm run typecheck:vue
else echo "[pre-push] skip typecheck"; fi

# --- token build (once): tokens:build:check emits the composed graph that
#     generate:check needs AND runs the committed-output drift diff. This folds
#     the old standalone tokens:build into one step. ---
if [ "${RUN_TOKEN_BUILD:-false}" = true ]; then
  echo ""; echo "[pre-push] tokens:build:check (build composed graph + drift diff)"
  pnpm run tokens:build:check
else echo "[pre-push] skip token build"; fi

# --- token gates: only when ds-tokens source changed ---
if [ "${RUN_TOKEN_GATES:-false}" = true ]; then
  echo ""; echo "[pre-push] tokens:validate"; pnpm run tokens:validate
  echo "[pre-push] tokens:check-contrast"; pnpm run tokens:check-contrast
  echo "[pre-push] tokens:check-brand-refs"; pnpm run tokens:check-brand-refs
  echo "[pre-push] tokens:check-usage:gate"; pnpm run tokens:check-usage:gate
else echo "[pre-push] skip token gates"; fi

# --- generate:check (reuses the composed graph built above) + docs claims ---
if [ "${RUN_GENERATE_CHECK:-false}" = true ]; then
  echo ""; echo "[pre-push] generate:check"; pnpm run generate:check
else echo "[pre-push] skip generate:check"; fi

if [ "${RUN_DOCS_CLAIMS:-false}" = true ]; then
  echo "[pre-push] docs:check-claims"; pnpm run docs:check-claims
else echo "[pre-push] skip docs:check-claims"; fi

# --- tests ---
if [ "${RUN_TESTS:-false}" = true ]; then
  echo ""; echo "[pre-push] test (root) + test:vue"; pnpm test; pnpm run test:vue
else echo "[pre-push] skip tests"; fi

# --- heaviest, last: governed:rail + generated-tree drift diff ---
if [ "${RUN_RAIL:-false}" = true ]; then
  echo ""; echo "[pre-push] governed:rail + framework-src diff"
  pnpm run governed:rail
  if ! git diff --exit-code -- \
      packages/ds-react/src \
      packages/ds-vue/src \
      packages/ds-svelte/src \
      packages/ds-angular/src \
      packages/ds-lit/src; then
    echo ""
    echo "[pre-push] generated framework src trees have uncommitted drift after"
    echo "[pre-push] running the rail. Commit the regen output before pushing."
    echo "[pre-push] CI will reject otherwise."
    exit 1
  fi
else echo "[pre-push] skip governed:rail"; fi

echo ""
echo "[pre-push] all selected checks passed; proceeding with push"
