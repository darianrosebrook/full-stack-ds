#!/usr/bin/env bash
# Pre-push gate — runs the same sequence GitHub Actions runs in
# .github/workflows/ci.yml. The contract: if this passes locally, CI
# should pass too. Reasoning behind every step is in that workflow file
# (search for the matching `- name:` block).
#
# Install: this file is tracked in `.githooks/`. To activate it for
# your clone, run once:
#
#     git config core.hooksPath .githooks
#
# To bypass for an emergency push (use sparingly — CI will still run):
#
#     git push --no-verify
#
# Maintenance: when .github/workflows/ci.yml changes its step list, this
# script must change in lockstep. The header comment in CI references
# this file by path so the dependency is discoverable.

set -euo pipefail

cd "$(git rev-parse --show-toplevel)"

# Don't run when pushing tags or when no commits are being pushed
# (e.g. `git push --tags` with up-to-date branch).
PUSHING_COMMITS=false
while IFS=' ' read -r _local_ref local_sha _remote_ref remote_sha; do
  if [ -n "$local_sha" ] && [ "$local_sha" != "0000000000000000000000000000000000000000" ]; then
    PUSHING_COMMITS=true
    break
  fi
done

if [ "$PUSHING_COMMITS" = false ]; then
  echo "[pre-push] no commits to push; skipping gate"
  exit 0
fi

echo "[pre-push] running CI-equivalent gate (mirrors .github/workflows/ci.yml)"
echo ""

# Mirror CI's `pnpm install --frozen-lockfile`. Running this catches
# lockfile drift before we push — the same drift that produces the
# "@jest/globals not found" class of CI failure.
echo "[pre-push 1/13] pnpm install --frozen-lockfile"
pnpm install --frozen-lockfile

# Mirror CI's "Build design tokens" step. `generate:check` (next step)
# loads `composed.tokens.json` to verify every contract's `resolvesTo`
# path, but that file is gitignored (regenerable scratch), so we have
# to emit it before validation runs. Without this step, every contract
# reports `token graph not built` DRIFT and the gate fails before any
# real validation runs.
echo ""
echo "[pre-push 2/13] pnpm -F @full-stack-ds/tokens build"
pnpm -F @full-stack-ds/tokens build

echo ""
echo "[pre-push 3/13] pnpm run generate:check"
# `generate:check` is `generate:validate` PLUS the cross-graph semantic
# checks (every contract resolvesTo path must exist in the composed
# token graph; emitted CSS must match contract truth; styles selectors
# don't collide). The bare `generate:validate` only checks JSON-Schema
# shape, which is how a token-graph cleanup landed silently in 2026-05:
# contracts still referenced `semantic.overlay.scrim.dialog` after the
# shard was deleted, and the shape validator said VALID because the
# contract JSON was well-formed. `generate:check` is the real gate.
pnpm run generate:check

# Design tokens — DTCG validation catches malformed token JSON,
# self-references, and unknown $type values before they reach codegen.
echo ""
echo "[pre-push 4/13] pnpm run tokens:validate"
pnpm run tokens:validate

# Design tokens — drift gate. Rebuilds composed.tokens.json + tokens.css
# from source and refuses if the regenerated artifacts differ from what's
# committed. Mirrors the `governed:rail` drift check below but scoped to
# the tokens output.
echo ""
echo "[pre-push 5/13] pnpm run tokens:build:check"
pnpm run tokens:build:check

# Design tokens — WCAG contrast gate. Loads resolved.tokens.json and
# checks the curated foreground × background pair list against AA. Fails
# loud if any pair drops below its declared level.
echo ""
echo "[pre-push 6/13] pnpm run tokens:check-contrast"
pnpm run tokens:check-contrast

# Design tokens — brand-reference verifier. Every `{ref}` inside the 10
# brand override files must resolve to an actual token in the composed
# graph. The token build deliberately skips brand-file ref validation
# (brand overrides land in a separate cascade layer with a local
# definedVars set), so `{color.palette.cobalt.500}` would silently
# no-op at runtime without this gate. See build/runners/check-brand-refs.ts.
echo ""
echo "[pre-push 7/13] pnpm run tokens:check-brand-refs"
pnpm run tokens:check-brand-refs

# Design tokens — usage regression gate. Fails if any token in the
# composed graph that was USED at baseline time has become unused, or
# if total unused count grew. Baseline lives at
# packages/ds-tokens/usage-baseline.json. To intentionally land a new
# unused token (e.g. publishing one ahead of consumers), re-baseline
# with `pnpm run tokens:write-usage-baseline` and commit the result.
echo ""
echo "[pre-push 8/13] pnpm run tokens:check-usage:gate"
pnpm run tokens:check-usage:gate

echo ""
echo "[pre-push 9/13] pnpm run lint"
pnpm run lint

echo ""
echo "[pre-push 10/13] pnpm run typecheck (root + codegen)"
pnpm run typecheck

echo ""
echo "[pre-push 11/13] pnpm run typecheck:vue"
pnpm run typecheck:vue

echo ""
echo "[pre-push 12/13] pnpm test (root) + pnpm run test:vue"
pnpm test
pnpm run test:vue

echo ""
echo "[pre-push 13/13] pnpm run governed:rail + framework-src diff check"
pnpm run governed:rail

# Mirror the CI "Generated artifacts are committed" step. If the rail
# regenerated and produced drift, this fails — preventing a push that
# would land out-of-sync generated files.
if ! git diff --exit-code -- \
    packages/ds-react/src \
    packages/ds-vue/src \
    packages/ds-svelte/src \
    packages/ds-angular/src \
    packages/ds-lit/src; then
  echo ""
  echo "[pre-push] generated framework src trees have uncommitted drift after"
  echo "[pre-push] running the rail. The rail regenerates from contracts; if"
  echo "[pre-push] the regen produced different output than what's committed,"
  echo "[pre-push] commit the regen output before pushing. CI will reject."
  exit 1
fi

echo ""
echo "[pre-push] all checks passed; proceeding with push"
