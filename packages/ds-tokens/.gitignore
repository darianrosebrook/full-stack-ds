# Build outputs — regenerated by `pnpm -F @full-stack-ds/tokens build`.
# Committed-but-not-tracked is unsafe for token CSS (consumers can't
# install from a fresh clone), so we DO track generated/tokens.css and
# generated/brands/*.brand.css. Everything else under generated/ is
# regenerable scratch.
dist/
generated/.cache/
# Incremental-build hash cache written by build/core/cache.ts (file-hashes.json).
# Per-clone state, not part of the source-of-truth.
.cache/
# Composed-tree intermediate (compose.ts → global.ts handoff). Regenerable; not
# tracked, since it'd churn on every build.
generated/composed.tokens.json
*.tsbuildinfo
