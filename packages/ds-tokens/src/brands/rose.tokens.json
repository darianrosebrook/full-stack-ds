{
  "$brand": {
    "name": "rose",
    "description": "Pink/rose brand theme - soft, elegant, and gentle",
    "accent": "pink",
    "density": "spacious"
  },
  "color": {
    "foreground": {
      "accent": {
        "$type": "color",
        "$value": "{color.palette.pink.600}",
        "$extensions": {
          "fsds.light": "{color.palette.pink.600}",
          "fsds.dark": "{color.palette.pink.400}"
        }
      },
      "link": {
        "$type": "color",
        "$value": "{color.palette.pink.600}",
        "$extensions": {
          "fsds.light": "{color.palette.pink.600}",
          "fsds.dark": "{color.palette.pink.400}"
        }
      },
      "linkHover": {
        "$type": "color",
        "$value": "{color.palette.pink.700}",
        "$extensions": {
          "fsds.light": "{color.palette.pink.700}",
          "fsds.dark": "{color.palette.pink.300}"
        }
      },
      "linkVisited": {
        "$type": "color",
        "$value": "{color.palette.pink.500}",
        "$extensions": {
          "fsds.light": "{color.palette.pink.500}",
          "fsds.dark": "{color.palette.pink.500}"
        }
      },
      "highlight": {
        "$type": "color",
        "$value": "{color.palette.pink.700}",
        "$extensions": {
          "fsds.light": "{color.palette.pink.700}",
          "fsds.dark": "{color.palette.pink.200}"
        }
      }
    },
    "background": {
      "accent": {
        "$type": "color",
        "$value": "{color.palette.pink.500}",
        "$extensions": {
          "fsds.light": "{color.palette.pink.500}",
          "fsds.dark": "{color.palette.pink.500}"
        }
      },
      "highlight": {
        "$type": "color",
        "$value": "{color.palette.pink.100}",
        "$extensions": {
          "fsds.light": "{color.palette.pink.100}",
          "fsds.dark": "{color.palette.pink.800}"
        }
      },
      "brand": {
        "$type": "color",
        "$value": "{color.palette.pink.50}",
        "$extensions": {
          "fsds.light": "{color.palette.pink.50}",
          "fsds.dark": "{color.palette.pink.900}"
        },
        "$description": "Softest pink wash for brand surfaces - gentle, airy"
      }
    },
    "border": {
      "accent": {
        "$type": "color",
        "$value": "{color.palette.pink.500}",
        "$extensions": {
          "fsds.light": "{color.palette.pink.500}",
          "fsds.dark": "{color.palette.pink.400}"
        }
      },
      "default": {
        "$type": "color",
        "$value": "{color.palette.pink.200}",
        "$extensions": {
          "fsds.light": "{color.palette.pink.200}",
          "fsds.dark": "{color.palette.pink.600}"
        },
        "$description": "Default input border - soft rose tint"
      },
      "hover": {
        "$type": "color",
        "$value": "{color.palette.pink.300}",
        "$extensions": {
          "fsds.light": "{color.palette.pink.300}",
          "fsds.dark": "{color.palette.pink.500}"
        },
        "$description": "Input hover border - warmer rose"
      },
      "focus": {
        "$type": "color",
        "$value": "{color.palette.pink.500}",
        "$extensions": {
          "fsds.light": "{color.palette.pink.500}",
          "fsds.dark": "{color.palette.pink.400}"
        },
        "$description": "Input focus border - elegant rose accent"
      },
      "light": {
        "$type": "color",
        "$value": "{color.palette.pink.100}",
        "$extensions": {
          "fsds.light": "{color.palette.pink.100}",
          "fsds.dark": "{color.palette.pink.700}"
        },
        "$description": "Light input border - very subtle rose"
      },
      "primary": {
        "$type": "color",
        "$value": "{color.palette.pink.300}",
        "$extensions": {
          "fsds.light": "{color.palette.pink.300}",
          "fsds.dark": "{color.palette.pink.500}"
        },
        "$description": "Primary input border - medium rose"
      }
    },
    "navigation": {
      "foreground": {
        "active": {
          "$type": "color",
          "$value": "{color.palette.pink.600}",
          "$extensions": {
            "fsds.light": "{color.palette.pink.600}",
            "fsds.dark": "{color.palette.pink.400}"
          }
        }
      },
      "background": {
        "active": {
          "$type": "color",
          "$value": "{color.palette.pink.50}",
          "$extensions": {
            "fsds.light": "{color.palette.pink.50}",
            "fsds.dark": "{color.palette.pink.900}"
          },
          "$description": "Active nav item background - soft pink wash via stateLayer"
        },
        "hover": {
          "$type": "color",
          "$value": "{color.palette.pink.100}",
          "$extensions": {
            "fsds.light": "{color.palette.pink.100}",
            "fsds.dark": "{color.palette.pink.800}"
          },
          "$description": "Hover nav item background - gentle pink tint"
        }
      },
      "stateLayer": {
        "hover": {
          "$type": "number",
          "$value": "{interaction.stateLayer.hover}",
          "$description": "Nav hover state-layer opacity - tonal pink overlay"
        },
        "selected": {
          "$type": "number",
          "$value": "{interaction.stateLayer.selected}",
          "$description": "Nav selected state-layer opacity - tonal pink overlay"
        }
      }
    },
    "action": {
      "background": {
        "primary": {
          "default": {
            "$type": "color",
            "$value": "{color.palette.pink.500}"
          },
          "hover": {
            "$type": "color",
            "$value": "{color.palette.pink.600}"
          },
          "active": {
            "$type": "color",
            "$value": "{color.palette.pink.700}"
          }
        }
      },
      "border": {
        "primary": {
          "default": {
            "$type": "color",
            "$value": "{color.palette.pink.500}"
          },
          "focus": {
            "$type": "color",
            "$value": "{color.palette.pink.400}"
          }
        }
      }
    },
    "status": {
      "highlight": {
        "$type": "color",
        "$value": "{color.palette.pink.300}",
        "$extensions": {
          "fsds.light": "{color.palette.pink.300}",
          "fsds.dark": "{color.palette.pink.400}"
        }
      }
    }
  },
  "shape": {
    "control": {
      "radius": {
        "default": {
          "$type": "dimension",
          "$value": "{shape.radius.full}",
          "$description": "Pill radius - soft, elegant curves"
        }
      }
    },
    "card": {
      "radius": {
        "$type": "dimension",
        "$value": "{shape.radius.05}",
        "$description": "Card border radius (32px) - very soft, elegant"
      },
      "border": {
        "light": {
          "$type": "color",
          "$value": "{color.palette.pink.100}",
          "$extensions": {
            "fsds.light": "{color.palette.pink.100}",
            "fsds.dark": "{color.palette.pink.800}"
          },
          "$description": "Light card border - very subtle rose"
        },
        "medium": {
          "$type": "color",
          "$value": "{color.palette.pink.200}",
          "$extensions": {
            "fsds.light": "{color.palette.pink.200}",
            "fsds.dark": "{color.palette.pink.700}"
          },
          "$description": "Medium card border - subtle elegant rose"
        },
        "dark": {
          "$type": "color",
          "$value": "{color.palette.pink.400}",
          "$extensions": {
            "fsds.light": "{color.palette.pink.400}",
            "fsds.dark": "{color.palette.pink.500}"
          },
          "$description": "Dark card border - visible rose"
        },
        "transparent": {
          "$type": "color",
          "$value": "{color.mode.transparent}",
          "$extensions": {
            "fsds.light": "{color.mode.transparent}",
            "fsds.dark": "{color.mode.transparent}"
          },
          "$description": "Transparent card border - soft, elegant"
        }
      },
      "elevation": {
        "near": {
          "$type": "shadow",
          "$value": "{elevation.surface.raised}",
          "$description": "Near elevation - gentle resting surface shadow"
        },
        "default": {
          "$type": "shadow",
          "$value": "{elevation.surface.raised}",
          "$description": "Default elevation - soft raised surface (elegant, not dramatic)"
        },
        "far": {
          "$type": "shadow",
          "$value": "{elevation.surface.floating}",
          "$description": "Far elevation - gently floating surface"
        },
        "none": {
          "$type": "shadow",
          "$value": "{elevation.surface.flat}",
          "$description": "No elevation - flush surface"
        }
      }
    },
    "element": {
      "radius": {
        "$type": "dimension",
        "$value": "{shape.radius.04}",
        "$description": "Internal element radius (16px) - gentle, elegant"
      }
    },
    "button": {
      "radius": {
        "$type": "dimension",
        "$value": "{shape.radius.04}",
        "$description": "Button radius (16px) - soft, distinguished from sunset"
      }
    },
    "badge": {
      "radius": {
        "$type": "dimension",
        "$value": "{shape.radius.full}",
        "$description": "Badge/chip radius (pill)"
      }
    },
    "input": {
      "radius": {
        "default": {
          "$type": "dimension",
          "$value": "{shape.radius.full}",
          "$description": "Input border radius - pill-shaped, elegant (9999px)"
        }
      },
      "border": {
        "defaultWidth": {
          "$type": "dimension",
          "$value": "{shape.border.width.hairline}",
          "$description": "Input border width - delicate, gentle (1px)"
        },
        "defaultStyle": {
          "$type": "strokeStyle",
          "$value": "{shape.border.style.solid}",
          "$description": "Input border style - solid, soft"
        },
        "focusWidth": {
          "$type": "dimension",
          "$value": "{shape.border.width.hairline}",
          "$description": "Input focus border width - gentle emphasis (1px)"
        }
      }
    },
    "field": {
      "radius": {
        "default": {
          "$type": "dimension",
          "$value": "{shape.radius.full}",
          "$description": "Field border radius - pill-shaped, elegant (9999px)"
        }
      },
      "border": {
        "defaultWidth": {
          "$type": "dimension",
          "$value": "{shape.border.width.hairline}",
          "$description": "Field border width - delicate (1px)"
        },
        "focusWidth": {
          "$type": "dimension",
          "$value": "{shape.border.width.hairline}",
          "$description": "Field focus border width - gentle (1px)"
        }
      }
    }
  },
  "spacing": {
    "component": {
      "padding": {
        "$type": "dimension",
        "$value": "{spacing.size.07}",
        "$description": "Airy component padding (24px)"
      },
      "gap": {
        "$type": "dimension",
        "$value": "{spacing.size.06}",
        "$description": "Airy component gap (16px)"
      }
    },
    "card": {
      "padding": {
        "$type": "dimension",
        "$value": "{spacing.size.08}",
        "$description": "Card padding (32px)"
      }
    }
  },
  "motion": {
    "interaction": {
      "duration": {
        "$type": "duration",
        "$value": "{motion.duration.long3}",
        "$description": "Very gentle transitions (1000ms) - soft, elegant"
      },
      "easing": {
        "$type": "cubicBezier",
        "$value": "{motion.easing.soft.enter}",
        "$description": "Soft, gentle easing curve"
      }
    }
  },
  "typography": {
    "body": {
      "fontWeight": {
        "$type": "fontWeight",
        "$value": "{typography.weight.light}",
        "$description": "Light body weight (300) - delicate"
      }
    },
    "heading": {
      "fontWeight": {
        "$type": "fontWeight",
        "$value": "{typography.weight.light}",
        "$description": "Light heading weight (300) - soft, elegant"
      }
    }
  }
}
