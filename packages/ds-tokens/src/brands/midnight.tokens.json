{
  "$brand": {
    "name": "midnight",
    "description": "Premium midnight brand with purple/violet accents - mysterious and sophisticated",
    "accent": "violet",
    "density": "tight"
  },
  "color": {
    "foreground": {
      "accent": {
        "$type": "color",
        "$value": "{color.palette.violet.500}",
        "$extensions": {
          "fsds.light": "{color.palette.violet.500}",
          "fsds.dark": "{color.palette.violet.400}"
        }
      },
      "link": {
        "$type": "color",
        "$value": "{color.palette.violet.500}",
        "$extensions": {
          "fsds.light": "{color.palette.violet.500}",
          "fsds.dark": "{color.palette.violet.400}"
        }
      },
      "linkHover": {
        "$type": "color",
        "$value": "{color.palette.violet.600}",
        "$extensions": {
          "fsds.light": "{color.palette.violet.600}",
          "fsds.dark": "{color.palette.violet.300}"
        }
      },
      "linkVisited": {
        "$type": "color",
        "$value": "{color.palette.violet.400}",
        "$extensions": {
          "fsds.light": "{color.palette.violet.400}",
          "fsds.dark": "{color.palette.violet.500}"
        }
      },
      "highlight": {
        "$type": "color",
        "$value": "{color.palette.violet.700}",
        "$extensions": {
          "fsds.light": "{color.palette.violet.700}",
          "fsds.dark": "{color.palette.violet.200}"
        }
      }
    },
    "background": {
      "accent": {
        "$type": "color",
        "$value": "{color.palette.violet.500}",
        "$extensions": {
          "fsds.light": "{color.palette.violet.500}",
          "fsds.dark": "{color.palette.violet.400}"
        }
      },
      "highlight": {
        "$type": "color",
        "$value": "{color.palette.violet.100}",
        "$extensions": {
          "fsds.light": "{color.palette.violet.100}",
          "fsds.dark": "{color.palette.violet.800}"
        }
      },
      "brand": {
        "$type": "color",
        "$value": "{color.palette.violet.500}",
        "$extensions": {
          "fsds.light": "{color.palette.violet.500}",
          "fsds.dark": "{color.palette.violet.400}"
        }
      }
    },
    "border": {
      "accent": {
        "$type": "color",
        "$value": "{color.palette.violet.500}",
        "$extensions": {
          "fsds.light": "{color.palette.violet.500}",
          "fsds.dark": "{color.palette.violet.400}"
        }
      },
      "default": {
        "$type": "color",
        "$value": "{color.palette.indigo.300}",
        "$extensions": {
          "fsds.light": "{color.palette.indigo.300}",
          "fsds.dark": "{color.palette.indigo.700}"
        },
        "$description": "Default border - cool indigo depth instead of neutral gray"
      },
      "hover": {
        "$type": "color",
        "$value": "{color.palette.indigo.500}",
        "$extensions": {
          "fsds.light": "{color.palette.indigo.500}",
          "fsds.dark": "{color.palette.indigo.400}"
        },
        "$description": "Hover border - mid indigo, cool counterpoint to violet accent"
      },
      "focus": {
        "$type": "color",
        "$value": "{color.palette.violet.600}",
        "$extensions": {
          "fsds.light": "{color.palette.violet.600}",
          "fsds.dark": "{color.palette.violet.400}"
        },
        "$description": "Focus border - deeper violet for decisive focus ring"
      },
      "light": {
        "$type": "color",
        "$value": "{color.palette.indigo.200}",
        "$extensions": {
          "fsds.light": "{color.palette.indigo.200}",
          "fsds.dark": "{color.palette.indigo.800}"
        },
        "$description": "Light border - whisper indigo tint"
      },
      "primary": {
        "$type": "color",
        "$value": "{color.palette.indigo.400}",
        "$extensions": {
          "fsds.light": "{color.palette.indigo.400}",
          "fsds.dark": "{color.palette.indigo.600}"
        },
        "$description": "Primary border - medium indigo structural line"
      }
    },
    "navigation": {
      "foreground": {
        "active": {
          "$type": "color",
          "$value": "{color.palette.violet.500}",
          "$extensions": {
            "fsds.light": "{color.palette.violet.500}",
            "fsds.dark": "{color.palette.violet.400}"
          }
        }
      }
    },
    "action": {
      "background": {
        "primary": {
          "default": {
            "$type": "color",
            "$value": "{color.palette.violet.600}",
            "$extensions": {
              "fsds.light": "{color.palette.violet.600}",
              "fsds.dark": "{color.palette.violet.500}"
            },
            "$description": "Primary action fill - deep violet 600 (AA white contrast light; 500 dark)"
          },
          "hover": {
            "$type": "color",
            "$value": "{color.palette.violet.700}",
            "$extensions": {
              "fsds.light": "{color.palette.violet.700}",
              "fsds.dark": "{color.palette.violet.600}"
            },
            "$description": "Primary action hover - violet 700 for decisive depth"
          },
          "active": {
            "$type": "color",
            "$value": "{color.palette.violet.800}",
            "$extensions": {
              "fsds.light": "{color.palette.violet.800}",
              "fsds.dark": "{color.palette.violet.700}"
            },
            "$description": "Primary action pressed - violet 800 for maximum depth"
          }
        }
      },
      "border": {
        "primary": {
          "default": {
            "$type": "color",
            "$value": "{color.palette.violet.600}",
            "$extensions": {
              "fsds.light": "{color.palette.violet.600}",
              "fsds.dark": "{color.palette.violet.500}"
            }
          },
          "focus": {
            "$type": "color",
            "$value": "{color.palette.indigo.500}",
            "$extensions": {
              "fsds.light": "{color.palette.indigo.500}",
              "fsds.dark": "{color.palette.indigo.400}"
            },
            "$description": "Focus ring - indigo 500 provides cool contrast against violet fill"
          }
        }
      }
    },
    "status": {
      "highlight": {
        "$type": "color",
        "$value": "{color.palette.violet.400}",
        "$extensions": {
          "fsds.light": "{color.palette.violet.400}",
          "fsds.dark": "{color.palette.violet.500}"
        }
      }
    },
    "background": {
      "accent": {
        "$type": "color",
        "$value": "{color.palette.violet.500}",
        "$extensions": {
          "fsds.light": "{color.palette.violet.500}",
          "fsds.dark": "{color.palette.violet.500}"
        },
        "$description": "Accent fill — violet.500 in both themes (not .400) so white on-color text clears WCAG AA (4.82:1 vs 3.5:1)."
      },
      "brand": {
        "$type": "color",
        "$value": "{color.palette.violet.500}",
        "$extensions": {
          "fsds.light": "{color.palette.violet.500}",
          "fsds.dark": "{color.palette.violet.500}"
        }
      },
      "highlight": {
        "$type": "color",
        "$value": "{color.palette.violet.100}",
        "$extensions": {
          "fsds.light": "{color.palette.violet.100}",
          "fsds.dark": "{color.palette.violet.800}"
        }
      },
      "info": {
        "softer": {
          "$type": "color",
          "$value": "{color.palette.indigo.50}",
          "$extensions": {
            "fsds.light": "{color.palette.indigo.50}",
            "fsds.dark": "{color.palette.indigo.900}"
          },
          "$description": "Info softer wash - indigo-tinted for midnight brand"
        }
      }
    }
  },
  "shape": {
    "control": {
      "radius": {
        "default": {
          "$type": "dimension",
          "$value": "{shape.radius.none}",
          "$description": "No radius (0px) - ultra-sharp, sophisticated"
        }
      }
    },
    "card": {
      "radius": {
        "$type": "dimension",
        "$value": "{shape.radius.none}",
        "$description": "Card border radius (0px) - angular, dramatic"
      },
      "border": {
        "light": {
          "$type": "color",
          "$value": "{color.palette.indigo.200}",
          "$extensions": {
            "fsds.light": "{color.palette.indigo.200}",
            "fsds.dark": "{color.palette.indigo.800}"
          },
          "$description": "Light card border - cool indigo whisper (depth without violet competition)"
        },
        "medium": {
          "$type": "color",
          "$value": "{color.palette.indigo.300}",
          "$extensions": {
            "fsds.light": "{color.palette.indigo.300}",
            "fsds.dark": "{color.palette.indigo.700}"
          },
          "$description": "Medium card border - indigo structural line, cool and decisive"
        },
        "dark": {
          "$type": "color",
          "$value": "{color.palette.violet.600}",
          "$extensions": {
            "fsds.light": "{color.palette.violet.600}",
            "fsds.dark": "{color.palette.violet.500}"
          },
          "$description": "Dark card border - deep violet accent, premium drama"
        },
        "transparent": {
          "$type": "color",
          "$value": "{color.mode.transparent}",
          "$extensions": {
            "fsds.light": "{color.mode.transparent}",
            "fsds.dark": "{color.mode.transparent}"
          },
          "$description": "Transparent card border - sophisticated, no border"
        }
      },
      "elevation": {
        "near": {
          "$type": "shadow",
          "$value": "{elevation.surface.raised}",
          "$description": "Near elevation - cards resting above the page plane"
        },
        "default": {
          "$type": "shadow",
          "$value": "{elevation.surface.floating}",
          "$description": "Default elevation - dramatic floating surface (midnight signature)"
        },
        "far": {
          "$type": "shadow",
          "$value": "{elevation.surface.dialog}",
          "$description": "Far elevation - full dialog-level shadow, maximum drama"
        },
        "none": {
          "$type": "shadow",
          "$value": "{elevation.surface.flat}",
          "$description": "No elevation - flush with the page plane"
        }
      }
    },
    "element": {
      "radius": {
        "$type": "dimension",
        "$value": "{shape.radius.none}",
        "$description": "Internal element radius (0px) - sharp corners"
      }
    },
    "button": {
      "radius": {
        "$type": "dimension",
        "$value": "{shape.radius.01}",
        "$description": "Button radius (2px) - barely rounded, sharp"
      }
    },
    "badge": {
      "radius": {
        "$type": "dimension",
        "$value": "{shape.radius.01}",
        "$description": "Badge/chip radius (2px) - minimal rounding"
      }
    },
    "input": {
      "radius": {
        "default": {
          "$type": "dimension",
          "$value": "{shape.radius.none}",
          "$description": "Input border radius - sharp, sophisticated (0px)"
        }
      },
      "border": {
        "defaultWidth": {
          "$type": "dimension",
          "$value": "{shape.border.width.thick}",
          "$description": "Input border width - bold, premium (2px)"
        },
        "defaultStyle": {
          "$type": "strokeStyle",
          "$value": "{shape.border.style.solid}",
          "$description": "Input border style - solid, sophisticated"
        },
        "focusWidth": {
          "$type": "dimension",
          "$value": "{shape.border.width.thick}",
          "$description": "Input focus border width - bold emphasis (2px)"
        }
      }
    },
    "field": {
      "radius": {
        "default": {
          "$type": "dimension",
          "$value": "{shape.radius.none}",
          "$description": "Field border radius - angular, dramatic (0px)"
        }
      },
      "border": {
        "defaultWidth": {
          "$type": "dimension",
          "$value": "{shape.border.width.thick}",
          "$description": "Field border width - bold (2px)"
        },
        "focusWidth": {
          "$type": "dimension",
          "$value": "{shape.border.width.thick}",
          "$description": "Field focus border width - bold (2px)"
        }
      }
    }
  },
  "spacing": {
    "component": {
      "padding": {
        "$type": "dimension",
        "$value": "{spacing.size.03}",
        "$description": "Ultra-dense component padding (4px)"
      },
      "gap": {
        "$type": "dimension",
        "$value": "{spacing.size.02}",
        "$description": "Ultra-dense component gap (2px)"
      }
    },
    "card": {
      "padding": {
        "$type": "dimension",
        "$value": "{spacing.size.04}",
        "$description": "Card padding (8px)"
      }
    }
  },
  "motion": {
    "interaction": {
      "duration": {
        "$type": "duration",
        "$value": "{motion.duration.short1}",
        "$description": "Ultra-snappy transition speed (50ms)"
      },
      "easing": {
        "$type": "cubicBezier",
        "$value": "{motion.easing.emphasizedIn}",
        "$description": "Sharp, decisive easing"
      }
    }
  },
  "typography": {
    "body": {
      "font": {
        "weight": {
          "$type": "fontWeight",
          "$value": "{typography.weight.bold}",
          "$description": "Bold body weight (700) - strong, confident"
        }
      }
    },
    "heading": {
      "font": {
        "weight": {
          "$type": "fontWeight",
          "$value": "{typography.weight.bold}",
          "$description": "Bold heading weight (700) - strong presence"
        }
      }
    }
  }
}
