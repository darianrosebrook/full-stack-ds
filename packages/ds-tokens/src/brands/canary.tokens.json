{
  "$brand": {
    "name": "canary",
    "description": "Yellow brand theme - bright, cheerful, and playful. WCAG-safe accent fills use yellow.600+ so white text on accent backgrounds clears AA (>=4.5:1).",
    "accent": "yellow",
    "density": "default"
  },
  "color": {
    "foreground": {
      "accent": {
        "$type": "color",
        "$value": "{color.palette.yellow.600}",
        "$extensions": {
          "fsds.light": "{color.palette.yellow.600}",
          "fsds.dark": "{color.palette.yellow.300}"
        },
        "$description": "Accent foreground - text on page; light uses .600 (dark enough on white), dark uses .300 (bright against dark surfaces)"
      },
      "link": {
        "$type": "color",
        "$value": "{color.palette.yellow.600}",
        "$extensions": {
          "fsds.light": "{color.palette.yellow.600}",
          "fsds.dark": "{color.palette.yellow.300}"
        }
      },
      "linkHover": {
        "$type": "color",
        "$value": "{color.palette.yellow.700}",
        "$extensions": {
          "fsds.light": "{color.palette.yellow.700}",
          "fsds.dark": "{color.palette.yellow.200}"
        }
      },
      "linkVisited": {
        "$type": "color",
        "$value": "{color.palette.yellow.500}",
        "$extensions": {
          "fsds.light": "{color.palette.yellow.500}",
          "fsds.dark": "{color.palette.yellow.400}"
        }
      },
      "highlight": {
        "$type": "color",
        "$value": "{color.palette.yellow.800}",
        "$extensions": {
          "fsds.light": "{color.palette.yellow.800}",
          "fsds.dark": "{color.palette.yellow.100}"
        },
        "$description": "Highlight text - deep amber in light, bright yellow tint in dark"
      }
    },
    "background": {
      "accent": {
        "$type": "color",
        "$value": "{color.palette.yellow.600}",
        "$extensions": {
          "fsds.light": "{color.palette.yellow.600}",
          "fsds.dark": "{color.palette.yellow.600}"
        },
        "$description": "Accent fill - yellow.600 passes WCAG AA with white text in both modes (approx 6.8:1)"
      },
      "highlight": {
        "$type": "color",
        "$value": "{color.palette.yellow.100}",
        "$extensions": {
          "fsds.light": "{color.palette.yellow.100}",
          "fsds.dark": "{color.palette.yellow.800}"
        },
        "$description": "Warm yellow wash for highlight surfaces"
      }
    },
    "border": {
      "accent": {
        "$type": "color",
        "$value": "{color.palette.yellow.600}",
        "$extensions": {
          "fsds.light": "{color.palette.yellow.600}",
          "fsds.dark": "{color.palette.yellow.400}"
        },
        "$description": "Accent border - .600 light (strong presence), .400 dark (bright pop)"
      },
      "default": {
        "$type": "color",
        "$value": "{color.palette.neutral.300}",
        "$extensions": {
          "fsds.light": "{color.palette.neutral.300}",
          "fsds.dark": "{color.palette.neutral.600}"
        },
        "$description": "Default input border - neutral gray"
      },
      "hover": {
        "$type": "color",
        "$value": "{color.palette.yellow.400}",
        "$extensions": {
          "fsds.light": "{color.palette.yellow.400}",
          "fsds.dark": "{color.palette.yellow.500}"
        },
        "$description": "Input hover border - warm amber pop"
      },
      "focus": {
        "$type": "color",
        "$value": "{color.palette.yellow.600}",
        "$extensions": {
          "fsds.light": "{color.palette.yellow.600}",
          "fsds.dark": "{color.palette.yellow.400}"
        },
        "$description": "Input focus border - bold yellow accent ring"
      },
      "light": {
        "$type": "color",
        "$value": "{color.palette.yellow.100}",
        "$extensions": {
          "fsds.light": "{color.palette.yellow.100}",
          "fsds.dark": "{color.palette.yellow.800}"
        },
        "$description": "Light input border - delicate yellow tint"
      },
      "primary": {
        "$type": "color",
        "$value": "{color.palette.yellow.300}",
        "$extensions": {
          "fsds.light": "{color.palette.yellow.300}",
          "fsds.dark": "{color.palette.yellow.600}"
        },
        "$description": "Primary input border - warm amber"
      }
    },
    "navigation": {
      "foreground": {
        "active": {
          "$type": "color",
          "$value": "{color.palette.yellow.600}",
          "$extensions": {
            "fsds.light": "{color.palette.yellow.600}",
            "fsds.dark": "{color.palette.yellow.300}"
          }
        }
      }
    },
    "action": {
      "background": {
        "primary": {
          "default": {
            "$type": "color",
            "$value": "{color.palette.yellow.600}",
            "$description": "Primary action fill - yellow.600 (approx 6.8:1 white text contrast)"
          },
          "hover": {
            "$type": "color",
            "$value": "{color.palette.yellow.700}",
            "$description": "Primary action hover - yellow.700 (approx 9.4:1 white text contrast)"
          },
          "active": {
            "$type": "color",
            "$value": "{color.palette.yellow.800}",
            "$description": "Primary action pressed - yellow.800 (deep amber, very high contrast)"
          }
        }
      },
      "border": {
        "primary": {
          "default": {
            "$type": "color",
            "$value": "{color.palette.yellow.600}"
          },
          "focus": {
            "$type": "color",
            "$value": "{color.palette.yellow.400}"
          }
        }
      }
    },
    "status": {
      "highlight": {
        "$type": "color",
        "$value": "{color.palette.yellow.300}",
        "$extensions": {
          "fsds.light": "{color.palette.yellow.300}",
          "fsds.dark": "{color.palette.yellow.400}"
        },
        "$description": "Status highlight - cheerful warm amber"
      }
    }
  },
  "shape": {
    "control": {
      "radius": {
        "default": {
          "$type": "dimension",
          "$value": "{shape.radius.04}",
          "$description": "Friendly rounded radius (16px) - playful, approachable feel"
        }
      }
    },
    "card": {
      "radius": {
        "$type": "dimension",
        "$value": "{shape.radius.05}",
        "$description": "Generously rounded card (32px) - playful, buoyant"
      },
      "border": {
        "light": {
          "$type": "color",
          "$value": "{color.palette.yellow.50}",
          "$extensions": {
            "fsds.light": "{color.palette.yellow.50}",
            "fsds.dark": "{color.palette.yellow.900}"
          },
          "$description": "Light card border - barely-there yellow wash"
        },
        "medium": {
          "$type": "color",
          "$value": "{color.palette.yellow.100}",
          "$extensions": {
            "fsds.light": "{color.palette.yellow.100}",
            "fsds.dark": "{color.palette.yellow.800}"
          },
          "$description": "Medium card border - warm subtle yellow"
        },
        "dark": {
          "$type": "color",
          "$value": "{color.palette.yellow.300}",
          "$extensions": {
            "fsds.light": "{color.palette.yellow.300}",
            "fsds.dark": "{color.palette.yellow.600}"
          },
          "$description": "Dark card border - vivid amber accent ring"
        },
        "transparent": {
          "$type": "color",
          "$value": "{color.mode.transparent}",
          "$extensions": {
            "fsds.light": "{color.mode.transparent}",
            "fsds.dark": "{color.mode.transparent}"
          },
          "$description": "Transparent card border - no border"
        }
      },
      "elevation": {
        "near": {
          "$type": "shadow",
          "$value": "{elevation.surface.raised}",
          "$description": "Resting card elevation"
        },
        "default": {
          "$type": "shadow",
          "$value": "{elevation.surface.floating}",
          "$description": "Hovered/active card elevation"
        },
        "far": {
          "$type": "shadow",
          "$value": "{elevation.surface.overlay}",
          "$description": "Prominent card elevation - floating above siblings"
        },
        "none": {
          "$type": "shadow",
          "$value": "{elevation.surface.flat}",
          "$description": "Flat card - no shadow"
        }
      }
    },
    "element": {
      "radius": {
        "$type": "dimension",
        "$value": "{shape.radius.04}",
        "$description": "Internal element radius (16px) - consistent playful curves"
      }
    },
    "button": {
      "radius": {
        "$type": "dimension",
        "$value": "{shape.radius.04}",
        "$description": "Button radius (16px) - friendly rounded buttons"
      }
    },
    "badge": {
      "radius": {
        "$type": "dimension",
        "$value": "{shape.radius.full}",
        "$description": "Badge/chip radius - pill shape for cheerful badges"
      }
    },
    "input": {
      "radius": {
        "default": {
          "$type": "dimension",
          "$value": "{shape.radius.04}",
          "$description": "Input border radius - playful, rounded (16px)"
        }
      },
      "border": {
        "defaultWidth": {
          "$type": "dimension",
          "$value": "{shape.border.width.thick}",
          "$description": "Input border width - thick for lively, tactile feel (2px)"
        },
        "defaultStyle": {
          "$type": "strokeStyle",
          "$value": "{shape.border.style.solid}",
          "$description": "Input border style - solid"
        },
        "focusWidth": {
          "$type": "dimension",
          "$value": "{shape.border.width.thick}",
          "$description": "Input focus border width - bold ring (2px)"
        }
      }
    },
    "field": {
      "radius": {
        "default": {
          "$type": "dimension",
          "$value": "{shape.radius.04}",
          "$description": "Field border radius - generously rounded (16px)"
        }
      },
      "border": {
        "defaultWidth": {
          "$type": "dimension",
          "$value": "{shape.border.width.thick}",
          "$description": "Field border width - playful thickness (2px)"
        },
        "focusWidth": {
          "$type": "dimension",
          "$value": "{shape.border.width.thick}",
          "$description": "Field focus border width - bold accent ring (2px)"
        }
      }
    }
  },
  "spacing": {
    "component": {
      "padding": {
        "$type": "dimension",
        "$value": "{spacing.size.07}",
        "$description": "Generous component padding (24px) - airy, spacious feel"
      },
      "gap": {
        "$type": "dimension",
        "$value": "{spacing.size.06}",
        "$description": "Comfortable component gap (16px)"
      }
    },
    "card": {
      "padding": {
        "$type": "dimension",
        "$value": "{spacing.size.08}",
        "$description": "Card padding (32px) - roomy and inviting"
      }
    }
  },
  "motion": {
    "interaction": {
      "duration": {
        "$type": "duration",
        "$value": "{motion.duration.short3}",
        "$description": "Snappy transitions (167ms) - energetic and responsive"
      },
      "easing": {
        "$type": "cubicBezier",
        "$value": "{motion.easing.bounce}",
        "$description": "Bounce easing - playful slight overshoot on interactions"
      }
    }
  },
  "typography": {
    "body": {
      "font": {
        "weight": {
          "$type": "fontWeight",
          "$value": "{typography.weight.medium}",
          "$description": "Medium body weight (500) - energetic, readable"
        }
      }
    },
    "heading": {
      "font": {
        "weight": {
          "$type": "fontWeight",
          "$value": "{typography.weight.bold}",
          "$description": "Bold heading weight (700) - bright, cheerful, high-impact"
        }
      }
    }
  }
}
