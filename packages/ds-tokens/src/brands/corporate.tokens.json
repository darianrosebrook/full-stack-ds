{
  "$brand": {
    "name": "corporate",
    "description": "Professional corporate brand with blue accents - trustworthy, stable, and restrained",
    "accent": "blue",
    "density": "compact"
  },
  "color": {
    "foreground": {
      "accent": {
        "$type": "color",
        "$value": "{color.palette.blue.600}",
        "$extensions": {
          "fsds.light": "{color.palette.blue.600}",
          "fsds.dark": "{color.palette.blue.400}"
        },
        "$description": "Corporate accent foreground - deep blue in light, lighter in dark (text/icon use only)"
      },
      "onColor": {
        "$type": "color",
        "$value": "{color.palette.neutral.50}",
        "$extensions": {
          "fsds.light": "{color.palette.neutral.50}",
          "fsds.dark": "{color.palette.neutral.50}"
        },
        "$description": "Text/icon on filled accent surfaces - fixed near-white for AA contrast"
      },
      "link": {
        "$type": "color",
        "$value": "{color.palette.blue.600}",
        "$extensions": {
          "fsds.light": "{color.palette.blue.600}",
          "fsds.dark": "{color.palette.blue.400}"
        },
        "$description": "Link color - authoritative deep blue"
      },
      "linkHover": {
        "$type": "color",
        "$value": "{color.palette.blue.700}",
        "$extensions": {
          "fsds.light": "{color.palette.blue.700}",
          "fsds.dark": "{color.palette.blue.300}"
        },
        "$description": "Hovered link - decisive blue shift"
      },
      "linkVisited": {
        "$type": "color",
        "$value": "{color.palette.blue.500}",
        "$extensions": {
          "fsds.light": "{color.palette.blue.500}",
          "fsds.dark": "{color.palette.blue.600}"
        },
        "$description": "Visited link - slightly muted blue"
      },
      "highlight": {
        "$type": "color",
        "$value": "{color.palette.blue.800}",
        "$extensions": {
          "fsds.light": "{color.palette.blue.800}",
          "fsds.dark": "{color.palette.blue.200}"
        },
        "$description": "Highlight text - deep navy for authority in light mode"
      }
    },
    "background": {
      "accent": {
        "$type": "color",
        "$value": "{color.palette.blue.500}",
        "$extensions": {
          "fsds.light": "{color.palette.blue.500}",
          "fsds.dark": "{color.palette.blue.500}"
        },
        "$description": "Accent fill - blue.500 in both modes (4.81:1 vs white, clears AA)"
      },
      "highlight": {
        "$type": "color",
        "$value": "{color.palette.blue.50}",
        "$extensions": {
          "fsds.light": "{color.palette.blue.50}",
          "fsds.dark": "{color.palette.blue.800}"
        },
        "$description": "Subtle accent wash - lightest blue tint in light, deep in dark"
      },
      "brand": {
        "$type": "color",
        "$value": "{color.palette.blue.700}",
        "$extensions": {
          "fsds.light": "{color.palette.blue.700}",
          "fsds.dark": "{color.palette.blue.600}"
        },
        "$description": "Brand hero surface - deep navy for headers/banners"
      }
    },
    "border": {
      "accent": {
        "$type": "color",
        "$value": "{color.palette.blue.600}",
        "$extensions": {
          "fsds.light": "{color.palette.blue.600}",
          "fsds.dark": "{color.palette.blue.500}"
        },
        "$description": "Accent border - crisp professional blue"
      },
      "default": {
        "$type": "color",
        "$value": "{color.palette.neutral.300}",
        "$extensions": {
          "fsds.light": "{color.palette.neutral.300}",
          "fsds.dark": "{color.palette.neutral.600}"
        },
        "$description": "Default border - hairline neutral, maximally restrained"
      },
      "hover": {
        "$type": "color",
        "$value": "{color.palette.blue.400}",
        "$extensions": {
          "fsds.light": "{color.palette.blue.400}",
          "fsds.dark": "{color.palette.blue.500}"
        },
        "$description": "Hover border - blue midtone signals interactivity without drama"
      },
      "focus": {
        "$type": "color",
        "$value": "{color.palette.blue.600}",
        "$extensions": {
          "fsds.light": "{color.palette.blue.600}",
          "fsds.dark": "{color.palette.blue.400}"
        },
        "$description": "Focus border - authoritative blue ring"
      },
      "light": {
        "$type": "color",
        "$value": "{color.palette.blue.100}",
        "$extensions": {
          "fsds.light": "{color.palette.blue.100}",
          "fsds.dark": "{color.palette.blue.700}"
        },
        "$description": "Light border - near-invisible blue tint"
      },
      "primary": {
        "$type": "color",
        "$value": "{color.palette.neutral.300}",
        "$extensions": {
          "fsds.light": "{color.palette.neutral.300}",
          "fsds.dark": "{color.palette.neutral.500}"
        },
        "$description": "Primary border - neutral gray, consistent with enterprise grid lines"
      }
    },
    "navigation": {
      "foreground": {
        "active": {
          "$type": "color",
          "$value": "{color.palette.blue.700}",
          "$extensions": {
            "fsds.light": "{color.palette.blue.700}",
            "fsds.dark": "{color.palette.blue.400}"
          },
          "$description": "Active nav item - deep blue authority in light mode"
        }
      }
    },
    "action": {
      "background": {
        "primary": {
          "default": {
            "$type": "color",
            "$value": "{color.palette.blue.600}",
            "$extensions": {
              "fsds.light": "{color.palette.blue.600}",
              "fsds.dark": "{color.palette.blue.600}"
            },
            "$description": "Primary action fill - blue.600, 6.30:1 vs white, clears AA in both modes"
          },
          "hover": {
            "$type": "color",
            "$value": "{color.palette.blue.700}",
            "$extensions": {
              "fsds.light": "{color.palette.blue.700}",
              "fsds.dark": "{color.palette.blue.500}"
            },
            "$description": "Hover fill - darker blue in light (8.72:1), blue.500 in dark (4.81:1)"
          },
          "active": {
            "$type": "color",
            "$value": "{color.palette.blue.800}",
            "$extensions": {
              "fsds.light": "{color.palette.blue.800}",
              "fsds.dark": "{color.palette.blue.400}"
            },
            "$description": "Pressed fill - deep navy pressed state"
          }
        }
      },
      "border": {
        "primary": {
          "default": {
            "$type": "color",
            "$value": "{color.palette.blue.600}",
            "$extensions": {
              "fsds.light": "{color.palette.blue.600}",
              "fsds.dark": "{color.palette.blue.500}"
            },
            "$description": "Primary action border"
          },
          "focus": {
            "$type": "color",
            "$value": "{color.palette.blue.500}",
            "$extensions": {
              "fsds.light": "{color.palette.blue.500}",
              "fsds.dark": "{color.palette.blue.300}"
            },
            "$description": "Focus ring - clear blue outline against the fill"
          }
        }
      }
    },
    "status": {
      "highlight": {
        "$type": "color",
        "$value": "{color.palette.blue.500}",
        "$extensions": {
          "fsds.light": "{color.palette.blue.500}",
          "fsds.dark": "{color.palette.blue.400}"
        },
        "$description": "Status highlight - blue accent for informational states"
      }
    }
  },
  "shape": {
    "control": {
      "radius": {
        "default": {
          "$type": "dimension",
          "$value": "{shape.radius.02}",
          "$description": "Small radius (4px) - crisp, professional enterprise look"
        }
      }
    },
    "card": {
      "radius": {
        "$type": "dimension",
        "$value": "{shape.radius.02}",
        "$description": "Card border radius (4px) - rectilinear, conservative"
      },
      "border": {
        "light": {
          "$type": "color",
          "$value": "{color.palette.blue.100}",
          "$extensions": {
            "fsds.light": "{color.palette.blue.100}",
            "fsds.dark": "{color.palette.blue.800}"
          },
          "$description": "Light card border - nearly invisible blue wash"
        },
        "medium": {
          "$type": "color",
          "$value": "{color.palette.blue.200}",
          "$extensions": {
            "fsds.light": "{color.palette.blue.200}",
            "fsds.dark": "{color.palette.blue.700}"
          },
          "$description": "Medium card border - subtle professional blue"
        },
        "dark": {
          "$type": "color",
          "$value": "{color.palette.blue.500}",
          "$extensions": {
            "fsds.light": "{color.palette.blue.500}",
            "fsds.dark": "{color.palette.blue.500}"
          },
          "$description": "Dark card border - visible blue rule for data-dense layouts"
        },
        "transparent": {
          "$type": "color",
          "$value": "{color.mode.transparent}",
          "$extensions": {
            "fsds.light": "{color.mode.transparent}",
            "fsds.dark": "{color.mode.transparent}"
          },
          "$description": "Transparent card border - no decoration"
        }
      },
      "elevation": {
        "near": {
          "$type": "shadow",
          "$value": "{elevation.surface.flat}",
          "$description": "Near elevation - flat, no shadow (corporate restraint)"
        },
        "default": {
          "$type": "shadow",
          "$value": "{elevation.surface.raised}",
          "$description": "Default elevation - minimal resting shadow"
        },
        "far": {
          "$type": "shadow",
          "$value": "{elevation.surface.floating}",
          "$description": "Far elevation - standard floating shadow (not dramatic)"
        },
        "none": {
          "$type": "shadow",
          "$value": "{elevation.surface.flat}",
          "$description": "No elevation - flush with page plane"
        }
      }
    },
    "element": {
      "radius": {
        "$type": "dimension",
        "$value": "{shape.radius.01}",
        "$description": "Internal element radius (2px) - near-square precision"
      }
    },
    "button": {
      "radius": {
        "$type": "dimension",
        "$value": "{shape.radius.02}",
        "$description": "Button radius (4px) - crisp, decisive"
      }
    },
    "badge": {
      "radius": {
        "$type": "dimension",
        "$value": "{shape.radius.02}",
        "$description": "Badge radius (4px) - rectangular, compact, data-table friendly"
      }
    },
    "input": {
      "radius": {
        "default": {
          "$type": "dimension",
          "$value": "{shape.radius.02}",
          "$description": "Input border radius - precise (4px)"
        }
      },
      "border": {
        "defaultWidth": {
          "$type": "dimension",
          "$value": "{shape.border.width.hairline}",
          "$description": "Input border width - hairline (1px) for crisp form grids"
        },
        "defaultStyle": {
          "$type": "strokeStyle",
          "$value": "{shape.border.style.solid}",
          "$description": "Input border style - solid"
        },
        "focusWidth": {
          "$type": "dimension",
          "$value": "{shape.border.width.thick}",
          "$description": "Input focus border width - 2px for clear keyboard focus"
        }
      }
    },
    "field": {
      "radius": {
        "default": {
          "$type": "dimension",
          "$value": "{shape.radius.02}",
          "$description": "Field border radius - crisp (4px)"
        }
      },
      "border": {
        "defaultWidth": {
          "$type": "dimension",
          "$value": "{shape.border.width.hairline}",
          "$description": "Field border width - hairline (1px)"
        },
        "focusWidth": {
          "$type": "dimension",
          "$value": "{shape.border.width.thick}",
          "$description": "Field focus border width - 2px"
        }
      }
    }
  },
  "spacing": {
    "component": {
      "padding": {
        "$type": "dimension",
        "$value": "{spacing.size.05}",
        "$description": "Compact component padding (12px) - dense information density"
      },
      "gap": {
        "$type": "dimension",
        "$value": "{spacing.size.04}",
        "$description": "Compact component gap (8px)"
      }
    },
    "card": {
      "padding": {
        "$type": "dimension",
        "$value": "{spacing.size.06}",
        "$description": "Card padding (16px) - efficient use of screen space"
      }
    }
  },
  "motion": {
    "interaction": {
      "duration": {
        "$type": "duration",
        "$value": "{motion.duration.short3}",
        "$description": "Standard hover/focus transition (167ms) - responsive without flash"
      },
      "easing": {
        "$type": "cubicBezier",
        "$value": "{motion.easing.standard}",
        "$description": "Standard easing - no personality, purely functional"
      }
    }
  },
  "typography": {
    "body": {
      "font": {
        "weight": {
          "$type": "fontWeight",
          "$value": "{typography.weight.regular}",
          "$description": "Regular body weight (400) - readable at data density"
        }
      }
    },
    "heading": {
      "font": {
        "weight": {
          "$type": "fontWeight",
          "$value": "{typography.weight.semibold}",
          "$description": "Semibold heading weight (600) - authoritative without shouting"
        }
      }
    }
  }
}
