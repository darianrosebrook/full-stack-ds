{
  "$brand": {
    "name": "slate",
    "description": "Steel blue brand — cool, architectural, compact density. Blue-indigo-neutral blend for a desaturated steel identity distinct from corporate's trustworthy pure blue.",
    "accent": "indigo",
    "density": "compact"
  },
  "color": {
    "foreground": {
      "accent": {
        "$type": "color",
        "$value": "{color.palette.indigo.600}",
        "$extensions": {
          "fsds.light": "{color.palette.indigo.600}",
          "fsds.dark": "{color.palette.indigo.400}"
        },
        "$description": "Steel accent foreground — indigo.600 in light (cooler than corporate blue), lighter in dark"
      },
      "onColor": {
        "$type": "color",
        "$value": "{color.palette.neutral.50}",
        "$extensions": {
          "fsds.light": "{color.palette.neutral.50}",
          "fsds.dark": "{color.palette.neutral.50}"
        },
        "$description": "Text/icon on filled accent surfaces — fixed near-white for AA contrast"
      },
      "link": {
        "$type": "color",
        "$value": "{color.palette.indigo.600}",
        "$extensions": {
          "fsds.light": "{color.palette.indigo.600}",
          "fsds.dark": "{color.palette.indigo.400}"
        },
        "$description": "Link color — steel indigo, cooler and more architectural than corporate blue"
      },
      "linkHover": {
        "$type": "color",
        "$value": "{color.palette.indigo.700}",
        "$extensions": {
          "fsds.light": "{color.palette.indigo.700}",
          "fsds.dark": "{color.palette.indigo.300}"
        },
        "$description": "Hovered link — deeper indigo shift"
      },
      "linkVisited": {
        "$type": "color",
        "$value": "{color.palette.indigo.500}",
        "$extensions": {
          "fsds.light": "{color.palette.indigo.500}",
          "fsds.dark": "{color.palette.indigo.600}"
        },
        "$description": "Visited link — muted indigo"
      },
      "highlight": {
        "$type": "color",
        "$value": "{color.palette.indigo.800}",
        "$extensions": {
          "fsds.light": "{color.palette.indigo.800}",
          "fsds.dark": "{color.palette.indigo.200}"
        },
        "$description": "Highlight text — deep steel indigo for authority in light mode"
      }
    },
    "background": {
      "accent": {
        "$type": "color",
        "$value": "{color.palette.indigo.600}",
        "$extensions": {
          "fsds.light": "{color.palette.indigo.600}",
          "fsds.dark": "{color.palette.indigo.500}"
        },
        "$description": "Accent fill — indigo.600 light (>4.5:1 vs white), indigo.500 dark (>4.5:1 vs white). Cooler steel cast vs corporate blue."
      },
      "highlight": {
        "$type": "color",
        "$value": "{color.palette.indigo.50}",
        "$extensions": {
          "fsds.light": "{color.palette.indigo.50}",
          "fsds.dark": "{color.palette.indigo.800}"
        },
        "$description": "Subtle accent wash — icy indigo tint in light, deep steel in dark"
      },
      "brand": {
        "$type": "color",
        "$value": "{color.palette.neutral.800}",
        "$extensions": {
          "fsds.light": "{color.palette.neutral.800}",
          "fsds.dark": "{color.palette.neutral.900}"
        },
        "$description": "Brand hero surface — near-black neutral steel for headers/banners. Maximum desaturation for architectural feel."
      }
    },
    "border": {
      "accent": {
        "$type": "color",
        "$value": "{color.palette.indigo.500}",
        "$extensions": {
          "fsds.light": "{color.palette.indigo.500}",
          "fsds.dark": "{color.palette.indigo.400}"
        },
        "$description": "Accent border — indigo.500, crisp steel line"
      },
      "default": {
        "$type": "color",
        "$value": "{color.palette.neutral.400}",
        "$extensions": {
          "fsds.light": "{color.palette.neutral.400}",
          "fsds.dark": "{color.palette.neutral.600}"
        },
        "$description": "Default border — neutral.400, slightly denser than corporate (300) for the steel structural grid feel"
      },
      "hover": {
        "$type": "color",
        "$value": "{color.palette.indigo.400}",
        "$extensions": {
          "fsds.light": "{color.palette.indigo.400}",
          "fsds.dark": "{color.palette.indigo.500}"
        },
        "$description": "Hover border — cool indigo midtone signals interactivity with steel cast"
      },
      "focus": {
        "$type": "color",
        "$value": "{color.palette.indigo.600}",
        "$extensions": {
          "fsds.light": "{color.palette.indigo.600}",
          "fsds.dark": "{color.palette.indigo.400}"
        },
        "$description": "Focus border — crisp steel indigo ring"
      },
      "light": {
        "$type": "color",
        "$value": "{color.palette.indigo.100}",
        "$extensions": {
          "fsds.light": "{color.palette.indigo.100}",
          "fsds.dark": "{color.palette.indigo.800}"
        },
        "$description": "Light border — icy indigo tint"
      },
      "primary": {
        "$type": "color",
        "$value": "{color.palette.neutral.400}",
        "$extensions": {
          "fsds.light": "{color.palette.neutral.400}",
          "fsds.dark": "{color.palette.neutral.600}"
        },
        "$description": "Primary border — neutral steel gray, structural grid line"
      }
    },
    "navigation": {
      "foreground": {
        "active": {
          "$type": "color",
          "$value": "{color.palette.indigo.700}",
          "$extensions": {
            "fsds.light": "{color.palette.indigo.700}",
            "fsds.dark": "{color.palette.indigo.400}"
          },
          "$description": "Active nav item — deep steel indigo authority in light mode"
        }
      },
      "background": {
        "active": {
          "$type": "color",
          "$value": "{color.palette.indigo.50}",
          "$extensions": {
            "fsds.light": "{color.palette.indigo.50}",
            "fsds.dark": "{color.palette.indigo.900}"
          },
          "$description": "Active nav background — icy wash using stateLayer-style tinting"
        }
      }
    },
    "action": {
      "background": {
        "primary": {
          "default": {
            "$type": "color",
            "$value": "{color.palette.indigo.600}",
            "$extensions": {
              "fsds.light": "{color.palette.indigo.600}",
              "fsds.dark": "{color.palette.indigo.600}"
            },
            "$description": "Primary action fill — indigo.600, cooler steel vs corporate blue.600. Contrast: ~6.0:1+ vs white, clears AA."
          },
          "hover": {
            "$type": "color",
            "$value": "{color.palette.indigo.700}",
            "$extensions": {
              "fsds.light": "{color.palette.indigo.700}",
              "fsds.dark": "{color.palette.indigo.500}"
            },
            "$description": "Hover fill — deeper indigo in light (~8.0:1 vs white), indigo.500 in dark (>4.5:1)"
          },
          "active": {
            "$type": "color",
            "$value": "{color.palette.indigo.800}",
            "$extensions": {
              "fsds.light": "{color.palette.indigo.800}",
              "fsds.dark": "{color.palette.indigo.400}"
            },
            "$description": "Pressed fill — deep steel indigo pressed state"
          }
        }
      },
      "border": {
        "primary": {
          "default": {
            "$type": "color",
            "$value": "{color.palette.indigo.600}",
            "$extensions": {
              "fsds.light": "{color.palette.indigo.600}",
              "fsds.dark": "{color.palette.indigo.500}"
            },
            "$description": "Primary action border — indigo steel"
          },
          "focus": {
            "$type": "color",
            "$value": "{color.palette.indigo.400}",
            "$extensions": {
              "fsds.light": "{color.palette.indigo.400}",
              "fsds.dark": "{color.palette.indigo.300}"
            },
            "$description": "Focus ring — cooler indigo outline against the fill"
          }
        }
      }
    },
    "status": {
      "highlight": {
        "$type": "color",
        "$value": "{color.palette.indigo.500}",
        "$extensions": {
          "fsds.light": "{color.palette.indigo.500}",
          "fsds.dark": "{color.palette.indigo.400}"
        },
        "$description": "Status highlight — steel indigo for informational states"
      }
    }
  },
  "shape": {
    "control": {
      "radius": {
        "default": {
          "$type": "dimension",
          "$value": "{shape.radius.01}",
          "$description": "Control radius (2px) — near-square precision, crisper than corporate's 4px for maximum steel architectural feel"
        }
      }
    },
    "card": {
      "radius": {
        "$type": "dimension",
        "$value": "{shape.radius.02}",
        "$description": "Card border radius (4px) — rectilinear steel, same as corporate but paired with neutral borders for distinction"
      },
      "border": {
        "light": {
          "$type": "color",
          "$value": "{color.palette.indigo.100}",
          "$extensions": {
            "fsds.light": "{color.palette.indigo.100}",
            "fsds.dark": "{color.palette.indigo.900}"
          },
          "$description": "Light card border — icy indigo wash, nearly invisible steel tint"
        },
        "medium": {
          "$type": "color",
          "$value": "{color.palette.neutral.300}",
          "$extensions": {
            "fsds.light": "{color.palette.neutral.300}",
            "fsds.dark": "{color.palette.neutral.600}"
          },
          "$description": "Medium card border — pure neutral gray for maximum steel cast (vs corporate's blue.200)"
        },
        "dark": {
          "$type": "color",
          "$value": "{color.palette.indigo.500}",
          "$extensions": {
            "fsds.light": "{color.palette.indigo.500}",
            "fsds.dark": "{color.palette.indigo.500}"
          },
          "$description": "Dark card border — visible indigo steel rule"
        },
        "transparent": {
          "$type": "color",
          "$value": "{color.mode.transparent}",
          "$extensions": {
            "fsds.light": "{color.mode.transparent}",
            "fsds.dark": "{color.mode.transparent}"
          },
          "$description": "Transparent card border — no decoration"
        }
      },
      "elevation": {
        "near": {
          "$type": "shadow",
          "$value": "{elevation.surface.flat}",
          "$description": "Near elevation — flat surface, maximum steel restraint"
        },
        "default": {
          "$type": "shadow",
          "$value": "{elevation.surface.raised}",
          "$description": "Default elevation — minimal resting shadow (raised surface)"
        },
        "far": {
          "$type": "shadow",
          "$value": "{elevation.surface.floating}",
          "$description": "Far elevation — floating surface, crisp but not dramatic"
        },
        "none": {
          "$type": "shadow",
          "$value": "{elevation.surface.flat}",
          "$description": "No elevation — flush with page plane"
        }
      }
    },
    "element": {
      "radius": {
        "$type": "dimension",
        "$value": "{shape.radius.01}",
        "$description": "Internal element radius (2px) — near-square for precise steel geometry"
      }
    },
    "button": {
      "radius": {
        "$type": "dimension",
        "$value": "{shape.radius.02}",
        "$description": "Button radius (4px) — crisp, decisive; slightly more rounded than control for usability"
      }
    },
    "badge": {
      "radius": {
        "$type": "dimension",
        "$value": "{shape.radius.02}",
        "$description": "Badge radius (4px) — rectangular, compact, data-density friendly"
      }
    },
    "input": {
      "radius": {
        "default": {
          "$type": "dimension",
          "$value": "{shape.radius.02}",
          "$description": "Input border radius — precise (4px), crisp form grids"
        }
      },
      "border": {
        "defaultWidth": {
          "$type": "dimension",
          "$value": "{shape.border.width.hairline}",
          "$description": "Input border width — hairline (1px) for precise steel form grids"
        },
        "defaultStyle": {
          "$type": "strokeStyle",
          "$value": "{shape.border.style.solid}",
          "$description": "Input border style — solid, crisp"
        },
        "focusWidth": {
          "$type": "dimension",
          "$value": "{shape.border.width.thick}",
          "$description": "Input focus border width — 2px for clear keyboard focus"
        }
      }
    },
    "field": {
      "radius": {
        "default": {
          "$type": "dimension",
          "$value": "{shape.radius.02}",
          "$description": "Field border radius — crisp (4px)"
        }
      },
      "border": {
        "defaultWidth": {
          "$type": "dimension",
          "$value": "{shape.border.width.hairline}",
          "$description": "Field border width — hairline (1px)"
        },
        "focusWidth": {
          "$type": "dimension",
          "$value": "{shape.border.width.thick}",
          "$description": "Field focus border width — 2px"
        }
      }
    }
  },
  "spacing": {
    "component": {
      "padding": {
        "$type": "dimension",
        "$value": "{spacing.size.05}",
        "$description": "Compact component padding (12px) — information-dense steel layout"
      },
      "gap": {
        "$type": "dimension",
        "$value": "{spacing.size.04}",
        "$description": "Compact component gap (8px)"
      }
    },
    "card": {
      "padding": {
        "$type": "dimension",
        "$value": "{spacing.size.06}",
        "$description": "Card padding (16px) — tight, efficient screen use"
      }
    }
  },
  "motion": {
    "interaction": {
      "duration": {
        "$type": "duration",
        "$value": "{motion.duration.short2}",
        "$description": "Restrained transitions (100ms) — near-instant, precision-tuned steel response. Crisper than corporate's short3 (167ms)."
      },
      "easing": {
        "$type": "cubicBezier",
        "$value": "{motion.easing.quick.enter}",
        "$description": "Quick enter easing — sharp acceleration for precise steel feel; no personality, maximum efficiency"
      }
    }
  },
  "typography": {
    "body": {
      "font": {
        "weight": {
          "$type": "fontWeight",
          "$value": "{typography.weight.regular}",
          "$description": "Regular body weight (400) — readable at compact density"
        }
      }
    },
    "heading": {
      "font": {
        "weight": {
          "$type": "fontWeight",
          "$value": "{typography.weight.semibold}",
          "$description": "Semibold heading weight (600) — authoritative steel precision, not bold-shouting"
        }
      }
    }
  }
}
