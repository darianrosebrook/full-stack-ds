{
  "$schema": "../../../build/w3c/w3c-schema-strict.json",
  "control": {
    "toggle": {
      "width": {
        "sm": {
          "$type": "string",
          "$value": "calc(var(--fsds-semantic-control-size-sm-height) + var(--fsds-semantic-control-size-sm-paddingX) * 2)",
          "$description": "ToggleSwitch track width sm (= 32px)"
        },
        "md": {
          "$type": "string",
          "$value": "calc(var(--fsds-semantic-control-size-md-height) + var(--fsds-semantic-control-size-md-paddingX) * 2)",
          "$description": "ToggleSwitch track width md (= 48px)"
        },
        "lg": {
          "$type": "string",
          "$value": "calc(var(--fsds-semantic-control-size-lg-height) + var(--fsds-semantic-control-size-lg-paddingX) * 2)",
          "$description": "ToggleSwitch track width lg (= 80px)"
        }
      },
      "thumb": {
        "sm": {
          "$type": "string",
          "$value": "calc(var(--fsds-semantic-control-size-sm-height) - var(--fsds-semantic-control-size-sm-paddingY) * 2)",
          "$description": "ToggleSwitch thumb size sm (= 20px)"
        },
        "md": {
          "$type": "string",
          "$value": "calc(var(--fsds-semantic-control-size-md-height) - var(--fsds-semantic-control-size-md-paddingY) * 2)",
          "$description": "ToggleSwitch thumb size md (= 24px)"
        },
        "lg": {
          "$type": "string",
          "$value": "calc(var(--fsds-semantic-control-size-lg-height) - var(--fsds-semantic-control-size-lg-paddingY) * 2)",
          "$description": "ToggleSwitch thumb size lg (= 32px)"
        }
      }
    }
  }
}
