  "glyph": {
    "badge": {
      "size": {
        "sm": {
          "paddingY": { "$type": "dimension", "$value": "{spacing.size.02}", "$description": "Content-inline badge sm vertical padding — 2px." },
          "paddingX": { "$type": "dimension", "$value": "{spacing.size.03}", "$description": "Content-inline badge sm horizontal padding — 4px." },
          "fontSize": { "$type": "dimension", "$value": "{typography.ramp.1}", "$description": "Content-inline badge sm font size — 10px." },
