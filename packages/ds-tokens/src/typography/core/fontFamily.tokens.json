{
  "$schema": "../../../build/w3c/w3c-schema-strict.json",
  "typography": {
    "font": {
      "family": {
        "sans": {
          "$type": "fontFamily",
          "$value": "\"Inter\", sans-serif"
        },
        "serif": {
          "$type": "fontFamily",
          "$value": "\"Georgia\", serif"
        },
        "mono": {
          "$type": "fontFamily",
          "$value": "\"Menlo\", monospace"
        },
        "inter": {
          "$type": "fontFamily",
          "$value": "\"Inter\", system-ui, -apple-system, Segoe UI, Roboto, Arial, sans-serif"
        },
        "newsreader": {
          "$type": "fontFamily",
          "$value": "\"Newsreader\", Georgia, serif"
        },
        "monaspace": {
          "$type": "fontFamily",
          "$value": "\"Monaspace\", ui-monospace, SFMono-Regular, Menlo, monospace"
        }
      }
    }
  }
}
