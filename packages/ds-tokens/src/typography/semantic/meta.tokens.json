{
  "$schema": "../../../build/w3c/w3c-schema-strict.json",
  "typography": {
    "meta": {
      "caption": {
        "font": {
          "family": {
            "$type": "fontFamily",
            "$value": "{typography.font.family.inter}"
          },
          "weight": {
            "$type": "fontWeight",
            "$value": "{typography.weight.medium}"
          },
          "size": {
            "$type": "dimension",
            "$value": "{typography.ramp.2}"
          }
        },
        "line": {
          "height": {
            "$type": "number",
            "$value": 1.5
          }
        }
      },
      "legal": {
        "font": {
          "family": {
            "$type": "fontFamily",
            "$value": "{typography.font.family.inter}"
          },
          "weight": {
            "$type": "fontWeight",
            "$value": "{typography.weight.regular}"
          },
          "size": {
            "$type": "dimension",
            "$value": "{typography.ramp.2}"
          }
        },
        "line": {
          "height": {
            "$type": "number",
            "$value": 1.8
          }
        }
      }
    }
  }
}
