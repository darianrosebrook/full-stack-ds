{
  "$schema": "../../../build/w3c/w3c-schema-strict.json",
  "typography": {
    "font": {
      "weight": {
        "black": {
          "$type": "fontWeight",
          "$value": "{typography.weight.black}"
        },
        "bold": {
          "$type": "fontWeight",
          "$value": "{typography.weight.bold}"
        },
        "light": {
          "$type": "fontWeight",
          "$value": "{typography.weight.light}"
        },
        "medium": {
          "$type": "fontWeight",
          "$value": "{typography.weight.medium}"
        },
        "regular": {
          "$type": "fontWeight",
          "$value": "{typography.weight.regular}"
        }
      }
    }
  }
}
