{
  "$schema": "../../../build/w3c/w3c-schema-strict.json",
  "typography": {
    "body": {
      "01": {
        "$type": "dimension",
        "$value": "{typography.ramp.5}"
      },
      "02": {
        "$type": "dimension",
        "$value": "{typography.ramp.4}"
      },
      "03": {
        "$type": "dimension",
        "$value": "{typography.ramp.3}"
      },
      "04": {
        "$type": "dimension",
        "$value": "{typography.ramp.2}"
      },
      "default": {
        "font": {
          "family": {
            "$type": "fontFamily",
            "$value": "{typography.font.family.inter}"
          },
          "weight": {
            "$type": "fontWeight",
            "$value": "{typography.weight.regular}"
          },
          "size": {
            "$type": "dimension",
            "$value": "{typography.ramp.4}"
          }
        },
        "line": {
          "height": {
            "$type": "number",
            "$value": 1.5
          }
        },
        "letter": {
          "spacing": {
            "$type": "dimension",
            "$value": {
              "value": 0,
              "unit": "rem"
            }
          }
        }
      },
      "small": {
        "font": {
          "family": {
            "$type": "fontFamily",
            "$value": "{typography.font.family.inter}"
          },
          "weight": {
            "$type": "fontWeight",
            "$value": "{typography.weight.regular}"
          },
          "size": {
            "$type": "dimension",
            "$value": "{typography.ramp.3}"
          }
        },
        "line": {
          "height": {
            "$type": "number",
            "$value": 1.5
          }
        }
      }
    }
  }
}
