{
  "$schema": "../../../build/w3c/w3c-schema-strict.json",
  "shape": {
    "radius": {
      "none": {
        "$type": "dimension",
        "$value": {
          "value": 0,
          "unit": "px"
        }
      },
      "01": {
        "$type": "dimension",
        "$value": {
          "value": 2,
          "unit": "px"
        }
      },
      "02": {
        "$type": "dimension",
        "$value": {
          "value": 4,
          "unit": "px"
        }
      },
      "medium": {
        "$type": "dimension",
        "$value": {
          "value": 6,
          "unit": "px"
        }
      },
      "03": {
        "$type": "dimension",
        "$value": {
          "value": 8,
          "unit": "px"
        }
      },
      "04": {
        "$type": "dimension",
        "$value": {
          "value": 16,
          "unit": "px"
        }
      },
      "05": {
        "$type": "dimension",
        "$value": {
          "value": 32,
          "unit": "px"
        }
      },
      "full": {
        "$type": "dimension",
        "$value": {
          "value": 9999,
          "unit": "px"
        }
      },
      "small": {
        "$type": "dimension",
        "$value": "{shape.radius.02}",
        "$description": "Named alias for shape.radius.02 (4px). Retained at core tier so contracts referencing core.shape.radius.small resolve. semantic.shape.radius.small is the canonical semantic alias and uses the same value."
      },
      "large": {
        "$type": "dimension",
        "$value": "{shape.radius.04}",
        "$description": "Named alias for shape.radius.04 (16px). Retained at core tier so contracts referencing core.shape.radius.large resolve. semantic.shape.radius.large is the canonical semantic alias and uses the same value."
      }
    }
  }
}
