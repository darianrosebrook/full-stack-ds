{
  "$schema": "../../../build/w3c/w3c-schema-strict.json",
  "shape": {
    "control": {
      "radius": {
        "default": {
          "$type": "dimension",
          "$value": "{shape.radius.medium}"
        },
        "pill": {
          "$type": "dimension",
          "$value": "{shape.radius.full}"
        }
      },
      "border": {
        "defaultWidth": {
          "$type": "dimension",
          "$value": "{shape.border.width.hairline}"
        },
        "defaultStyle": {
          "$type": "strokeStyle",
          "$value": "{shape.border.style.solid}"
        },
        "focusWidth": {
          "$type": "dimension",
          "$value": "{shape.border.width.thick}"
        }
      }
    }
  }
}
