    "@angular/platform-browser-dynamic": "^19.2.21",
    "@types/jest": "^30.0.0",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "jest-preset-angular": "^16.1.4",
    "rxjs": "^7.8.0",
