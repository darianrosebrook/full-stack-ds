{
  "name": "@full-stack-ds/angular",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Angular implementation of Full Stack DS (Stack primitive + generated components)",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./preview": {
      "types": "./src/preview/index.ts",
      "default": "./src/preview/index.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "typecheck:ngc": "ngc -p tsconfig.ngc.json",
    "test": "jest --config jest.config.cjs",
    "build": "tsc -p tsconfig.build.json"
  },
  "peerDependencies": {
    "@angular/common": ">=17.0.0",
    "@angular/core": ">=17.0.0"
  },
  "devDependencies": {
    "@angular/common": "^21.2.13",
    "@angular/compiler": "^21.2.13",
    "@angular/compiler-cli": "^21.2.13",
    "@angular/core": "^21.2.13",
    "@angular/platform-browser": "^21.2.13",
    "@angular/platform-browser-dynamic": "^21.2.13",
    "@jest/globals": "^30.0.0",
    "@types/jest": "^30.0.0",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "jest-preset-angular": "^16.1.5",
    "rxjs": "^7.8.0",
    "typescript": "^6.0.2",
    "zone.js": "^0.15.0"
  },
  "dependencies": {
    "@full-stack-ds/iconography": "workspace:*"
  }
}
