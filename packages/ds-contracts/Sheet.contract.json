{
  "$schema": "./component.contract.schema.json",
  "name": "Sheet",
  "description": "Slide-in panel (drawer) that overlays the page from an edge. Traps focus until dismissed.",
  "layer": "composer",
  "anatomy": {
    "parts": [
      "root",
      "overlay",
      "content",
      "header",
      "title",
      "description",
      "body",
      "footer",
      "close"
    ],
    "dom": {
      "tag": "div",
      "part": "root",
      "children": [
        {
          "tag": "div",
          "part": "overlay",
          "if": "open",
          "attrs": {
            "aria-hidden": "true"
          }
        },
        {
          "tag": "div",
          "part": "content",
          "if": "open",
          "attrs": {
            "role": "dialog",
            "aria-modal": "true"
          },
          "bindings": {
            "aria-labelledby": "literal:sheet-title-id",
            "aria-describedby": "literal:sheet-description-id",
            "data-side": "prop:side"
          },
          "children": [
            {
              "tag": "div",
              "part": "header",
              "children": [
                {
                  "tag": "h2",
                  "part": "title",
                  "children": [
                    {
                      "tag": "slot",
                      "name": "title"
                    }
                  ]
                },
                {
                  "tag": "p",
                  "part": "description",
                  "children": [
                    {
                      "tag": "slot",
                      "name": "description"
                    }
                  ]
                },
                {
                  "tag": "button",
                  "part": "close",
                  "attrs": {
                    "type": "button",
                    "aria-label": "Close sheet"
                  }
                }
              ]
            },
            {
              "tag": "div",
              "part": "body",
              "children": [
                {
                  "tag": "children"
                }
              ]
            },
            {
              "tag": "div",
              "part": "footer"
            }
          ]
        }
      ]
    }
  },
  "variants": {
    "side": [
      "top",
      "right",
      "bottom",
      "left"
    ]
  },
  "states": [
    "default",
    "hover",
    "focus",
    "open",
    "closed"
  ],
  "a11y": {
    "role": "dialog",
    "labeling": [
      "aria-label",
      "aria-labelledby",
      "aria-describedby"
    ],
    "keyboard": [
      {
        "key": "Escape",
        "action": "Close the sheet and return focus to the trigger element.",
        "when": "open"
      },
      {
        "key": "Tab",
        "action": "Cycle focus forward through interactive elements within the sheet.",
        "when": "open"
      },
      {
        "key": "Shift+Tab",
        "action": "Cycle focus backward through interactive elements within the sheet.",
        "when": "open"
      }
    ]
  },
  "channels": {
    "openness": {
      "description": "Whether the sheet panel is open.",
      "value": "open",
      "defaultValue": "defaultOpen",
      "onChange": "onOpenChange",
      "valueType": "boolean"
    }
  },
  "portal": {
    "enabled": true,
    "defaultTarget": "body",
    "positioning": "anchored",
    "layering": "modal",
    "backdrop": true
  },
  "dismissal": {
    "triggers": [
      {
        "event": "escape"
      },
      {
        "event": "overlayClick"
      }
    ]
  },
  "focus": {
    "strategy": "trap",
    "initialFocus": "content",
    "returnFocus": "trigger",
    "scrollLock": true,
    "wrap": true
  },
  "tokens": {
    "root": {
      "sheet.color.overlay": {
        "resolvesTo": "semantic.overlay.scrim.sheet",
        "fallback": "rgba(0,0,0,0.50)",
        "layer": "semantic"
      },
      "sheet.color.background": {
        "resolvesTo": "semantic.color.background.primary",
        "fallback": "#ffffff",
        "property": "background-color",
        "layer": "semantic"
      },
      "sheet.color.border": {
        "resolvesTo": "semantic.color.border.light",
        "fallback": "#fceaea",
        "property": "border-color",
        "layer": "semantic"
      },
      "sheet.color.text": {
        "resolvesTo": "semantic.color.foreground.primary",
        "fallback": "#141414",
        "property": "color",
        "layer": "semantic"
      },
      "sheet.color.textTitle": {
        "resolvesTo": "semantic.color.foreground.primary",
        "fallback": "#141414",
        "property": "color",
        "layer": "semantic"
      },
      "sheet.color.textDescription": {
        "resolvesTo": "semantic.color.foreground.secondary",
        "fallback": "#555555",
        "property": "color",
        "layer": "semantic"
      },
      "sheet.border.width": {
        "resolvesTo": "core.shape.border.width.hairline",
        "fallback": "1px",
        "property": "border-width",
        "layer": "core"
      },
      "sheet.border.radius": {
        "resolvesTo": "core.shape.radius.medium",
        "fallback": "8px",
        "property": "border-radius",
        "layer": "core"
      },
      "sheet.size.width": {
        "literal": "400px"
      },
      "sheet.size.height": {
        "literal": "300px"
      },
      "sheet.size.close": {
        "resolvesTo": "core.spacing.size.06",
        "fallback": "16px",
        "layer": "core"
      },
      "sheet.spacing.padding": {
        "resolvesTo": "core.spacing.size.06",
        "fallback": "16px",
        "property": "padding",
        "layer": "core"
      },
      "sheet.spacing.gap": {
        "resolvesTo": "core.spacing.size.04",
        "fallback": "8px",
        "property": "gap",
        "layer": "core"
      },
      "sheet.text.size": {
        "resolvesTo": "semantic.typography.body.02",
        "fallback": "16px",
        "property": "font-size",
        "layer": "semantic"
      },
      "sheet.text.sizeTitle": {
        "resolvesTo": "semantic.typography.heading.06",
        "fallback": "14px",
        "property": "font-size",
        "layer": "semantic"
      },
      "sheet.text.weightTitle": {
        "resolvesTo": "semantic.typography.font.weight.medium",
        "fallback": "500",
        "property": "font-weight",
        "layer": "semantic"
      },
      "sheet.shadow": {
        "resolvesTo": "semantic.elevation.surface.floating",
        "fallback": "0 4px 24px rgba(0,0,0,0.12)",
        "property": "box-shadow",
        "layer": "semantic"
      },
      "sheet.focus.width": {
        "resolvesTo": "core.shape.border.width.thick",
        "fallback": "2px",
        "layer": "core"
      },
      "sheet.focus.color": {
        "resolvesTo": "semantic.color.border.accent",
        "fallback": "#d9292b",
        "layer": "semantic"
      }
    },
    "hover": {
      "sheet.color.backgroundHover": {
        "resolvesTo": "semantic.interaction.background.hover",
        "fallback": "#efefef",
        "property": "background-color",
        "layer": "semantic"
      }
    }
  },
  "props": {
    "styled": {
      "description": "Props for the <Sheet> component.",
      "members": [
        {
          "name": "open",
          "type": "boolean",
          "description": "Controlled open state."
        },
        {
          "name": "defaultOpen",
          "type": "boolean",
          "description": "Uncontrolled initial open state."
        },
        {
          "name": "onOpenChange",
          "type": "(open: boolean) => void",
          "description": "Called when the open state changes."
        },
        {
          "name": "side",
          "type": "SheetSide",
          "description": "Edge from which the sheet slides in.",
          "default": "right"
        },
        {
          "name": "modal",
          "type": "boolean",
          "description": "When true, renders a modal sheet with backdrop and focus trap.",
          "default": true
        }
      ]
    }
  },
  "types": {
    "SheetSide": {
      "kind": "union",
      "values": [
        "top",
        "right",
        "bottom",
        "left"
      ]
    }
  }
}
