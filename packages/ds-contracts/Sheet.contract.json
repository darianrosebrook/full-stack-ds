{
  "$schema": "./component.contract.schema.json",
  "name": "Sheet",
  "description": "Slide-in panel (drawer) that overlays the page from an edge. Traps focus until dismissed.",
  "layer": "composer",
  "anatomy": {
    "parts": [
      "root",
      "overlay",
      "content",
      "header",
      "title",
      "description",
      "body",
      "footer",
      "close"
    ],
    "dom": {
      "tag": "div",
      "part": "root",
      "children": [
        {
          "tag": "div",
          "part": "overlay",
          "if": "open",
          "attrs": {
            "aria-hidden": "true"
          }
        },
        {
          "tag": "div",
          "part": "content",
          "if": "open",
          "attrs": {
            "role": "dialog",
            "aria-modal": "true"
          },
          "bindings": {
            "aria-labelledby": "literal:sheet-title-id",
            "aria-describedby": "literal:sheet-description-id",
            "data-side": "prop:side"
          },
          "children": [
            {
              "tag": "div",
              "part": "header",
              "children": [
                {
                  "tag": "h2",
                  "part": "title",
                  "children": [
                    {
                      "tag": "slot",
                      "name": "title"
                    }
                  ]
                },
                {
                  "tag": "p",
                  "part": "description",
                  "children": [
                    {
                      "tag": "slot",
                      "name": "description"
                    }
                  ]
                },
                {
                  "tag": "button",
                  "part": "close",
                  "attrs": {
                    "type": "button",
                    "aria-label": "Close sheet"
                  }
                }
              ]
            },
            {
              "tag": "div",
              "part": "body",
              "children": [
                {
                  "tag": "children"
                }
              ]
            },
            {
              "tag": "div",
              "part": "footer"
            }
          ]
        }
      ]
    }
  },
  "props": {
    "styled": {
      "description": "Props for the <Sheet> component.",
      "members": [
        {
          "name": "open",
          "type": "boolean",
          "description": "Controlled open state."
        },
        {
          "name": "defaultOpen",
          "type": "boolean",
          "description": "Uncontrolled initial open state."
        },
        {
          "name": "onOpenChange",
          "type": "(open: boolean) => void",
          "description": "Called when the open state changes."
        },
        {
          "name": "side",
          "type": "SheetSide",
          "description": "Edge from which the sheet slides in.",
          "default": "right"
        },
        {
          "name": "modal",
          "type": "boolean",
          "description": "When true, renders a modal sheet with backdrop and focus trap.",
          "default": true
        }
      ]
    }
  },
  "channels": {
    "openness": {
      "description": "Whether the sheet panel is open.",
      "value": "open",
      "defaultValue": "defaultOpen",
      "onChange": "onOpenChange",
      "valueType": "boolean"
    }
  },
  "types": {
    "SheetSide": {
      "kind": "union",
      "values": [
        "top",
        "right",
        "bottom",
        "left"
      ]
    }
  },
  "variants": {
    "side": [
      "top",
      "right",
      "bottom",
      "left"
    ]
  },
  "states": [
    "default",
    "hover",
    "focus",
    "open",
    "closed"
  ],
  "tokens": {
    "root": {
      "sheet.color.overlay": {
        "resolvesTo": "semantic.overlay.scrim.sheet",
        "fallback": "rgba(0,0,0,0.50)",
        "layer": "semantic"
      },
      "sheet.color.background": {
        "resolvesTo": "semantic.color.background.primary",
        "fallback": "#ffffff",
        "property": "background-color",
        "layer": "semantic"
      },
      "sheet.color.border": {
        "resolvesTo": "semantic.color.border.light",
        "fallback": "#fceaea",
        "property": "border-color",
        "layer": "semantic"
      },
      "sheet.color.text": {
        "resolvesTo": "semantic.color.foreground.primary",
        "fallback": "#141414",
        "property": "color",
        "layer": "semantic"
      },
      "sheet.color.textTitle": {
        "resolvesTo": "semantic.color.foreground.primary",
        "fallback": "#141414",
        "property": "color",
        "layer": "semantic"
      },
      "sheet.color.textDescription": {
        "resolvesTo": "semantic.color.foreground.secondary",
        "fallback": "#555555",
        "property": "color",
        "layer": "semantic"
      },
      "sheet.border.width": {
        "resolvesTo": "core.shape.border.width.hairline",
        "fallback": "1px",
        "property": "border-width",
        "layer": "core"
      },
      "sheet.border.radius": {
        "resolvesTo": "core.shape.radius.medium",
        "fallback": "8px",
        "property": "border-radius",
        "layer": "core"
      },
      "sheet.size.width": {
        "literal": "400px"
      },
      "sheet.size.height": {
        "literal": "300px"
      },
      "sheet.size.close": {
        "resolvesTo": "core.spacing.size.06",
        "fallback": "16px",
        "layer": "core"
      },
      "sheet.spacing.padding": {
        "resolvesTo": "core.spacing.size.06",
        "fallback": "16px",
        "property": "padding",
        "layer": "core"
      },
      "sheet.spacing.gap": {
        "resolvesTo": "core.spacing.size.04",
        "fallback": "8px",
        "property": "gap",
        "layer": "core"
      },
      "sheet.text.size": {
        "resolvesTo": "semantic.typography.body.02",
        "fallback": "16px",
        "property": "font-size",
        "layer": "semantic"
      },
      "sheet.text.sizeTitle": {
        "resolvesTo": "semantic.typography.heading.06",
        "fallback": "14px",
        "property": "font-size",
        "layer": "semantic"
      },
      "sheet.text.weightTitle": {
        "resolvesTo": "semantic.typography.font.weight.medium",
        "fallback": "500",
        "property": "font-weight",
        "layer": "semantic"
      },
      "sheet.shadow": {
        "resolvesTo": "semantic.elevation.surface.floating",
        "fallback": "0 4px 24px rgba(0,0,0,0.12)",
        "property": "box-shadow",
        "layer": "semantic"
      },
      "sheet.focus.width": {
        "resolvesTo": "core.shape.border.width.thick",
        "fallback": "2px",
        "layer": "core"
      },
      "sheet.focus.color": {
        "resolvesTo": "semantic.color.border.accent",
        "fallback": "#d9292b",
        "layer": "semantic"
      }
    },
    "hover": {
      "sheet.color.backgroundHover": {
        "resolvesTo": "semantic.interaction.background.hover",
        "fallback": "#efefef",
        "property": "background-color",
        "layer": "semantic"
      }
    }
  },
  "events": {
    "opennessChange": {
      "description": "Fires whenever the dialog moves toward open or closed. Distinct from `close` \u2014 this reports the new intent, it does not ask for confirmation.",
      "emittedVia": [
        "onOpenChange"
      ],
      "triggeredBy": [
        "Programmatic open() / close()",
        "Escape keypress (when closeOnEscape)",
        "Overlay click (when closeOnOverlayClick)"
      ],
      "payload": [
        {
          "name": "isOpen",
          "type": "boolean",
          "description": "The new desired open state."
        }
      ],
      "returns": "void"
    },
    "close": {
      "description": "Fires on a user-initiated close request. A specialization of opennessChange that fires only on close (escape, overlay click). Emitted via the same onOpenChange callback with value=false; the consumer distinguishes by inspecting the new value.",
      "emittedVia": [
        "onOpenChange"
      ],
      "triggeredBy": [
        "Escape keypress",
        "Overlay click"
      ],
      "payload": [],
      "returns": "void"
    }
  },
  "stateMachine": {
    "transitions": [
      {
        "event": "open",
        "from": "openness=closed",
        "to": "openness=opening",
        "effect": "emit opennessChange(true); lock body scroll; record return-focus target; move focus to initialFocus when `opening` completes"
      },
      {
        "event": "animationend",
        "from": "openness=opening",
        "to": "openness=open"
      },
      {
        "event": "escape",
        "from": "openness=open",
        "to": "openness=closing",
        "guard": "closeOnEscape=true",
        "effect": "emit close; emit opennessChange(false)"
      },
      {
        "event": "overlayClick",
        "from": "openness=open",
        "to": "openness=closing",
        "guard": "closeOnOverlayClick=true",
        "effect": "emit close; emit opennessChange(false)"
      },
      {
        "event": "close",
        "from": "openness=open",
        "to": "openness=closing",
        "effect": "emit opennessChange(false)"
      },
      {
        "event": "animationend",
        "from": "openness=closing",
        "to": "openness=closed",
        "effect": "unlock body scroll; return focus to elementRefToFocusOnClose or stored return-focus target"
      }
    ]
  },
  "motion": {
    "reducedMotion": "respect",
    "reducedMotionStrategy": "Duration set to 0; panel appears/disappears instantly without slide animation.",
    "transitions": [
      {
        "name": "open",
        "trigger": "openness=closed\u2192opening",
        "phase": "enter",
        "properties": [
          "transform"
        ],
        "duration": "core.motion.duration.short",
        "easing": "core.motion.easing.emphasized-in"
      },
      {
        "name": "close",
        "trigger": "openness=open\u2192closing",
        "phase": "exit",
        "properties": [
          "transform"
        ],
        "duration": "core.motion.duration.short",
        "easing": "core.motion.easing.emphasized-out"
      }
    ]
  },
  "focus": {
    "strategy": "trap",
    "initialFocus": "content",
    "returnFocus": "trigger",
    "scrollLock": true,
    "wrap": true
  },
  "portal": {
    "enabled": true,
    "defaultTarget": "body",
    "positioning": "anchored",
    "layering": "modal",
    "backdrop": true
  },
  "dismissal": {
    "triggers": [
      {
        "event": "escape"
      },
      {
        "event": "overlayClick"
      }
    ]
  },
  "slots": {
    "body": {
      "required": false,
      "selector": "[data-slot=\"sheet-body\"]"
    },
    "close": {
      "required": false,
      "selector": "[data-slot=\"sheet-close\"]"
    },
    "content": {
      "required": false,
      "selector": "[data-slot=\"sheet-content\"]"
    },
    "description": {
      "required": false,
      "selector": "[data-slot=\"sheet-description\"]"
    },
    "footer": {
      "required": false,
      "selector": "[data-slot=\"sheet-footer\"]"
    },
    "header": {
      "required": false,
      "selector": "[data-slot=\"sheet-header\"]"
    },
    "overlay": {
      "required": false,
      "selector": "[data-slot=\"sheet-overlay\"]"
    },
    "portal": {
      "required": false
    },
    "root": {
      "required": true,
      "selector": "[data-slot=\"sheet\"]"
    },
    "title": {
      "required": false,
      "selector": "[data-slot=\"sheet-title\"]"
    },
    "trigger": {
      "required": false,
      "selector": "[data-slot=\"sheet-trigger\"]"
    }
  },
  "ssr": {
    "hydrateOn": "interaction"
  },
  "rtl": {
    "flipIcon": false
  },
  "relationships": [
    {
      "from": "root",
      "to": "title",
      "attribute": "aria-labelledby",
      "description": "Sheet dialog takes its accessible name from its title element."
    }
  ],
  "a11y": {
    "role": "dialog",
    "apgPattern": "dialog-modal",
    "labeling": [
      "aria-label",
      "aria-labelledby",
      "aria-describedby"
    ],
    "keyboard": [
      {
        "key": "Escape",
        "action": "Close the sheet and return focus to the trigger element.",
        "when": "open"
      },
      {
        "key": "Tab",
        "action": "Cycle focus forward through interactive elements within the sheet.",
        "when": "open"
      },
      {
        "key": "Shift+Tab",
        "action": "Cycle focus backward through interactive elements within the sheet.",
        "when": "open"
      }
    ]
  },
  "usage": {
    "hookExample": "const { isOpen, open, close, getTriggerProps, getOverlayProps, getContentProps } = useModal({\n  closeOnEscape: true,\n  closeOnOverlayClick: true,\n});"
  },
  "a2ui": {
    "category": "overlay",
    "usageHints": [
      "Use side to control which edge the sheet slides in from (left, right, top, bottom)",
      "Bind open and onOpenChange to control visibility",
      "Sheet traps focus while open; Escape or clicking the overlay closes it by default",
      "Prefer Dialog for centered confirmations; use Sheet for detail panels, filters, or nav drawers"
    ],
    "children": {
      "allowed": true,
      "slot": "children",
      "accepts": [
        "node-ref"
      ]
    }
  }
}
