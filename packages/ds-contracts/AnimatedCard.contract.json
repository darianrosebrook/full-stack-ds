{
  "$schema": "./component.contract.schema.json",
  "name": "AnimatedCard",
  "description": "A card component that animates into view when it enters the viewport.",
  "layer": "primitive",
  "anatomy": {
    "parts": ["root", "imageWrapper", "image", "title", "overlay"],
    "dom": {
      "tag": "div",
      "part": "root",
      "bindings": {
        "data-as": "prop:as"
      },
      "children": [
        {
          "tag": "children"
        }
      ]
    }
  },
  "variants": {
    "as": ["article", "div", "li", "a"]
  },
  "states": ["default", "hover", "focus"],
  "a11y": {
    "labeling": [],
    "keyboard": []
  },
  "tokens": {
    "root": {
      "animatedCard.motion.duration.enter": {
        "resolvesTo": "core.motion.duration.medium",
        "fallback": "250ms",
        "property": "transition-duration",
        "layer": "core"
      },
      "animatedCard.motion.easing.enter": {
        "resolvesTo": "core.motion.easing.emphasizedOut",
        "fallback": "cubic-bezier(0.0, 0.0, 0.2, 1)",
        "property": "transition-timing-function",
        "layer": "core"
      }
    }
  },
  "props": {
    "styled": {
      "description": "Props for the <AnimatedCard> component.",
      "members": [
        {
          "name": "as",
          "type": "AnimatedCardAs",
          "description": "Element type to render."
        },
        {
          "name": "duration",
          "type": "number",
          "description": "Duration of entry animation in seconds."
        },
        {
          "name": "delay",
          "type": "number",
          "description": "Delay before animation starts in seconds."
        },
        {
          "name": "triggerOnScroll",
          "type": "boolean",
          "description": "Whether to trigger the animation on scroll into view."
        },
        {
          "name": "scrollStart",
          "type": "string",
          "description": "ScrollTrigger start position string."
        },
        {
          "name": "enableHover",
          "type": "boolean",
          "description": "Enable hover effects."
        },
        {
          "name": "href",
          "type": "string",
          "description": "Card href when rendered as an anchor (as=\"a\")."
        }
      ]
    }
  },
  "types": {
    "AnimatedCardAs": {
      "kind": "union",
      "values": ["article", "div", "li", "a"]
    }
  }
}
