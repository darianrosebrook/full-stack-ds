{
  "$schema": "./component.contract.schema.json",
  "name": "Progress",
  "description": "Visual indicator for task completion. Supports linear bar and circular ring variants.",
  "layer": "primitive",
  "anatomy": {
    "parts": ["root", "track", "fill", "value"],
    "dom": {
      "tag": "div",
      "part": "root",
      "attrs": {
        "role": "progressbar"
      },
      "bindings": {
        "aria-valuenow": "prop:value",
        "aria-valuemin": "literal:0",
        "aria-valuemax": "literal:100",
        "aria-label": "prop:label"
      },
      "children": [
        {
          "tag": "span",
          "part": "track",
          "attrs": {
            "aria-hidden": "true"
          },
          "children": [
            {
              "tag": "span",
              "part": "fill"
            }
          ]
        },
        {
          "tag": "span",
          "part": "value",
          "if": "showValue",
          "children": [
            {
              "tag": "children"
            }
          ]
        }
      ]
    }
  },
  "variants": {
    "variant": ["linear", "circular"],
    "size": ["sm", "md", "lg"],
    "intent": ["info", "success", "warning", "danger"]
  },
  "states": ["default"],
  "a11y": {
    "role": "progressbar",
    "labeling": ["aria-label", "aria-valuenow", "aria-valuemin", "aria-valuemax"],
    "keyboard": []
  },
  "tokens": {
    "root": {
      "progress.color.text.default": {
        "resolvesTo": "semantic.color.foreground.secondary",
        "fallback": "#555555",
        "property": "color",
        "layer": "semantic"
      },
      "progress.spacing.gap": {
        "resolvesTo": "core.spacing.size.02",
        "fallback": "2px",
        "property": "gap",
        "layer": "core"
      },
      "progress.motion.duration.indeterminate": {
        "resolvesTo": "core.motion.duration.extra.long1",
        "fallback": "1500ms",
        "property": "transition-duration",
        "layer": "core"
      }
    },
    "track": {
      "progress.color.track.background": {
        "resolvesTo": "semantic.color.background.secondary",
        "fallback": "#efefef",
        "property": "background-color",
        "layer": "semantic"
      }
    },
    "fill": {
      "progress.color.fill.info": {
        "resolvesTo": "semantic.color.status.info",
        "fallback": "#0a65fe",
        "property": "background-color",
        "layer": "semantic"
      }
    }
  },
  "props": {
    "styled": {
      "description": "Props for the <Progress> component.",
      "members": [
        {
          "name": "value",
          "type": "number",
          "description": "Progress value (0-100). Omit for indeterminate progress."
        },
        {
          "name": "variant",
          "type": "ProgressVariant",
          "description": "Progress variant."
        },
        {
          "name": "size",
          "type": "ProgressSize",
          "description": "Size token."
        },
        {
          "name": "intent",
          "type": "ProgressIntent",
          "description": "Visual intent / color."
        },
        {
          "name": "label",
          "type": "string",
          "description": "Accessible label."
        },
        {
          "name": "showValue",
          "type": "boolean",
          "description": "Show the percentage label inside the component."
        },
        {
          "name": "formatValue",
          "type": "(value: number, max: number) => string",
          "description": "Custom value formatter."
        }
      ]
    }
  },
  "types": {
    "ProgressVariant": {
      "kind": "union",
      "values": ["linear", "circular"]
    },
    "ProgressSize": {
      "kind": "union",
      "values": ["sm", "md", "lg"]
    },
    "ProgressIntent": {
      "kind": "union",
      "values": ["info", "success", "warning", "danger"]
    }
  }
}
