{
  "$schema": "./component.contract.schema.json",
  "name": "SlinkyCursor",
  "description": "Animated custom cursor indicator following the pointer with a spring-physics trail.",
  "layer": "primitive",
  "anatomy": {
    "parts": ["root", "pest"],
    "dom": {
      "tag": "div",
      "part": "root",
      "children": [
        {
          "tag": "div",
          "part": "pest"
        }
      ]
    }
  },
  "variants": {},
  "states": ["default", "active"],
  "a11y": {
    "labeling": [],
    "keyboard": []
  },
  "tokens": {
    "root": {
      "slinkycursor.color.border.primary": {
        "resolvesTo": "semantic.color.border.primary",
        "fallback": "#f29495",
        "property": "border-color",
        "layer": "semantic"
      },
      "slinkycursor.shape.radius.full": {
        "resolvesTo": "core.shape.radius.full",
        "fallback": "9999px",
        "property": "border-radius",
        "layer": "core"
      }
    },
    "active": {
      "slinkycursor.color.border.hover": {
        "resolvesTo": "semantic.color.border.hover",
        "fallback": "#f29495",
        "property": "border-color",
        "layer": "semantic"
      }
    }
  },
  "props": {
    "styled": {
      "description": "Props for the <SlinkyCursor> component.",
      "members": []
    }
  }
}
