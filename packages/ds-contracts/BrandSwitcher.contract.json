{
  "$schema": "./component.contract.schema.json",
  "name": "BrandSwitcher",
  "description": "Navigation control for switching between brands or product lines, including swatch selection, density, and font controls.",
  "layer": "primitive",
  "anatomy": {
    "parts": [
      "root",
      "sectionCard",
      "sectionHeader",
      "sectionTitle",
      "selectedBrandInfo",
      "selectedBrandDot",
      "selectedBrandName",
      "selectedBrandMood",
      "swatchGrid",
      "swatchBtn",
      "swatchDot",
      "densitySlider",
      "densityLabel",
      "rangeInput",
      "densityTicks",
      "segmentedControl",
      "segment",
      "subsection",
      "subsectionLabel",
      "keyboardHint",
      "kbd"
    ],
    "dom": {
      "tag": "div",
      "part": "root",
      "children": [
        {
          "tag": "children"
        }
      ]
    }
  },
  "variants": {},
  "states": ["default", "hover", "focus", "active", "selected"],
  "a11y": {
    "labeling": ["title"],
    "keyboard": [
      {
        "key": "Enter|Space",
        "action": "Activate the focused swatch or segment.",
        "when": "swatchBtn or segment has focus"
      }
    ]
  },
  "tokens": {
    "root": {
      "brandSwitcher.color.background.primary": {
        "resolvesTo": "semantic.color.background.primary",
        "fallback": "#ffffff",
        "property": "background-color",
        "layer": "semantic"
      },
      "brandSwitcher.color.background.secondary": {
        "resolvesTo": "semantic.color.background.secondary",
        "fallback": "#efefef",
        "property": "background-color",
        "layer": "semantic"
      },
      "brandSwitcher.color.background.tertiary": {
        "resolvesTo": "semantic.color.background.tertiary",
        "fallback": "#cecece",
        "property": "background-color",
        "layer": "semantic"
      },
      "brandSwitcher.color.background.accent": {
        "resolvesTo": "semantic.color.background.accent",
        "fallback": "#d9292b",
        "property": "background-color",
        "layer": "semantic"
      },
      "brandSwitcher.color.background.highlight": {
        "resolvesTo": "semantic.color.background.highlight",
        "fallback": "#f7c1c2",
        "property": "background-color",
        "layer": "semantic"
      },
      "brandSwitcher.color.foreground.primary": {
        "resolvesTo": "semantic.color.foreground.primary",
        "fallback": "#141414",
        "property": "color",
        "layer": "semantic"
      },
      "brandSwitcher.color.foreground.secondary": {
        "resolvesTo": "semantic.color.foreground.secondary",
        "fallback": "#555555",
        "property": "color",
        "layer": "semantic"
      },
      "brandSwitcher.color.foreground.tertiary": {
        "resolvesTo": "semantic.color.foreground.tertiary",
        "fallback": "#717171",
        "property": "color",
        "layer": "semantic"
      },
      "brandSwitcher.color.border.default": {
        "resolvesTo": "semantic.color.border.default",
        "fallback": "#aeaeae",
        "property": "border-color",
        "layer": "semantic"
      },
      "brandSwitcher.color.border.accent": {
        "resolvesTo": "semantic.color.border.accent",
        "fallback": "#d9292b",
        "property": "border-color",
        "layer": "semantic"
      },
      "brandSwitcher.spacing.gap.xs": {
        "resolvesTo": "semantic.spacing.gap.component",
        "fallback": "8px",
        "property": "gap",
        "layer": "semantic"
      },
      "brandSwitcher.spacing.gap.sm": {
        "resolvesTo": "semantic.spacing.gap.grid",
        "fallback": "16px",
        "property": "gap",
        "layer": "semantic"
      },
      "brandSwitcher.spacing.gap.md": {
        "resolvesTo": "semantic.spacing.gap.grid.medium",
        "fallback": "24px",
        "property": "gap",
        "layer": "semantic"
      },
      "brandSwitcher.spacing.padding.xs": {
        "resolvesTo": "semantic.spacing.padding.component",
        "fallback": "16px",
        "property": "padding",
        "layer": "semantic"
      },
      "brandSwitcher.spacing.padding.lg": {
        "resolvesTo": "semantic.spacing.padding.section",
        "fallback": "32px",
        "property": "padding",
        "layer": "semantic"
      },
      "brandSwitcher.size.radius.01": {
        "resolvesTo": "core.shape.radius.01",
        "fallback": "2px",
        "property": "border-radius",
        "layer": "core"
      },
      "brandSwitcher.size.radius.02": {
        "resolvesTo": "core.shape.radius.02",
        "fallback": "4px",
        "property": "border-radius",
        "layer": "core"
      },
      "brandSwitcher.size.radius.03": {
        "resolvesTo": "core.shape.radius.03",
        "fallback": "8px",
        "property": "border-radius",
        "layer": "core"
      },
      "brandSwitcher.typography.lineHeight.default": {
        "resolvesTo": "semantic.typography.body.default.line.height",
        "fallback": "1.5",
        "property": "line-height",
        "layer": "semantic"
      }
    },
    "hover": {
      "brandSwitcher.color.border.hover": {
        "resolvesTo": "semantic.color.border.hover",
        "fallback": "#f29495",
        "property": "border-color",
        "layer": "semantic"
      }
    },
    "focus": {
      "brandSwitcher.color.border.focus": {
        "resolvesTo": "semantic.color.border.focus",
        "fallback": "#d9292b",
        "property": "border-color",
        "layer": "semantic"
      }
    }
  },
  "props": {
    "styled": {
      "description": "Props for the <BrandSwitcher> component.",
      "members": [
        {
          "name": "showAutoCycle",
          "type": "boolean",
          "description": "Show the auto-cycle controls.",
          "default": false
        },
        {
          "name": "showDensity",
          "type": "boolean",
          "description": "Show density controls.",
          "default": false
        },
        {
          "name": "showFonts",
          "type": "boolean",
          "description": "Show font family controls.",
          "default": false
        },
        {
          "name": "compact",
          "type": "boolean",
          "description": "Compact mode — just swatches, no labels.",
          "default": false
        },
        {
          "name": "sticky",
          "type": "boolean",
          "description": "Enable sticky positioning.",
          "default": false
        },
        {
          "name": "enableKeyboard",
          "type": "boolean",
          "description": "Enable keyboard navigation (arrow keys to cycle).",
          "default": true
        }
      ]
    }
  }
}
