{
  "$schema": "./component.contract.schema.json",
  "name": "Text",
  "description": "Polymorphic text element with design-system typography variants and semantic element control.",
  "layer": "primitive",
  "anatomy": {
    "parts": [
      "root",
      "headline",
      "title",
      "body",
      "caption",
      "overline",
      "code"
    ],
    "dom": {
      "tag": "p",
      "part": "root"
    }
  },
  "props": {
    "styled": {
      "description": "Props for the <Text> component.",
      "members": [
        {
          "name": "as",
          "type": "TextElement",
          "description": "Element tag to render."
        },
        {
          "name": "variant",
          "type": "TextVariant",
          "description": "Typography variant"
        },
        {
          "name": "size",
          "type": "TextSize",
          "description": "Type-scale size token"
        },
        {
          "name": "weight",
          "type": "TextWeight",
          "description": "Font weight token"
        },
        {
          "name": "align",
          "type": "TextAlign",
          "description": "Text alignment"
        },
        {
          "name": "transform",
          "type": "TextTransform",
          "description": "CSS text-transform"
        },
        {
          "name": "truncate",
          "type": "boolean",
          "description": "Single-line truncation with ellipsis."
        }
      ]
    }
  },
  "types": {
    "TextElement": {
      "kind": "union",
      "values": [
        "p",
        "span",
        "div",
        "h1",
        "h2",
        "h3",
        "h4",
        "h5",
        "h6"
      ]
    },
    "TextVariant": {
      "kind": "union",
      "values": [
        "display",
        "headline",
        "title",
        "body",
        "caption",
        "overline",
        "code"
      ]
    },
    "TextSize": {
      "kind": "union",
      "values": [
        "xs",
        "sm",
        "md",
        "lg",
        "xl",
        "2xl",
        "3xl"
      ]
    },
    "TextWeight": {
      "kind": "union",
      "values": [
        "light",
        "normal",
        "medium",
        "semibold",
        "bold"
      ]
    },
    "TextAlign": {
      "kind": "union",
      "values": [
        "left",
        "center",
        "right",
        "justify"
      ]
    },
    "TextTransform": {
      "kind": "union",
      "values": [
        "none",
        "uppercase",
        "lowercase",
        "capitalize"
      ]
    }
  },
  "variants": {
    "variant": [
      "display",
      "headline",
      "title",
      "body",
      "caption",
      "overline",
      "code"
    ],
    "size": [
      "xs",
      "sm",
      "md",
      "lg",
      "xl",
      "2xl",
      "3xl"
    ],
    "weight": [
      "light",
      "normal",
      "medium",
      "semibold",
      "bold"
    ],
    "align": [
      "left",
      "center",
      "right",
      "justify"
    ],
    "transform": [
      "none",
      "uppercase",
      "lowercase",
      "capitalize"
    ]
  },
  "states": [
    "default",
    "error",
    "success"
  ],
  "tokens": {
    "root": {
      "text.color.foreground.primary": {
        "resolvesTo": "semantic.color.foreground.primary",
        "fallback": "#141414",
        "property": "color",
        "layer": "semantic"
      },
      "text.color.foreground.secondary": {
        "resolvesTo": "semantic.color.foreground.secondary",
        "fallback": "#555555",
        "property": "color",
        "layer": "semantic"
      },
      "text.typography.fontWeight.light": {
        "resolvesTo": "semantic.typography.font.weight.light",
        "fallback": "300",
        "layer": "semantic"
      },
      "text.typography.fontWeight.regular": {
        "resolvesTo": "semantic.typography.font.weight.regular",
        "fallback": "400",
        "layer": "semantic"
      },
      "text.typography.fontWeight.medium": {
        "resolvesTo": "semantic.typography.font.weight.medium",
        "fallback": "500",
        "layer": "semantic"
      },
      "text.typography.fontWeight.bold": {
        "resolvesTo": "semantic.typography.font.weight.bold",
        "fallback": "700",
        "layer": "semantic"
      },
      "text.typography.lineHeight.heading": {
        "resolvesTo": "semantic.typography.line.height.heading",
        "fallback": "1",
        "property": "line-height",
        "layer": "semantic"
      },
      "text.typography.lineHeight.body": {
        "resolvesTo": "semantic.typography.line.height.body",
        "fallback": "1.5",
        "property": "line-height",
        "layer": "semantic"
      }
    },
    "error": {
      "text.color.foreground.danger": {
        "resolvesTo": "semantic.color.foreground.danger",
        "fallback": "#d9292b",
        "property": "color",
        "layer": "semantic"
      }
    },
    "success": {
      "text.color.foreground.success": {
        "resolvesTo": "semantic.color.foreground.success",
        "fallback": "#487e1e",
        "property": "color",
        "layer": "semantic"
      }
    }
  },
  "slots": {
    "root": {
      "required": true,
      "selector": "[data-slot=\"text\"]"
    }
  },
  "ssr": {
    "hydrateOn": "interaction"
  },
  "rtl": {
    "flipIcon": false
  },
  "a11y": {
    "role": "generic",
    "labeling": [],
    "keyboard": []
  },
  "a2ui": {
    "category": "display",
    "usageHints": [
      "Use as to control the rendered element (p, span, h1\u2013h6, label, etc.)",
      "Use variant to apply typography scale (body, caption, heading, etc.)",
      "Do not nest block-level Text elements inside inline ones"
    ],
    "children": {
      "allowed": true,
      "slot": "children",
      "accepts": [
        "string",
        "node-ref"
      ]
    }
  }
}
