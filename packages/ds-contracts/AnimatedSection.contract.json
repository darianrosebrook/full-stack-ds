{
  "$schema": "./component.contract.schema.json",
  "name": "AnimatedSection",
  "description": "A page section that fades and slides into view when it enters the viewport.",
  "layer": "primitive",
  "anatomy": {
    "parts": ["root", "child"],
    "dom": {
      "tag": "section",
      "part": "root",
      "children": [
        {
          "tag": "children"
        }
      ]
    }
  },
  "variants": {
    "as": ["section", "div", "article", "main", "aside", "header", "footer"],
    "variant": ["fade-up", "fade-in", "slide-in", "stagger-children"]
  },
  "states": ["default"],
  "a11y": {
    "labeling": [],
    "keyboard": []
  },
  "tokens": {
    "root": {
      "animatedSection.motion.duration.enter": {
        "resolvesTo": "core.motion.duration.medium",
        "fallback": "250ms",
        "property": "transition-duration",
        "layer": "core"
      },
      "animatedSection.motion.easing.enter": {
        "resolvesTo": "core.motion.easing.emphasizedOut",
        "fallback": "cubic-bezier(0.0, 0.0, 0.2, 1)",
        "property": "transition-timing-function",
        "layer": "core"
      }
    }
  },
  "props": {
    "styled": {
      "description": "Props for the <AnimatedSection> component.",
      "members": [
        {
          "name": "as",
          "type": "AnimatedSectionAs",
          "description": "Element type to render."
        },
        {
          "name": "variant",
          "type": "AnimatedSectionVariant",
          "description": "Animation variant."
        },
        {
          "name": "duration",
          "type": "number",
          "description": "Duration of animation in seconds."
        },
        {
          "name": "stagger",
          "type": "number",
          "description": "Stagger delay between children in seconds (for stagger-children variant)."
        },
        {
          "name": "delay",
          "type": "number",
          "description": "Delay before animation starts in seconds."
        },
        {
          "name": "triggerOnScroll",
          "type": "boolean",
          "description": "Whether to trigger the animation on scroll into view."
        },
        {
          "name": "scrollStart",
          "type": "string",
          "description": "ScrollTrigger start position string."
        }
      ]
    }
  },
  "types": {
    "AnimatedSectionAs": {
      "kind": "union",
      "values": ["section", "div", "article", "main", "aside", "header", "footer"]
    },
    "AnimatedSectionVariant": {
      "kind": "union",
      "values": ["fade-up", "fade-in", "slide-in", "stagger-children"]
    }
  }
}
