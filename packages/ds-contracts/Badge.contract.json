{
  "$schema": "./component.contract.schema.json",
  "name": "Badge",
  "description": "Small label conveying status, category, or count. Typically paired with other content.",
  "layer": "primitive",
  "anatomy": {
    "parts": ["root", "icon", "content"],
    "dom": {
      "tag": "span",
      "part": "root",
      "children": [
        {
          "tag": "span",
          "part": "icon",
          "attrs": {
            "aria-hidden": "true"
          },
          "if": "icon"
        },
        {
          "tag": "span",
          "part": "content",
          "children": [
            {
              "tag": "children"
            }
          ]
        }
      ]
    }
  },
  "variants": {
    "variant": ["default", "status", "counter", "tag"],
    "intent": ["info", "success", "warning", "danger"],
    "size": ["sm", "md", "lg"]
  },
  "states": ["default", "hover"],
  "a11y": {
    "labeling": [],
    "keyboard": []
  },
  "tokens": {
    "root": {
      "badge.color.background.default": {
        "resolvesTo": "semantic.color.background.secondary",
        "fallback": "#efefef",
        "property": "background-color",
        "layer": "semantic"
      },
      "badge.color.background.info": {
        "resolvesTo": "semantic.color.background.info.subtle",
        "fallback": "#d9f3fe",
        "property": "background-color",
        "layer": "semantic"
      },
      "badge.color.background.success": {
        "resolvesTo": "semantic.color.background.success.subtle",
        "fallback": "#e4f2e0",
        "property": "background-color",
        "layer": "semantic"
      },
      "badge.color.background.warning": {
        "resolvesTo": "semantic.color.background.warning.subtle",
        "fallback": "#ffedcc",
        "property": "background-color",
        "layer": "semantic"
      },
      "badge.color.background.danger": {
        "resolvesTo": "semantic.color.background.danger.subtle",
        "fallback": "#fceaea",
        "property": "background-color",
        "layer": "semantic"
      },
      "badge.color.foreground.primary": {
        "resolvesTo": "semantic.color.foreground.primary",
        "fallback": "#141414",
        "property": "color",
        "layer": "semantic"
      },
      "badge.color.border.default": {
        "resolvesTo": "semantic.color.border.light",
        "fallback": "#fceaea",
        "property": "border-color",
        "layer": "semantic"
      },
      "badge.spacing.gap": {
        "resolvesTo": "core.spacing.size.02",
        "fallback": "2px",
        "property": "gap",
        "layer": "core"
      }
    }
  },
  "props": {
    "styled": {
      "description": "Props for the <Badge> component.",
      "members": [
        {
          "name": "variant",
          "type": "BadgeVariant",
          "description": "Visual variant of the badge"
        },
        {
          "name": "intent",
          "type": "BadgeIntent",
          "description": "Intent/severity for status badges"
        },
        {
          "name": "size",
          "type": "BadgeSize",
          "description": "Badge size token"
        },
        {
          "name": "icon",
          "type": "ReactNode",
          "description": "Icon to display. For status variant, defaults to a star icon if not provided. Pass null to hide."
        },
        {
          "name": "showStatusIcon",
          "type": "boolean",
          "description": "Whether to show the default status icon (only applies to status variant)"
        }
      ]
    }
  },
  "types": {
    "BadgeVariant": {
      "kind": "union",
      "values": ["default", "status", "counter", "tag"]
    },
    "BadgeIntent": {
      "kind": "union",
      "values": ["info", "success", "warning", "danger"]
    },
    "BadgeSize": {
      "kind": "union",
      "values": ["sm", "md", "lg"]
    }
  }
}
