{
  "$schema": "./component.contract.schema.json",
  "name": "Table",
  "description": "Data table with sortable columns, row selection, and pagination support.",
  "layer": "composite",
  "anatomy": {
    "parts": ["root", "container", "caption", "head", "body", "footer", "row", "header", "cell"]
  },
  "variants": {},
  "states": ["default", "hover", "focus", "selected"],
  "a11y": {
    "labeling": ["aria-sort", "aria-label", "aria-labelledby"],
    "keyboard": [
      {
        "key": "Tab",
        "action": "Move focus between interactive column headers and rows"
      },
      {
        "key": "Space|Enter",
        "action": "Activate sort on focused column header"
      },
      {
        "key": "ArrowUp|ArrowDown",
        "action": "Navigate between rows",
        "when": "interactive row is focused"
      }
    ]
  },
  "tokens": {
    "root": {
      "table.color.text": {
        "resolvesTo": "semantic.color.foreground.primary",
        "fallback": "#141414",
        "property": "color",
        "layer": "semantic"
      },
      "table.color.textMuted": {
        "resolvesTo": "semantic.color.foreground.secondary",
        "fallback": "#555555",
        "property": "color",
        "layer": "semantic"
      },
      "table.color.border": {
        "resolvesTo": "semantic.color.border.light",
        "fallback": "#fceaea",
        "property": "border-color",
        "layer": "semantic"
      },
      "table.color.background.footer": {
        "resolvesTo": "semantic.color.background.secondary",
        "fallback": "#efefef",
        "property": "background-color",
        "layer": "semantic"
      },
      "table.border.width": {
        "resolvesTo": "core.shape.border.width.hairline",
        "fallback": "1px",
        "property": "border-width",
        "layer": "core"
      },
      "table.spacing.cellX": {
        "resolvesTo": "core.spacing.size.03",
        "fallback": "4px",
        "layer": "core"
      },
      "table.spacing.cellY": {
        "resolvesTo": "core.spacing.size.02",
        "fallback": "2px",
        "layer": "core"
      },
      "table.spacing.caption": {
        "resolvesTo": "core.spacing.size.04",
        "fallback": "8px",
        "layer": "core"
      },
      "table.spacing.sortGap": {
        "resolvesTo": "core.spacing.size.02",
        "fallback": "2px",
        "property": "gap",
        "layer": "core"
      },
      "table.size.cellHeight": {
        "resolvesTo": "semantic.control.size.md.height",
        "fallback": "32px",
        "layer": "semantic"
      },
      "table.size.radius": {
        "resolvesTo": "semantic.shape.control.radius.default",
        "fallback": "8px",
        "property": "border-radius",
        "layer": "semantic"
      },
      "table.text.size": {
        "resolvesTo": "semantic.typography.body.03",
        "fallback": "14px",
        "property": "font-size",
        "layer": "semantic"
      },
      "table.text.lineHeight": {
        "resolvesTo": "semantic.typography.line.height.normal",
        "fallback": "1.5",
        "property": "line-height",
        "layer": "semantic"
      },
      "table.text.sizeCaption": {
        "resolvesTo": "semantic.typography.body.04",
        "fallback": "12px",
        "property": "font-size",
        "layer": "semantic"
      },
      "table.text.weightHead": {
        "resolvesTo": "semantic.typography.font.weight.bold",
        "fallback": "700",
        "property": "font-weight",
        "layer": "semantic"
      },
      "table.text.weightFooter": {
        "resolvesTo": "semantic.typography.font.weight.medium",
        "fallback": "500",
        "property": "font-weight",
        "layer": "semantic"
      }
    },
    "hover": {
      "table.color.background.hover": {
        "resolvesTo": "semantic.interaction.background.hover",
        "fallback": "#efefef",
        "property": "background-color",
        "layer": "semantic"
      }
    },
    "selected": {
      "table.color.background.selected": {
        "resolvesTo": "semantic.color.background.accent",
        "fallback": "#d9292b",
        "property": "background-color",
        "layer": "semantic"
      }
    },
    "focus": {
      "table.focus.width": {
        "resolvesTo": "core.shape.border.width.thick",
        "fallback": "2px",
        "layer": "core"
      },
      "table.focus.color": {
        "resolvesTo": "semantic.color.border.accent",
        "fallback": "#d9292b",
        "layer": "semantic"
      },
      "table.focus.offset": {
        "resolvesTo": "core.spacing.size.01",
        "fallback": "1px",
        "layer": "core"
      }
    }
  },
  "props": {
    "styled": {
      "description": "Props for the <Table> component.",
      "members": [
        {
          "name": "responsive",
          "type": "boolean",
          "description": "Enable responsive horizontal scrolling"
        },
        {
          "name": "ariaLabel",
          "type": "string",
          "description": "Accessible label for the table"
        }
      ]
    }
  }
}
