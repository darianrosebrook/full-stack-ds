{
  "$schema": "./component.contract.schema.json",
  "name": "Table",
  "description": "Data table with sortable columns, row selection, and pagination support.",
  "layer": "compound",
  "anatomy": {
    "parts": [
      "root",
      "container",
      "caption",
      "head",
      "body",
      "footer",
      "row",
      "header",
      "cell"
    ]
  },
  "props": {
    "styled": {
      "description": "Props for the <Table> component.",
      "members": [
        {
          "name": "responsive",
          "type": "boolean",
          "description": "Enable responsive horizontal scrolling"
        },
        {
          "name": "ariaLabel",
          "type": "string",
          "description": "Accessible label for the table"
        }
      ]
    }
  },
  "variants": {},
  "states": [
    "default",
    "hover",
    "focus",
    "selected"
  ],
  "tokens": {
    "root": {
      "table.color.text": {
        "resolvesTo": "semantic.color.foreground.primary",
        "fallback": "#141414",
        "property": "color",
        "layer": "semantic"
      },
      "table.color.textMuted": {
        "resolvesTo": "semantic.color.foreground.secondary",
        "fallback": "#555555",
        "property": "color",
        "layer": "semantic"
      },
      "table.color.border": {
        "resolvesTo": "semantic.color.border.light",
        "fallback": "#fceaea",
        "property": "border-color",
        "layer": "semantic"
      },
      "table.color.background.footer": {
        "resolvesTo": "semantic.color.background.secondary",
        "fallback": "#efefef",
        "property": "background-color",
        "layer": "semantic"
      },
      "table.border.width": {
        "resolvesTo": "core.shape.border.width.hairline",
        "fallback": "1px",
        "property": "border-width",
        "layer": "core"
      },
      "table.spacing.cellX": {
        "resolvesTo": "core.spacing.size.03",
        "fallback": "4px",
        "layer": "core"
      },
      "table.spacing.cellY": {
        "resolvesTo": "core.spacing.size.02",
        "fallback": "2px",
        "layer": "core"
      },
      "table.spacing.caption": {
        "resolvesTo": "core.spacing.size.04",
        "fallback": "8px",
        "layer": "core"
      },
      "table.spacing.sortGap": {
        "resolvesTo": "core.spacing.size.02",
        "fallback": "2px",
        "property": "gap",
        "layer": "core"
      },
      "table.size.cellHeight": {
        "resolvesTo": "semantic.control.size.md.height",
        "fallback": "32px",
        "layer": "semantic"
      },
      "table.size.radius": {
        "resolvesTo": "semantic.shape.control.radius.default",
        "fallback": "8px",
        "property": "border-radius",
        "layer": "semantic"
      },
      "table.text.size": {
        "resolvesTo": "semantic.typography.body.03",
        "fallback": "14px",
        "property": "font-size",
        "layer": "semantic"
      },
      "table.text.lineHeight": {
        "resolvesTo": "semantic.typography.line.height.normal",
        "fallback": "1.5",
        "property": "line-height",
        "layer": "semantic"
      },
      "table.text.sizeCaption": {
        "resolvesTo": "semantic.typography.body.04",
        "fallback": "12px",
        "property": "font-size",
        "layer": "semantic"
      },
      "table.text.weightHead": {
        "resolvesTo": "semantic.typography.font.weight.bold",
        "fallback": "700",
        "property": "font-weight",
        "layer": "semantic"
      },
      "table.text.weightFooter": {
        "resolvesTo": "semantic.typography.font.weight.medium",
        "fallback": "500",
        "property": "font-weight",
        "layer": "semantic"
      }
    },
    "hover": {
      "table.color.background.hover": {
        "resolvesTo": "semantic.interaction.background.hover",
        "fallback": "#efefef",
        "property": "background-color",
        "layer": "semantic"
      }
    },
    "selected": {
      "table.color.background.selected": {
        "resolvesTo": "semantic.color.background.accent",
        "fallback": "#d9292b",
        "property": "background-color",
        "layer": "semantic"
      }
    },
    "focus": {
      "table.focus.width": {
        "resolvesTo": "core.shape.border.width.thick",
        "fallback": "2px",
        "layer": "core"
      },
      "table.focus.color": {
        "resolvesTo": "semantic.color.border.accent",
        "fallback": "#d9292b",
        "layer": "semantic"
      },
      "table.focus.offset": {
        "resolvesTo": "core.spacing.size.01",
        "fallback": "1px",
        "layer": "core"
      }
    }
  },
  "focus": {
    "strategy": "none",
    "description": "The table itself does not manage focus. Individual interactive cells (sortable headers, checkboxes) are reachable via standard tab order."
  },
  "portal": {
    "enabled": false
  },
  "slots": {
    "body": {
      "required": false,
      "selector": "[data-slot=\"table-body\"]"
    },
    "caption": {
      "required": false,
      "selector": "[data-slot=\"table-caption\"]"
    },
    "cell": {
      "required": false,
      "selector": "[data-slot=\"table-cell\"]"
    },
    "container": {
      "required": false,
      "selector": "[data-slot=\"table-container\"]"
    },
    "element": {
      "required": false
    },
    "footer": {
      "required": false,
      "selector": "[data-slot=\"table-footer\"]"
    },
    "head": {
      "required": false,
      "selector": "[data-slot=\"table-head\"]"
    },
    "header": {
      "required": false,
      "selector": "[data-slot=\"table-header\"]"
    },
    "root": {
      "required": true,
      "selector": "[data-slot=\"table\"]"
    },
    "row": {
      "required": false,
      "selector": "[data-slot=\"table-row\"]"
    }
  },
  "ssr": {
    "hydrateOn": "interaction"
  },
  "rtl": {
    "flipIcon": false
  },
  "relationships": [
    {
      "from": "root",
      "to": "head",
      "attribute": "aria-labelledby",
      "description": "If a caption or external label is used, root references it via aria-labelledby."
    },
    {
      "from": "headerCell",
      "to": "cell",
      "attribute": "aria-sort",
      "description": "Sorted column's headerCell carries aria-sort; associated cells are in the same column."
    }
  ],
  "a11y": {
    "labeling": [
      "aria-sort",
      "aria-label",
      "aria-labelledby"
    ],
    "keyboard": [
      {
        "key": "Tab",
        "action": "Move focus between interactive column headers and rows"
      },
      {
        "key": "Space|Enter",
        "action": "Activate sort on focused column header"
      },
      {
        "key": "ArrowUp|ArrowDown",
        "action": "Navigate between rows",
        "when": "interactive row is focused"
      }
    ]
  },
  "a2ui": {
    "category": "display",
    "usageHints": [
      "Use for structured data that benefits from sorting or comparison across rows",
      "Enable row selection for bulk actions; pair with a toolbar for the action bar",
      "Keep column count to 6\u20138 max; use column visibility controls for wider datasets"
    ],
    "children": {
      "allowed": false
    }
  }
}
