{
  "$schema": "./component.contract.schema.json",
  "name": "Tooltip",
  "description": "Anchored ephemeral presence surface that exposes supplemental information about a trigger element on hover or focus. Composes as <Tooltip><Tooltip.Trigger>...</Tooltip.Trigger><Tooltip.Content>...</Tooltip.Content></Tooltip>; the substrate wires aria-describedby, hover/focus opening, and escape/blur/pointer-leave dismissal.",
  "layer": "primitive",
  "anatomy": {
    "parts": ["root", "trigger", "content"],
    "details": {
      "root": {
        "role": "group"
      },
      "trigger": {
        "role": "trigger",
        "interactive": true,
        "focusable": true
      },
      "content": {
        "role": "content",
        "aria": {
          "role": "tooltip"
        }
      }
    }
  },
  "variants": {
    "placement": ["top", "bottom", "left", "right", "auto"]
  },
  "states": ["default", "hover", "entering", "leaving"],
  "a11y": {
    "role": "tooltip",
    "labeling": ["aria-describedby"],
    "keyboard": [
      {
        "key": "Escape",
        "action": "Dismiss the tooltip without moving focus from the trigger (WCAG 2.1 SC 1.4.13)."
      }
    ]
  },
  "channels": {
    "open": {
      "value": "open",
      "defaultValue": "defaultOpen",
      "onChange": "onOpenChange",
      "valueType": "boolean",
      "description": "Whether the tooltip is visible."
    }
  },
  "surface": {
    "kind": "tooltip",
    "presence": "ephemeral",
    "modality": "non-blocking",
    "anchor": {
      "part": "trigger",
      "relation": "describedby"
    },
    "content": {
      "part": "content",
      "interactive": false
    },
    "positioning": {
      "strategy": "anchored",
      "placementProp": "placement",
      "collision": "flip-shift"
    },
    "dismissal": ["escape", "blur", "pointer-leave"],
    "openTriggers": ["hover", "focus"]
  },
  "portal": {
    "enabled": true,
    "defaultTarget": "body",
    "positioning": "anchored",
    "layering": "tooltip",
    "collision": "flip-shift"
  },
  "dismissal": {
    "triggers": [
      {
        "event": "escape",
        "enabledBy": "closeOnEscape"
      },
      {
        "event": "blur",
        "enabledBy": "closeOnBlur"
      }
    ]
  },
  "tokens": {
    "root": {
      "tooltip.color.background.default": {
        "resolvesTo": "semantic.color.background.inverse",
        "fallback": "#141414",
        "property": "background-color",
        "layer": "semantic"
      },
      "tooltip.color.foreground.default": {
        "resolvesTo": "semantic.color.foreground.inverse",
        "fallback": "#fafafa",
        "property": "color",
        "layer": "semantic"
      },
      "tooltip.color.border.default": {
        "resolvesTo": "semantic.color.border.subtle",
        "fallback": "#cecece",
        "property": "border-color",
        "layer": "semantic"
      },
      "tooltip.size.padding.y": {
        "resolvesTo": "core.spacing.size.03",
        "fallback": "4px",
        "property": "padding",
        "layer": "core"
      },
      "tooltip.size.padding.x": {
        "resolvesTo": "core.spacing.size.04",
        "fallback": "8px",
        "property": "padding",
        "layer": "core"
      },
      "tooltip.size.radius.default": {
        "resolvesTo": "core.shape.radius.small",
        "fallback": "4px",
        "property": "border-radius",
        "layer": "core"
      },
      "tooltip.size.maxWidth": {
        "literal": "200px",
        "property": "max-width"
      },
      "tooltip.typography.fontSize": {
        "resolvesTo": "semantic.typography.caption.01",
        "fallback": "14px",
        "property": "font-size",
        "layer": "semantic"
      }
    }
  },
  "props": {
    "styled": {
      "description": "Props for the <Tooltip> root component.",
      "members": [
        {
          "name": "open",
          "type": "boolean",
          "description": "Controlled visibility."
        },
        {
          "name": "defaultOpen",
          "type": "boolean",
          "description": "Uncontrolled initial visibility."
        },
        {
          "name": "onOpenChange",
          "type": "(open: boolean) => void",
          "description": "Called when visibility changes."
        },
        {
          "name": "placement",
          "type": "TooltipPlacement",
          "description": "Preferred placement. May be overridden by collision detection."
        },
        {
          "name": "disabled",
          "type": "boolean",
          "description": "Suppresses the tooltip entirely; the trigger renders but never opens."
        },
        {
          "name": "closeOnEscape",
          "type": "boolean",
          "description": "When true, Escape closes the tooltip and returns focus is preserved.",
          "default": true
        },
        {
          "name": "closeOnBlur",
          "type": "boolean",
          "description": "When true, blur on the trigger closes the tooltip.",
          "default": true
        }
      ]
    }
  },
  "types": {
    "TooltipPlacement": {
      "kind": "union",
      "values": ["top", "bottom", "left", "right", "auto"]
    }
  }
}
