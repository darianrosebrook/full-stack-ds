{
  "$schema": "./component.contract.schema.json",
  "name": "Calendar",
  "description": "Interactive calendar grid for selecting a single date or a date range.",
  "layer": "composer",
  "anatomy": {
    "parts": [
      "root",
      "header",
      "nav",
      "grid",
      "cell",
      "day",
      "caption"
    ],
    "dom": {
      "tag": "div",
      "part": "root",
      "attrs": {
        "role": "application"
      },
      "children": [
        {
          "tag": "div",
          "part": "header",
          "children": [
            {
              "tag": "button",
              "part": "nav",
              "attrs": {
                "aria-label": "Previous month"
              }
            },
            {
              "tag": "span",
              "part": "caption"
            },
            {
              "tag": "button",
              "part": "nav",
              "attrs": {
                "aria-label": "Next month"
              }
            }
          ]
        },
        {
          "tag": "table",
          "part": "grid",
          "attrs": {
            "role": "grid",
            "aria-label": "Calendar"
          },
          "children": [
            {
              "tag": "tbody",
              "children": [
                {
                  "tag": "tr",
                  "children": [
                    {
                      "tag": "td",
                      "part": "cell",
                      "attrs": {
                        "role": "gridcell"
                      },
                      "children": [
                        {
                          "tag": "button",
                          "part": "day"
                        }
                      ]
                    }
                  ]
                }
              ]
            }
          ]
        }
      ]
    }
  },
  "variants": {
    "mode": [
      "single",
      "range"
    ]
  },
  "states": [
    "default",
    "hover",
    "focus",
    "selected",
    "disabled",
    "today",
    "outsideMonth"
  ],
  "a11y": {
    "labeling": [
      "aria-label",
      "aria-labelledby"
    ],
    "keyboard": [
      {
        "key": "ArrowLeft",
        "action": "Move focus to the previous day."
      },
      {
        "key": "ArrowRight",
        "action": "Move focus to the next day."
      },
      {
        "key": "ArrowUp",
        "action": "Move focus to the same day in the previous week."
      },
      {
        "key": "ArrowDown",
        "action": "Move focus to the same day in the next week."
      },
      {
        "key": "PageUp",
        "action": "Move focus to the same day in the previous month."
      },
      {
        "key": "PageDown",
        "action": "Move focus to the same day in the next month."
      },
      {
        "key": "Home",
        "action": "Move focus to the first day of the current week."
      },
      {
        "key": "End",
        "action": "Move focus to the last day of the current week."
      },
      {
        "key": "Enter|Space",
        "action": "Select the focused date."
      }
    ]
  },
  "channels": {
    "value": {
      "description": "Selected date or date range.",
      "value": "value",
      "defaultValue": "defaultValue",
      "onChange": "onChange",
      "valueType": "Date | Date[] | null"
    }
  },
  "tokens": {
    "root": {
      "calendar.color.background.default": {
        "resolvesTo": "semantic.color.background.secondary",
        "fallback": "#efefef",
        "property": "background-color",
        "layer": "semantic"
      },
      "calendar.color.foreground.primary": {
        "resolvesTo": "semantic.color.foreground.primary",
        "fallback": "#141414",
        "property": "color",
        "layer": "semantic"
      },
      "calendar.color.foreground.secondary": {
        "resolvesTo": "semantic.color.foreground.secondary",
        "fallback": "#555555",
        "property": "color",
        "layer": "semantic"
      },
      "calendar.color.border.default": {
        "resolvesTo": "semantic.color.border.light",
        "fallback": "#fceaea",
        "property": "border-color",
        "layer": "semantic"
      },
      "calendar.color.border.accent": {
        "resolvesTo": "semantic.color.border.accent",
        "fallback": "#d9292b",
        "property": "border-color",
        "layer": "semantic"
      },
      "calendar.size.padding.default": {
        "resolvesTo": "core.spacing.size.07",
        "fallback": "24px",
        "property": "padding",
        "layer": "core"
      },
      "calendar.size.radius.default": {
        "resolvesTo": "core.shape.radius.medium",
        "fallback": "8px",
        "property": "border-radius",
        "layer": "core"
      },
      "calendar.elevation.default": {
        "resolvesTo": "semantic.elevation.default",
        "fallback": "none",
        "layer": "semantic"
      }
    },
    "hover": {
      "calendar.elevation.hover": {
        "resolvesTo": "semantic.elevation.surface.floating",
        "fallback": "0 2px 8px rgba(0,0,0,0.12)",
        "layer": "semantic"
      }
    }
  },
  "props": {
    "styled": {
      "description": "Props for the <Calendar> component.",
      "members": [
        {
          "name": "value",
          "type": "Date | Date[] | null",
          "description": "Controlled selected date or range."
        },
        {
          "name": "defaultValue",
          "type": "Date | Date[] | null",
          "description": "Uncontrolled initial selected date or range."
        },
        {
          "name": "onChange",
          "type": "(value: Date | Date[] | null) => void",
          "description": "Called when the selected date changes."
        },
        {
          "name": "mode",
          "type": "CalendarMode",
          "description": "Selection mode: single date or date range.",
          "default": "single"
        },
        {
          "name": "disabled",
          "type": "boolean",
          "description": "Disables all interaction."
        },
        {
          "name": "minDate",
          "type": "Date",
          "description": "Earliest selectable date."
        },
        {
          "name": "maxDate",
          "type": "Date",
          "description": "Latest selectable date."
        },
        {
          "name": "locale",
          "type": "string",
          "description": "BCP 47 locale tag for date formatting.",
          "default": "en-US"
        }
      ]
    }
  },
  "types": {
    "CalendarMode": {
      "kind": "union",
      "values": [
        "single",
        "range"
      ]
    }
  }
}
