{
  "$schema": "./primitive.contract.schema.json",
  "name": "Stack",
  "description": "Polymorphic layout shell; generated components compose Stack as the sole layout primitive.",
  "props": [
    {
      "name": "as",
      "kind": "elementType",
      "default": "div",
      "notes": "Underlying HTML element or intrinsic tag."
    },
    {
      "name": "variant",
      "kind": "layoutVariant",
      "default": "vertical",
      "notes": "Maps to stack--vertical | stack--horizontal layout classes."
    },
    {
      "name": "layout",
      "kind": "layoutMode",
      "default": "stack",
      "notes": "Platform-neutral layout intent. stack applies the primitive's axis layout; native lets the rendered host keep its own display/layout behavior."
    },
    {
      "name": "className",
      "kind": "string",
      "notes": "Merged with stack layout classes."
    },
    {
      "name": "role",
      "kind": "string",
      "notes": "Forwarded to the host element so generated components can declare ARIA role in one place (e.g. role=\"group\" on a Card shell)."
    },
    {
      "name": "data-testid",
      "kind": "string",
      "notes": "Forwarded to the host element for test targeting."
    },
    {
      "name": "children",
      "kind": "children"
    }
  ],
  "layout": {
    "classPrefix": "stack",
    "displayByMode": {
      "stack": "flex",
      "inline-stack": "inline-flex",
      "block": "block",
      "inline": "inline",
      "contents": "contents",
      "native": null
    },
    "axisByVariant": {
      "vertical": "column",
      "horizontal": "row"
    },
    "gap": {
      "token": "spacing.gap.stack",
      "cssVar": "--fsds-semantic-spacing-gap-stack"
    }
  },
  "implementation": {
    "targets": {
      "react": {
        "module": "@full-stack-ds/react/primitives",
        "export": "Stack",
        "relativeFromComponents": "../../primitives"
      },
      "vue": {
        "module": "@full-stack-ds/vue/primitives",
        "export": "Stack",
        "relativeFromComponents": "../../primitives"
      },
      "angular": {
        "module": "@full-stack-ds/angular/primitives",
        "export": "StackComponent",
        "relativeFromComponents": "../../primitives"
      },
      "lit": {
        "module": "@full-stack-ds/lit/primitives",
        "export": "StackElement",
        "relativeFromComponents": "../../primitives"
      },
      "svelte": {
        "module": "@full-stack-ds/svelte/primitives",
        "export": "Stack",
        "relativeFromComponents": "../../primitives"
      },
      "react-native": {
        "module": "@full-stack-ds/react-native/primitives",
        "export": "Stack",
        "relativeFromComponents": "../../primitives"
      }
    }
  }
}
