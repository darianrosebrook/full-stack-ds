{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "primitive.contract.schema.json",
  "title": "Layout primitive contract",
  "description": "Canonical definition of the shared layout primitive (Stack) per framework target.",
  "type": "object",
  "required": ["name", "description", "props", "implementation"],
  "additionalProperties": false,
  "properties": {
    "$schema": { "type": "string" },
    "name": {
      "type": "string",
      "pattern": "^[A-Z][a-zA-Z0-9]+$",
      "description": "PascalCase primitive name (e.g. Stack)."
    },
    "description": { "type": "string" },
    "props": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "kind"],
        "additionalProperties": false,
        "properties": {
          "name": { "type": "string" },
          "kind": {
            "type": "string",
            "enum": [
              "elementType",
              "layoutVariant",
              "layoutMode",
              "string",
              "boolean",
              "children",
              "record"
            ]
          },
          "default": {},
          "notes": { "type": "string" }
        }
      }
    },
    "implementation": {
      "type": "object",
      "required": ["targets"],
      "additionalProperties": false,
      "properties": {
        "targets": {
          "type": "object",
          "minProperties": 1,
          "additionalProperties": {
            "type": "object",
            "required": ["relativeFromComponents"],
            "additionalProperties": false,
            "properties": {
              "module": {
                "type": "string",
                "description": "Published import path for application code."
              },
              "export": {
                "type": "string",
                "description": "Named export symbol."
              },
              "relativeFromComponents": {
                "type": "string",
                "description": "Relative path from each generated component folder to the primitive module."
              }
            }
          }
        }
      }
    }
  }
}
