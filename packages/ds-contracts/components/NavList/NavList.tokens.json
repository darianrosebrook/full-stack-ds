{
  "box-model.gap": {
    "resolvesTo": "semantic.structure.size.gap",
    "fallback": "8px",
    "layer": "semantic"
  },
  "nav-list.color.foreground.default": {
    "resolvesTo": "semantic.color.foreground.secondary",
    "fallback": "#555555",
    "layer": "semantic"
  },
  "nav-list.color.foreground.hover": {
    "resolvesTo": "semantic.color.foreground.primary",
    "fallback": "#141414",
    "layer": "semantic"
  },
  "nav-list.color.foreground.current": {
    "resolvesTo": "semantic.color.foreground.primary",
    "fallback": "#141414",
    "layer": "semantic"
  },
  "nav-list.color.background.default": {
    "resolvesTo": "semantic.color.background.transparent",
    "fallback": "transparent",
    "layer": "semantic"
  },
  "nav-list.color.background.hover": {
    "resolvesTo": "semantic.color.background.subtle",
    "fallback": "#f5f5f5",
    "layer": "semantic"
  },
  "nav-list.stateLayer.hover": {
    "resolvesTo": "semantic.interaction.stateLayer.hover",
