  "nav-list.size.fontSize.item": {
    "resolvesTo": "semantic.typography.body.03",
    "fallback": "14px",
    "layer": "semantic"
  },
  "nav-list.size.fontSize.groupLabel": {
    "resolvesTo": "semantic.typography.caption.03",
    "fallback": "11px",
    "layer": "semantic"
  }
