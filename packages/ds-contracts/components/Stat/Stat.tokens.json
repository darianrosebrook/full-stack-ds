{
  "box-model.width": {
    "resolvesTo": "semantic.glyph.size.medium.extent",
    "fallback": "16px",
    "layer": "semantic"
  },
  "box-model.height": {
    "resolvesTo": "semantic.glyph.size.medium.extent",
    "fallback": "16px",
    "layer": "semantic"
  },
  "stat.color.foreground.value": {
    "resolvesTo": "semantic.color.foreground.primary",
    "fallback": "#141414",
    "layer": "semantic"
  },
  "stat.color.foreground.label": {
    "resolvesTo": "semantic.color.foreground.secondary",
    "fallback": "#555555",
    "layer": "semantic"
  },
  "stat.color.foreground.trend.up": {
    "resolvesTo": "semantic.color.feedback.foreground.success.default",
    "fallback": "#1f8a4c",
    "layer": "semantic"
  },
  "stat.color.foreground.trend.down": {
    "resolvesTo": "semantic.color.feedback.foreground.danger.default",
    "fallback": "#d9292b",
    "layer": "semantic"
  },
  "stat.color.foreground.trend.neutral": {
    "resolvesTo": "semantic.color.foreground.secondary",
    "fallback": "#555555",
    "layer": "semantic"
  },
  "stat.size.value.sm": {
    "resolvesTo": "semantic.typography.heading.03",
    "fallback": "20px",
    "layer": "semantic"
  },
  "stat.size.value.md": {
    "resolvesTo": "semantic.typography.heading.02",
    "fallback": "28px",
    "layer": "semantic"
  },
  "stat.size.value.lg": {
    "resolvesTo": "semantic.typography.heading.01",
    "fallback": "40px",
    "layer": "semantic"
  },
  "stat.size.label": {
    "resolvesTo": "semantic.typography.caption.02",
    "fallback": "12px",
    "layer": "semantic"
  },
  "stat.size.gap": {
    "resolvesTo": "core.spacing.size.02",
    "fallback": "4px",
    "layer": "core"
  },
  "stat.typography.weight.value": {
    "resolvesTo": "semantic.typography.font.weight.bold",
    "fallback": "700",
    "layer": "semantic"
  },
  "stat.typography.weight.label": {
    "resolvesTo": "semantic.typography.font.weight.medium",
    "fallback": "500",
    "layer": "semantic"
  }
}
