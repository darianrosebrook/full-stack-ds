{
  "root": {
    "display": {
      "literal": "inline-flex",
      "platforms": [
        "web"
      ]
    },
    "align-items": {
      "literal": "center",
      "platforms": [
        "web"
      ]
    },
    "justify-content": {
      "literal": "center",
      "platforms": [
        "web"
      ]
    },
    "box-sizing": {
      "literal": "border-box",
      "platforms": [
        "web"
      ]
    },
    "cursor": {
      "literal": "pointer",
      "platforms": [
        "web"
      ]
    },
    "border-style": {
      "literal": "solid",
      "platforms": [
        "web"
      ]
    },
    "white-space": {
      "literal": "nowrap",
      "platforms": [
        "web"
      ]
    },
    "user-select": {
      "literal": "none",
      "platforms": [
        "web"
      ]
    },
    "background-color": {
      "resolvesTo": "button.color.background.default"
    },
    "color": {
      "resolvesTo": "button.color.foreground.default"
    },
    "border-color": {
      "resolvesTo": "button.color.border.default"
    },
    "gap": {
      "resolvesTo": "button.size.gap.default"
    },
    "border-radius": {
      "resolvesTo": "button.size.radius"
    },
    "border-width": {
      "resolvesTo": "button.size.border"
    },
    "font-weight": {
      "resolvesTo": "button.text.weight"
    },
    "transition-duration": {
      "resolvesTo": "button.motion.duration.fast"
    },
    "transition-timing-function": {
      "resolvesTo": "button.motion.easing.standard"
    }
  },
  "--small": {
    "button.size.padding-block.medium": {
      "resolvesTo": "core.spacing.size.03",
      "fallback": "4px"
    },
    "button.size.padding-inline.medium": {
      "resolvesTo": "core.spacing.size.04",
      "fallback": "8px"
    },
    "button.size.minHeight.medium": {
      "resolvesTo": "core.dimension.actionMinHeightSmall",
      "fallback": "28px"
    },
    "button.size.fontSize.medium": {
      "resolvesTo": "core.typography.ramp.3",
      "fallback": "0.875rem"
    }
  },
  "--medium": {
    "padding-block": {
      "resolvesTo": "button.size.padding-block.medium"
    },
    "padding-inline": {
      "resolvesTo": "button.size.padding-inline.medium"
    },
    "min-height": {
      "resolvesTo": "button.size.minHeight.medium"
    },
    "font-size": {
      "resolvesTo": "button.size.fontSize.medium"
    }
  },
  "--large": {
    "button.size.padding-block.medium": {
      "resolvesTo": "core.spacing.size.05",
      "fallback": "12px"
    },
    "button.size.padding-inline.medium": {
      "resolvesTo": "core.spacing.size.06",
      "fallback": "16px"
    },
    "button.size.minHeight.medium": {
      "resolvesTo": "core.dimension.actionMinHeightLarge",
      "fallback": "48px"
    },
    "button.size.fontSize.medium": {
      "resolvesTo": "core.typography.ramp.5",
      "fallback": "1.125rem"
    }
  },
  "--primary": {
    "button.color.background.default": {
      "resolvesTo": "semantic.color.action.background.primary.default"
    },
    "button.color.foreground.default": {
      "resolvesTo": "semantic.color.foreground.inverse"
    },
    "button.color.border.default": {
      "resolvesTo": "semantic.color.action.background.primary.default"
    }
  },
  "--secondary": {
    "button.color.background.default": {
      "resolvesTo": "semantic.color.action.background.secondary.default",
      "fallback": "#ffffff"
    },
    "button.color.foreground.default": {
      "resolvesTo": "semantic.color.foreground.primary",
      "fallback": "#141414"
    },
    "button.color.border.default": {
      "resolvesTo": "semantic.color.border.default",
      "fallback": "#8f8f8f"
    }
  },
  "--tertiary": {
    "button.color.background.default": {
      "literal": "transparent",
      "platforms": [
        "web",
        "ios",
        "android"
      ]
    },
    "button.color.foreground.default": {
      "resolvesTo": "semantic.color.foreground.primary",
      "fallback": "#141414"
    },
    "button.color.border.default": {
      "literal": "transparent",
      "platforms": [
        "web",
        "ios",
        "android"
      ]
    }
  },
  "--destructive": {
    "button.color.background.default": {
      "resolvesTo": "semantic.color.action.background.danger.default",
      "fallback": "#d9292b"
    },
    "button.color.foreground.default": {
      "resolvesTo": "semantic.color.foreground.inverse",
      "fallback": "#fafafa"
    },
    "button.color.border.default": {
      "resolvesTo": "semantic.color.action.background.danger.default",
      "fallback": "#d9292b"
    }
  },
  "--ghost": {
    "button.color.background.default": {
      "literal": "transparent",
      "platforms": [
        "web",
        "ios",
        "android"
      ]
    },
    "button.color.foreground.default": {
      "resolvesTo": "semantic.color.foreground.primary",
      "fallback": "#141414"
    },
    "button.color.border.default": {
      "literal": "transparent",
      "platforms": [
        "web",
        "ios",
        "android"
      ]
    }
  },
  "--outline": {
    "button.color.background.default": {
      "literal": "transparent",
      "platforms": [
        "web",
        "ios",
        "android"
      ]
    },
    "button.color.foreground.default": {
      "resolvesTo": "semantic.color.foreground.primary",
      "fallback": "#141414"
    },
    "button.color.border.default": {
      "resolvesTo": "semantic.color.border.default",
      "fallback": "#8f8f8f"
    }
  },
  "hover": {
    "button.color.background.default": {
      "resolvesTo": "semantic.interaction.background.hover",
      "fallback": "#efefef"
    },
    "button.color.border.default": {
      "resolvesTo": "semantic.interaction.border.hover",
      "fallback": "#8f8f8f"
    }
  },
  "active": {
    "button.color.background.default": {
      "resolvesTo": "semantic.interaction.background.active",
      "fallback": "#cecece"
    }
  },
  "focus": {
    "button.color.border.default": {
      "resolvesTo": "semantic.color.border.accent",
      "fallback": "#d9292b"
    }
  },
  "disabled": {
    "button.color.background.default": {
      "resolvesTo": "semantic.color.action.background.primary.disabled",
      "fallback": "#cecece"
    },
    "button.color.foreground.default": {
      "resolvesTo": "semantic.color.foreground.disabled",
      "fallback": "#aeaeae"
    }
  },
  "spinner": {
    "display": {
      "literal": "inline-block",
      "platforms": [
        "web"
      ]
    },
    "width": {
      "literal": "1em",
      "platforms": [
        "web"
      ]
    },
    "height": {
      "literal": "1em",
      "platforms": [
        "web"
      ]
    },
    "flex-shrink": {
      "literal": "0",
      "platforms": [
        "web"
      ]
    },
    "animation": {
      "literal": "spin 1s linear infinite",
      "platforms": [
        "web"
      ]
    }
  },
  "loadingText": {
    "display": {
      "literal": "inline-block",
      "platforms": [
        "web"
      ]
    },
    "opacity": {
      "literal": "0.7",
      "platforms": [
        "web"
      ]
    }
  }
}
