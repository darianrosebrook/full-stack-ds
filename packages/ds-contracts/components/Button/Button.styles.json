{
  "root": {
    "display": { "literal": "inline-flex", "platforms": ["web"] },
    "align-items": { "literal": "center", "platforms": ["web"] },
    "justify-content": { "literal": "center", "platforms": ["web"] },
    "box-sizing": { "literal": "border-box", "platforms": ["web"] },
    "cursor": { "literal": "pointer", "platforms": ["web"] },
    "border-style": { "literal": "solid", "platforms": ["web"] },
    "white-space": { "literal": "nowrap", "platforms": ["web"] },
    "user-select": { "literal": "none", "platforms": ["web"] },
    "background-color": {
      "resolvesTo": "button.color.background.default"
    },
    "color": {
      "resolvesTo": "button.color.foreground.default"
    },
    "border-color": {
      "resolvesTo": "button.color.border.default"
    },
    "gap": {
      "resolvesTo": "button.size.gap.default"
    },
    "border-radius": {
      "resolvesTo": "button.size.radius"
    },
    "border-width": {
      "resolvesTo": "button.size.border"
    },
    "font-weight": {
      "resolvesTo": "button.text.weight"
    },
    "transition-duration": {
      "resolvesTo": "button.motion.duration.fast"
    },
    "transition-timing-function": {
      "resolvesTo": "button.motion.easing.standard"
    }
  },
  "--small": {
    "padding-block": { "resolvesTo": "button.size.padding-block.small" },
    "padding-inline": { "resolvesTo": "button.size.padding-inline.small" },
    "min-height": { "resolvesTo": "button.size.minHeight.small" },
    "font-size": { "resolvesTo": "button.size.fontSize.small" }
  },
  "--medium": {
    "padding-block": { "resolvesTo": "button.size.padding-block.medium" },
    "padding-inline": { "resolvesTo": "button.size.padding-inline.medium" },
    "min-height": { "resolvesTo": "button.size.minHeight.medium" },
    "font-size": { "resolvesTo": "button.size.fontSize.medium" }
  },
  "--large": {
    "padding-block": { "resolvesTo": "button.size.padding-block.large" },
    "padding-inline": { "resolvesTo": "button.size.padding-inline.large" },
    "min-height": { "resolvesTo": "button.size.minHeight.large" },
    "font-size": { "resolvesTo": "button.size.fontSize.large" }
  },
  "hover": {
    "background-color": {
      "resolvesTo": "button.color.background.hover"
    },
    "border-color": {
      "resolvesTo": "button.color.border.hover"
    }
  },
  "active": {
    "background-color": {
      "resolvesTo": "button.color.background.active"
    }
  },
  "focus": {
    "border-color": {
      "resolvesTo": "button.color.border.focus"
    }
  },
  "disabled": {
    "background-color": {
      "resolvesTo": "button.color.background.disabled"
    },
    "color": {
      "resolvesTo": "button.color.foreground.disabled"
    }
  },
  "spinner": {
    "display": { "literal": "inline-block", "platforms": ["web"] },
    "width": { "literal": "1em", "platforms": ["web"] },
    "height": { "literal": "1em", "platforms": ["web"] },
    "flex-shrink": { "literal": "0", "platforms": ["web"] },
    "animation": { "literal": "spin 1s linear infinite", "platforms": ["web"] }
  },
  "loadingText": {
    "display": { "literal": "inline-block", "platforms": ["web"] },
    "opacity": { "literal": "0.7", "platforms": ["web"] }
  }
}
