{
  "$schema": "../../component.contract.schema.json",
  "name": "Button",
  "description": "Clickable element for triggering actions. Supports multiple visual variants and semantic intents.",
  "layer": "primitive",
  "category": "action",
  "anatomy": {
    "parts": [
      "root",
      "spinner",
      "loadingText"
    ],
    "dom": {
      "tag": "button",
      "part": "root",
      "bindings": {
        "type": "prop:type",
        "disabled": "prop:disabled",
        "aria-label": "prop:ariaLabel",
        "aria-expanded": "prop:ariaExpanded",
        "aria-pressed": "prop:ariaPressed",
        "aria-busy": "prop:loading"
      },
      "children": [
        {
          "tag": "children"
        }
      ]
    }
  },
  "props": {
    "designed": {
      "members": [
        {
          "name": "size",
          "propType": { "kind": "ref", "to": "ButtonSize" },
          "description": "Visual size variant.",
          "default": "medium"
        },
        {
          "name": "variant",
          "propType": { "kind": "ref", "to": "ButtonVariant" },
          "description": "Visual intent variant. Use destructive only for irreversible actions.",
          "default": "primary"
        },
        {
          "name": "type",
          "propType": { "kind": "ref", "to": "ButtonType" },
          "description": "HTML button type. Defaults to button to prevent accidental form submission.",
          "default": "button"
        },
        {
          "name": "loading",
          "propType": { "kind": "boolean" },
          "description": "When true, replaces content with a spinner and sets aria-busy."
        },
        {
          "name": "disabled",
          "propType": { "kind": "boolean" },
          "description": "Prevents interaction and applies disabled styling."
        },
        {
          "name": "ariaLabel",
          "propType": { "kind": "string" },
          "description": "Accessible label for icon-only buttons."
        },
        {
          "name": "ariaExpanded",
          "propType": { "kind": "boolean" },
          "description": "aria-expanded for disclosure triggers."
        },
        {
          "name": "ariaPressed",
          "propType": { "kind": "boolean" },
          "description": "aria-pressed for toggle buttons."
        },
        {
          "name": "title",
          "propType": { "kind": "string" },
          "description": "Supplementary tooltip text."
        }
      ]
    }
  },
  "types": {
    "ButtonSize": {
      "kind": "union",
      "values": [
        "small",
        "medium",
        "large"
      ]
    },
    "ButtonVariant": {
      "kind": "union",
      "values": [
        "primary",
        "secondary",
        "tertiary",
        "ghost",
        "destructive",
        "outline"
      ]
    },
    "ButtonType": {
      "kind": "union",
      "values": [
        "button",
        "submit",
        "reset"
      ]
    }
  },
  "variants": {
    "size": [
      "small",
      "medium",
      "large"
    ],
    "variant": [
      "primary",
      "secondary",
      "tertiary",
      "ghost",
      "destructive",
      "outline"
    ]
  },
  "states": [
    "default",
    "hover",
    "focus",
    "active",
    "disabled"
  ],
  "slots": {
    "root": {
      "required": true,
      "selector": "[data-slot=\"button\"]"
    }
  },
  "ssr": {
    "hydrateOn": "interaction"
  },
  "rtl": {
    "flipIcon": false
  },
  "a11y": {
    "role": "button",
    "labeling": [
      "aria-label",
      "title"
    ],
    "keyboard": [
      {
        "key": "Enter|Space",
        "action": "Activate the button (same as click)."
      }
    ]
  },
  "a2ui": {
    "category": "action",
    "usageHints": [
      "Use variant=primary for the single most important action in a view",
      "Use variant=danger for irreversible or destructive actions",
      "Use variant=ghost for tertiary actions that should not compete visually",
      "Set disabled to prevent interaction when the action is unavailable",
      "Use as=\"a\" with href for navigation-style buttons"
    ],
    "children": {
      "allowed": true,
      "slot": "children",
      "accepts": [
        "string",
        "icon-ref"
      ]
    }
  },
  "keyframes": {
    "spin": {
      "from": {
        "transform": "rotate(0deg)"
      },
      "to": {
        "transform": "rotate(360deg)"
      }
    }
  }
}
