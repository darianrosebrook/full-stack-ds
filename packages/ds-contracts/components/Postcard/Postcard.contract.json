{
  "$schema": "../../component.contract.schema.json",
  "name": "Postcard",
  "description": "Social-media-style post card with author, content, media embed, and engagement stat slots.",
  "layer": "compound",
  "category": "surface",
  "anatomy": {
    "parts": [
      "root",
      "header",
      "userInfo",
      "displayName",
      "handle",
      "timestamp",
      "content",
      "footer",
      "stats",
      "stat"
    ],
    "details": {
      "root": {
        "tag": "article",
        "description": "Article-like post container grouping author, timestamp, content, and engagement stats.",
        "role": "region"
      },
      "header": {
        "tag": "div",
        "description": "Post header containing author identity and publishing time.",
        "role": "group"
      },
      "userInfo": {
        "tag": "div",
        "description": "Author identity cluster containing display name and handle.",
        "role": "group"
      },
      "displayName": {
        "tag": "span",
        "description": "Visible author display name.",
        "role": "label"
      },
      "handle": {
        "tag": "span",
        "description": "Author handle or username.",
        "role": "context"
      },
      "timestamp": {
        "tag": "time",
        "description": "Machine-readable post publication time.",
        "role": "context"
      },
      "content": {
        "tag": "div",
        "description": "Primary post body and optional media content.",
        "role": "content"
      },
      "footer": {
        "tag": "div",
        "description": "Footer region for engagement metadata.",
        "role": "group"
      },
      "stats": {
        "tag": "div",
        "description": "Engagement statistics group such as replies, reposts, and likes.",
        "role": "group"
      },
      "stat": {
        "tag": "span",
        "description": "Single engagement statistic value or label.",
        "role": "item",
        "multiple": true
      }
    },
    "dom": {
      "tag": "article",
      "part": "root",
      "children": [
        {
          "tag": "div",
          "part": "header",
          "children": [
            {
              "tag": "div",
              "part": "userInfo",
              "children": [
                {
                  "tag": "span",
                  "part": "displayName"
                },
                {
                  "tag": "span",
                  "part": "handle"
                }
              ]
            },
            {
              "tag": "time",
              "part": "timestamp"
            }
          ]
        },
        {
          "tag": "div",
          "part": "content",
          "children": [
            {
              "tag": "children"
            }
          ]
        },
        {
          "tag": "div",
          "part": "footer",
          "children": [
            {
              "tag": "div",
              "part": "stats",
              "children": [
                {
                  "tag": "span",
                  "part": "stat"
                }
              ]
            }
          ]
        }
      ]
    }
  },
  "props": {
    "styled": {
      "description": "Props for the <Postcard> component.",
      "members": [
        {
          "name": "postId",
          "type": "string",
          "description": "Unique identifier for the post.",
          "required": true
        },
        {
          "name": "author",
          "type": "PostcardAuthor",
          "description": "Author metadata: name, handle, and avatar URL.",
          "required": true
        },
        {
          "name": "timestamp",
          "type": "string",
          "description": "ISO 8601 timestamp of the post.",
          "required": true
        },
        {
          "name": "stats",
          "type": "PostcardStats",
          "description": "Engagement statistics: likes, replies, reposts.",
          "required": true
        },
        {
          "name": "embed",
          "type": "PostcardEmbed",
          "description": "Optional media embed with type, URL, and aspect ratio."
        }
      ]
    }
  },
  "types": {
    "PostcardAuthor": {
      "kind": "alias",
      "alias": "{ name: string; handle: string; avatar: string }"
    },
    "PostcardStats": {
      "kind": "alias",
      "alias": "{ likes: number; replies: number; reposts: number }"
    },
    "PostcardEmbed": {
      "kind": "alias",
      "alias": "{ type: 'image' | 'video' | 'audio'; url: string; aspectRatio: { width: number; height: number } }"
    }
  },
  "variants": {
    "type": [
      "image",
      "video",
      "audio"
    ]
  },
  "states": {
    "dimensions": {
      "pointer": {
        "category": "interaction",
        "values": [
          "default",
          "hover"
        ],
        "initial": "default",
        "exclusive": true
      }
    }
  },
  "slots": {
    "root": {
      "required": true,
      "selector": "[data-slot=\"postcard\"]"
    },
    "header": {
      "required": false,
      "selector": "[data-slot=\"postcard-header\"]"
    },
    "body": {
      "required": false,
      "selector": "[data-slot=\"postcard-body\"]"
    },
    "footer": {
      "required": false,
      "selector": "[data-slot=\"postcard-footer\"]"
    },
    "stats": {
      "required": false,
      "selector": "[data-slot=\"postcard-stats\"]"
    },
    "author": {
      "required": false,
      "selector": "[data-slot=\"postcard-author\"]"
    },
    "timestamp": {
      "required": false,
      "selector": "[data-slot=\"postcard-timestamp\"]"
    },
    "content": {
      "required": false,
      "selector": "[data-slot=\"postcard-content\"]"
    },
    "embed": {
      "required": false,
      "selector": "[data-slot=\"postcard-embed\"]"
    },
    "stat": {
      "required": false,
      "selector": "[data-slot=\"postcard-stat\"]"
    }
  },
  "ssr": {
    "hydrateOn": "interaction"
  },
  "rtl": {
    "flipIcon": false
  },
  "focus": {
    "strategy": "none",
    "description": "Postcard is a display surface. Focus is not managed — child engagement actions (Like, Reply, Repost) carry their own focus handling."
  },
  "a11y": {
    "role": "article",
    "apgPattern": null,
    "labeling": [
      "aria-labelledby"
    ],
    "keyboard": []
  },
  "a2ui": {
    "category": "content",
    "usageHints": [
      "Compose with Postcard.Header, .Body, .Footer, .Stats, .Author, .Timestamp, .Content, .Embed",
      "Like, Reply, Repost, and ExternalLink sub-components render the engagement action buttons",
      "Postcard.Embed auto-selects image/video/audio renderer based on embed.type"
    ],
    "children": {
      "allowed": true,
      "slot": "children",
      "accepts": [
        "Postcard.Header",
        "Postcard.Body",
        "Postcard.Footer",
        "Postcard.Stats"
      ]
    }
  }
}
