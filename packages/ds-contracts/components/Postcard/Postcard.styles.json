{
  "root": {
    "background-color": {
      "resolvesTo": "postcard.color.background.default"
    },
    "border-color": {
      "resolvesTo": "postcard.color.border.accent"
    },
    "color": {
      "resolvesTo": "postcard.color.foreground.secondary"
    },
    "padding": {
      "resolvesTo": "postcard.size.padding.default"
    },
    "border-radius": {
      "resolvesTo": "postcard.size.radius.default"
    },
    "gap": {
      "resolvesTo": "postcard.size.gap.default"
    },
    "line-height": {
      "resolvesTo": "postcard.typography.content.lineHeight"
    },
    "display": { "literal": "flex", "platforms": ["web"] },
    "flex-direction": { "literal": "column", "platforms": ["web"] },
    "border-style": { "literal": "solid", "platforms": ["web"] },
    "border-width": { "resolvesTo": "postcard.size.border.default" },
    "box-sizing": { "literal": "border-box", "platforms": ["web"] }
  },
  "hover": {
    "background-color": {
      "resolvesTo": "postcard.color.background.hover"
    },
    "border-color": {
      "resolvesTo": "postcard.color.border.hover"
    }
  },
  "content": {
    "line-height": {
      "resolvesTo": "postcard.typography.content.lineHeight"
    },
    "display": { "literal": "flex", "platforms": ["web"] },
    "flex-direction": { "literal": "column", "platforms": ["web"] },
    "gap": { "resolvesTo": "postcard.size.gap.default" },
    "color": { "resolvesTo": "postcard.color.foreground.primary" },
    "font-size": { "resolvesTo": "postcard.typography.content.fontSize" }
  },
  "header": {
    "display": { "literal": "flex", "platforms": ["web"] },
    "align-items": { "literal": "center", "platforms": ["web"] },
    "justify-content": { "literal": "space-between", "platforms": ["web"] },
    "gap": { "resolvesTo": "postcard.size.gap.default" }
  },
  "userInfo": {
    "display": { "literal": "flex", "platforms": ["web"] },
    "align-items": { "literal": "center", "platforms": ["web"] },
    "gap": { "resolvesTo": "postcard.size.gap.small" },
    "flex": { "literal": "1 1 auto", "platforms": ["web"] }
  },
  "displayName": {
    "font-weight": { "resolvesTo": "postcard.typography.displayName.fontWeight" },
    "font-size": { "resolvesTo": "postcard.typography.displayName.fontSize" },
    "color": { "resolvesTo": "postcard.color.foreground.primary" }
  },
  "handle": {
    "color": { "resolvesTo": "postcard.color.foreground.secondary" },
    "font-size": { "resolvesTo": "postcard.typography.handle.fontSize" }
  },
  "timestamp": {
    "color": { "resolvesTo": "postcard.color.foreground.secondary" },
    "font-size": { "resolvesTo": "postcard.typography.footer.fontSize" },
    "flex-shrink": { "literal": "0", "platforms": ["web"] }
  },
  "footer": {
    "display": { "literal": "flex", "platforms": ["web"] },
    "align-items": { "literal": "center", "platforms": ["web"] },
    "gap": { "resolvesTo": "postcard.size.gap.default" },
    "padding-top": { "resolvesTo": "postcard.size.padding.default" },
    "border-top-color": { "resolvesTo": "postcard.color.border.default" },
    "border-top-style": { "literal": "solid", "platforms": ["web"] },
    "border-top-width": { "resolvesTo": "postcard.size.border.default" },
    "font-size": { "resolvesTo": "postcard.typography.footer.fontSize" }
  },
  "stats": {
    "display": { "literal": "flex", "platforms": ["web"] },
    "align-items": { "literal": "center", "platforms": ["web"] },
    "gap": { "resolvesTo": "postcard.size.gap.default" }
  },
  "stat": {
    "display": { "literal": "inline-flex", "platforms": ["web"] },
    "align-items": { "literal": "center", "platforms": ["web"] },
    "gap": { "resolvesTo": "postcard.size.gap.small" },
    "color": { "resolvesTo": "postcard.color.foreground.secondary" },
    "font-size": { "resolvesTo": "postcard.typography.footer.fontSize" }
  }
}
