      "literal": "pointer",
      "platforms": [
        "web"
      ]
    },
    "font": {
      "literal": "inherit",
      "platforms": [
        "web"
      ]
    },
    "line-height": {
      "literal": "1",
      "platforms": [
        "web"
      ]
    }
  },
  ".alert__dismiss:hover": {
    "opacity": {
      "literal": "0.7",
      "platforms": [
        "web"
      ]
    }
  },
  ".alert__dismiss:focus-visible": {
    "outline": {
      "literal": "2px solid currentColor",
      "platforms": [
        "web"
      ]
    },
    "outline-offset": {
      "literal": "2px",
      "platforms": [
        "web"
      ]
    }
  },
