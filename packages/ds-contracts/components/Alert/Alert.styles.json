      "platforms": [
        "web"
      ]
    },
    "border-style": {
      "literal": "solid",
      "platforms": [
        "web"
      ]
    },
    "border-width": {
      "literal": "1px",
      "platforms": [
        "web"
      ]
    },
    "box-sizing": {
