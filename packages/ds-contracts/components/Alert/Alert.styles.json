    },
    "border-radius": {
      "resolvesTo": "alert.size.radius"
    },
    "gap": {
      "resolvesTo": "alert.spacing.gap"
    },
    "font-size": {
      "resolvesTo": "alert.text.size"
    },
    "font-weight": {
      "resolvesTo": "alert.text.weight"
    },
    "background-color": {
