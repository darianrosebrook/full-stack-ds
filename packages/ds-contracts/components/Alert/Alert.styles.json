      "resolvesTo": "alert.color.background.danger"
    },
    "color": {
      "resolvesTo": "alert.color.foreground.danger"
    },
    "border-color": {
      "resolvesTo": "alert.color.border.danger"
    },
    "padding": {
      "resolvesTo": "alert.size.padding"
    },
    "border-radius": {
      "resolvesTo": "alert.size.radius"
    },
