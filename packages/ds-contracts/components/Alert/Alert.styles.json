      "platforms": [
        "web"
      ]
    },
    "justify-content": {
      "literal": "center",
      "platforms": [
        "web"
      ]
    },
    "flex-shrink": {
      "literal": "0",
      "platforms": [
        "web"
      ]
    }
  },
  "body": {
    "flex": {
      "literal": "1 1 auto",
      "platforms": [
        "web"
      ]
    },
    "display": {
      "literal": "flex",
      "platforms": [
        "web"
      ]
