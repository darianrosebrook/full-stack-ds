{
  "$schema": "../../component.contract.schema.json",
  "name": "Alert",
  "description": "Inline notification banner for important messages. Does not require user interaction to dismiss.",
  "layer": "compound",
  "anatomy": {
    "parts": [
      "root",
      "icon",
      "body",
      "title",
      "dismiss"
    ]
  },
  "props": {
    "styled": {
      "description": "Props for the <Alert> component.",
      "members": [
        {
          "name": "intent",
          "type": "AlertIntent",
          "description": "Visual intent/severity of the alert"
        },
        {
          "name": "level",
          "type": "AlertLevel",
          "description": "Display level affecting layout and emphasis"
        },
        {
          "name": "dismissible",
          "type": "boolean",
          "description": "Whether the alert can be dismissed by the user"
        },
        {
          "name": "icon",
          "type": "ReactNode",
          "description": "Optional icon node rendered before the alert content"
        }
      ]
    }
  },
  "types": {
    "AlertIntent": {
      "kind": "union",
      "values": [
        "info",
        "success",
        "warning",
        "danger"
      ]
    },
    "AlertLevel": {
      "kind": "union",
      "values": [
        "inline",
        "section",
        "page"
      ]
    }
  },
  "variants": {
    "intent": [
      "info",
      "success",
      "warning",
      "danger"
    ],
    "level": [
      "inline",
      "section",
      "page"
    ]
  },
  "states": [
    "default",
    "hover"
  ],
  "tokens": {
    "root": {
      "alert.color.background.primary": {
        "resolvesTo": "semantic.color.background.primary",
        "fallback": "#ffffff",
        "property": "background-color",
        "layer": "semantic"
      },
      "alert.color.foreground.primary": {
        "resolvesTo": "semantic.color.foreground.primary",
        "fallback": "#141414",
        "property": "color",
        "layer": "semantic"
      },
      "alert.color.border.primary": {
        "resolvesTo": "semantic.color.border.primary",
        "fallback": "#f29495",
        "property": "border-color",
        "layer": "semantic"
      },
      "alert.color.background.info": {
        "resolvesTo": "semantic.color.background.info.subtle",
        "fallback": "#d9f3fe",
        "property": "background-color",
        "layer": "semantic"
      },
      "alert.color.background.success": {
        "resolvesTo": "semantic.color.background.success.subtle",
        "fallback": "#e4f2e0",
        "property": "background-color",
        "layer": "semantic"
      },
      "alert.color.background.warning": {
        "resolvesTo": "semantic.color.background.warning.subtle",
        "fallback": "#ffedcc",
        "property": "background-color",
        "layer": "semantic"
      },
      "alert.color.background.danger": {
        "resolvesTo": "semantic.color.background.danger.subtle",
        "fallback": "#fceaea",
        "property": "background-color",
        "layer": "semantic"
      },
      "alert.color.foreground.info": {
        "resolvesTo": "semantic.color.foreground.on.info.subtle",
        "fallback": "#002d99",
        "property": "color",
        "layer": "semantic"
      },
      "alert.color.foreground.success": {
        "resolvesTo": "semantic.color.foreground.on.success.subtle",
        "fallback": "#234104",
        "property": "color",
        "layer": "semantic"
      },
      "alert.color.foreground.warning": {
        "resolvesTo": "semantic.color.foreground.on.warning.subtle",
        "fallback": "#593000",
        "property": "color",
        "layer": "semantic"
      },
      "alert.color.foreground.danger": {
        "resolvesTo": "semantic.color.foreground.on.danger.subtle",
        "fallback": "#7b0000",
        "property": "color",
        "layer": "semantic"
      },
      "alert.color.border.info": {
        "resolvesTo": "semantic.color.border.info",
        "fallback": "#0042dc",
        "property": "border-color",
        "layer": "semantic"
      },
      "alert.color.border.success": {
        "resolvesTo": "semantic.color.border.success",
        "fallback": "#336006",
        "property": "border-color",
        "layer": "semantic"
      },
      "alert.color.border.warning": {
        "resolvesTo": "semantic.color.border.warning",
        "fallback": "#824500",
        "property": "border-color",
        "layer": "semantic"
      },
      "alert.color.border.danger": {
        "resolvesTo": "semantic.color.border.danger",
        "fallback": "#ae0001",
        "property": "border-color",
        "layer": "semantic"
      },
      "alert.size.padding": {
        "resolvesTo": "core.spacing.size.06",
        "fallback": "16px",
        "property": "padding",
        "layer": "core"
      },
      "alert.size.radius": {
        "resolvesTo": "semantic.shape.control.radius.default",
        "fallback": "8px",
        "property": "border-radius",
        "layer": "semantic"
      },
      "alert.spacing.gap": {
        "resolvesTo": "semantic.spacing.gap.grid.small",
        "fallback": "8px",
        "property": "gap",
        "layer": "semantic"
      },
      "alert.text.size": {
        "resolvesTo": "semantic.typography.body.03",
        "fallback": "14px",
        "property": "font-size",
        "layer": "semantic"
      },
      "alert.text.weight": {
        "resolvesTo": "semantic.typography.font.weight.regular",
        "fallback": "400",
        "property": "font-weight",
        "layer": "semantic"
      },
      "alert.icon.size": {
        "resolvesTo": "core.spacing.size.06",
        "fallback": "16px",
        "layer": "core"
      }
    },
    "title": {
      "alert.typography.title.fontWeight": {
        "resolvesTo": "semantic.typography.font.weight.bold",
        "fallback": "700",
        "property": "font-weight",
        "layer": "semantic"
      },
      "alert.typography.title.fontSize": {
        "resolvesTo": "semantic.typography.body.02",
        "fallback": "16px",
        "property": "font-size",
        "layer": "semantic"
      }
    }
  },
  "slots": {
    "body": {
      "required": false
    },
    "container": {
      "required": false
    },
    "dismiss": {
      "required": false
    },
    "icon": {
      "required": false
    },
    "title": {
      "required": false
    }
  },
  "ssr": {
    "hydrateOn": "interaction"
  },
  "rtl": {
    "flipIcon": true
  },
  "a11y": {
    "role": "alert",
    "labeling": [
      "aria-label"
    ],
    "keyboard": []
  },
  "a2ui": {
    "category": "display",
    "usageHints": [
      "Use intent to convey severity: info, success, warning, or error",
      "Keep messages concise \u2014 Alert is for brief contextual feedback, not lengthy instructions",
      "Pair with an icon to reinforce intent visually"
    ],
    "children": {
      "allowed": true,
      "slot": "children",
      "accepts": [
        "string",
        "node-ref"
      ]
    }
  }
}
