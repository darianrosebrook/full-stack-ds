{
  "$schema": "../../component.contract.schema.json",
  "name": "Links",
  "description": "Styled anchor links with design-system typography and color variants.",
  "layer": "primitive",
  "category": "display",
  "anatomy": {
    "parts": [
      "root"
    ],
    "details": {
      "root": {
        "tag": "a",
        "description": "Anchor element that navigates to the linked document and carries target/relationship metadata.",
        "role": "trigger",
        "interactive": true,
        "focusable": true
      }
    },
    "dom": {
      "tag": "a",
      "part": "root",
      "bindings": {
        "href": "prop:href",
        "target": "prop:target",
        "rel": "prop:rel"
      },
      "children": [
        {
          "tag": "children"
        }
      ]
    }
  },
  "props": {
    "designed": {
      "members": [
        {
          "name": "href",
          "propType": { "kind": "string" },
          "description": "Navigation destination URL."
        },
        {
          "name": "target",
          "propType": { "kind": "ref", "to": "LinkTarget" },
          "description": "Where to open the linked document."
        },
        {
          "name": "rel",
          "propType": { "kind": "string" },
          "description": "Relationship between current document and the linked one (e.g., \"noopener noreferrer\")."
        },
        {
          "name": "size",
          "propType": { "kind": "ref", "to": "LinkSize" },
          "description": "Visual size token."
        },
        {
          "name": "disabled",
          "propType": { "kind": "boolean" },
          "description": "Visually disables the link. Note: anchors are not natively disable-able; intercept onClick to actually prevent navigation."
        }
      ]
    }
  },
  "types": {
    "LinkTarget": {
      "kind": "union",
      "values": [
        "_self",
        "_blank",
        "_parent",
        "_top"
      ]
    },
    "LinkSize": {
      "kind": "union",
      "values": [
        "small",
        "medium",
        "large"
      ]
    }
  },
  "variants": {
    "size": [
      "small",
      "medium",
      "large"
    ]
  },
  "states": {
    "dimensions": {
      "pointer": {
        "category": "interaction",
        "values": [
          "default",
          "hover",
          "visited"
        ],
        "initial": "default",
        "exclusive": true
      },
      "focus": {
        "category": "interaction",
        "values": [
          "unfocused",
          "focus"
        ],
        "initial": "unfocused",
        "exclusive": true
      },
      "availability": {
        "category": "availability",
        "effect": "restyle",
        "values": [
          "enabled",
          "disabled"
        ],
        "initial": "enabled",
        "exclusive": true,
        "suppresses": {
          "categories": [
            "interaction"
          ]
        }
      }
    }
  },
  "slots": {
    "root": {
      "required": true,
      "selector": "[data-slot=\"links\"]"
    }
  },
  "ssr": {
    "hydrateOn": "interaction"
  },
  "rtl": {
    "flipIcon": false
  },
  "a11y": {
    "labeling": [],
    "keyboard": []
  },
  "a2ui": {
    "category": "navigation",
    "usageHints": [
      "Use for inline hyperlinks within body copy",
      "Use variant=standalone for a link that stands alone, not within a sentence",
      "Prefer Button for actions — Links are for navigation"
    ],
    "children": {
      "allowed": true,
      "slot": "children",
      "accepts": [
        "string",
        "ReactNode"
      ]
    }
  }
}
