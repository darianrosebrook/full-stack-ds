{
  "box-model.gap": {
    "resolvesTo": "semantic.display.size.gap",
    "fallback": "4px",
    "layer": "semantic"
  },
  "links.color.foreground.default": {
    "resolvesTo": "semantic.color.foreground.link",
    "fallback": "#d9292b",
    "layer": "semantic"
  },
  "links.color.foreground.hover": {
    "resolvesTo": "semantic.color.foreground.linkHover",
    "fallback": "#ae0001",
    "layer": "semantic"
  },
  "links.color.foreground.visited": {
    "resolvesTo": "semantic.color.foreground.linkVisited",
    "fallback": "#9b0002",
    "layer": "semantic"
  },
  "links.color.foreground.disabled": {
    "resolvesTo": "semantic.color.foreground.disabled",
    "fallback": "#aeaeae",
    "layer": "semantic"
  },
  "links.color.underline.default": {
    "resolvesTo": "semantic.color.border.light",
    "fallback": "#fceaea",
    "layer": "semantic"
  },
  "links.spacing.gap.default": {
    "resolvesTo": "core.spacing.size.02",
    "fallback": "2px",
    "layer": "core"
  },
  "links.motion.duration.fast": {
    "resolvesTo": "core.motion.duration.short",
    "fallback": "150ms",
    "layer": "core"
  },
  "links.focus.ring.width": {
    "resolvesTo": "semantic.focus.ring.width",
    "fallback": "2px",
    "layer": "semantic"
  },
  "links.focus.ring.color": {
    "resolvesTo": "semantic.focus.ring.color",
    "fallback": "#0a65fe",
    "layer": "semantic"
  },
  "links.focus.ring.style": {
    "resolvesTo": "semantic.focus.ring.style",
    "fallback": "solid",
    "layer": "semantic"
  },
  "links.focus.ring.offset": {
    "resolvesTo": "semantic.focus.ring.offset",
    "fallback": "2px",
    "layer": "semantic"
  },
  "links.focus.ring.radius": {
    "resolvesTo": "core.shape.radius.small",
    "fallback": "2px",
    "layer": "core"
  },
  "links.size.fontSize.small": {
    "resolvesTo": "core.typography.ramp.3",
    "fallback": "0.875rem",
    "layer": "core"
  },
  "links.size.fontSize.medium": {
    "resolvesTo": "core.typography.ramp.4",
    "fallback": "1rem",
    "layer": "core"
  },
  "links.size.fontSize.large": {
    "resolvesTo": "core.typography.ramp.5",
    "fallback": "1.125rem",
    "layer": "core"
  }
}
