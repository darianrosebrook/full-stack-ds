{
  "$schema": "../../component.contract.schema.json",
  "name": "ShowMore",
  "description": "Expandable container that truncates long content with a 'show more' affordance.",
  "layer": "composer",
  "category": "action",
  "anatomy": {
    "parts": [
      "root",
      "content",
      "trigger"
    ],
    "details": {
      "root": {
        "tag": "div",
        "description": "Expandable content host that coordinates truncation and expanded state.",
        "role": "root"
      },
      "content": {
        "tag": "div",
        "description": "Content region clamped to maxLines while collapsed and fully revealed when expanded.",
        "role": "content"
      },
      "trigger": {
        "tag": "button",
        "description": "Button that toggles whether the full content is revealed.",
        "role": "trigger",
        "interactive": true,
        "focusable": true,
        "aria": {
          "attributes": [
            "aria-expanded"
          ]
        }
      }
    },
    "dom": {
      "tag": "div",
      "part": "root",
      "children": [
        {
          "tag": "div",
          "part": "content",
          "cssVariableBindings": {
            "--fsds-show-more-content-max-lines": "prop:maxLines"
          },
          "children": [
            {
              "tag": "children"
            }
          ]
        },
        {
          "tag": "button",
          "part": "trigger",
          "attrs": {
            "type": "button"
          },
          "bindings": {
            "aria-expanded": "channel:expanded.value"
          },
          "events": {
            "click": "channel:expanded.onChange"
          },
          "content": "prop:showMoreLabel"
        }
      ]
    }
  },
  "props": {
    "styled": {
      "description": "Props for the <ShowMore> expandable content component.",
      "members": [
        {
          "name": "expanded",
          "type": "boolean",
          "description": "Controlled expanded state."
        },
        {
          "name": "defaultExpanded",
          "type": "boolean",
          "description": "Default expanded state for uncontrolled usage."
        },
        {
          "name": "onExpandedChange",
          "type": "(expanded: boolean) => void",
          "description": "Called when expanded state changes."
        },
        {
          "name": "maxLines",
          "type": "number",
          "description": "Number of lines to show before truncation.",
          "default": 3
        },
        {
          "name": "showMoreLabel",
          "type": "string",
          "description": "Label for the expand trigger button.",
          "default": "Show more"
        },
        {
          "name": "showLessLabel",
          "type": "string",
          "description": "Label for the collapse trigger button.",
          "default": "Show less"
        }
      ]
    }
  },
  "channels": {
    "expanded": {
      "value": "expanded",
      "defaultValue": "defaultExpanded",
      "onChange": "onExpandedChange",
      "valueType": "boolean",
      "description": "Whether the full content is revealed."
    }
  },
  "variants": {},
  "states": {
    "dimensions": {
      "pointer": {
        "category": "interaction",
        "values": [
          "default"
        ],
        "initial": "default",
        "exclusive": true
      },
      "expansion": {
        "category": "visibility",
        "effect": "channel",
        "values": [
          "collapsed",
          "expanded"
        ],
        "initial": "collapsed",
        "exclusive": true,
        "a11y": {
          "attribute": "aria-expanded",
          "values": {
            "collapsed": "false",
            "expanded": "true"
          }
        }
      }
    }
  },
  "slots": {
    "content": {
      "required": false
    },
    "trigger": {
      "required": false
    }
  },
  "focus": {
    "strategy": "auto",
    "description": "Focus stays on the trigger when expanded or collapsed; the revealed content is not auto-focused."
  },
  "ssr": {
    "hydrateOn": "interaction"
  },
  "rtl": {
    "flipIcon": false
  },
  "a11y": {
    "role": "button",
    "apgPattern": "button",
    "labeling": [
      "aria-expanded"
    ],
    "keyboard": [
      {
        "key": "Enter",
        "action": "Toggle expanded state.",
        "when": "trigger"
      },
      {
        "key": "Space",
        "action": "Toggle expanded state.",
        "when": "trigger"
      }
    ]
  },
  "a2ui": {
    "category": "content",
    "usageHints": [
      "Use when content could be long but brevity is preferred by default",
      "Configure maxLines to control how many lines are shown before truncation",
      "Avoid if the full content is always needed — prefer Details instead"
    ],
    "children": {
      "allowed": true,
      "slot": "children",
      "accepts": [
        "ReactNode"
      ]
    }
  }
}
