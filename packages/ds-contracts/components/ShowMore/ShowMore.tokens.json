{
  "root": {
    "showmore.color.background.default": {
      "resolvesTo": "semantic.color.background.secondary",
      "fallback": "#efefef",
      "property": "background-color",
      "layer": "semantic"
    },
    "showmore.color.foreground.primary": {
      "resolvesTo": "semantic.color.foreground.primary",
      "fallback": "#141414",
      "property": "color",
      "layer": "semantic"
    },
    "showmore.color.foreground.secondary": {
      "resolvesTo": "semantic.color.foreground.secondary",
      "fallback": "#555555",
      "property": "color",
      "layer": "semantic"
    },
    "showmore.color.border.default": {
      "resolvesTo": "semantic.color.border.light",
      "fallback": "#fceaea",
      "property": "border-color",
      "layer": "semantic"
    },
    "showmore.color.border.accent": {
      "resolvesTo": "semantic.color.border.accent",
      "fallback": "#d9292b",
      "property": "border-color",
      "layer": "semantic"
    },
    "showmore.size.padding.default": {
      "resolvesTo": "core.spacing.size.07",
      "fallback": "24px",
      "property": "padding",
      "layer": "core"
    },
    "showmore.size.radius.default": {
      "resolvesTo": "core.shape.radius.medium",
      "fallback": "8px",
      "property": "border-radius",
      "layer": "core"
    },
    "showmore.overlay.imageOverlay": {
      "resolvesTo": "semantic.color.background.image.overlay",
      "fallback": "rgba(0, 0, 0, 0.5)",
      "layer": "semantic"
    }
  }
}
