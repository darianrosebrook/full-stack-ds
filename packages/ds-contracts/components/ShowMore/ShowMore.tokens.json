{
  "show-more.color.background.default": {
    "resolvesTo": "semantic.color.background.secondary",
    "fallback": "#efefef",
    "layer": "semantic"
  },
  "show-more.color.foreground.primary": {
    "resolvesTo": "semantic.color.foreground.primary",
    "fallback": "#141414",
    "layer": "semantic"
  },
  "show-more.color.foreground.secondary": {
    "resolvesTo": "semantic.color.foreground.secondary",
    "fallback": "#555555",
    "layer": "semantic"
  },
  "show-more.color.border.default": {
    "resolvesTo": "semantic.color.border.light",
    "fallback": "#fceaea",
    "layer": "semantic"
  },
  "show-more.color.border.accent": {
    "resolvesTo": "semantic.color.border.accent",
    "fallback": "#d9292b",
    "layer": "semantic"
  },
  "show-more.size.padding.default": {
    "resolvesTo": "core.spacing.size.07",
    "fallback": "24px",
    "layer": "core"
  },
  "show-more.size.radius.default": {
    "resolvesTo": "core.shape.radius.medium",
    "fallback": "8px",
    "layer": "core"
  },
  "show-more.overlay.imageOverlay": {
    "resolvesTo": "semantic.color.background.image.overlay",
    "fallback": "rgba(0, 0, 0, 0.5)",
    "layer": "semantic"
  }
}
