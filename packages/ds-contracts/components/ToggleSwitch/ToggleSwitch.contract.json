{
  "$schema": "../../component.contract.schema.json",
  "name": "ToggleSwitch",
  "description": "Binary switch control rendered as a button[role=switch] with an adjacent label.",
  "layer": "primitive",
  "anatomy": {
    "parts": [
      "root",
      "label",
      "input"
    ],
    "dom": {
      "tag": "button",
      "part": "root",
      "attrs": {
        "type": "button"
      },
      "bindings": {
        "aria-checked": "channel:checked.value",
        "aria-label": "prop:ariaLabel",
        "aria-describedby": "prop:ariaDescribedby",
        "disabled": "prop:disabled",
        "onClick": "channel:checked.onChange"
      }
    }
  },
  "props": {
    "styled": {
      "description": "Props for the <ToggleSwitch> component.",
      "members": [
        {
          "name": "checked",
          "type": "boolean",
          "description": "Controlled checked state."
        },
        {
          "name": "defaultChecked",
          "type": "boolean",
          "description": "Uncontrolled initial checked state."
        },
        {
          "name": "onChange",
          "type": "(checked: boolean) => void",
          "description": "Called when checked changes."
        },
        {
          "name": "size",
          "type": "ToggleSwitchSize",
          "description": "Size token.",
          "default": "medium"
        },
        {
          "name": "disabled",
          "type": "boolean",
          "description": "Prevents interaction."
        },
        {
          "name": "ariaLabel",
          "type": "string",
          "description": "Accessible label."
        },
        {
          "name": "ariaDescribedby",
          "type": "string",
          "description": "External description element id appended to aria-describedby."
        }
      ]
    }
  },
  "channels": {
    "checked": {
      "value": "checked",
      "defaultValue": "defaultChecked",
      "onChange": "onChange",
      "valueType": "boolean",
      "description": "Whether the toggle switch is on."
    }
  },
  "types": {
    "ToggleSwitchSize": {
      "kind": "union",
      "values": [
        "small",
        "medium",
        "large"
      ]
    }
  },
  "variants": {
    "size": [
      "small",
      "medium",
      "large"
    ]
  },
  "states": [
    "default",
    "hover",
    "focus",
    "active",
    "disabled",
    "checked"
  ],
  "tokens": {
    "root": {
      "toggleSwitch.color.background.default": {
        "resolvesTo": "semantic.color.background.secondary",
        "fallback": "#efefef",
        "property": "background-color",
        "layer": "semantic"
      },
      "toggleSwitch.color.foreground.default": {
        "resolvesTo": "semantic.color.foreground.primary",
        "fallback": "#141414",
        "property": "color",
        "layer": "semantic"
      },
      "toggleSwitch.color.border.default": {
        "resolvesTo": "semantic.color.border.light",
        "fallback": "#fceaea",
        "property": "border-color",
        "layer": "semantic"
      },
      "toggleSwitch.border.radius.default": {
        "resolvesTo": "core.shape.radius.full",
        "fallback": "9999px",
        "property": "border-radius",
        "layer": "core"
      },
      "toggleSwitch.motion.duration.fast": {
        "resolvesTo": "core.motion.duration.short",
        "fallback": "150ms",
        "property": "transition-duration",
        "layer": "core"
      }
    },
    "hover": {
      "toggleSwitch.color.background.hover": {
        "resolvesTo": "semantic.interaction.background.hover",
        "fallback": "#efefef",
        "property": "background-color",
        "layer": "semantic"
      }
    },
    "checked": {
      "toggleSwitch.color.background.checked": {
        "resolvesTo": "semantic.color.action.background.primary.default",
        "fallback": "#d9292b",
        "property": "background-color",
        "layer": "semantic"
      }
    },
    "disabled": {
      "toggleSwitch.color.background.disabled": {
        "resolvesTo": "semantic.color.background.disabled",
        "fallback": "#cecece",
        "property": "background-color",
        "layer": "semantic"
      }
    }
  },
  "form": {
    "participates": true,
    "inputType": "checkbox",
    "name": {
      "prop": "name"
    },
    "serialization": {
      "valueType": "string",
      "valueSource": "static:on",
      "omitWhen": "unchecked"
    },
    "validity": {
      "model": "native",
      "ariaAttributes": [
        "aria-disabled"
      ]
    },
    "labeling": {
      "strategy": "associated-label",
      "required": true,
      "via": [
        "aria-labelledby",
        "aria-label"
      ]
    }
  },
  "focus": {
    "strategy": "auto",
    "description": "Native input[role=switch] receives focus via Tab. Space toggles the checked state."
  },
  "slots": {
    "root": {
      "required": true,
      "selector": "[data-slot=\"toggle-switch\"]"
    },
    "input": {
      "required": true,
      "selector": "[data-slot=\"toggle-switch-input\"]"
    },
    "label": {
      "required": false,
      "selector": "[data-slot=\"toggle-switch-label\"]"
    }
  },
  "ssr": {
    "hydrateOn": "interaction"
  },
  "rtl": {
    "flipIcon": false
  },
  "relationships": [
    {
      "from": "input",
      "to": "label",
      "attribute": "aria-labelledby",
      "description": "The input's htmlFor attribute links to the label element's id for accessible naming."
    }
  ],
  "a11y": {
    "role": "switch",
    "labeling": [
      "aria-label",
      "aria-checked",
      "aria-describedby"
    ],
    "keyboard": [
      {
        "key": "Space|Enter",
        "action": "Toggle the switch."
      }
    ]
  },
  "a2ui": {
    "category": "form-field",
    "usageHints": [
      "Use for immediate on/off settings that take effect without a Submit button",
      "Use checked and onChange for controlled mode; defaultChecked for uncontrolled",
      "Always provide ariaLabel or a visible label sibling for screen reader users",
      "Use name for native form submission (submits \"on\" when checked)"
    ],
    "children": {
      "allowed": false
    }
  }
}
