{
  "$schema": "../../component.contract.schema.json",
  "name": "ToggleSwitch",
  "description": "Binary switch control rendered as a button[role=switch] with an adjacent label.",
  "layer": "primitive",
  "category": "action",
  "anatomy": {
    "parts": [
      "root",
      "label",
      "input"
    ],
    "details": {
      "root": {
        "tag": "button",
        "description": "Button-based switch control that toggles the checked channel.",
        "role": "trigger",
        "interactive": true,
        "focusable": true,
        "aria": {
          "role": "switch",
          "attributes": [
            "aria-checked",
            "aria-label",
            "aria-describedby"
          ]
        }
      },
      "label": {
        "description": "Adjacent visible text label for the switch.",
        "role": "label"
      },
      "input": {
        "description": "Switch state carrier represented by the button root in the current DOM realization.",
        "role": "context",
        "collapsibleTo": "native-toggle-affordance"
      }
    },
    "dom": {
      "tag": "button",
      "part": "root",
      "attrs": {
        "type": "button"
      },
      "bindings": {
        "aria-checked": "channel:checked.value",
        "aria-label": "prop:ariaLabel",
        "aria-describedby": "prop:ariaDescribedby",
        "disabled": "prop:disabled"
      },
      "events": {
        "click": "channel:checked.onChange"
      }
    }
  },
  "props": {
    "designed": {
      "members": [
        {
          "name": "checked",
          "propType": { "kind": "boolean" },
          "description": "Controlled checked state."
        },
        {
          "name": "defaultChecked",
          "propType": { "kind": "boolean" },
          "description": "Uncontrolled initial checked state."
        },
        {
          "name": "onChange",
          "propType": {
            "kind": "callback",
            "params": [{ "name": "checked", "type": { "kind": "boolean" } }],
            "returns": { "kind": "void" }
          },
          "description": "Called when checked changes."
        },
        {
          "name": "size",
          "propType": { "kind": "ref", "to": "ToggleSwitchSize" },
          "description": "Size token.",
          "default": "medium"
        },
        {
          "name": "disabled",
          "propType": { "kind": "boolean" },
          "description": "Prevents interaction."
        },
        {
          "name": "ariaLabel",
          "propType": { "kind": "string" },
          "description": "Accessible label."
        },
        {
          "name": "ariaDescribedby",
          "propType": { "kind": "string" },
          "description": "External description element id appended to aria-describedby."
        }
      ]
    }
  },
  "channels": {
    "checked": {
      "value": "checked",
      "defaultValue": "defaultChecked",
      "onChange": "onChange",
      "valueType": "boolean",
      "description": "Whether the toggle switch is on."
    }
  },
  "types": {
    "ToggleSwitchSize": {
      "kind": "union",
      "values": [
        "small",
        "medium",
        "large"
      ]
    }
  },
  "variants": {
    "size": [
      "small",
      "medium",
      "large"
    ]
  },
  "states": {
    "dimensions": {
      "pointer": {
        "category": "interaction",
        "values": [
          "default",
          "hover",
          "active"
        ],
        "initial": "default",
        "exclusive": true
      },
      "focus": {
        "category": "interaction",
        "values": [
          "unfocused",
          "focus"
        ],
        "initial": "unfocused",
        "exclusive": true
      },
      "availability": {
        "category": "availability",
        "effect": "restyle",
        "values": [
          "enabled",
          "disabled"
        ],
        "initial": "enabled",
        "exclusive": true,
        "suppresses": {
          "categories": [
            "interaction"
          ]
        }
      },
      "selection": {
        "category": "selection",
        "effect": "restyle",
        "values": [
          "unchecked",
          "checked"
        ],
        "initial": "unchecked",
        "exclusive": true,
        "a11y": {
          "attribute": "aria-checked",
          "values": {
            "unchecked": "false",
            "checked": "true"
          }
        }
      }
    }
  },
  "form": {
    "participates": true,
    "inputType": "checkbox",
    "name": {
      "prop": "name"
    },
    "serialization": {
      "valueType": "string",
      "valueSource": "static:on",
      "omitWhen": "unchecked"
    },
    "validity": {
      "model": "native",
      "ariaAttributes": [
        "aria-disabled"
      ]
    },
    "labeling": {
      "strategy": "associated-label",
      "required": true,
      "via": [
        "aria-labelledby",
        "aria-label"
      ]
    }
  },
  "focus": {
    "strategy": "auto",
    "description": "Native input[role=switch] receives focus via Tab. Space toggles the checked state."
  },
  "slots": {
    "root": {
      "required": true,
      "selector": "[data-slot=\"toggle-switch\"]"
    },
    "input": {
      "required": true,
      "selector": "[data-slot=\"toggle-switch-input\"]"
    },
    "label": {
      "required": false,
      "selector": "[data-slot=\"toggle-switch-label\"]"
    }
  },
  "ssr": {
    "hydrateOn": "interaction"
  },
  "rtl": {
    "flipIcon": false
  },
  "relationships": [
    {
      "from": "input",
      "to": "label",
      "attribute": "aria-labelledby",
      "description": "The input's htmlFor attribute links to the label element's id for accessible naming."
    }
  ],
  "a11y": {
    "role": "switch",
    "labeling": [
      "aria-label",
      "aria-checked",
      "aria-describedby"
    ],
    "keyboard": [
      {
        "key": "Space|Enter",
        "action": "Toggle the switch."
      }
    ]
  },
  "a2ui": {
    "category": "form-field",
    "usageHints": [
      "Use for immediate on/off settings that take effect without a Submit button",
      "Use checked and onChange for controlled mode; defaultChecked for uncontrolled",
      "Always provide ariaLabel or a visible label sibling for screen reader users",
      "Use name for native form submission (submits \"on\" when checked)"
    ],
    "children": {
      "allowed": false
    }
  }
}
