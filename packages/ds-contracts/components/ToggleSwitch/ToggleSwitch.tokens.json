{
  "toggle-switch.color.background.default": {
    "resolvesTo": "semantic.color.background.secondary",
    "fallback": "#efefef",
    "layer": "semantic"
  },
  "toggle-switch.color.foreground.default": {
    "resolvesTo": "semantic.color.foreground.primary",
    "fallback": "#141414",
    "layer": "semantic"
  },
  "toggle-switch.color.border.default": {
    "resolvesTo": "semantic.color.border.light",
    "fallback": "#fceaea",
    "layer": "semantic"
  },
  "toggle-switch.border.radius.default": {
    "resolvesTo": "core.shape.radius.full",
    "fallback": "9999px",
    "layer": "core"
  },
  "toggle-switch.motion.duration.fast": {
    "resolvesTo": "core.motion.duration.short",
    "fallback": "150ms",
    "layer": "core"
  },
  "toggle-switch.color.background.hover": {
    "resolvesTo": "semantic.interaction.background.hover",
    "fallback": "#efefef",
    "layer": "semantic"
  },
  "toggle-switch.color.background.checked": {
    "resolvesTo": "semantic.color.action.background.primary.default",
    "fallback": "#d9292b",
    "layer": "semantic"
  },
  "toggle-switch.color.background.disabled": {
    "resolvesTo": "semantic.color.background.disabled",
    "fallback": "#cecece",
    "layer": "semantic"
  },
  "toggle-switch.focus.ring.width": {
    "resolvesTo": "semantic.focus.ring.width",
    "fallback": "2px",
    "layer": "semantic"
  },
  "toggle-switch.focus.ring.color": {
    "resolvesTo": "semantic.focus.ring.color",
    "fallback": "#0a65fe",
    "layer": "semantic"
  },
  "toggle-switch.focus.ring.style": {
    "resolvesTo": "semantic.focus.ring.style",
    "fallback": "solid",
    "layer": "semantic"
  },
  "toggle-switch.focus.ring.offset": {
    "resolvesTo": "semantic.focus.ring.offset",
    "fallback": "2px",
    "layer": "semantic"
  }
}
