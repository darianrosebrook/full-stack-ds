  "box-model.padding-inline-end": {
    "resolvesTo": "semantic.action.size.medium.padding-inline",
    "fallback": "12px",
    "layer": "semantic"
  },
  "box-model.gap": {
    "resolvesTo": "semantic.action.size.medium.gap",
