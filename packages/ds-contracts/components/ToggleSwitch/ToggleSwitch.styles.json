{
  "root": {
    "display": { "literal": "inline-flex", "platforms": ["web"] },
    "align-items": { "literal": "center", "platforms": ["web"] },
    "background-color": {
      "resolvesTo": "toggle-switch.color.background.default"
    },
    "color": {
      "resolvesTo": "toggle-switch.color.foreground.default"
    },
    "border-color": {
      "resolvesTo": "toggle-switch.color.border.default"
    },
    "border-radius": {
      "resolvesTo": "toggle-switch.border.radius.default"
    },
    "transition-duration": {
      "resolvesTo": "toggle-switch.motion.duration.fast"
    },
    "border-style": { "literal": "solid", "platforms": ["web"] },
    "border-width": { "literal": "1px", "platforms": ["web"] },
    "cursor": { "literal": "pointer", "platforms": ["web"] },
    "box-sizing": { "literal": "border-box", "platforms": ["web"] }
  },
  "hover": {
    "background-color": {
      "resolvesTo": "toggle-switch.color.background.hover"
    }
  },
  "[aria-checked=\"true\"]": {
    "background-color": {
      "resolvesTo": "toggle-switch.color.background.checked"
    }
  },
  "disabled": {
    "background-color": {
      "resolvesTo": "toggle-switch.color.background.disabled"
    },
    "cursor": { "literal": "not-allowed", "platforms": ["web"] }
  },
  "focus": {
    "outline-width": {
      "resolvesTo": "toggle-switch.focus.ring.width"
    },
    "outline-color": {
      "resolvesTo": "toggle-switch.focus.ring.color"
    },
    "outline-style": {
      "resolvesTo": "toggle-switch.focus.ring.style"
    },
    "outline-offset": {
      "resolvesTo": "toggle-switch.focus.ring.offset"
    }
  }
}
