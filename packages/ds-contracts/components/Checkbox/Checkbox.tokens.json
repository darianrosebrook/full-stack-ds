{
  "box-model.padding-block-start": {
    "resolvesTo": "semantic.input.size.medium.padding-block",
    "fallback": "8px",
    "layer": "semantic"
  },
  "box-model.padding-block-end": {
    "resolvesTo": "semantic.input.size.medium.padding-block",
    "fallback": "8px",
    "layer": "semantic"
  },
  "box-model.padding-inline-start": {
    "resolvesTo": "semantic.input.size.medium.padding-inline",
    "fallback": "12px",
    "layer": "semantic"
  },
  "box-model.padding-inline-end": {
    "resolvesTo": "semantic.input.size.medium.padding-inline",
    "fallback": "12px",
    "layer": "semantic"
  },
  "box-model.gap": {
    "resolvesTo": "semantic.input.size.medium.gap",
    "fallback": "8px",
    "layer": "semantic"
  },
  "box-model.min-height": {
    "resolvesTo": "semantic.input.size.medium.min-height",
    "fallback": "36px",
    "layer": "semantic"
  },
  "checkbox.color.background.default": {
    "resolvesTo": "semantic.color.background.primary",
    "fallback": "#ffffff",
    "layer": "semantic"
  },
  "checkbox.color.border.default": {
    "resolvesTo": "semantic.color.border.default",
    "fallback": "#aeaeae",
    "layer": "semantic"
  },
  "checkbox.border.width": {
    "resolvesTo": "semantic.shape.control.border.defaultWidth",
    "fallback": "1px",
    "layer": "semantic"
  },
  "checkbox.border.radius": {
    "resolvesTo": "semantic.shape.radius.small",
    "fallback": "4px",
    "layer": "semantic"
  },
  "checkbox.transition.duration": {
    "resolvesTo": "core.motion.duration.short",
    "fallback": "150ms",
    "layer": "core"
  },
  "checkbox.focus.ring.width": {
    "resolvesTo": "semantic.focus.ring.width",
    "fallback": "2px",
    "layer": "semantic"
  },
  "checkbox.focus.ring.color": {
    "resolvesTo": "semantic.focus.ring.color",
    "fallback": "#0a65fe",
    "layer": "semantic"
  },
  "checkbox.focus.ring.style": {
    "resolvesTo": "semantic.focus.ring.style",
    "fallback": "solid",
    "layer": "semantic"
  },
  "checkbox.focus.ring.offset": {
    "resolvesTo": "semantic.focus.ring.offset",
    "fallback": "2px",
    "layer": "semantic"
  }
}
