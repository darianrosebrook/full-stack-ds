{
  "$schema": "../../component.contract.schema.json",
  "name": "Checkbox",
  "description": "Binary or tri-state input for boolean selection. Supports indeterminate state for partial group selection.",
  "layer": "primitive",
  "category": "input",
  "anatomy": {
    "parts": [
      "root",
      "input",
      "indicator"
    ],
    "dom": {
      "tag": "input",
      "part": "input",
      "attrs": {
        "type": "checkbox"
      },
      "bindings": {
        "checked": "channel:checked.value",
        "disabled": "prop:disabled",
        "name": "prop:name",
        "value": "prop:value"
      },
      "events": {
        "change": "channel:checked.onChange"
      }
    }
  },
  "props": {
    "designed": {
      "members": [
        {
          "name": "size",
          "propType": { "kind": "ref", "to": "CheckboxSize" },
          "description": "Visual size variant.",
          "default": "md"
        },
        {
          "name": "checked",
          "propType": { "kind": "boolean" },
          "description": "Controlled checked state."
        },
        {
          "name": "defaultChecked",
          "propType": { "kind": "boolean" },
          "description": "Uncontrolled initial checked state."
        },
        {
          "name": "onChange",
          "propType": {
            "kind": "callback",
            "params": [{ "name": "checked", "type": { "kind": "boolean" } }],
            "returns": { "kind": "void" }
          },
          "description": "Called when checked state changes."
        },
        {
          "name": "indeterminate",
          "propType": { "kind": "boolean" },
          "description": "Renders indeterminate state (some-but-not-all children selected)."
        },
        {
          "name": "disabled",
          "propType": { "kind": "boolean" },
          "description": "Prevents interaction."
        },
        {
          "name": "name",
          "propType": { "kind": "string" },
          "description": "Form name for native submission."
        },
        {
          "name": "value",
          "propType": { "kind": "string" },
          "description": "Form value submitted when checked."
        }
      ]
    }
  },
  "channels": {
    "checked": {
      "value": "checked",
      "defaultValue": "defaultChecked",
      "onChange": "onChange",
      "valueType": "boolean",
      "description": "Whether the checkbox is checked."
    }
  },
  "types": {
    "CheckboxSize": {
      "kind": "union",
      "values": [
        "sm",
        "md",
        "lg"
      ]
    }
  },
  "variants": {
    "size": [
      "sm",
      "md",
      "lg"
    ]
  },
  "states": {
    "dimensions": {
      "pointer": {
        "category": "interaction",
        "values": [
          "default",
          "hover"
        ],
        "initial": "default",
        "exclusive": true
      },
      "focus": {
        "category": "interaction",
        "values": [
          "unfocused",
          "focus"
        ],
        "initial": "unfocused",
        "exclusive": true
      },
      "availability": {
        "category": "availability",
        "values": [
          "enabled",
          "disabled"
        ],
        "initial": "enabled",
        "exclusive": true,
        "suppresses": {
          "categories": [
            "interaction"
          ]
        }
      },
      "selection": {
        "category": "selection",
        "values": [
          "unchecked",
          "checked"
        ],
        "initial": "unchecked",
        "exclusive": true,
        "a11y": {
          "attribute": "aria-checked",
          "values": {
            "unchecked": "false",
            "checked": "true"
          }
        }
      }
    }
  },
  "form": {
    "participates": true,
    "inputType": "checkbox",
    "name": {
      "prop": "name"
    },
    "serialization": {
      "valueType": "string",
      "valueSource": "prop:value",
      "omitWhen": "unchecked",
      "multiple": false
    },
    "validity": {
      "model": "native",
      "ariaAttributes": [
        "aria-invalid",
        "aria-required",
        "aria-describedby"
      ]
    },
    "labeling": {
      "strategy": "associated-label",
      "required": true,
      "via": [
        "aria-labelledby",
        "aria-label"
      ]
    }
  },
  "focus": {
    "strategy": "auto",
    "description": "Native checkbox receives focus via Tab. No custom roving or trap needed."
  },
  "portal": {
    "enabled": false
  },
  "slots": {
    "root": {
      "required": true,
      "selector": "[data-slot=\"checkbox\"]"
    },
    "input": {
      "required": true,
      "selector": "[data-slot=\"checkbox-input\"]"
    },
    "indicator": {
      "required": true,
      "selector": "[data-slot=\"checkbox-indicator\"]"
    }
  },
  "ssr": {
    "hydrateOn": "interaction"
  },
  "rtl": {
    "flipIcon": false
  },
  "relationships": [
    {
      "from": "input",
      "to": "indicator",
      "attribute": "aria-hidden",
      "description": "The visual indicator div is aria-hidden so screen readers use only the native input's state."
    }
  ],
  "a11y": {
    "role": "checkbox",
    "labeling": [
      "aria-label",
      "aria-labelledby",
      "aria-checked"
    ],
    "keyboard": [
      {
        "key": "Space",
        "action": "Toggle the checked state."
      }
    ]
  },
  "a2ui": {
    "category": "form-field",
    "usageHints": [
      "Use checked and onChange for controlled mode; defaultChecked for uncontrolled",
      "Set indeterminate for parent checkboxes in a group where some children are checked",
      "Always pair with a label — either via prop:label or a visible sibling Label component",
      "Use name and value for native form submission"
    ],
    "children": {
      "allowed": false
    }
  }
}
