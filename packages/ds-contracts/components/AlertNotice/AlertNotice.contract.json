{
  "$schema": "../../component.contract.schema.json",
  "name": "AlertNotice",
  "description": "Inline alert message communicating status, errors, warnings, or success. Always visible (not triggered by user interaction).",
  "layer": "compound",
  "category": "feedback",
  "anatomy": {
    "parts": [
      "root",
      "icon",
      "body",
      "title",
      "dismiss"
    ],
    "details": {
      "root": {
        "tag": "div",
        "description": "Notice region announced as an alert for status, warning, success, or error messages.",
        "role": "region",
        "aria": {
          "role": "alert"
        }
      },
      "icon": {
        "tag": "span",
        "description": "Optional visual status cue; hidden from assistive technology.",
        "role": "decoration"
      },
      "body": {
        "description": "Main notice message content supplied by children.",
        "role": "content"
      },
      "title": {
        "description": "Optional short heading that names the notice.",
        "role": "label"
      },
      "dismiss": {
        "tag": "button",
        "description": "Optional control that asks the consumer to remove or hide the notice.",
        "role": "trigger",
        "interactive": true,
        "focusable": true,
        "aria": {
          "attributes": [
            "aria-label"
          ]
        }
      }
    },
    "dom": {
      "tag": "div",
      "part": "root",
      "attrs": {
        "role": "alert"
      },
      "children": [
        {
          "tag": "span",
          "part": "icon",
          "if": "icon",
          "attrs": {
            "aria-hidden": "true"
          },
          "content": "prop:icon"
        },
        {
          "tag": "children"
        },
        {
          "tag": "button",
          "part": "dismiss",
          "if": "dismissible",
          "attrs": {
            "type": "button"
          },
          "bindings": {
            "aria-label": "prop:dismissLabel"
          },
          "events": {
            "click": "prop:onDismiss"
          }
        }
      ]
    }
  },
  "props": {
    "designed": {
      "members": [
        {
          "name": "status",
          "propType": { "kind": "ref", "to": "AlertNoticeStatus" },
          "description": "Status severity of the alert notice"
        },
        {
          "name": "level",
          "propType": { "kind": "ref", "to": "AlertNoticeLevel" },
          "description": "Display level affecting layout and emphasis"
        },
        {
          "name": "dismissible",
          "propType": { "kind": "boolean" },
          "description": "Whether the alert notice can be dismissed by the user"
        },
        {
          "name": "onDismiss",
          "propType": { "kind": "callback", "params": [], "returns": { "kind": "void" } },
          "description": "Called when the user clicks the dismiss control. Required surface for `dismissible`; consumers handle removing/hiding the notice."
        },
        {
          "name": "dismissLabel",
          "propType": { "kind": "string" },
          "description": "Accessible label for the dismiss control. Defaults to \"Dismiss\".",
          "default": "Dismiss"
        },
        {
          "name": "icon",
          "propType": { "kind": "node", "of": "content" },
          "description": "Optional icon node rendered before the alert content"
        }
      ]
    }
  },
  "types": {
    "AlertNoticeStatus": {
      "kind": "union",
      "values": [
        "info",
        "success",
        "warning",
        "error"
      ]
    },
    "AlertNoticeLevel": {
      "kind": "union",
      "values": [
        "page",
        "section",
        "inline"
      ]
    }
  },
  "variants": {
    "status": [
      "info",
      "success",
      "warning",
      "error"
    ],
    "level": [
      "page",
      "section",
      "inline"
    ]
  },
  "states": {
    "dimensions": {
      "pointer": {
        "category": "interaction",
        "values": [
          "default"
        ],
        "initial": "default",
        "exclusive": true
      }
    }
  },
  "slots": {
    "body": {
      "required": false
    },
    "container": {
      "required": false
    },
    "dismiss": {
      "required": false
    },
    "icon": {
      "required": false
    },
    "title": {
      "required": false
    }
  },
  "ssr": {
    "hydrateOn": "interaction"
  },
  "rtl": {
    "flipIcon": true
  },
  "a11y": {
    "role": "alert",
    "labeling": [
      "aria-label"
    ],
    "keyboard": []
  },
  "a2ui": {
    "category": "display",
    "usageHints": [
      "Use variant=error when a form submission or action failed",
      "Use variant=warning for recoverable issues that need attention",
      "Use variant=success after a positive outcome",
      "Avoid using for transient notifications — use Toast instead"
    ],
    "children": {
      "allowed": true,
      "slot": "children",
      "accepts": [
        "string",
        "ReactNode"
      ]
    }
  }
}
