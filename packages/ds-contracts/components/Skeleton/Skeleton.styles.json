{
  "root": {
    "display": {
      "literal": "block",
      "platforms": [
        "web"
      ]
    },
    "background-color": {
      "resolvesTo": "skeleton.color.base"
    },
    "transition-duration": {
      "resolvesTo": "skeleton.anim.duration"
    },
    "transition-timing-function": {
      "resolvesTo": "skeleton.anim.easing"
    },
    "animation": {
      "literal": "skeleton-shimmer var(--fsds-skeleton-anim-duration, 400ms) var(--fsds-skeleton-anim-easing, cubic-bezier(0.4, 0, 0.2, 1)) infinite",
      "platforms": [
        "web"
      ]
    },
    "skeleton.radius.md": {
      "resolvesTo": "core.shape.radius.04",
      "fallback": "16px"
    },
    "skeleton.gap.md": {
      "resolvesTo": "core.spacing.size.07",
      "fallback": "24px"
    }
  }
}
