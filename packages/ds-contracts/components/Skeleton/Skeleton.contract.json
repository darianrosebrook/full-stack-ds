{
  "$schema": "../../component.contract.schema.json",
  "name": "Skeleton",
  "description": "Loading placeholder that mimics the shape of content before data is available.",
  "layer": "primitive",
  "category": "feedback",
  "morphology": "loading-block",
  "anatomy": {
    "parts": [
      "root",
      "stack",
      "row",
      "shape"
    ],
    "details": {
      "root": {
        "tag": "div",
        "description": "Loading placeholder host that carries busy state and optional loading label.",
        "role": "root",
        "aria": {
          "attributes": [
            "aria-busy",
            "aria-label"
          ]
        }
      },
      "stack": {
        "description": "Layout stack used by multi-line or compound skeleton variants.",
        "role": "group"
      },
      "row": {
        "description": "Repeated skeleton row used to mimic text or list content.",
        "role": "decoration",
        "multiple": true
      },
      "shape": {
        "description": "Placeholder shape representing the eventual content block, avatar, media, or action.",
        "role": "decoration",
        "multiple": true
      }
    },
    "dom": {
      "tag": "div",
      "part": "root",
      "bindings": {
        "role": "conditional:prop:decorative|literal:presentation|literal:status",
        "aria-busy": "conditional:prop:decorative|literal:false|literal:true",
        "aria-hidden": "conditional:prop:decorative|literal:true|literal:false",
        "aria-label": "prop:ariaLabel"
      }
    }
  },
  "props": {
    "designed": {
      "members": [
        {
          "name": "variant",
          "propType": { "kind": "ref", "to": "SkeletonVariant" },
          "description": "Visual variant",
          "default": "block"
        },
        {
          "name": "animate",
          "propType": { "kind": "ref", "to": "SkeletonAnimate" },
          "description": "Animation style",
          "default": "shimmer"
        },
        {
          "name": "density",
          "propType": { "kind": "ref", "to": "SkeletonDensity" },
          "description": "Spacing density to match surrounding content",
          "default": "regular"
        },
        {
          "name": "aspectRatio",
          "propType": { "kind": "string" },
          "description": "CSS aspect-ratio value to size the placeholder"
        },
        {
          "name": "lines",
          "propType": { "kind": "ref", "to": "SkeletonLines" },
          "description": "Number of lines to render for text variant. Pass a number or {min, max} range."
        },
        {
          "name": "radius",
          "propType": { "kind": "ref", "to": "SkeletonRadius" },
          "description": "Border radius token"
        },
        {
          "name": "decorative",
          "propType": { "kind": "boolean" },
          "description": "Set true for decorative skeletons that should not announce to screen readers.",
          "default": true
        },
        {
          "name": "ariaLabel",
          "propType": { "kind": "string" },
          "description": "Localized loading label when decorative is false."
        }
      ]
    }
  },
  "types": {
    "SkeletonVariant": {
      "kind": "union",
      "values": [
        "block",
        "text",
        "avatar",
        "media",
        "dataviz",
        "actions"
      ]
    },
    "SkeletonAnimate": {
      "kind": "union",
      "values": [
        "shimmer",
        "wipe",
        "pulse",
        "none"
      ]
    },
    "SkeletonDensity": {
      "kind": "union",
      "values": [
        "compact",
        "regular",
        "spacious"
      ]
    },
    "SkeletonRadius": {
      "kind": "union",
      "values": [
        "sm",
        "md",
        "lg"
      ]
    },
    "SkeletonLines": {
      "kind": "alias",
      "alias": "number | { min: number; max: number }"
    }
  },
  "variants": {
    "variant": [
      "block",
      "text",
      "avatar",
      "media",
      "dataviz",
      "actions"
    ],
    "animate": [
      "shimmer",
      "wipe",
      "pulse",
      "none"
    ],
    "density": [
      "compact",
      "regular",
      "spacious"
    ]
  },
  "states": {
    "dimensions": {
      "pointer": {
        "category": "interaction",
        "values": [
          "default"
        ],
        "initial": "default",
        "exclusive": true
      }
    }
  },
  "slots": {
    "root": {
      "required": true,
      "selector": "[data-slot=\"skeleton\"]"
    }
  },
  "ssr": {
    "hydrateOn": "interaction"
  },
  "rtl": {
    "flipIcon": false
  },
  "a11y": {
    "role": "status",
    "labeling": [
      "aria-label",
      "aria-busy"
    ],
    "keyboard": []
  },
  "keyframes": {
    "skeleton-shimmer": {
      "0%": {
        "opacity": "1"
      },
      "50%": {
        "opacity": "0.5"
      },
      "100%": {
        "opacity": "1"
      }
    },
    "skeleton-wipe": {
      "0%": {
        "transform": "translateX(-100%)"
      },
      "100%": {
        "transform": "translateX(100%)"
      }
    }
  },
  "a2ui": {
    "category": "display",
    "usageHints": [
      "Match the width and height to the content it replaces to minimize layout shift",
      "Use animate to select the loading animation (shimmer, pulse, wipe, or none)",
      "Use density to match the spacing of the surrounding content",
      "Remove Skeleton and render real content once data is loaded"
    ],
    "children": {
      "allowed": false
    }
  }
}
