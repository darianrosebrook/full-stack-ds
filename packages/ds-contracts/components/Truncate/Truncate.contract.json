{
  "$schema": "../../component.contract.schema.json",
  "name": "Truncate",
  "description": "Clamps multi-line text to a fixed number of lines with an optional expand/collapse toggle.",
  "layer": "primitive",
  "category": "display",
  "anatomy": {
    "parts": [
      "root",
      "content",
      "toggle"
    ],
    "details": {
      "root": {
        "tag": "div",
        "description": "Text truncation host that coordinates line clamping and optional expansion.",
        "role": "root"
      },
      "content": {
        "tag": "span",
        "description": "Text content clamped to the configured number of visible lines.",
        "role": "content"
      },
      "toggle": {
        "tag": "button",
        "description": "Optional button that expands or collapses the truncated content.",
        "role": "trigger",
        "interactive": true,
        "focusable": true,
        "aria": {
          "attributes": [
            "aria-expanded"
          ]
        }
      }
    },
    "dom": {
      "tag": "div",
      "part": "root",
      "children": [
        {
          "tag": "span",
          "part": "content",
          "cssVariableBindings": {
            "--fsds-truncate-content-lines": "prop:lines"
          },
          "children": [
            {
              "tag": "children"
            }
          ]
        },
        {
          "tag": "button",
          "part": "toggle",
          "if": "expandable",
          "attrs": {
            "type": "button"
          },
          "bindings": {
            "aria-expanded": "channel:expanded.value"
          },
          "events": {
            "click": "channel:expanded.onChange"
          },
          "content": "conditional:channel:expanded.value|prop:collapseText|prop:expandText"
        }
      ]
    }
  },
  "props": {
    "designed": {
      "members": [
        {
          "name": "lines",
          "propType": { "kind": "number" },
          "description": "Maximum number of visible lines before truncation."
        },
        {
          "name": "expandable",
          "propType": { "kind": "boolean" },
          "description": "Whether to render an expand/collapse toggle button."
        },
        {
          "name": "expanded",
          "propType": { "kind": "boolean" },
          "description": "Controlled expanded state."
        },
        {
          "name": "defaultExpanded",
          "propType": { "kind": "boolean" },
          "description": "Initial expanded state for uncontrolled mode."
        },
        {
          "name": "onExpandedChange",
          "propType": {
            "kind": "callback",
            "params": [{ "name": "expanded", "type": { "kind": "boolean" } }],
            "returns": { "kind": "void" }
          },
          "description": "Called when expanded changes."
        },
        {
          "name": "expandText",
          "propType": { "kind": "string" },
          "description": "Custom expand button label.",
          "default": "Show more"
        },
        {
          "name": "collapseText",
          "propType": { "kind": "string" },
          "description": "Custom collapse button label.",
          "default": "Show less"
        }
      ]
    }
  },
  "channels": {
    "expanded": {
      "value": "expanded",
      "defaultValue": "defaultExpanded",
      "onChange": "onExpandedChange",
      "valueType": "boolean",
      "description": "Whether the truncated content is fully visible."
    }
  },
  "states": {
    "dimensions": {
      "pointer": {
        "category": "interaction",
        "values": [
          "default",
          "hover"
        ],
        "initial": "default",
        "exclusive": true
      },
      "focus": {
        "category": "interaction",
        "values": [
          "unfocused",
          "focus"
        ],
        "initial": "unfocused",
        "exclusive": true
      },
      "expansion": {
        "category": "visibility",
        "effect": "channel",
        "values": [
          "collapsed",
          "expanded"
        ],
        "initial": "collapsed",
        "exclusive": true,
        "a11y": {
          "attribute": "aria-expanded",
          "values": {
            "collapsed": "false",
            "expanded": "true"
          }
        }
      }
    }
  },
  "slots": {
    "root": {
      "required": true,
      "selector": "[data-slot=\"truncate\"]"
    },
    "content": {
      "required": true,
      "selector": "[data-slot=\"truncate-content\"]"
    },
    "toggle": {
      "required": false,
      "selector": "[data-slot=\"truncate-toggle\"]"
    }
  },
  "ssr": {
    "hydrateOn": "interaction"
  },
  "rtl": {
    "flipIcon": false
  },
  "a11y": {
    "labeling": [],
    "keyboard": [
      {
        "key": "Enter|Space",
        "when": "toggle",
        "action": "Toggle the expanded/collapsed state."
      }
    ]
  },
  "a2ui": {
    "category": "display",
    "usageHints": [
      "Set lines to control the maximum number of visible lines before truncation",
      "Set expandable=false to hard-truncate without a toggle button",
      "Use expandText and collapseText to customize the toggle button labels",
      "Bind expanded and onExpandedChange for controlled mode"
    ],
    "children": {
      "allowed": true,
      "slot": "children",
      "accepts": [
        "string",
        "node-ref"
      ]
    }
  }
}
