{
  "$schema": "../../component.contract.schema.json",
  "name": "Status",
  "description": "Compact icon-and-label pair conveying a status condition (online, offline, busy, etc.).",
  "layer": "primitive",
  "anatomy": {
    "parts": [
      "root",
      "icon",
      "label"
    ],
    "dom": {
      "tag": "span",
      "part": "root",
      "children": [
        {
          "tag": "span",
          "part": "icon",
          "attrs": {
            "aria-hidden": "true"
          }
        },
        {
          "tag": "span",
          "part": "label",
          "children": [
            {
              "tag": "children"
            }
          ]
        }
      ]
    }
  },
  "props": {
    "styled": {
      "description": "Props for the <Status> component.",
      "members": [
        {
          "name": "status",
          "type": "StatusIntent",
          "description": "Status intent that drives the icon and color scheme.",
          "required": true
        }
      ]
    }
  },
  "types": {
    "StatusIntent": {
      "kind": "union",
      "values": [
        "info",
        "success",
        "warning",
        "danger",
        "error"
      ]
    }
  },
  "variants": {
    "status": [
      "info",
      "success",
      "warning",
      "danger",
      "error"
    ]
  },
  "states": [
    "default"
  ],
  "slots": {
    "root": {
      "required": true,
      "selector": "[data-slot=\"status\"]"
    },
    "icon": {
      "required": true,
      "selector": "[data-slot=\"status-icon\"]"
    },
    "label": {
      "required": true,
      "selector": "[data-slot=\"status-label\"]"
    }
  },
  "ssr": {
    "hydrateOn": "interaction"
  },
  "rtl": {
    "flipIcon": false
  },
  "a11y": {
    "labeling": [
      "aria-label"
    ],
    "keyboard": []
  },
  "a2ui": {
    "category": "display",
    "usageHints": [
      "The icon is chosen automatically based on the status prop value",
      "Pair with Avatar to show user presence",
      "Use size to match surrounding text"
    ],
    "children": {
      "allowed": false
    }
  }
}
