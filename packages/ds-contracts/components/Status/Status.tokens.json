{
  "status.color.background.default": {
    "resolvesTo": "semantic.color.background.primary",
    "fallback": "#ffffff",
    "layer": "semantic"
  },
  "status.color.foreground.primary": {
    "resolvesTo": "semantic.color.foreground.primary",
    "fallback": "#141414",
    "layer": "semantic"
  },
  "status.color.border.default": {
    "resolvesTo": "semantic.color.border.primary",
    "fallback": "#f29495",
    "layer": "semantic"
  },
  "status.size.radius.default": {
    "resolvesTo": "core.shape.radius.full",
    "fallback": "9999px",
    "layer": "core"
  },
  "status.size.padding.default": {
    "resolvesTo": "core.spacing.size.04",
    "fallback": "8px",
    "layer": "core"
  },
  "status.size.border.default": {
    "resolvesTo": "core.shape.border.width.hairline",
    "fallback": "1px",
    "layer": "core"
  },
  "status.typography.lineHeight": {
    "resolvesTo": "semantic.typography.line.height.collapse",
    "fallback": "1",
    "layer": "semantic"
  }
}
