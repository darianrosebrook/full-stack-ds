  },
  "box-model.padding-inline-end": {
    "resolvesTo": "semantic.glyph.badge.size.md.paddingX",
    "fallback": "8px",
    "layer": "semantic"
  },
  "box-model.gap": {
    "resolvesTo": "semantic.glyph.badge.size.md.gap",
