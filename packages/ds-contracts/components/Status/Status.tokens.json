  },
  "box-model.padding-block-end": {
    "resolvesTo": "semantic.glyph.badge.size.md.paddingY",
    "fallback": "2px",
    "layer": "semantic"
  },
  "box-model.padding-inline-start": {
    "resolvesTo": "semantic.glyph.badge.size.md.paddingX",
