{
  "root": {
    "background-color": {
      "resolvesTo": "status.color.background.default"
    },
    "color": {
      "resolvesTo": "status.color.foreground.primary"
    },
    "border-color": {
      "resolvesTo": "status.color.border.default"
    },
    "border-radius": {
      "resolvesTo": "status.size.radius.default"
    },
    "padding": {
      "resolvesTo": "status.size.padding.default"
    },
    "line-height": {
      "resolvesTo": "status.typography.lineHeight"
    }
  },
  "icon": {
    "display": { "literal": "inline-flex", "platforms": ["web"] },
    "align-items": { "literal": "center", "platforms": ["web"] },
    "flex-shrink": { "literal": "0", "platforms": ["web"] },
    "width": { "literal": "1em", "platforms": ["web"] },
    "height": { "literal": "1em", "platforms": ["web"] },
    "margin-right": { "literal": "4px", "platforms": ["web"] }
  },
  "label": {
    "display": { "literal": "inline-block", "platforms": ["web"] },
    "color": { "resolvesTo": "status.color.foreground.primary" }
  }
}
