    "pointer-events": { "literal": "none", "platforms": ["web"] }
  },
  "overlay": {
    "position": { "literal": "absolute", "platforms": ["web", "ios", "android"] },
    "inset": { "literal": "0", "platforms": ["web"] },
    "background-color": { "resolvesTo": "command.color.overlay" },
    "pointer-events": { "literal": "auto", "platforms": ["web"] }
  },
  "dialog": {
