{
  "$schema": "../../component.contract.schema.json",
  "name": "Toast",
  "description": "Transient notification message appearing briefly at the edge of the viewport.",
  "layer": "composer",
  "category": "surface",
  "anatomy": {
    "parts": [
      "root",
      "viewport",
      "item",
      "title",
      "description",
      "row",
      "action",
      "close"
    ],
    "details": {
      "root": {
        "description": "Toast system host represented by the notification viewport and visible toast item.",
        "role": "root"
      },
      "viewport": {
        "tag": "div",
        "description": "Live notification region that contains transient toast items.",
        "role": "region",
        "aria": {
          "attributes": [
            "aria-live",
            "aria-label"
          ]
        }
      },
      "item": {
        "tag": "div",
        "description": "Single visible toast notification.",
        "role": "region",
        "aria": {
          "role": "status"
        }
      },
      "title": {
        "tag": "div",
        "description": "Optional short heading for the toast.",
        "role": "label"
      },
      "description": {
        "tag": "div",
        "description": "Primary toast message content.",
        "role": "content"
      },
      "row": {
        "tag": "div",
        "description": "Layout row grouping message text, optional action, and close control.",
        "role": "group"
      },
      "action": {
        "tag": "div",
        "description": "Optional action area for a consumer-provided toast action.",
        "role": "trigger",
        "interactive": true,
        "focusable": true
      },
      "close": {
        "tag": "button",
        "description": "Dismissal control for hiding the toast.",
        "role": "trigger",
        "interactive": true,
        "focusable": true,
        "aria": {
          "attributes": [
            "aria-label"
          ]
        }
      }
    },
    "dom": {
      "tag": "div",
      "part": "viewport",
      "attrs": {
        "aria-live": "polite",
        "aria-label": "Notifications"
      },
      "children": [
        {
          "tag": "div",
          "part": "item",
          "attrs": {
            "role": "status"
          },
          "if": "open",
          "children": [
            {
              "tag": "div",
              "part": "row",
              "children": [
                {
                  "tag": "div",
                  "part": "title",
                  "if": "title"
                },
                {
                  "tag": "div",
                  "part": "description",
                  "children": [
                    {
                      "tag": "children"
                    }
                  ]
                },
                {
                  "tag": "div",
                  "part": "action",
                  "if": "action"
                },
                {
                  "tag": "button",
                  "part": "close",
                  "attrs": {
                    "type": "button",
                    "aria-label": "Dismiss"
                  }
                }
              ]
            }
          ]
        }
      ]
    }
  },
  "props": {
    "styled": {
      "description": "Props for the <Toast> notification component.",
      "members": [
        {
          "name": "open",
          "type": "boolean",
          "description": "Whether this toast is visible."
        },
        {
          "name": "onOpenChange",
          "type": "(open: boolean) => void",
          "description": "Called when the toast is dismissed."
        },
        {
          "name": "title",
          "type": "string",
          "description": "Toast title text."
        },
        {
          "name": "variant",
          "type": "ToastVariant",
          "description": "Visual style indicating intent.",
          "default": "info"
        },
        {
          "name": "politeness",
          "type": "ToastPoliteness",
          "description": "ARIA live region politeness level.",
          "default": "polite"
        },
        {
          "name": "action",
          "type": "ReactNode",
          "description": "Optional action slot rendered next to the toast description (e.g. an undo button)."
        }
      ]
    }
  },
  "channels": {
    "open": {
      "value": "open",
      "onChange": "onOpenChange",
      "valueType": "boolean",
      "description": "Per-toast visibility managed by ToastProvider."
    }
  },
  "types": {
    "ToastVariant": {
      "kind": "union",
      "values": [
        "info",
        "success",
        "warning",
        "error"
      ]
    },
    "ToastPoliteness": {
      "kind": "union",
      "values": [
        "polite",
        "assertive"
      ]
    }
  },
  "variants": {
    "variant": [
      "info",
      "success",
      "warning",
      "error"
    ],
    "politeness": [
      "polite",
      "assertive"
    ]
  },
  "states": {
    "dimensions": {
      "pointer": {
        "category": "interaction",
        "values": [
          "default",
          "hover"
        ],
        "initial": "default",
        "exclusive": true
      },
      "focus": {
        "category": "interaction",
        "values": [
          "unfocused",
          "focus"
        ],
        "initial": "unfocused",
        "exclusive": true
      },
      "visibility": {
        "category": "visibility",
        "effect": "channel",
        "values": [
          "hidden",
          "visible"
        ],
        "initial": "hidden",
        "exclusive": true
      },
      "transition": {
        "category": "motion",
        "effect": "channel",
        "values": [
          "idle",
          "entering",
          "leaving"
        ],
        "initial": "idle",
        "exclusive": true
      }
    }
  },
  "motion": {
    "reducedMotion": "respect",
    "reducedMotionStrategy": "Duration set to 0 so enter/exit collapses to immediate show/hide.",
    "transitions": [
      {
        "name": "open",
        "trigger": "openness=hidden→visible",
        "phase": "enter",
        "properties": [
          "opacity",
          "transform"
        ],
        "duration": "core.motion.duration.short",
        "easing": "core.motion.easing.emphasized-in"
      },
      {
        "name": "close",
        "trigger": "openness=visible→hidden",
        "phase": "exit",
        "properties": [
          "opacity",
          "transform"
        ],
        "duration": "core.motion.duration.short",
        "easing": "core.motion.easing.emphasized-out"
      }
    ]
  },
  "focus": {
    "strategy": "none",
    "description": "ToastViewport is an ARIA live region. Toasts appear without moving keyboard focus."
  },
  "portal": {
    "enabled": true,
    "defaultTarget": "body",
    "positioning": "fixed",
    "layering": "popover"
  },
  "dismissal": {
    "triggers": [
      {
        "event": "escape"
      },
      {
        "event": "userDismiss"
      }
    ]
  },
  "slots": {
    "viewport": {
      "required": true,
      "selector": "[data-slot=\"toast-viewport\"]"
    },
    "root": {
      "required": true,
      "selector": "[data-slot=\"toast\"]"
    },
    "title": {
      "required": false,
      "selector": "[data-slot=\"toast-title\"]"
    },
    "description": {
      "required": false,
      "selector": "[data-slot=\"toast-description\"]"
    },
    "row": {
      "required": false,
      "selector": "[data-slot=\"toast-row\"]"
    },
    "action": {
      "required": false,
      "selector": "[data-slot=\"toast-action\"]"
    },
    "close": {
      "required": false,
      "selector": "[data-slot=\"toast-close\"]"
    }
  },
  "ssr": {
    "hydrateOn": "interaction"
  },
  "rtl": {
    "flipIcon": false
  },
  "relationships": [
    {
      "from": "item",
      "to": "title",
      "attribute": "aria-labelledby",
      "description": "Each toast item has an implicit aria-live region; the title provides accessible labeling."
    }
  ],
  "a11y": {
    "role": "alert",
    "apgPattern": "alert",
    "labeling": [
      "aria-label",
      "aria-live",
      "aria-labelledby"
    ],
    "keyboard": [
      {
        "key": "Escape",
        "action": "Dismiss the focused toast.",
        "when": "item"
      }
    ]
  },
  "a2ui": {
    "category": "overlay",
    "usageHints": [
      "Trigger toasts via the useToast hook or ToastProvider API — do not render Toast directly",
      "Use variant to set the visual style (default, success, warning, error)",
      "Toasts are live regions — screen readers announce them without requiring focus",
      "Keep toast messages brief; use an action button only for critical reversible operations"
    ],
    "children": {
      "allowed": true,
      "slot": "children",
      "accepts": [
        "ToastTitle",
        "ToastDescription",
        "ToastAction",
        "ToastClose"
      ]
    }
  }
}
