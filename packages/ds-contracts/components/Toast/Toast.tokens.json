{
  "box-model.padding-block-start": {
    "resolvesTo": "semantic.surface.size.padding-block",
    "fallback": "16px",
    "layer": "semantic"
  },
  "box-model.padding-block-end": {
    "resolvesTo": "semantic.surface.size.padding-block",
    "fallback": "16px",
    "layer": "semantic"
  },
  "box-model.padding-inline-start": {
    "resolvesTo": "semantic.surface.size.padding-inline",
    "fallback": "16px",
    "layer": "semantic"
  },
  "box-model.padding-inline-end": {
    "resolvesTo": "semantic.surface.size.padding-inline",
    "fallback": "16px",
    "layer": "semantic"
  },
  "box-model.gap": {
    "resolvesTo": "semantic.surface.size.gap",
    "fallback": "12px",
    "layer": "semantic"
  },
  "box-model.min-width": {
    "resolvesTo": "semantic.surface.size.min-width",
    "fallback": "64px",
    "layer": "semantic"
  },
  "toast.surface.bg": {
    "resolvesTo": "semantic.color.background.secondary",
    "fallback": "#efefef",
    "layer": "semantic"
  },
  "toast.surface.border": {
    "resolvesTo": "semantic.color.border.subtle",
    "fallback": "#cecece",
    "layer": "semantic"
  },
  "toast.surface.radius": {
    "resolvesTo": "core.shape.radius.medium",
    "fallback": "8px",
    "layer": "core"
  },
  "toast.surface.shadow": {
    "resolvesTo": "semantic.elevation.surface.overlay",
    "fallback": "0 8px 24px rgba(0,0,0,0.12), 0 2px 8px rgba(0,0,0,0.08)",
    "layer": "semantic"
  },
  "toast.color.default": {
    "resolvesTo": "semantic.color.foreground.primary",
    "fallback": "#141414",
    "layer": "semantic"
  },
  "toast.accent.default": {
    "resolvesTo": "semantic.color.status.info",
    "fallback": "#0a65fe",
    "layer": "semantic"
  },
  "toast.color.intent.bg": {
    "resolvesTo": "semantic.color.background.secondary",
    "fallback": "#efefef",
    "layer": "semantic"
  },
  "toast.color.intent.border": {
    "resolvesTo": "semantic.color.border.subtle",
    "fallback": "#cecece",
    "layer": "semantic"
  },
  "toast.spacing.padding": {
    "resolvesTo": "core.spacing.size.05",
    "fallback": "12px",
    "layer": "core"
  },
  "toast.spacing.gap": {
    "resolvesTo": "core.spacing.size.04",
    "fallback": "8px",
    "layer": "core"
  },
  "toast.spacing.stackGap": {
    "resolvesTo": "core.spacing.size.04",
    "fallback": "8px",
    "layer": "core"
  },
  "toast.size.maxWidth": {
    "literal": "400px"
  },
  "toast.motion.enter": {
    "resolvesTo": "core.motion.duration.short",
    "fallback": "150ms",
    "layer": "core"
  },
  "toast.motion.leave": {
    "resolvesTo": "core.motion.duration.short",
    "fallback": "150ms",
    "layer": "core"
  },
  "toast.timing.auto-dismiss": {
    "resolvesTo": "semantic.motion.dwell.notification",
    "fallback": "6000ms",
    "layer": "semantic"
  }
}
