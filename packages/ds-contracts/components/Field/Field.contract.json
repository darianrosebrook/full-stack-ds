{
  "$schema": "../../component.contract.schema.json",
  "name": "Field",
  "description": "Form field layout wrapper that pairs a label, input, and optional hint or error message.",
  "layer": "composer",
  "anatomy": {
    "parts": [
      "root",
      "label",
      "header",
      "control",
      "help",
      "error",
      "meta",
      "validatingIndicator"
    ],
    "dom": {
      "tag": "div",
      "part": "root",
      "children": [
        {
          "tag": "div",
          "part": "header",
          "children": [
            {
              "tag": "label",
              "part": "label",
              "if": "label",
              "children": [
                {
                  "tag": "children"
                }
              ]
            }
          ]
        },
        {
          "tag": "div",
          "part": "control",
          "children": [
            {
              "tag": "children"
            }
          ]
        },
        {
          "tag": "div",
          "part": "meta",
          "children": [
            {
              "tag": "span",
              "part": "help",
              "if": "helpText"
            },
            {
              "tag": "span",
              "part": "error",
              "if": "error"
            },
            {
              "tag": "span",
              "part": "validatingIndicator",
              "if": "validating"
            }
          ]
        }
      ]
    }
  },
  "props": {
    "styled": {
      "description": "Props for the <Field> form layout wrapper.",
      "members": [
        {
          "name": "name",
          "type": "string",
          "description": "Form field name used for form submission and as the base for auto-generated element IDs.",
          "required": true
        },
        {
          "name": "id",
          "type": "string",
          "description": "Explicit input element ID. Auto-generated from name if omitted."
        },
        {
          "name": "required",
          "type": "boolean",
          "description": "Marks the field as required. Surfaces as aria-required on the control element."
        },
        {
          "name": "disabled",
          "type": "boolean",
          "description": "Disables the field and all of its child controls."
        },
        {
          "name": "readOnly",
          "type": "boolean",
          "description": "Puts the field into read-only mode. The value is visible but not editable."
        },
        {
          "name": "value",
          "type": "unknown",
          "description": "Controlled value passed through to the control adapter."
        },
        {
          "name": "defaultValue",
          "type": "unknown",
          "description": "Uncontrolled initial value passed through to the control adapter."
        },
        {
          "name": "onChange",
          "type": "(value: unknown) => void",
          "description": "Change handler called with the new value when the control changes."
        },
        {
          "name": "validate",
          "type": "((value: unknown, context: { name: string; touched: boolean; dirty: boolean }) => string | string[] | null | Promise<string | string[] | null>)",
          "description": "Async-capable validation function. Return null for valid, or error string(s) for invalid."
        },
        {
          "name": "label",
          "type": "ReactNode",
          "description": "Label content rendered by the FieldLabel slot."
        },
        {
          "name": "helpText",
          "type": "ReactNode",
          "description": "Supplementary help text rendered in the help slot below the control."
        },
        {
          "name": "error",
          "type": "string",
          "description": "Validation error message. When present, the field renders in invalid state."
        },
        {
          "name": "status",
          "type": "FieldStatus",
          "description": "Validation status of the field."
        },
        {
          "name": "validating",
          "type": "boolean",
          "description": "True while async validation is in flight. Drives the validating indicator slot."
        }
      ]
    }
  },
  "types": {
    "FieldStatus": {
      "kind": "union",
      "values": [
        "idle",
        "validating",
        "valid",
        "invalid"
      ]
    }
  },
  "variants": {
    "status": [
      "idle",
      "validating",
      "valid",
      "invalid"
    ]
  },
  "states": [
    "default",
    "focus",
    "disabled"
  ],
  "tokens": {
    "root": {
      "field.gap.y": {
        "resolvesTo": "semantic.spacing.density.compact.sm",
        "fallback": "8px",
        "property": "gap",
        "layer": "semantic"
      },
      "field.gap.meta": {
        "resolvesTo": "core.spacing.size.03",
        "fallback": "4px",
        "property": "gap",
        "layer": "core"
      },
      "field.radius": {
        "resolvesTo": "semantic.shape.control.radius.default",
        "fallback": "8px",
        "property": "border-radius",
        "layer": "semantic"
      },
      "field.pad.x": {
        "resolvesTo": "semantic.spacing.density.compact.md",
        "fallback": "12px",
        "layer": "semantic"
      },
      "field.pad.y": {
        "resolvesTo": "semantic.spacing.density.compact.sm",
        "fallback": "8px",
        "layer": "semantic"
      },
      "field.color.bg": {
        "resolvesTo": "semantic.color.background.elevated",
        "fallback": "#ffffff",
        "layer": "semantic"
      },
      "field.color.fg": {
        "resolvesTo": "semantic.color.foreground.primary",
        "fallback": "#141414",
        "layer": "semantic"
      },
      "field.color.border": {
        "resolvesTo": "semantic.color.border.subtle",
        "fallback": "#cecece",
        "property": "border-color",
        "layer": "semantic"
      },
      "field.color.borderBold": {
        "resolvesTo": "semantic.color.border.bold",
        "fallback": "#8f8f8f",
        "property": "border-color",
        "layer": "semantic"
      },
      "field.color.focus-border": {
        "resolvesTo": "semantic.color.border.focus",
        "fallback": "#d9292b",
        "layer": "semantic"
      },
      "field.color.invalid-border": {
        "resolvesTo": "semantic.color.border.danger",
        "fallback": "#ae0001",
        "layer": "semantic"
      },
      "field.color.invalid-text": {
        "resolvesTo": "semantic.color.foreground.danger",
        "fallback": "#d9292b",
        "layer": "semantic"
      },
      "field.color.valid-border": {
        "resolvesTo": "semantic.color.feedback.border.success",
        "fallback": "#336006",
        "layer": "semantic"
      },
      "field.spacing.indicator": {
        "resolvesTo": "core.spacing.size.03",
        "fallback": "4px",
        "layer": "core"
      }
    },
    "label": {
      "field.label.fontSize": {
        "resolvesTo": "semantic.typography.body.small.font.size",
        "fallback": "14px",
        "layer": "semantic"
      },
      "field.label.color": {
        "resolvesTo": "semantic.color.foreground.secondary",
        "fallback": "#555555",
        "layer": "semantic"
      }
    }
  },
  "form": {
    "participates": false
  },
  "focus": {
    "strategy": "none",
    "description": "FormField does not manage focus. The child control inside children handles its own focus."
  },
  "portal": {
    "enabled": false
  },
  "slots": {
    "error": {
      "required": false
    },
    "help": {
      "required": false
    },
    "label": {
      "required": false
    }
  },
  "ssr": {
    "hydrateOn": "none"
  },
  "rtl": {
    "flipIcon": false
  },
  "relationships": [
    {
      "from": "label",
      "to": "control",
      "attribute": "for",
      "description": "label.for is wired to the child control's id, establishing the label association. Field propagates IDs to its slotted control via React context internally; the schema relationship records the resulting ARIA attribute."
    },
    {
      "from": "control",
      "to": "help",
      "attribute": "aria-describedby",
      "when": "validity=valid",
      "description": "Child control receives help id (via context propagation) to set aria-describedby when valid."
    },
    {
      "from": "control",
      "to": "error",
      "attribute": "aria-describedby",
      "when": "validity=invalid",
      "description": "Child control receives error id (via context propagation) to set aria-describedby when invalid."
    }
  ],
  "channels": {
    "value": {
      "description": "Controlled value of the field's child control, passed through context.",
      "value": "value",
      "defaultValue": "defaultValue",
      "onChange": "onChange",
      "valueType": "unknown"
    }
  },
  "a11y": {
    "role": "group",
    "roles": [
      "group",
      "alert",
      "radiogroup"
    ],
    "apgPattern": "alert",
    "labeling": [
      "aria-labelledby",
      "aria-describedby",
      "aria-errormessage"
    ],
    "keyboard": []
  },
  "usage": {
    "example": "<Field label=\"Name\" helpText=\"Enter your full name\" error={errors.name}>\n  <Input name=\"name\" value={name} onChange={setName} />\n</Field>"
  },
  "a2ui": {
    "category": "layout",
    "usageHints": [
      "Wrap every form control in a Field to ensure consistent label/error placement",
      "Pass error to Field (not the input) to colocate validation state",
      "Field handles aria-describedby wiring between hint/error and the input"
    ],
    "children": {
      "allowed": true,
      "slot": "children",
      "accepts": [
        "ReactNode"
      ]
    }
  }
}
