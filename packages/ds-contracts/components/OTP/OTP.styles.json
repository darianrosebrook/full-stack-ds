{
  "root": {
    "display": {
      "literal": "inline-flex",
      "platforms": [
        "web"
      ]
    },
    "align-items": {
      "literal": "center",
      "platforms": [
        "web"
      ]
    }
  },
  "group": {
    "display": {
      "literal": "inline-flex",
      "platforms": [
        "web"
      ]
    },
    "align-items": {
      "literal": "center",
      "platforms": [
        "web"
      ]
    },
    "gap": {
      "literal": "4px",
      "platforms": [
        "web"
      ]
    }
  },
  "field": {
    "display": {
      "literal": "block",
      "platforms": [
        "web"
      ]
    },
    "width": {
      "literal": "40px",
      "platforms": [
        "web"
      ]
    },
    "height": {
      "literal": "40px",
      "platforms": [
        "web"
      ]
    },
    "text-align": {
      "literal": "center",
      "platforms": [
        "web"
      ]
    },
    "font-size": {
      "literal": "1rem",
      "platforms": [
        "web"
      ]
    },
    "box-sizing": {
      "literal": "border-box",
      "platforms": [
        "web"
      ]
    },
    "border-style": {
      "literal": "solid",
      "platforms": [
        "web"
      ]
    },
    "border-width": {
      "literal": "1px",
      "platforms": [
        "web"
      ]
    },
    "border-radius": {
      "resolvesTo": "otp.size.radius.default"
    },
    "border-color": {
      "resolvesTo": "otp.color.border.default"
    },
    "background-color": {
      "resolvesTo": "otp.color.background.default"
    },
    "color": {
      "resolvesTo": "otp.color.foreground.primary"
    }
  },
  ".otp__field:focus-visible": {
    "border-color": {
      "resolvesTo": "otp.color.border.accent"
    },
    "outline-width": {
      "resolvesTo": "otp.focus.ring.width"
    },
    "outline-color": {
      "resolvesTo": "otp.focus.ring.color"
    },
    "outline-style": {
      "resolvesTo": "otp.focus.ring.style"
    },
    "outline-offset": {
      "resolvesTo": "otp.focus.ring.offset"
    }
  },
  ".otp__field:disabled": {
    "opacity": {
      "literal": "0.5",
      "platforms": [
        "web"
      ]
    },
    "cursor": {
      "literal": "not-allowed",
      "platforms": [
        "web"
      ]
    }
  }
}
