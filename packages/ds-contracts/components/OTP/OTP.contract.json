{
  "$schema": "../../component.contract.schema.json",
  "name": "OTP",
  "description": "One-time password input composed of individual single-character digit fields.",
  "layer": "composer",
  "anatomy": {
    "parts": [
      "root",
      "group",
      "field"
    ],
    "dom": {
      "tag": "div",
      "part": "root",
      "attrs": {
        "role": "group"
      },
      "bindings": {
        "aria-label": "prop:label",
        "aria-describedby": "literal:otp-error-id"
      },
      "children": [
        {
          "tag": "div",
          "part": "group",
          "children": [
            {
              "tag": "input",
              "part": "field",
              "attrs": {
                "type": "text",
                "inputmode": "numeric",
                "autocomplete": "one-time-code",
                "maxlength": "1"
              },
              "bindings": {
                "disabled": "prop:disabled",
                "aria-readonly": "prop:readOnly"
              }
            }
          ]
        }
      ]
    }
  },
  "props": {
    "styled": {
      "description": "Props for the <OTP> component.",
      "members": [
        {
          "name": "length",
          "type": "number",
          "description": "Number of individual input fields to render.",
          "default": 6
        },
        {
          "name": "value",
          "type": "string",
          "description": "Controlled OTP value string."
        },
        {
          "name": "defaultValue",
          "type": "string",
          "description": "Uncontrolled initial OTP value."
        },
        {
          "name": "onChange",
          "type": "(value: string) => void",
          "description": "Called when the OTP value changes."
        },
        {
          "name": "onComplete",
          "type": "(value: string) => void",
          "description": "Called when all fields are filled."
        },
        {
          "name": "mode",
          "type": "OTPMode",
          "description": "Whether fields accept only digits or any alphanumeric character.",
          "default": "numeric"
        },
        {
          "name": "disabled",
          "type": "boolean",
          "description": "Disables all input fields."
        },
        {
          "name": "readOnly",
          "type": "boolean",
          "description": "Makes all fields read-only."
        },
        {
          "name": "label",
          "type": "string",
          "description": "Accessible label for the OTP group.",
          "default": "One-time password"
        }
      ]
    }
  },
  "channels": {
    "value": {
      "description": "The full OTP string assembled from individual digit inputs.",
      "value": "value",
      "defaultValue": "defaultValue",
      "onChange": "onChange",
      "valueType": "string"
    }
  },
  "types": {
    "OTPMode": {
      "kind": "union",
      "values": [
        "numeric",
        "alphanumeric"
      ]
    }
  },
  "variants": {
    "mode": [
      "numeric",
      "alphanumeric"
    ]
  },
  "states": [
    "default",
    "focus",
    "disabled"
  ],
  "form": {
    "participates": true,
    "inputType": "text",
    "serialization": {
      "valueType": "string",
      "valueSource": "channel:value"
    },
    "validity": {
      "model": "native",
      "errorSurface": "aria-describedby"
    }
  },
  "focus": {
    "strategy": "manual",
    "orientation": "horizontal",
    "initialFocus": "field",
    "wrap": false,
    "description": "Focus moves automatically to the next OTPField after a digit is entered, and to the previous field on Backspace. Arrow keys can also navigate between fields."
  },
  "slots": {
    "root": {
      "required": true,
      "selector": "[data-slot=\"otp\"]"
    },
    "group": {
      "required": false,
      "selector": "[data-slot=\"otp-group\"]"
    },
    "field": {
      "required": true,
      "selector": "[data-slot=\"otp-field\"]"
    }
  },
  "ssr": {
    "hydrateOn": "interaction"
  },
  "rtl": {
    "flipIcon": false
  },
  "relationships": [
    {
      "from": "field",
      "to": "group",
      "attribute": "aria-label",
      "description": "Each individual input field carries an aria-label like 'Digit N of M' for screen reader enumeration."
    }
  ],
  "a11y": {
    "role": "group",
    "apgPattern": "spinbutton",
    "labeling": [
      "aria-label",
      "aria-describedby",
      "aria-readonly"
    ],
    "keyboard": [
      {
        "key": "0-9",
        "action": "Enter a digit and advance focus to the next field.",
        "when": "field"
      },
      {
        "key": "Backspace",
        "action": "Clear the current field and move focus to the previous field.",
        "when": "field"
      },
      {
        "key": "ArrowLeft",
        "action": "Move focus to the previous OTP field.",
        "when": "field"
      },
      {
        "key": "ArrowRight",
        "action": "Move focus to the next OTP field.",
        "when": "field"
      }
    ]
  },
  "a2ui": {
    "category": "form-field",
    "usageHints": [
      "Set length to control the number of digit fields",
      "Focus advances automatically after each digit is entered",
      "Compose with OTPLabel for the field label and OTPError for validation feedback",
      "Use OTPSeparator between fields for visual grouping (e.g., 3+3 pattern)"
    ],
    "children": {
      "allowed": true,
      "slot": "children",
      "accepts": [
        "OTPInput",
        "OTPLabel",
        "OTPError",
        "OTPSeparator"
      ]
    }
  }
}
