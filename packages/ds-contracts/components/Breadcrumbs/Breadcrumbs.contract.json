{
  "$schema": "../../component.contract.schema.json",
  "name": "Breadcrumbs",
  "description": "Navigation landmark showing the current page location within a site hierarchy.",
  "layer": "compound",
  "category": "structure",
  "anatomy": {
    "parts": [
      "root",
      "list",
      "link",
      "current",
      "separator",
      "overflow"
    ],
    "details": {
      "root": {
        "tag": "nav",
        "description": "Navigation landmark labeled for the breadcrumb trail.",
        "role": "region",
        "aria": {
          "role": "navigation",
          "attributes": [
            "aria-label"
          ]
        }
      },
      "list": {
        "tag": "ol",
        "description": "Ordered list that preserves hierarchy order from the root page to the current page.",
        "role": "group"
      },
      "link": {
        "description": "Navigable breadcrumb item for an ancestor page.",
        "role": "item",
        "multiple": true,
        "interactive": true,
        "focusable": true
      },
      "current": {
        "description": "Terminal breadcrumb item representing the current page.",
        "role": "item",
        "aria": {
          "attributes": [
            "aria-current"
          ]
        }
      },
      "separator": {
        "description": "Visual divider between breadcrumb items.",
        "role": "decoration",
        "multiple": true
      },
      "overflow": {
        "description": "Optional overflow affordance for collapsed middle breadcrumb items.",
        "role": "trigger",
        "interactive": true,
        "focusable": true
      }
    },
    "dom": {
      "tag": "nav",
      "part": "root",
      "bindings": {
        "aria-label": "prop:ariaLabel"
      },
      "children": [
        {
          "tag": "ol",
          "part": "list",
          "children": [
            {
              "tag": "children"
            }
          ]
        }
      ]
    }
  },
  "props": {
    "styled": {
      "description": "Props for the <Breadcrumbs> component.",
      "members": [
        {
          "name": "ariaLabel",
          "type": "string",
          "description": "Accessible label for the nav landmark. Defaults to \"Breadcrumb\".",
          "default": "Breadcrumb"
        },
        {
          "name": "separator",
          "type": "string",
          "description": "Separator character or string rendered between items."
        }
      ]
    }
  },
  "variants": {},
  "states": {
    "dimensions": {
      "pointer": {
        "category": "interaction",
        "values": [
          "default",
          "hover"
        ],
        "initial": "default",
        "exclusive": true
      },
      "focus": {
        "category": "interaction",
        "values": [
          "unfocused",
          "focus"
        ],
        "initial": "unfocused",
        "exclusive": true
      }
    }
  },
  "slots": {
    "root": {
      "required": true,
      "selector": "[data-slot=\"breadcrumbs\"]"
    },
    "list": {
      "required": true,
      "selector": "[data-slot=\"breadcrumbs-list\"]"
    },
    "separator": {
      "required": false,
      "selector": "[data-slot=\"breadcrumbs-separator\"]"
    },
    "current": {
      "required": true,
      "selector": "[data-slot=\"breadcrumbs-current\"]"
    }
  },
  "ssr": {
    "hydrateOn": "none"
  },
  "rtl": {
    "flipIcon": false
  },
  "a11y": {
    "role": "navigation",
    "labeling": [
      "aria-label"
    ],
    "keyboard": []
  },
  "a2ui": {
    "category": "navigation",
    "usageHints": [
      "Provide items as an array of { label, href } objects; the last item is the current page (no href)",
      "The component automatically renders a nav[aria-label=\"Breadcrumb\"] and marks the current item with aria-current=\"page\"",
      "Use separator to customize the divider character"
    ],
    "children": {
      "allowed": false
    }
  }
}
