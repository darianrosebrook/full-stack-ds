{
  "$schema": "../../component.contract.schema.json",
  "name": "Breadcrumbs",
  "description": "Navigation landmark showing the current page location within a site hierarchy.",
  "layer": "compound",
  "category": "structure",
  "anatomy": {
    "parts": [
      "root",
      "list",
      "link",
      "current",
      "separator",
      "overflow"
    ],
    "dom": {
      "tag": "nav",
      "part": "root",
      "bindings": {
        "aria-label": "prop:ariaLabel"
      },
      "children": [
        {
          "tag": "ol",
          "part": "list",
          "children": [
            {
              "tag": "children"
            }
          ]
        }
      ]
    }
  },
  "props": {
    "styled": {
      "description": "Props for the <Breadcrumbs> component.",
      "members": [
        {
          "name": "ariaLabel",
          "type": "string",
          "description": "Accessible label for the nav landmark. Defaults to \"Breadcrumb\".",
          "default": "Breadcrumb"
        },
        {
          "name": "separator",
          "type": "string",
          "description": "Separator character or string rendered between items."
        }
      ]
    }
  },
  "variants": {},
  "states": [
    "default",
    "hover",
    "focus"
  ],
  "slots": {
    "root": {
      "required": true,
      "selector": "[data-slot=\"breadcrumbs\"]"
    },
    "list": {
      "required": true,
      "selector": "[data-slot=\"breadcrumbs-list\"]"
    },
    "separator": {
      "required": false,
      "selector": "[data-slot=\"breadcrumbs-separator\"]"
    },
    "current": {
      "required": true,
      "selector": "[data-slot=\"breadcrumbs-current\"]"
    }
  },
  "ssr": {
    "hydrateOn": "none"
  },
  "rtl": {
    "flipIcon": false
  },
  "a11y": {
    "role": "navigation",
    "labeling": [
      "aria-label"
    ],
    "keyboard": []
  },
  "a2ui": {
    "category": "navigation",
    "usageHints": [
      "Provide items as an array of { label, href } objects; the last item is the current page (no href)",
      "The component automatically renders a nav[aria-label=\"Breadcrumb\"] and marks the current item with aria-current=\"page\"",
      "Use separator to customize the divider character"
    ],
    "children": {
      "allowed": false
    }
  }
}
