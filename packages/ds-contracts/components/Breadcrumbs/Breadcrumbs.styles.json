{
  "root": {
    "background-color": {
      "resolvesTo": "breadcrumbs.color.background.elevated"
    },
    "border-color": {
      "resolvesTo": "breadcrumbs.color.border.subtle"
    },
    "line-height": {
      "resolvesTo": "breadcrumbs.typography.lineHeight.collapse"
    },
    "display": {
      "literal": "block",
      "platforms": [
        "web"
      ]
    },
    "breadcrumbs.shape.radius.medium": {
      "resolvesTo": "core.shape.radius.small",
      "fallback": "4px"
    },
    "breadcrumbs.spacing.gap.default": {
      "resolvesTo": "core.spacing.size.03",
      "fallback": "4px"
    },
    "breadcrumbs.spacing.padding.default": {
      "resolvesTo": "core.spacing.size.03",
      "fallback": "4px"
    },
    "breadcrumbs.color.foreground.primary": {
      "resolvesTo": "semantic.color.foreground.tertiary",
      "fallback": "#717171"
    }
  },
  "focus": {
    "outline-color": {
      "resolvesTo": "breadcrumbs.color.focus"
    }
  },
  "list": {
    "list-style": {
      "literal": "none",
      "platforms": [
        "web"
      ]
    },
    "padding": {
      "literal": "0",
      "platforms": [
        "web"
      ]
    },
    "margin": {
      "literal": "0",
      "platforms": [
        "web"
      ]
    },
    "display": {
      "literal": "flex",
      "platforms": [
        "web"
      ]
    },
    "align-items": {
      "literal": "center",
      "platforms": [
        "web"
      ]
    },
    "flex-wrap": {
      "literal": "wrap",
      "platforms": [
        "web"
      ]
    },
    "gap": {
      "resolvesTo": "breadcrumbs.spacing.gap.default"
    }
  }
}
