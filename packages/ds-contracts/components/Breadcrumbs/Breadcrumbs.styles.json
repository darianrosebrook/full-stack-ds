{
  "root": {
    "color": {
      "resolvesTo": "breadcrumbs.color.foreground.tertiary"
    },
    "background-color": {
      "resolvesTo": "breadcrumbs.color.background.elevated"
    },
    "border-color": {
      "resolvesTo": "breadcrumbs.color.border.subtle"
    },
    "line-height": {
      "resolvesTo": "breadcrumbs.typography.lineHeight.collapse"
    },
    "border-radius": {
      "resolvesTo": "breadcrumbs.shape.radius.small"
    },
    "gap": {
      "resolvesTo": "breadcrumbs.spacing.gap.small"
    },
    "padding": {
      "resolvesTo": "breadcrumbs.spacing.padding.small"
    },
    "display": { "literal": "block", "platforms": ["web"] }
  },
  "focus": {
    "outline-color": {
      "resolvesTo": "breadcrumbs.color.focus"
    }
  },
  "list": {
    "list-style": { "literal": "none", "platforms": ["web"] },
    "padding": { "literal": "0", "platforms": ["web"] },
    "margin": { "literal": "0", "platforms": ["web"] },
    "display": { "literal": "flex", "platforms": ["web"] },
    "align-items": { "literal": "center", "platforms": ["web"] },
    "flex-wrap": { "literal": "wrap", "platforms": ["web"] },
    "gap": { "resolvesTo": "breadcrumbs.spacing.gap.default" }
  }
}
