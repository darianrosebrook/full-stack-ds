{
  "root": {
    "background-color": {
      "resolvesTo": "breadcrumbs.color.background.elevated"
    },
    "border-color": {
      "resolvesTo": "breadcrumbs.color.border.subtle"
    },
    "line-height": {
      "resolvesTo": "breadcrumbs.typography.lineHeight.collapse"
    },
    "display": {
      "literal": "block",
      "platforms": [
        "web"
      ]
    },
    "border-radius": {
      "resolvesTo": "breadcrumbs.shape.radius.medium"
    },
    "padding": {
      "resolvesTo": "breadcrumbs.spacing.padding.default"
    },
    "color": {
      "resolvesTo": "breadcrumbs.color.foreground.primary"
    }
  },
  "focus": {
    "outline-color": {
      "resolvesTo": "breadcrumbs.color.focus"
    }
  },
  "list": {
    "list-style": {
      "literal": "none",
      "platforms": [
        "web"
      ]
    },
    "padding": {
      "literal": "0",
      "platforms": [
        "web"
      ]
    },
    "margin": {
      "literal": "0",
      "platforms": [
        "web"
      ]
    },
    "display": {
      "literal": "flex",
      "platforms": [
        "web"
      ]
    },
    "align-items": {
      "literal": "center",
      "platforms": [
        "web"
      ]
    },
    "flex-wrap": {
      "literal": "wrap",
      "platforms": [
        "web"
      ]
    },
    "gap": {
      "resolvesTo": "breadcrumbs.spacing.gap.default"
    }
  }
}
