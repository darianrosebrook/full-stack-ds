{
  "root": {
    "sheet.color.overlay": {
      "resolvesTo": "semantic.overlay.scrim.sheet",
      "fallback": "rgba(0,0,0,0.50)",
      "layer": "semantic"
    },
    "sheet.color.background": {
      "resolvesTo": "semantic.color.background.primary",
      "fallback": "#ffffff",
      "property": "background-color",
      "layer": "semantic"
    },
    "sheet.color.border": {
      "resolvesTo": "semantic.color.border.light",
      "fallback": "#fceaea",
      "property": "border-color",
      "layer": "semantic"
    },
    "sheet.color.text": {
      "resolvesTo": "semantic.color.foreground.primary",
      "fallback": "#141414",
      "property": "color",
      "layer": "semantic"
    },
    "sheet.color.textTitle": {
      "resolvesTo": "semantic.color.foreground.primary",
      "fallback": "#141414",
      "property": "color",
      "layer": "semantic"
    },
    "sheet.color.textDescription": {
      "resolvesTo": "semantic.color.foreground.secondary",
      "fallback": "#555555",
      "property": "color",
      "layer": "semantic"
    },
    "sheet.border.width": {
      "resolvesTo": "core.shape.border.width.hairline",
      "fallback": "1px",
      "property": "border-width",
      "layer": "core"
    },
    "sheet.border.radius": {
      "resolvesTo": "core.shape.radius.medium",
      "fallback": "8px",
      "property": "border-radius",
      "layer": "core"
    },
    "sheet.size.width": {
      "literal": "400px"
    },
    "sheet.size.height": {
      "literal": "300px"
    },
    "sheet.size.close": {
      "resolvesTo": "core.spacing.size.06",
      "fallback": "16px",
      "layer": "core"
    },
    "sheet.spacing.padding": {
      "resolvesTo": "core.spacing.size.06",
      "fallback": "16px",
      "property": "padding",
      "layer": "core"
    },
    "sheet.spacing.gap": {
      "resolvesTo": "core.spacing.size.04",
      "fallback": "8px",
      "property": "gap",
      "layer": "core"
    },
    "sheet.text.size": {
      "resolvesTo": "semantic.typography.body.02",
      "fallback": "16px",
      "property": "font-size",
      "layer": "semantic"
    },
    "sheet.text.sizeTitle": {
      "resolvesTo": "semantic.typography.heading.06",
      "fallback": "14px",
      "property": "font-size",
      "layer": "semantic"
    },
    "sheet.text.weightTitle": {
      "resolvesTo": "semantic.typography.font.weight.medium",
      "fallback": "500",
      "property": "font-weight",
      "layer": "semantic"
    },
    "sheet.shadow": {
      "resolvesTo": "semantic.elevation.surface.floating",
      "fallback": "0 4px 24px rgba(0,0,0,0.12)",
      "property": "box-shadow",
      "layer": "semantic"
    },
    "sheet.focus.width": {
      "resolvesTo": "core.shape.border.width.thick",
      "fallback": "2px",
      "layer": "core"
    },
    "sheet.focus.color": {
      "resolvesTo": "semantic.color.border.accent",
      "fallback": "#d9292b",
      "layer": "semantic"
    }
  },
  "hover": {
    "sheet.color.backgroundHover": {
      "resolvesTo": "semantic.interaction.background.hover",
      "fallback": "#efefef",
      "property": "background-color",
      "layer": "semantic"
    }
  }
}
