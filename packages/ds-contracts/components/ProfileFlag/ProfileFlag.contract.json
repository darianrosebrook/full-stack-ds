{
  "$schema": "../../component.contract.schema.json",
  "name": "ProfileFlag",
  "description": "Avatar-style display of a user or entity identity with name and optional status badge.",
  "layer": "primitive",
  "anatomy": {
    "parts": [
      "root"
    ],
    "dom": {
      "tag": "div",
      "part": "root",
      "children": [
        {
          "tag": "children"
        }
      ]
    }
  },
  "props": {
    "styled": {
      "description": "Props for the <ProfileFlag> component.",
      "members": [
        {
          "name": "profile",
          "type": "ProfileFlagData",
          "description": "Profile data object to display."
        }
      ]
    }
  },
  "types": {
    "ProfileFlagData": {
      "kind": "alias",
      "alias": "{ id: string; username: string; full_name: string; first_name: string | null; last_name: string | null; avatar_url: string | null; bio: string; occupation: string | null; account_status: string; created_at: string; updated_at: string | null }"
    }
  },
  "variants": {},
  "states": [
    "default",
    "hover"
  ],
  "tokens": {
    "root": {
      "profileFlag.color.background.default": {
        "resolvesTo": "semantic.color.background.primary",
        "fallback": "#ffffff",
        "property": "background-color",
        "layer": "semantic"
      },
      "profileFlag.color.border.default": {
        "resolvesTo": "semantic.color.border.light",
        "fallback": "#fceaea",
        "property": "border-color",
        "layer": "semantic"
      },
      "profileFlag.color.foreground.primary": {
        "resolvesTo": "semantic.color.foreground.primary",
        "fallback": "#141414",
        "property": "color",
        "layer": "semantic"
      },
      "profileFlag.size.radius.default": {
        "resolvesTo": "semantic.shape.control.radius.default",
        "fallback": "8px",
        "property": "border-radius",
        "layer": "semantic"
      },
      "profileFlag.spacing.gap.default": {
        "resolvesTo": "core.spacing.size.03",
        "fallback": "4px",
        "property": "gap",
        "layer": "core"
      },
      "profileFlag.spacing.padding.default": {
        "resolvesTo": "core.spacing.size.04",
        "fallback": "8px",
        "property": "padding",
        "layer": "core"
      },
      "profileFlag.spacing.padding.right": {
        "resolvesTo": "core.spacing.size.06",
        "fallback": "16px",
        "property": "padding",
        "layer": "core"
      }
    },
    "hover": {
      "profileFlag.color.border.hover": {
        "resolvesTo": "semantic.color.border.bold",
        "fallback": "#8f8f8f",
        "property": "border-color",
        "layer": "semantic"
      }
    }
  },
  "slots": {
    "root": {
      "required": true,
      "selector": "[data-slot=\"profile-flag\"]"
    }
  },
  "ssr": {
    "hydrateOn": "none"
  },
  "rtl": {
    "flipIcon": false
  },
  "a11y": {
    "labeling": [],
    "keyboard": []
  },
  "a2ui": {
    "category": "display",
    "usageHints": [
      "Use in comment threads, tables, or nav bars to identify the actor",
      "size=compact for dense layouts like table rows",
      "Pairs with StatusDot to indicate presence or role"
    ],
    "children": {
      "allowed": false
    }
  }
}
