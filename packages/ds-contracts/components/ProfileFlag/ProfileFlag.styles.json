{
  "root": {
    "background-color": {
      "resolvesTo": "profile-flag.color.background.default"
    },
    "border-color": {
      "resolvesTo": "profile-flag.color.border.default"
    },
    "color": {
      "resolvesTo": "profile-flag.color.foreground.primary"
    },
    "border-radius": {
      "resolvesTo": "profile-flag.size.radius.default"
    },
    "gap": {
      "resolvesTo": "profile-flag.spacing.gap.default"
    },
    "padding": {
      "resolvesTo": "profile-flag.spacing.padding.right"
    }
  },
  "hover": {
    "border-color": {
      "resolvesTo": "profile-flag.color.border.hover"
    }
  }
}
