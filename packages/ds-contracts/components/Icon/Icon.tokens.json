{
  "box-model.width": {
    "resolvesTo": "semantic.glyph.size.medium.extent",
    "fallback": "16px",
    "layer": "semantic"
  },
  "box-model.height": {
    "resolvesTo": "semantic.glyph.size.medium.extent",
    "fallback": "16px",
    "layer": "semantic"
  },
  "icon.color.foreground.default": {
    "resolvesTo": "semantic.color.foreground.primary",
    "fallback": "#141414",
    "layer": "semantic"
  },
  "icon.size.padding.default": {
    "resolvesTo": "core.spacing.size.01",
    "fallback": "1px",
    "layer": "core"
  }
}
