{
  "$schema": "../../component.contract.schema.json",
  "name": "Icon",
  "description": "Renders a named SVG icon from the design system icon set.",
  "layer": "primitive",
  "category": "glyph",
  "anatomy": {
    "parts": [
      "root"
    ],
    "dom": {
      "tag": "span",
      "part": "root",
      "attrs": {
        "aria-hidden": "true"
      }
    }
  },
  "props": {
    "styled": {
      "description": "Props for the <Icon> component.",
      "members": [
        {
          "name": "icon",
          "type": "IconDefinition",
          "description": "Icon definition object (name + glyph data).",
          "required": true
        },
        {
          "name": "width",
          "type": "number",
          "description": "Pixel width of the rendered glyph.",
          "default": 20
        },
        {
          "name": "height",
          "type": "number",
          "description": "Pixel height of the rendered glyph.",
          "default": 20
        }
      ]
    }
  },
  "types": {
    "IconDefinition": {
      "kind": "alias",
      "alias": "{ iconName: string; prefix?: string; icon?: unknown }"
    }
  },
  "states": [
    "default"
  ],
  "focus": {
    "strategy": "none"
  },
  "portal": {
    "enabled": false
  },
  "slots": {
    "root": {
      "required": true,
      "selector": "[data-slot=\"icon\"]"
    }
  },
  "ssr": {
    "hydrateOn": "none"
  },
  "rtl": {
    "flipIcon": false
  },
  "a11y": {
    "labeling": [
      "aria-label",
      "aria-hidden"
    ],
    "keyboard": []
  },
  "a2ui": {
    "category": "display",
    "usageHints": [
      "Set aria-hidden=\"true\" when the icon is decorative (has adjacent visible text)",
      "Set aria-label when the icon stands alone without visible text",
      "Use size to scale the icon to match surrounding text"
    ],
    "children": {
      "allowed": false
    }
  }
}
