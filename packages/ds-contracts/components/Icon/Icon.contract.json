{
  "$schema": "../../component.contract.schema.json",
  "name": "Icon",
  "description": "Renders a named SVG icon from the design system icon set.",
  "layer": "primitive",
  "category": "glyph",
  "morphology": "fixed-square",
  "anatomy": {
    "parts": [
      "root"
    ],
    "dom": {
      "tag": "span",
      "part": "root",
      "attrs": {
        "aria-hidden": "true"
      },
      "children": [
        {
          "tag": "svg",
          "attrs": {
            "viewBox": "0 0 17 17",
            "fill": "none",
            "xmlns": "http://www.w3.org/2000/svg"
          },
          "bindings": {
            "width": "prop:width",
            "height": "prop:height"
          },
          "children": [
            {
              "tag": "circle",
              "attrs": {
                "cx": "8.5",
                "cy": "8.5",
                "r": "8",
                "stroke": "currentColor",
                "stroke-linecap": "round",
                "stroke-dasharray": "2 4"
              }
            },
            {
              "tag": "circle",
              "attrs": {
                "cx": "8.5",
                "cy": "8.5",
                "r": "3",
                "stroke": "currentColor",
                "stroke-linecap": "round",
                "stroke-dasharray": ".125 3"
              }
            }
          ]
        }
      ]
    }
  },
  "props": {
    "designed": {
      "members": [
        {
          "name": "icon",
          "propType": { "kind": "ref", "to": "IconDefinition" },
          "description": "Icon definition object (name + glyph data).",
          "required": true
        },
        {
          "name": "width",
          "propType": { "kind": "number" },
          "description": "Pixel width of the rendered glyph.",
          "default": 20
        },
        {
          "name": "height",
          "propType": { "kind": "number" },
          "description": "Pixel height of the rendered glyph.",
          "default": 20
        }
      ]
    }
  },
  "types": {
    "IconDefinition": {
      "kind": "alias",
      "alias": "{ iconName: string; prefix?: string; icon?: unknown }"
    }
  },
  "states": {
    "dimensions": {
      "pointer": {
        "category": "interaction",
        "values": [
          "default"
        ],
        "initial": "default",
        "exclusive": true
      }
    }
  },
  "focus": {
    "strategy": "none"
  },
  "portal": {
    "enabled": false
  },
  "slots": {
    "root": {
      "required": true,
      "selector": "[data-slot=\"icon\"]"
    }
  },
  "ssr": {
    "hydrateOn": "none"
  },
  "rtl": {
    "flipIcon": false
  },
  "a11y": {
    "labeling": [
      "aria-label",
      "aria-hidden"
    ],
    "keyboard": []
  },
  "a2ui": {
    "category": "display",
    "usageHints": [
      "Set aria-hidden=\"true\" when the icon is decorative (has adjacent visible text)",
      "Set aria-label when the icon stands alone without visible text",
      "Use size to scale the icon to match surrounding text"
    ],
    "children": {
      "allowed": false
    }
  }
}
