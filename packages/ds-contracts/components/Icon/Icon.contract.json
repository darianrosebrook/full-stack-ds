{
  "$schema": "../../component.contract.schema.json",
  "name": "Icon",
  "description": "Renders a named SVG icon from the design system icon set.",
  "layer": "primitive",
  "category": "glyph",
  "morphology": "fixed-square",
  "anatomy": {
    "parts": [
      "root"
    ],
    "details": {
      "root": {
        "tag": "span",
        "description": "Glyph wrapper for the rendered SVG icon; decorative by default unless labeled by the consumer.",
        "role": "decoration",
        "aria": {
          "attributes": [
            "aria-hidden",
            "aria-label"
          ]
        }
      }
    },
    "dom": {
      "tag": "span",
      "part": "root",
      "attrs": {
        "aria-hidden": "true"
      },
      "children": [
        {
          "tag": "svg",
          "attrs": {
            "fill": "none",
            "xmlns": "http://www.w3.org/2000/svg"
          },
          "iconGlyph": {
            "nameFrom": "prop:name",
            "sizeFrom": "prop:size",
            "sizeHints": {
              "sm": 16,
              "md": 20,
              "lg": 24,
              "xl": 32
            }
          }
        }
      ]
    }
  },
  "props": {
    "designed": {
      "members": [
        {
          "name": "name",
          "propType": { "kind": "string" },
          "description": "Canonical icon name resolved against the @full-stack-ds/iconography catalog (e.g. \"check\", \"circle\"). An unknown name renders no glyph.",
          "required": true
        },
        {
          "name": "size",
          "propType": { "kind": "enum", "values": ["sm", "md", "lg", "xl"] },
          "description": "Rendered glyph size. Maps to pixels (sm=16, md=20, lg=24, xl=32 — mirroring the icon.size token scale) and selects the nearest authored size variant.",
          "default": "md"
        }
      ]
    }
  },
  "states": {
    "dimensions": {
      "pointer": {
        "category": "interaction",
        "values": [
          "default"
        ],
        "initial": "default",
        "exclusive": true
      }
    }
  },
  "focus": {
    "strategy": "none"
  },
  "portal": {
    "enabled": false
  },
  "slots": {
    "root": {
      "required": true,
      "selector": "[data-slot=\"icon\"]"
    }
  },
  "ssr": {
    "hydrateOn": "none"
  },
  "rtl": {
    "flipIcon": false
  },
  "a11y": {
    "labeling": [
      "aria-label",
      "aria-hidden"
    ],
    "keyboard": []
  },
  "a2ui": {
    "category": "display",
    "usageHints": [
      "Set aria-hidden=\"true\" when the icon is decorative (has adjacent visible text)",
      "Set aria-label when the icon stands alone without visible text",
      "Use size to scale the icon to match surrounding text"
    ],
    "children": {
      "allowed": false
    }
  }
}
