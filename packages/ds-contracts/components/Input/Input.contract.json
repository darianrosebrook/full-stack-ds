{
  "$schema": "../../component.contract.schema.json",
  "name": "Input",
  "description": "Native text input with design-system styling. Use inside TextField for label and error support.",
  "layer": "primitive",
  "category": "input",
  "anatomy": {
    "parts": [
      "root"
    ],
    "dom": {
      "tag": "input",
      "part": "root",
      "bindings": {
        "value": "channel:value.value",
        "disabled": "prop:disabled",
        "aria-invalid": "prop:invalid",
        "type": "prop:type",
        "placeholder": "prop:placeholder",
        "name": "prop:name",
        "required": "prop:required"
      },
      "events": {
        "change": "channel:value.onChange"
      }
    }
  },
  "props": {
    "designed": {
      "members": [
        {
          "name": "type",
          "propType": { "kind": "string" },
          "description": "HTML input type (text, email, password, number, search, etc.)."
        },
        {
          "name": "value",
          "propType": { "kind": "string" },
          "description": "Controlled value."
        },
        {
          "name": "defaultValue",
          "propType": { "kind": "string" },
          "description": "Uncontrolled initial value."
        },
        {
          "name": "onChange",
          "propType": {
            "kind": "callback",
            "params": [{ "name": "value", "type": { "kind": "string" } }],
            "returns": { "kind": "void" }
          },
          "description": "Called when value changes."
        },
        {
          "name": "placeholder",
          "propType": { "kind": "string" },
          "description": "Placeholder text shown when empty."
        },
        {
          "name": "disabled",
          "propType": { "kind": "boolean" },
          "description": "Prevents interaction."
        },
        {
          "name": "invalid",
          "propType": { "kind": "boolean" },
          "description": "Applies error styling and sets aria-invalid."
        },
        {
          "name": "required",
          "propType": { "kind": "boolean" },
          "description": "Sets the native required attribute."
        },
        {
          "name": "name",
          "propType": { "kind": "string" },
          "description": "Form name for native submission."
        }
      ]
    }
  },
  "channels": {
    "value": {
      "value": "value",
      "defaultValue": "defaultValue",
      "onChange": "onChange",
      "valueType": "string",
      "description": "The current text value of the input."
    }
  },
  "states": {
    "dimensions": {
      "pointer": {
        "category": "interaction",
        "values": [
          "default",
          "hover"
        ],
        "initial": "default",
        "exclusive": true
      },
      "focus": {
        "category": "interaction",
        "values": [
          "unfocused",
          "focus"
        ],
        "initial": "unfocused",
        "exclusive": true
      },
      "availability": {
        "category": "availability",
        "values": [
          "enabled",
          "disabled"
        ],
        "initial": "enabled",
        "exclusive": true,
        "suppresses": {
          "categories": [
            "interaction"
          ]
        }
      },
      "validation": {
        "category": "validation",
        "values": [
          "valid",
          "invalid"
        ],
        "initial": "valid",
        "exclusive": true
      }
    }
  },
  "form": {
    "participates": true,
    "inputType": "text",
    "name": {
      "prop": "name"
    },
    "required": {
      "prop": "required",
      "constraintValidation": true
    },
    "serialization": {
      "valueType": "string",
      "valueSource": "channel:value",
      "omitWhen": "never"
    },
    "validity": {
      "model": "hybrid",
      "invalidProp": "invalid",
      "ariaAttributes": [
        "aria-invalid",
        "aria-required",
        "aria-describedby"
      ]
    },
    "labeling": {
      "strategy": "associated-label",
      "required": true,
      "via": [
        "aria-labelledby",
        "aria-label"
      ]
    }
  },
  "focus": {
    "strategy": "none"
  },
  "portal": {
    "enabled": false
  },
  "slots": {
    "root": {
      "required": true,
      "selector": "[data-slot=\"input\"]"
    }
  },
  "ssr": {
    "hydrateOn": "interaction"
  },
  "rtl": {
    "flipIcon": false
  },
  "a11y": {
    "role": "textbox",
    "labeling": [
      "aria-label",
      "aria-labelledby",
      "aria-invalid"
    ],
    "keyboard": []
  },
  "a2ui": {
    "category": "form-field",
    "usageHints": [
      "Prefer TextField over Input when you need a label, description, or error message",
      "Use type to change the input mode (text, email, password, number, search, etc.)",
      "Set invalid for error state styling without a form validation message",
      "Use name for native form submission"
    ],
    "children": {
      "allowed": false
    }
  }
}
