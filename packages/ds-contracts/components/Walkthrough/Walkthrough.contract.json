{
  "$schema": "../../component.contract.schema.json",
  "name": "Walkthrough",
  "description": "Step-by-step guided tour overlay anchored to page elements. Manages step progression and keyboard navigation.",
  "layer": "composer",
  "anatomy": {
    "parts": [
      "root",
      "content",
      "title",
      "description",
      "controls",
      "skip",
      "prev",
      "next",
      "dots",
      "dot",
      "counter"
    ],
    "dom": {
      "tag": "div",
      "part": "root",
      "attrs": {
        "role": "status"
      },
      "bindings": {
        "aria-label": "prop:label"
      },
      "children": [
        {
          "tag": "div",
          "part": "content",
          "children": [
            {
              "tag": "h3",
              "part": "title",
              "children": [
                {
                  "tag": "slot",
                  "name": "title"
                }
              ]
            },
            {
              "tag": "p",
              "part": "description",
              "children": [
                {
                  "tag": "slot",
                  "name": "description"
                }
              ]
            }
          ]
        },
        {
          "tag": "div",
          "part": "controls",
          "children": [
            {
              "tag": "button",
              "part": "skip",
              "attrs": {
                "type": "button"
              }
            },
            {
              "tag": "button",
              "part": "prev",
              "attrs": {
                "type": "button"
              }
            },
            {
              "tag": "div",
              "part": "dots",
              "children": [
                {
                  "tag": "button",
                  "part": "dot",
                  "attrs": {
                    "type": "button"
                  }
                }
              ]
            },
            {
              "tag": "span",
              "part": "counter"
            },
            {
              "tag": "button",
              "part": "next",
              "attrs": {
                "type": "button"
              }
            }
          ]
        }
      ]
    }
  },
  "props": {
    "styled": {
      "description": "Props for the <Walkthrough> component.",
      "members": [
        {
          "name": "steps",
          "type": "WalkthroughStepSpec[]",
          "description": "Array of step definitions, each specifying an anchor target and content."
        },
        {
          "name": "index",
          "type": "number",
          "description": "Controlled active step index."
        },
        {
          "name": "defaultIndex",
          "type": "number",
          "description": "Uncontrolled initial step index.",
          "default": 0
        },
        {
          "name": "onStepChange",
          "type": "(index: number) => void",
          "description": "Called when the active step changes."
        },
        {
          "name": "onComplete",
          "type": "() => void",
          "description": "Called when the user advances past the last step."
        },
        {
          "name": "onSkip",
          "type": "() => void",
          "description": "Called when the user skips the tour."
        },
        {
          "name": "label",
          "type": "string",
          "description": "Accessible label for the walkthrough region.",
          "default": "Feature tour"
        },
        {
          "name": "storageKey",
          "type": "string",
          "description": "localStorage key to persist tour completion state across sessions."
        },
        {
          "name": "autoStart",
          "type": "boolean",
          "description": "Automatically begin the tour on mount.",
          "default": false
        },
        {
          "name": "closeOnOutsideClick",
          "type": "boolean",
          "description": "Close/skip the tour when the user clicks outside the panel.",
          "default": false
        },
        {
          "name": "placement",
          "type": "WalkthroughPlacement",
          "description": "Preferred placement of the walkthrough panel relative to its anchor.",
          "default": "auto"
        }
      ]
    }
  },
  "channels": {
    "step": {
      "description": "Active step index.",
      "value": "index",
      "defaultValue": "defaultIndex",
      "onChange": "onStepChange",
      "valueType": "number"
    }
  },
  "types": {
    "WalkthroughPlacement": {
      "kind": "union",
      "values": [
        "top",
        "bottom",
        "left",
        "right",
        "auto"
      ]
    },
    "WalkthroughStepSpec": {
      "kind": "alias",
      "alias": "{ anchor: string; title: string; description?: string }"
    }
  },
  "variants": {
    "placement": [
      "top",
      "bottom",
      "left",
      "right",
      "auto"
    ]
  },
  "states": [
    "default",
    "hover",
    "disabled"
  ],
  "tokens": {
    "root": {
      "walkthrough.surface.bg": {
        "resolvesTo": "semantic.color.background.secondary",
        "fallback": "#efefef",
        "layer": "semantic"
      },
      "walkthrough.surface.border": {
        "resolvesTo": "semantic.color.border.subtle",
        "fallback": "#cecece",
        "layer": "semantic"
      },
      "walkthrough.surface.radius": {
        "resolvesTo": "core.shape.radius.04",
        "fallback": "16px",
        "property": "border-radius",
        "layer": "core"
      },
      "walkthrough.surface.shadow": {
        "resolvesTo": "semantic.elevation.surface.floating",
        "fallback": "0 4px 24px rgba(0,0,0,0.12)",
        "property": "box-shadow",
        "layer": "semantic"
      },
      "walkthrough.surface.padding": {
        "resolvesTo": "core.spacing.size.08",
        "fallback": "32px",
        "property": "padding",
        "layer": "core"
      },
      "walkthrough.title.fontSize": {
        "resolvesTo": "semantic.typography.heading.03",
        "fallback": "20px",
        "layer": "semantic"
      },
      "walkthrough.title.fontWeight": {
        "resolvesTo": "semantic.typography.font.weight.bold",
        "fallback": "700",
        "layer": "semantic"
      },
      "walkthrough.title.color": {
        "resolvesTo": "semantic.color.foreground.primary",
        "fallback": "#141414",
        "layer": "semantic"
      },
      "walkthrough.description.fontSize": {
        "resolvesTo": "semantic.typography.body.02",
        "fallback": "16px",
        "layer": "semantic"
      },
      "walkthrough.description.color": {
        "resolvesTo": "semantic.color.foreground.secondary",
        "fallback": "#555555",
        "layer": "semantic"
      },
      "walkthrough.description.marginTop": {
        "resolvesTo": "core.spacing.size.04",
        "fallback": "8px",
        "layer": "core"
      },
      "walkthrough.controls.gap": {
        "resolvesTo": "core.spacing.size.05",
        "fallback": "12px",
        "property": "gap",
        "layer": "core"
      },
      "walkthrough.controls.marginTop": {
        "resolvesTo": "core.spacing.size.06",
        "fallback": "16px",
        "layer": "core"
      },
      "walkthrough.dots.size": {
        "resolvesTo": "core.spacing.size.02",
        "fallback": "2px",
        "layer": "core"
      },
      "walkthrough.dots.gap": {
        "resolvesTo": "core.spacing.size.03",
        "fallback": "4px",
        "property": "gap",
        "layer": "core"
      },
      "walkthrough.dots.active": {
        "resolvesTo": "semantic.color.action.background.primary.default",
        "fallback": "#d9292b",
        "layer": "semantic"
      },
      "walkthrough.dots.idle": {
        "resolvesTo": "semantic.color.border.subtle",
        "fallback": "#cecece",
        "layer": "semantic"
      },
      "walkthrough.button.primary.bg": {
        "resolvesTo": "semantic.color.action.background.primary.default",
        "fallback": "#d9292b",
        "layer": "semantic"
      },
      "walkthrough.button.primary.color": {
        "resolvesTo": "semantic.color.action.foreground.primary.default",
        "fallback": "#ffffff",
        "layer": "semantic"
      },
      "walkthrough.button.primary.radius": {
        "resolvesTo": "core.shape.radius.medium",
        "fallback": "8px",
        "property": "border-radius",
        "layer": "core"
      },
      "walkthrough.button.secondary.bg": {
        "resolvesTo": "core.color.mode.transparent",
        "fallback": "transparent",
        "layer": "core"
      },
      "walkthrough.button.secondary.color": {
        "resolvesTo": "semantic.color.foreground.secondary",
        "fallback": "#555555",
        "layer": "semantic"
      },
      "walkthrough.button.secondary.border": {
        "resolvesTo": "semantic.color.border.subtle",
        "fallback": "#cecece",
        "layer": "semantic"
      }
    },
    "title": {
      "walkthrough.title.fontSize": {
        "resolvesTo": "semantic.typography.heading.03",
        "fallback": "20px",
        "layer": "semantic"
      },
      "walkthrough.title.fontWeight": {
        "resolvesTo": "semantic.typography.font.weight.bold",
        "fallback": "700",
        "layer": "semantic"
      },
      "walkthrough.title.color": {
        "resolvesTo": "semantic.color.foreground.primary",
        "fallback": "#141414",
        "layer": "semantic"
      }
    },
    "description": {
      "walkthrough.description.fontSize": {
        "resolvesTo": "semantic.typography.body.02",
        "fallback": "16px",
        "layer": "semantic"
      },
      "walkthrough.description.color": {
        "resolvesTo": "semantic.color.foreground.secondary",
        "fallback": "#555555",
        "layer": "semantic"
      }
    },
    "controls": {
      "walkthrough.controls.gap": {
        "resolvesTo": "core.spacing.size.05",
        "fallback": "12px",
        "property": "gap",
        "layer": "core"
      }
    },
    "dots": {
      "walkthrough.dots.size": {
        "resolvesTo": "core.spacing.size.02",
        "fallback": "2px",
        "layer": "core"
      },
      "walkthrough.dots.gap": {
        "resolvesTo": "core.spacing.size.03",
        "fallback": "4px",
        "property": "gap",
        "layer": "core"
      },
      "walkthrough.dots.active": {
        "resolvesTo": "semantic.color.action.background.primary.default",
        "fallback": "#d9292b",
        "layer": "semantic"
      },
      "walkthrough.dots.idle": {
        "resolvesTo": "semantic.color.border.subtle",
        "fallback": "#cecece",
        "layer": "semantic"
      }
    }
  },
  "motion": {
    "reducedMotion": "respect",
    "transitions": [
      {
        "name": "open",
        "trigger": "openness=hidden\u2192visible",
        "phase": "enter",
        "properties": [
          "opacity",
          "transform"
        ],
        "duration": "core.motion.duration.short",
        "easing": "core.motion.easing.emphasized-in"
      },
      {
        "name": "close",
        "trigger": "openness=visible\u2192hidden",
        "phase": "exit",
        "properties": [
          "opacity"
        ],
        "duration": "core.motion.duration.short",
        "easing": "core.motion.easing.emphasized-out"
      }
    ]
  },
  "focus": {
    "strategy": "none",
    "description": "Walkthrough panels are non-blocking. Focus remains on the anchored element while the panel is visible."
  },
  "portal": {
    "enabled": true,
    "defaultTarget": "body",
    "positioning": "anchored",
    "layering": "popover",
    "collision": "flip-shift"
  },
  "dismissal": {
    "triggers": [
      {
        "event": "escape"
      },
      {
        "event": "outsideClick",
        "enabledBy": "closeOnOutsideClick"
      }
    ]
  },
  "slots": {
    "root": {
      "required": true,
      "selector": "[data-slot=\"walkthrough\"]"
    },
    "title": {
      "required": false,
      "selector": "[data-slot=\"walkthrough-title\"]"
    },
    "description": {
      "required": false,
      "selector": "[data-slot=\"walkthrough-description\"]"
    },
    "controls": {
      "required": false,
      "selector": "[data-slot=\"walkthrough-controls\"]"
    },
    "skip": {
      "required": false,
      "selector": "[data-slot=\"walkthrough-skip\"]"
    },
    "prev": {
      "required": false,
      "selector": "[data-slot=\"walkthrough-prev\"]"
    },
    "next": {
      "required": false,
      "selector": "[data-slot=\"walkthrough-next\"]"
    },
    "progress": {
      "required": false,
      "selector": "[data-slot=\"walkthrough-progress\"]"
    },
    "dot": {
      "required": false,
      "selector": "[data-slot=\"walkthrough-dot\"]"
    },
    "counter": {
      "required": false,
      "selector": "[data-slot=\"walkthrough-counter\"]"
    }
  },
  "ssr": {
    "hydrateOn": "interaction"
  },
  "rtl": {
    "flipIcon": false
  },
  "relationships": [
    {
      "from": "content",
      "to": "title",
      "attribute": "aria-labelledby",
      "description": "Walkthrough content region takes its accessible name from its title element."
    },
    {
      "from": "content",
      "to": "description",
      "attribute": "aria-describedby",
      "description": "Walkthrough content region is described by its description element."
    }
  ],
  "a11y": {
    "role": "status",
    "apgPattern": "status",
    "labeling": [
      "aria-label"
    ],
    "keyboard": [
      {
        "key": "ArrowRight",
        "action": "Advance to the next step.",
        "when": "active"
      },
      {
        "key": "ArrowLeft",
        "action": "Go to the previous step.",
        "when": "active"
      },
      {
        "key": "Escape",
        "action": "Close/skip the walkthrough tour.",
        "when": "active"
      },
      {
        "key": "Enter|Space",
        "action": "Activate the focused control (skip, prev, next, or dot).",
        "when": "active"
      }
    ]
  },
  "a2ui": {
    "category": "overlay",
    "usageHints": [
      "Define each step as a WalkthroughStep with an anchor ref and content",
      "WalkthroughAnchor wraps the element each step points to",
      "Use WalkthroughControls and WalkthroughProgress for navigation UI",
      "Keyboard: ArrowRight/ArrowLeft navigate steps; Escape closes the tour",
      "The walkthrough is non-blocking \u2014 it does not trap focus to the panel"
    ],
    "children": {
      "allowed": true,
      "slot": "children",
      "accepts": [
        "WalkthroughStep",
        "WalkthroughAnchor"
      ]
    }
  }
}
