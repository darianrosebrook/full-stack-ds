{
  "$schema": "../../component.contract.schema.json",
  "name": "Walkthrough",
  "description": "Step-by-step guided tour overlay anchored to page elements. Manages step progression and keyboard navigation.",
  "layer": "composer",
  "category": "structure",
  "anatomy": {
    "parts": [
      "root",
      "content",
      "title",
      "description",
      "controls",
      "skip",
      "prev",
      "next",
      "dots",
      "dot",
      "counter"
    ],
    "details": {
      "root": {
        "tag": "div",
        "description": "Guided-tour status region for the active walkthrough step.",
        "role": "root",
        "aria": {
          "role": "status",
          "attributes": [
            "aria-label"
          ]
        }
      },
      "content": {
        "tag": "div",
        "description": "Panel content containing the active step title and description.",
        "role": "content"
      },
      "title": {
        "tag": "h3",
        "description": "Heading for the active walkthrough step.",
        "role": "label"
      },
      "description": {
        "tag": "p",
        "description": "Supporting explanatory text for the active walkthrough step.",
        "role": "content"
      },
      "controls": {
        "tag": "div",
        "description": "Control group for skipping, navigating, and indicating walkthrough progress.",
        "role": "group"
      },
      "skip": {
        "tag": "button",
        "description": "Button that exits or skips the walkthrough.",
        "role": "trigger",
        "interactive": true,
        "focusable": true
      },
      "prev": {
        "tag": "button",
        "description": "Button that moves to the previous walkthrough step.",
        "role": "trigger",
        "interactive": true,
        "focusable": true
      },
      "next": {
        "tag": "button",
        "description": "Button that advances to the next walkthrough step or completes the tour.",
        "role": "trigger",
        "interactive": true,
        "focusable": true
      },
      "dots": {
        "tag": "div",
        "description": "Progress-dot group representing the full step sequence.",
        "role": "group"
      },
      "dot": {
        "tag": "button",
        "description": "Step navigation dot for a single walkthrough step.",
        "role": "trigger",
        "multiple": true,
        "interactive": true,
        "focusable": true,
        "aria": {
          "attributes": [
            "aria-label"
          ]
        }
      },
      "counter": {
        "tag": "span",
        "description": "Visible current-step count within the walkthrough sequence.",
        "role": "context"
      }
    },
    "dom": {
      "tag": "div",
      "part": "root",
      "attrs": {
        "role": "status"
      },
      "bindings": {
        "aria-label": "prop:label"
      },
      "children": [
        {
          "tag": "div",
          "part": "content",
          "attrs": {
            "role": "group"
          },
          "children": [
            {
              "tag": "h3",
              "part": "title",
              "children": [
                {
                  "tag": "slot",
                  "name": "title"
                }
              ]
            },
            {
              "tag": "p",
              "part": "description",
              "children": [
                {
                  "tag": "slot",
                  "name": "description"
                }
              ]
            }
          ]
        },
        {
          "tag": "div",
          "part": "controls",
          "children": [
            {
              "tag": "button",
              "part": "skip",
              "attrs": {
                "type": "button"
              }
            },
            {
              "tag": "button",
              "part": "prev",
              "attrs": {
                "type": "button"
              }
            },
            {
              "tag": "div",
              "part": "dots",
              "children": [
                {
                  "tag": "button",
                  "part": "dot",
                  "iterate": {
                    "source": "prop:steps",
                    "kind": "array",
                    "itemType": "WalkthroughStepSpec"
                  },
                  "attrs": {
                    "type": "button"
                  },
                  "bindings": {
                    "aria-label": "iter:item.title",
                    "data-step-index": "iter:index"
                  }
                }
              ]
            },
            {
              "tag": "span",
              "part": "counter"
            },
            {
              "tag": "button",
              "part": "next",
              "attrs": {
                "type": "button"
              }
            }
          ]
        }
      ]
    }
  },
  "props": {
    "styled": {
      "description": "Props for the <Walkthrough> component.",
      "members": [
        {
          "name": "steps",
          "type": "WalkthroughStepSpec[]",
          "description": "Array of step definitions, each specifying an anchor target and content.",
          "default": [
            { "anchor": "#step-1", "title": "Welcome to the tour" },
            { "anchor": "#step-2", "title": "Browse your dashboard" },
            { "anchor": "#step-3", "title": "Configure preferences" }
          ]
        },
        {
          "name": "index",
          "type": "number",
          "description": "Controlled active step index."
        },
        {
          "name": "defaultIndex",
          "type": "number",
          "description": "Uncontrolled initial step index.",
          "default": 0
        },
        {
          "name": "onStepChange",
          "type": "(index: number) => void",
          "description": "Called when the active step changes."
        },
        {
          "name": "onComplete",
          "type": "() => void",
          "description": "Called when the user advances past the last step."
        },
        {
          "name": "onSkip",
          "type": "() => void",
          "description": "Called when the user skips the tour."
        },
        {
          "name": "label",
          "type": "string",
          "description": "Accessible label for the walkthrough region.",
          "default": "Feature tour"
        },
        {
          "name": "storageKey",
          "type": "string",
          "description": "localStorage key to persist tour completion state across sessions."
        },
        {
          "name": "autoStart",
          "type": "boolean",
          "description": "Automatically begin the tour on mount.",
          "default": false
        },
        {
          "name": "closeOnOutsideClick",
          "type": "boolean",
          "description": "Close/skip the tour when the user clicks outside the panel.",
          "default": false
        },
        {
          "name": "placement",
          "type": "WalkthroughPlacement",
          "description": "Preferred placement of the walkthrough panel relative to its anchor.",
          "default": "auto"
        }
      ]
    }
  },
  "channels": {
    "step": {
      "description": "Active step index.",
      "value": "index",
      "defaultValue": "defaultIndex",
      "onChange": "onStepChange",
      "valueType": "number"
    }
  },
  "types": {
    "WalkthroughPlacement": {
      "kind": "union",
      "values": [
        "top",
        "bottom",
        "left",
        "right",
        "auto"
      ]
    },
    "WalkthroughStepSpec": {
      "kind": "alias",
      "alias": "{ anchor: string; title: string; description?: string }"
    }
  },
  "variants": {
    "placement": [
      "top",
      "bottom",
      "left",
      "right",
      "auto"
    ]
  },
  "states": {
    "dimensions": {
      "pointer": {
        "category": "interaction",
        "values": [
          "default",
          "hover"
        ],
        "initial": "default",
        "exclusive": true
      },
      "availability": {
        "category": "availability",
        "effect": "restyle",
        "values": [
          "enabled",
          "disabled"
        ],
        "initial": "enabled",
        "exclusive": true,
        "suppresses": {
          "categories": [
            "interaction"
          ]
        }
      }
    }
  },
  "motion": {
    "reducedMotion": "respect",
    "transitions": [
      {
        "name": "open",
        "trigger": "openness=hidden→visible",
        "phase": "enter",
        "properties": [
          "opacity",
          "transform"
        ],
        "duration": "core.motion.duration.short",
        "easing": "core.motion.easing.emphasized-in"
      },
      {
        "name": "close",
        "trigger": "openness=visible→hidden",
        "phase": "exit",
        "properties": [
          "opacity"
        ],
        "duration": "core.motion.duration.short",
        "easing": "core.motion.easing.emphasized-out"
      }
    ]
  },
  "focus": {
    "strategy": "none",
    "description": "Walkthrough panels are non-blocking. Focus remains on the anchored element while the panel is visible."
  },
  "dismissal": {
    "triggers": [
      {
        "event": "escape"
      },
      {
        "event": "outsideClick",
        "enabledBy": "closeOnOutsideClick"
      }
    ]
  },
  "slots": {
    "root": {
      "required": true,
      "selector": "[data-slot=\"walkthrough\"]"
    },
    "title": {
      "required": false,
      "selector": "[data-slot=\"walkthrough-title\"]"
    },
    "description": {
      "required": false,
      "selector": "[data-slot=\"walkthrough-description\"]"
    },
    "controls": {
      "required": false,
      "selector": "[data-slot=\"walkthrough-controls\"]"
    },
    "skip": {
      "required": false,
      "selector": "[data-slot=\"walkthrough-skip\"]"
    },
    "prev": {
      "required": false,
      "selector": "[data-slot=\"walkthrough-prev\"]"
    },
    "next": {
      "required": false,
      "selector": "[data-slot=\"walkthrough-next\"]"
    },
    "progress": {
      "required": false,
      "selector": "[data-slot=\"walkthrough-progress\"]"
    },
    "dot": {
      "required": false,
      "selector": "[data-slot=\"walkthrough-dot\"]"
    },
    "counter": {
      "required": false,
      "selector": "[data-slot=\"walkthrough-counter\"]"
    }
  },
  "ssr": {
    "hydrateOn": "interaction"
  },
  "rtl": {
    "flipIcon": false
  },
  "relationships": [
    {
      "from": "content",
      "to": "title",
      "attribute": "aria-labelledby",
      "description": "Walkthrough content region takes its accessible name from its title element."
    },
    {
      "from": "content",
      "to": "description",
      "attribute": "aria-describedby",
      "description": "Walkthrough content region is described by its description element."
    }
  ],
  "a11y": {
    "role": "status",
    "apgPattern": "status",
    "labeling": [
      "aria-label"
    ],
    "keyboard": [
      {
        "key": "ArrowRight",
        "action": "Advance to the next step.",
        "when": "active"
      },
      {
        "key": "ArrowLeft",
        "action": "Go to the previous step.",
        "when": "active"
      },
      {
        "key": "Escape",
        "action": "Close/skip the walkthrough tour.",
        "when": "active"
      },
      {
        "key": "Enter|Space",
        "action": "Activate the focused control (skip, prev, next, or dot).",
        "when": "active"
      }
    ]
  },
  "a2ui": {
    "category": "overlay",
    "usageHints": [
      "Define each step as a WalkthroughStep with an anchor ref and content",
      "WalkthroughAnchor wraps the element each step points to",
      "Use WalkthroughControls and WalkthroughProgress for navigation UI",
      "Keyboard: ArrowRight/ArrowLeft navigate steps; Escape closes the tour",
      "The walkthrough is non-blocking — it does not trap focus to the panel"
    ],
    "children": {
      "allowed": true,
      "slot": "children",
      "accepts": [
        "WalkthroughStep",
        "WalkthroughAnchor"
      ]
    }
  }
}
