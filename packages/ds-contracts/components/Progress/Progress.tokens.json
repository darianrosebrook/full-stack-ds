{
  "box-model.padding-block-start": {
    "resolvesTo": "semantic.feedback.size.padding-block",
    "fallback": "16px",
    "layer": "semantic"
  },
  "box-model.padding-block-end": {
    "resolvesTo": "semantic.feedback.size.padding-block",
    "fallback": "16px",
    "layer": "semantic"
  },
  "box-model.padding-inline-start": {
    "resolvesTo": "semantic.feedback.size.padding-inline",
    "fallback": "16px",
    "layer": "semantic"
  },
  "box-model.padding-inline-end": {
    "resolvesTo": "semantic.feedback.size.padding-inline",
    "fallback": "16px",
    "layer": "semantic"
  },
  "box-model.gap": {
    "resolvesTo": "semantic.feedback.size.gap",
    "fallback": "12px",
    "layer": "semantic"
  },
  "progress.color.text.default": {
    "resolvesTo": "semantic.color.foreground.secondary",
    "fallback": "#555555",
    "layer": "semantic"
  },
  "progress.spacing.gap": {
    "resolvesTo": "core.spacing.size.02",
    "fallback": "2px",
    "layer": "core"
  },
  "progress.motion.duration.indeterminate": {
    "resolvesTo": "core.motion.duration.extra.long1",
    "fallback": "1500ms",
    "layer": "core"
  },
  "progress.color.track.background": {
    "resolvesTo": "semantic.color.background.secondary",
    "fallback": "#efefef",
    "layer": "semantic"
  },
  "progress.color.fill.info": {
    "resolvesTo": "semantic.color.status.info",
    "fallback": "#0a65fe",
    "layer": "semantic"
  }
}
