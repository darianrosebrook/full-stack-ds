{
  "progress.color.text.default": {
    "resolvesTo": "semantic.color.foreground.secondary",
    "fallback": "#555555",
    "layer": "semantic"
  },
  "progress.spacing.gap": {
    "resolvesTo": "core.spacing.size.02",
    "fallback": "2px",
    "layer": "core"
  },
  "progress.motion.duration.indeterminate": {
    "resolvesTo": "core.motion.duration.extra.long1",
    "fallback": "1500ms",
    "layer": "core"
  },
  "progress.color.track.background": {
    "resolvesTo": "semantic.color.background.secondary",
    "fallback": "#efefef",
    "layer": "semantic"
  },
  "progress.color.fill.info": {
    "resolvesTo": "semantic.color.status.info",
    "fallback": "#0a65fe",
    "layer": "semantic"
  },
  "progress.color.fill.success": {
    "resolvesTo": "semantic.color.status.success",
    "fallback": "#487e1e",
    "layer": "semantic"
  },
  "progress.color.fill.warning": {
    "resolvesTo": "semantic.color.status.warning",
    "fallback": "#ac5c00",
    "layer": "semantic"
  },
  "progress.color.fill.danger": {
    "resolvesTo": "semantic.color.status.danger",
    "fallback": "#d9292b",
    "layer": "semantic"
  }
}
