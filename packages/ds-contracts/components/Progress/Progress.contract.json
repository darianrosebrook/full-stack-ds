{
  "$schema": "../../component.contract.schema.json",
  "name": "Progress",
  "description": "Visual indicator for task completion. Supports linear bar and circular ring variants.",
  "layer": "primitive",
  "anatomy": {
    "parts": [
      "root",
      "track",
      "fill",
      "value"
    ],
    "dom": {
      "tag": "div",
      "part": "root",
      "attrs": {
        "role": "progressbar"
      },
      "bindings": {
        "aria-valuenow": "prop:value",
        "aria-valuemin": "literal:0",
        "aria-valuemax": "literal:100",
        "aria-label": "prop:label"
      },
      "children": [
        {
          "tag": "span",
          "part": "track",
          "attrs": {
            "aria-hidden": "true"
          },
          "children": [
            {
              "tag": "span",
              "part": "fill"
            }
          ]
        },
        {
          "tag": "span",
          "part": "value",
          "if": "showValue",
          "children": [
            {
              "tag": "children"
            }
          ]
        }
      ]
    }
  },
  "props": {
    "styled": {
      "description": "Props for the <Progress> component.",
      "members": [
        {
          "name": "value",
          "type": "number",
          "description": "Progress value (0-100). Omit for indeterminate progress."
        },
        {
          "name": "variant",
          "type": "ProgressVariant",
          "description": "Progress variant."
        },
        {
          "name": "size",
          "type": "ProgressSize",
          "description": "Size token."
        },
        {
          "name": "intent",
          "type": "ProgressIntent",
          "description": "Visual intent / color."
        },
        {
          "name": "label",
          "type": "string",
          "description": "Accessible label."
        },
        {
          "name": "showValue",
          "type": "boolean",
          "description": "Show the percentage label inside the component."
        },
        {
          "name": "formatValue",
          "type": "(value: number, max: number) => string",
          "description": "Custom value formatter."
        }
      ]
    }
  },
  "types": {
    "ProgressVariant": {
      "kind": "union",
      "values": [
        "linear",
        "circular"
      ]
    },
    "ProgressSize": {
      "kind": "union",
      "values": [
        "sm",
        "md",
        "lg"
      ]
    },
    "ProgressIntent": {
      "kind": "union",
      "values": [
        "info",
        "success",
        "warning",
        "danger"
      ]
    }
  },
  "variants": {
    "variant": [
      "linear",
      "circular"
    ],
    "size": [
      "sm",
      "md",
      "lg"
    ],
    "intent": [
      "info",
      "success",
      "warning",
      "danger"
    ]
  },
  "states": [
    "default"
  ],
  "slots": {
    "root": {
      "required": true,
      "selector": "[data-slot=\"progress\"]"
    },
    "track": {
      "required": false,
      "selector": "[data-slot=\"progress-track\"]"
    },
    "fill": {
      "required": false,
      "selector": "[data-slot=\"progress-fill\"]"
    },
    "value": {
      "required": false,
      "selector": "[data-slot=\"progress-value\"]"
    }
  },
  "ssr": {
    "hydrateOn": "interaction"
  },
  "rtl": {
    "flipIcon": false
  },
  "a11y": {
    "role": "progressbar",
    "labeling": [
      "aria-label",
      "aria-valuenow",
      "aria-valuemin",
      "aria-valuemax"
    ],
    "keyboard": []
  },
  "a2ui": {
    "category": "display",
    "usageHints": [
      "Use variant=linear for step-by-step progress; variant=circular for compact space-constrained contexts",
      "Set value (0\u2013100) for determinate progress; omit for indeterminate animation",
      "Set showValue to display the percentage label inside the component",
      "Always provide aria-label when the progress bar has no adjacent visible label"
    ],
    "children": {
      "allowed": false
    }
  }
}
