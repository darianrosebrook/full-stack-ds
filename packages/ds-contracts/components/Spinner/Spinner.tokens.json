{
  "spinner.size.xs": {
    "resolvesTo": "semantic.glyph.size.small.extent",
    "fallback": "12px",
    "layer": "semantic"
  },
  "spinner.size.sm": {
    "resolvesTo": "core.icon.size.sm",
    "fallback": "16px",
    "layer": "core"
  },
  "spinner.size.md": {
    "resolvesTo": "core.icon.size.md",
    "fallback": "20px",
    "layer": "core"
  },
  "spinner.size.lg": {
    "resolvesTo": "core.icon.size.lg",
    "fallback": "24px",
    "layer": "core"
  },
  "spinner.thickness.hairline": {
    "literal": "2px"
  },
  "spinner.thickness.regular": {
    "literal": "3px"
  },
  "spinner.thickness.bold": {
    "literal": "4px"
  },
  "spinner.color.accent": {
    "resolvesTo": "semantic.color.background.accent",
    "fallback": "#d9292b",
    "layer": "semantic"
  },
  "spinner.color.track": {
    "resolvesTo": "semantic.color.border.subtle",
    "fallback": "#cecece",
    "layer": "semantic"
  },
  "spinner.anim.duration": {
    "literal": "800ms"
  }
}
