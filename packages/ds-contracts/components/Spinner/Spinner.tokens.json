{
  "root": {
    "spinner.size.xs": {
      "literal": "12px"
    },
    "spinner.size.sm": {
      "literal": "16px"
    },
    "spinner.size.md": {
      "literal": "20px"
    },
    "spinner.size.lg": {
      "literal": "28px"
    },
    "spinner.thickness.hairline": {
      "literal": "2px"
    },
    "spinner.thickness.regular": {
      "literal": "3px"
    },
    "spinner.thickness.bold": {
      "literal": "4px"
    },
    "spinner.color.accent": {
      "resolvesTo": "semantic.color.background.accent",
      "fallback": "#d9292b",
      "layer": "semantic"
    },
    "spinner.color.track": {
      "resolvesTo": "semantic.color.border.subtle",
      "fallback": "#cecece",
      "layer": "semantic"
    },
    "spinner.dots.gap": {
      "resolvesTo": "core.spacing.size.04",
      "fallback": "8px",
      "property": "gap",
      "layer": "core"
    },
    "spinner.anim.duration": {
      "literal": "800ms",
      "property": "transition-duration"
    }
  }
}
