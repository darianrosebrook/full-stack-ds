{
  "box-model.padding-block-start": {
    "resolvesTo": "semantic.feedback.size.padding-block",
    "fallback": "16px",
    "layer": "semantic"
  },
  "box-model.padding-block-end": {
    "resolvesTo": "semantic.feedback.size.padding-block",
    "fallback": "16px",
    "layer": "semantic"
  },
  "box-model.padding-inline-start": {
    "resolvesTo": "semantic.feedback.size.padding-inline",
    "fallback": "16px",
    "layer": "semantic"
  },
  "box-model.padding-inline-end": {
    "resolvesTo": "semantic.feedback.size.padding-inline",
    "fallback": "16px",
    "layer": "semantic"
  },
  "box-model.gap": {
    "resolvesTo": "semantic.feedback.size.gap",
    "fallback": "12px",
    "layer": "semantic"
  },
  "spinner.size.xs": {
    "literal": "12px"
  },
  "spinner.size.sm": {
    "literal": "16px"
  },
  "spinner.size.md": {
    "literal": "20px"
  },
  "spinner.size.lg": {
    "literal": "28px"
  },
  "spinner.thickness.hairline": {
    "literal": "2px"
  },
  "spinner.thickness.regular": {
    "literal": "3px"
  },
  "spinner.thickness.bold": {
    "literal": "4px"
  },
  "spinner.color.accent": {
    "resolvesTo": "semantic.color.background.accent",
    "fallback": "#d9292b",
    "layer": "semantic"
  },
  "spinner.color.track": {
    "resolvesTo": "semantic.color.border.subtle",
    "fallback": "#cecece",
    "layer": "semantic"
  },
  "spinner.dots.gap": {
    "resolvesTo": "core.spacing.size.04",
    "fallback": "8px",
    "layer": "core"
  },
  "spinner.anim.duration": {
    "literal": "800ms"
  }
}
