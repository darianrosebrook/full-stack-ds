{
  "$schema": "../../component.contract.schema.json",
  "name": "Spinner",
  "description": "Rotating indicator for indeterminate loading states.",
  "layer": "primitive",
  "anatomy": {
    "parts": [
      "root",
      "visual"
    ],
    "dom": {
      "tag": "div",
      "part": "root",
      "children": [
        {
          "tag": "span",
          "part": "visual",
          "attrs": {
            "aria-hidden": "true"
          }
        }
      ]
    }
  },
  "props": {
    "styled": {
      "description": "Props for the <Spinner> component.",
      "members": [
        {
          "name": "size",
          "type": "SpinnerSize",
          "description": "Visual size token"
        },
        {
          "name": "variant",
          "type": "SpinnerVariant",
          "description": "Visual variant: ring, dots, or bars"
        },
        {
          "name": "thickness",
          "type": "SpinnerThickness",
          "description": "Stroke thickness token"
        },
        {
          "name": "ariaHidden",
          "type": "boolean",
          "description": "If decorative only, set ariaHidden; else provide label"
        },
        {
          "name": "label",
          "type": "string",
          "description": "Localized label for screen reader users; ignored if ariaHidden"
        },
        {
          "name": "inline",
          "type": "boolean",
          "description": "Inline layout (align with baseline)"
        },
        {
          "name": "showAfterMs",
          "type": "number",
          "description": "Delay before showing (ms) to avoid spinner flash"
        }
      ]
    }
  },
  "types": {
    "SpinnerSize": {
      "kind": "union",
      "values": [
        "xs",
        "sm",
        "md",
        "lg"
      ]
    },
    "SpinnerVariant": {
      "kind": "union",
      "values": [
        "ring",
        "dots",
        "bars"
      ]
    },
    "SpinnerThickness": {
      "kind": "union",
      "values": [
        "hairline",
        "regular",
        "bold"
      ]
    }
  },
  "variants": {
    "size": [
      "xs",
      "sm",
      "md",
      "lg"
    ],
    "variant": [
      "ring",
      "dots",
      "bars"
    ],
    "thickness": [
      "hairline",
      "regular",
      "bold"
    ]
  },
  "states": [
    "default"
  ],
  "slots": {
    "root": {
      "required": true,
      "selector": "[data-slot=\"spinner\"]"
    },
    "visual": {
      "required": true,
      "selector": "[data-slot=\"spinner-visual\"]"
    }
  },
  "ssr": {
    "hydrateOn": "interaction"
  },
  "rtl": {
    "flipIcon": false
  },
  "a11y": {
    "role": "status",
    "labeling": [
      "aria-label"
    ],
    "keyboard": []
  },
  "a2ui": {
    "category": "display",
    "usageHints": [
      "Add aria-label when the spinner is the only loading indicator visible",
      "Use size to match the spinner to its surrounding context",
      "Use thickness to adjust visual weight (hairline for subtle, bold for prominent)",
      "Prefer Skeleton for content areas; use Spinner for button or icon loading states"
    ],
    "children": {
      "allowed": false
    }
  }
}
