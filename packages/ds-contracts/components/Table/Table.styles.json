{
  "root": {
    "color": {
      "resolvesTo": "table.color.text"
    },
    "font-size": {
      "resolvesTo": "table.text.size"
    },
    "line-height": {
      "resolvesTo": "table.text.lineHeight"
    },
    "width": { "literal": "100%", "platforms": ["web"] },
    "overflow-x": { "literal": "auto", "platforms": ["web"] }
  },
  "container": {
    "border-collapse": { "literal": "collapse", "platforms": ["web"] },
    "border-color": {
      "resolvesTo": "table.color.border"
    },
    "border-width": {
      "resolvesTo": "table.border.width"
    },
    "border-radius": {
      "resolvesTo": "table.size.radius"
    },
    "width": { "literal": "100%", "platforms": ["web"] }
  },
  "caption": {
    "font-size": {
      "resolvesTo": "table.text.sizeCaption"
    },
    "text-align": { "literal": "start", "platforms": ["web"] },
    "padding-bottom": {
      "resolvesTo": "table.spacing.caption"
    }
  },
  "head": {
    "background-color": {
      "resolvesTo": "table.color.background.footer"
    }
  },
  "footer": {
    "background-color": {
      "resolvesTo": "table.color.background.footer"
    },
    "font-weight": {
      "resolvesTo": "table.text.weightFooter"
    }
  },
  "headerCell": {
    "font-weight": {
      "resolvesTo": "table.text.weightHead"
    },
    "color": {
      "resolvesTo": "table.color.text"
    },
    "padding-left": {
      "resolvesTo": "table.spacing.cellX"
    },
    "padding-right": {
      "resolvesTo": "table.spacing.cellX"
    },
    "padding-top": {
      "resolvesTo": "table.spacing.cellY"
    },
    "padding-bottom": {
      "resolvesTo": "table.spacing.cellY"
    },
    "border-bottom-width": {
      "resolvesTo": "table.border.width"
    },
    "border-bottom-color": {
      "resolvesTo": "table.color.border"
    },
    "border-bottom-style": { "literal": "solid", "platforms": ["web"] },
    "text-align": { "literal": "start", "platforms": ["web"] }
  },
  "cell": {
    "padding-left": {
      "resolvesTo": "table.spacing.cellX"
    },
    "padding-right": {
      "resolvesTo": "table.spacing.cellX"
    },
    "padding-top": {
      "resolvesTo": "table.spacing.cellY"
    },
    "padding-bottom": {
      "resolvesTo": "table.spacing.cellY"
    },
    "border-bottom-width": {
      "resolvesTo": "table.border.width"
    },
    "border-bottom-color": {
      "resolvesTo": "table.color.border"
    },
    "border-bottom-style": { "literal": "solid", "platforms": ["web"] }
  },
  "hover": {
    "background-color": {
      "resolvesTo": "table.color.background.hover"
    }
  },
  "selected": {
    "background-color": {
      "resolvesTo": "table.color.background.selected"
    }
  }
}
