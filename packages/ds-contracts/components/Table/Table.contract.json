{
  "$schema": "../../component.contract.schema.json",
  "name": "Table",
  "description": "Data table with sortable columns, row selection, and pagination support.",
  "layer": "compound",
  "category": "structure",
  "anatomy": {
    "parts": [
      "root",
      "container",
      "caption",
      "head",
      "body",
      "footer",
      "row",
      "headerCell",
      "cell"
    ],
    "details": {
      "root": {
        "tag": "div",
        "description": "Responsive wrapper around the table element."
      },
      "container": {
        "tag": "table",
        "description": "The native <table> element; carries the table's accessible label."
      },
      "caption": {
        "tag": "caption",
        "description": "Accessible caption rendered above the table body."
      },
      "head": {
        "tag": "thead",
        "description": "Group of header rows."
      },
      "body": {
        "tag": "tbody",
        "description": "Group of data rows."
      },
      "footer": {
        "tag": "tfoot",
        "description": "Group of footer/summary rows."
      },
      "row": {
        "tag": "tr",
        "multiple": true,
        "description": "Table row."
      },
      "headerCell": {
        "tag": "th",
        "multiple": true,
        "description": "Column or row header cell. scope is consumer-controlled; default header semantics infer from <thead>."
      },
      "cell": {
        "tag": "td",
        "multiple": true,
        "description": "Data cell."
      }
    },
    "dom": {
      "tag": "div",
      "part": "root",
      "children": [
        {
          "tag": "table",
          "part": "container",
          "bindings": {
            "aria-label": "prop:ariaLabel"
          },
          "children": [
            {
              "tag": "children"
            }
          ]
        }
      ]
    }
  },
  "props": {
    "styled": {
      "description": "Props for the <Table> component.",
      "members": [
        {
          "name": "responsive",
          "type": "boolean",
          "description": "Enable responsive horizontal scrolling"
        },
        {
          "name": "ariaLabel",
          "type": "string",
          "description": "Accessible label for the table"
        }
      ]
    }
  },
  "variants": {},
  "states": [
    "default",
    "hover",
    "focus",
    "selected"
  ],
  "focus": {
    "strategy": "none",
    "description": "The table itself does not manage focus. Individual interactive cells (sortable headers, checkboxes) are reachable via standard tab order."
  },
  "portal": {
    "enabled": false
  },
  "slots": {
    "body": {
      "required": false,
      "selector": "[data-slot=\"table-body\"]"
    },
    "caption": {
      "required": false,
      "selector": "[data-slot=\"table-caption\"]"
    },
    "cell": {
      "required": false,
      "selector": "[data-slot=\"table-cell\"]"
    },
    "container": {
      "required": false,
      "selector": "[data-slot=\"table-container\"]"
    },
    "element": {
      "required": false
    },
    "footer": {
      "required": false,
      "selector": "[data-slot=\"table-footer\"]"
    },
    "head": {
      "required": false,
      "selector": "[data-slot=\"table-head\"]"
    },
    "headerCell": {
      "required": false,
      "selector": "[data-slot=\"table-header-cell\"]"
    },
    "root": {
      "required": true,
      "selector": "[data-slot=\"table\"]"
    },
    "row": {
      "required": false,
      "selector": "[data-slot=\"table-row\"]"
    }
  },
  "ssr": {
    "hydrateOn": "interaction"
  },
  "rtl": {
    "flipIcon": false
  },
  "relationships": [
    {
      "from": "container",
      "to": "caption",
      "attribute": "aria-labelledby",
      "description": "When a caption is present, the table's accessible name is composed from the caption text by the user agent. Authors who supply ariaLabel override caption-derived naming."
    },
    {
      "from": "headerCell",
      "to": "cell",
      "attribute": "aria-sort",
      "description": "Sorted column's <th> carries aria-sort; associated <td> cells are in the same column. Cell-to-header association is derived from native <thead>/<tbody> structure, not authored explicitly."
    }
  ],
  "a11y": {
    "labeling": [
      "aria-sort",
      "aria-label",
      "aria-labelledby"
    ],
    "keyboard": [
      {
        "key": "Tab",
        "action": "Move focus between interactive column headers and rows"
      },
      {
        "key": "Space|Enter",
        "action": "Activate sort on focused column header"
      },
      {
        "key": "ArrowUp|ArrowDown",
        "action": "Navigate between rows",
        "when": "interactive row is focused"
      }
    ]
  },
  "a2ui": {
    "category": "display",
    "usageHints": [
      "Use for structured data that benefits from sorting or comparison across rows",
      "Enable row selection for bulk actions; pair with a toolbar for the action bar",
      "Keep column count to 6–8 max; use column visibility controls for wider datasets"
    ],
    "children": {
      "allowed": true,
      "slot": "children",
      "accepts": [
        "node-ref"
      ]
    }
  }
}
