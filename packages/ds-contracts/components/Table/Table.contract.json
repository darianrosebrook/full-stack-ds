{
  "$schema": "../../component.contract.schema.json",
  "name": "Table",
  "description": "Data table with sortable columns, row selection, and pagination support.",
  "layer": "compound",
  "anatomy": {
    "parts": [
      "root",
      "container",
      "caption",
      "head",
      "body",
      "footer",
      "row",
      "header",
      "cell"
    ]
  },
  "props": {
    "styled": {
      "description": "Props for the <Table> component.",
      "members": [
        {
          "name": "responsive",
          "type": "boolean",
          "description": "Enable responsive horizontal scrolling"
        },
        {
          "name": "ariaLabel",
          "type": "string",
          "description": "Accessible label for the table"
        }
      ]
    }
  },
  "variants": {},
  "states": [
    "default",
    "hover",
    "focus",
    "selected"
  ],
  "focus": {
    "strategy": "none",
    "description": "The table itself does not manage focus. Individual interactive cells (sortable headers, checkboxes) are reachable via standard tab order."
  },
  "portal": {
    "enabled": false
  },
  "slots": {
    "body": {
      "required": false,
      "selector": "[data-slot=\"table-body\"]"
    },
    "caption": {
      "required": false,
      "selector": "[data-slot=\"table-caption\"]"
    },
    "cell": {
      "required": false,
      "selector": "[data-slot=\"table-cell\"]"
    },
    "container": {
      "required": false,
      "selector": "[data-slot=\"table-container\"]"
    },
    "element": {
      "required": false
    },
    "footer": {
      "required": false,
      "selector": "[data-slot=\"table-footer\"]"
    },
    "head": {
      "required": false,
      "selector": "[data-slot=\"table-head\"]"
    },
    "header": {
      "required": false,
      "selector": "[data-slot=\"table-header\"]"
    },
    "root": {
      "required": true,
      "selector": "[data-slot=\"table\"]"
    },
    "row": {
      "required": false,
      "selector": "[data-slot=\"table-row\"]"
    }
  },
  "ssr": {
    "hydrateOn": "interaction"
  },
  "rtl": {
    "flipIcon": false
  },
  "relationships": [
    {
      "from": "root",
      "to": "head",
      "attribute": "aria-labelledby",
      "description": "If a caption or external label is used, root references it via aria-labelledby."
    },
    {
      "from": "header",
      "to": "cell",
      "attribute": "aria-sort",
      "description": "Sorted column's header carries aria-sort; associated cells are in the same column. (Table anatomy uses `header` as the column-header role; row-header semantics are inferred from scope.)"
    }
  ],
  "a11y": {
    "labeling": [
      "aria-sort",
      "aria-label",
      "aria-labelledby"
    ],
    "keyboard": [
      {
        "key": "Tab",
        "action": "Move focus between interactive column headers and rows"
      },
      {
        "key": "Space|Enter",
        "action": "Activate sort on focused column header"
      },
      {
        "key": "ArrowUp|ArrowDown",
        "action": "Navigate between rows",
        "when": "interactive row is focused"
      }
    ]
  },
  "a2ui": {
    "category": "display",
    "usageHints": [
      "Use for structured data that benefits from sorting or comparison across rows",
      "Enable row selection for bulk actions; pair with a toolbar for the action bar",
      "Keep column count to 6\u20138 max; use column visibility controls for wider datasets"
    ],
    "children": {
      "allowed": false
    }
  }
}
