{
  "$schema": "../../component.contract.schema.json",
  "name": "Select",
  "description": "Dropdown selector with optional search, single or multi-select, and keyboard navigation. Renders a floating listbox anchored to the trigger.",
  "layer": "composer",
  "category": "input",
  "anatomy": {
    "parts": [
      "root",
      "trigger",
      "text",
      "content",
      "search",
      "options",
      "option",
      "emptyState"
    ],
    "details": {
      "root": {
        "tag": "div",
        "description": "Combobox host that coordinates trigger state, selected value, and listbox visibility.",
        "role": "root",
        "aria": {
          "role": "combobox",
          "attributes": [
            "aria-haspopup",
            "aria-controls",
            "aria-expanded",
            "aria-disabled"
          ]
        }
      },
      "trigger": {
        "tag": "button",
        "description": "Button control that opens or closes the select listbox.",
        "role": "trigger",
        "interactive": true,
        "focusable": true
      },
      "text": {
        "tag": "span",
        "description": "Visible selected-option text or placeholder inside the trigger.",
        "role": "label"
      },
      "content": {
        "tag": "div",
        "description": "Floating listbox surface rendered while the select is open.",
        "role": "content",
        "aria": {
          "role": "listbox"
        }
      },
      "search": {
        "tag": "div",
        "description": "Optional search field wrapper for filtering available options.",
        "role": "group",
        "interactive": true,
        "focusable": true
      },
      "options": {
        "tag": "div",
        "description": "Container for the rendered option set.",
        "role": "group"
      },
      "option": {
        "tag": "div",
        "description": "Selectable option row bound to an option value.",
        "role": "item",
        "multiple": true,
        "interactive": true,
        "focusable": "roving",
        "aria": {
          "role": "option",
          "attributes": [
            "aria-selected"
          ]
        }
      },
      "emptyState": {
        "tag": "div",
        "description": "Message region shown when no options are available.",
        "role": "content"
      }
    },
    "dom": {
      "tag": "div",
      "part": "root",
      "attrs": {
        "role": "combobox",
        "aria-haspopup": "listbox",
        "aria-controls": "fsds-select-listbox"
      },
      "bindings": {
        "aria-expanded": "channel:open.value",
        "aria-disabled": "prop:disabled"
      },
      "children": [
        {
          "tag": "button",
          "part": "trigger",
          "attrs": {
            "type": "button"
          },
          "bindings": {
            "disabled": "prop:disabled"
          },
          "events": {
            "click": "channel:open.onChange"
          },
          "children": [
            {
              "tag": "span",
              "part": "text"
            }
          ]
        },
        {
          "tag": "div",
          "part": "content",
          "if": "open",
          "attrs": {
            "role": "listbox",
            "id": "fsds-select-listbox"
          },
          "children": [
            {
              "tag": "div",
              "part": "search",
              "if": "searchable",
              "children": [
                {
                  "tag": "input",
                  "attrs": {
                    "type": "text"
                  }
                }
              ]
            },
            {
              "tag": "div",
              "part": "options",
              "children": [
                {
                  "tag": "div",
                  "part": "option",
                  "iterate": {
                    "source": "prop:options",
                    "kind": "array",
                    "itemType": "SelectOption"
                  },
                  "attrs": {
                    "role": "option"
                  },
                  "bindings": {
                    "aria-selected": "predicate:memberOf(iter:item.value, channel:selection.value)",
                    "data-value": "iter:item.value"
                  },
                  "children": [
                    { "tag": "span", "content": "iter:item.label" }
                  ]
                }
              ]
            },
            {
              "tag": "div",
              "part": "emptyState",
              "if": "empty"
            }
          ]
        }
      ]
    }
  },
  "props": {
    "designed": {
      "members": [
        {
          "name": "options",
          "propType": { "kind": "array", "items": { "kind": "ref", "to": "SelectOption" } },
          "description": "Available options.",
          "required": true,
          "default": [
            { "value": "alpha", "label": "Alpha" },
            { "value": "beta", "label": "Beta" },
            { "value": "gamma", "label": "Gamma" }
          ]
        },
        {
          "name": "value",
          "propType": { "kind": "union", "of": [{ "kind": "string" }, { "kind": "array", "items": { "kind": "string" } }] },
          "description": "Controlled selected value(s)."
        },
        {
          "name": "defaultValue",
          "propType": { "kind": "union", "of": [{ "kind": "string" }, { "kind": "array", "items": { "kind": "string" } }] },
          "description": "Default selected value(s) for uncontrolled usage.",
          "default": "beta"
        },
        {
          "name": "onChange",
          "propType": {
            "kind": "callback",
            "params": [{ "name": "value", "type": { "kind": "union", "of": [{ "kind": "string" }, { "kind": "array", "items": { "kind": "string" } }] } }],
            "returns": { "kind": "void" }
          },
          "description": "Called when selection changes."
        },
        {
          "name": "open",
          "propType": { "kind": "boolean" },
          "description": "Controlled open state."
        },
        {
          "name": "defaultOpen",
          "propType": { "kind": "boolean" },
          "description": "Default open state for uncontrolled usage.",
          "default": true
        },
        {
          "name": "onOpenChange",
          "propType": {
            "kind": "callback",
            "params": [{ "name": "open", "type": { "kind": "boolean" } }],
            "returns": { "kind": "void" }
          },
          "description": "Called when open state changes."
        },
        {
          "name": "multiple",
          "propType": { "kind": "boolean" },
          "description": "Allow multiple selections."
        },
        {
          "name": "disabled",
          "propType": { "kind": "boolean" },
          "description": "Disabled state."
        },
        {
          "name": "size",
          "propType": { "kind": "ref", "to": "SelectSize" },
          "description": "Size variant.",
          "default": "md"
        },
        {
          "name": "filterFn",
          "type": "((option: SelectOption, searchTerm: string) => boolean)",
          "description": "Custom filter function for search."
        },
        {
          "name": "searchable",
          "propType": { "kind": "boolean" },
          "description": "Whether to render the search input inside the dropdown."
        },
        {
          "name": "empty",
          "propType": { "kind": "boolean" },
          "description": "Whether the option list is empty (drives the empty-state slot)."
        }
      ]
    }
  },
  "channels": {
    "selection": {
      "value": "value",
      "defaultValue": "defaultValue",
      "onChange": "onChange",
      "valueType": "string | string[]",
      "description": "Currently selected value(s)."
    },
    "open": {
      "value": "open",
      "defaultValue": "defaultOpen",
      "onChange": "onOpenChange",
      "valueType": "boolean",
      "description": "Whether the dropdown is open."
    }
  },
  "types": {
    "SelectSize": {
      "kind": "union",
      "values": [
        "sm",
        "md",
        "lg"
      ]
    },
    "SelectOption": {
      "kind": "alias",
      "alias": "{ value: string; label: string; disabled?: boolean }"
    }
  },
  "variants": {
    "size": [
      "sm",
      "md",
      "lg"
    ],
    "position": [
      "bottom",
      "top",
      "auto"
    ]
  },
  "states": {
    "dimensions": {
      "pointer": {
        "category": "interaction",
        "values": [
          "default",
          "hover",
          "active"
        ],
        "initial": "default",
        "exclusive": true
      },
      "focus": {
        "category": "interaction",
        "values": [
          "unfocused",
          "focus"
        ],
        "initial": "unfocused",
        "exclusive": true
      },
      "availability": {
        "category": "availability",
        "effect": "restyle",
        "values": [
          "enabled",
          "disabled"
        ],
        "initial": "enabled",
        "exclusive": true,
        "suppresses": {
          "categories": [
            "interaction"
          ]
        }
      },
      "selection": {
        "category": "selection",
        "effect": "restyle",
        "values": [
          "unselected",
          "selected"
        ],
        "initial": "unselected",
        "exclusive": true,
        "a11y": {
          "attribute": "aria-selected",
          "values": {
            "unselected": "false",
            "selected": "true"
          }
        }
      },
      "disclosure": {
        "category": "visibility",
        "effect": "channel",
        "values": [
          "closed",
          "open"
        ],
        "initial": "closed",
        "exclusive": true,
        "a11y": {
          "attribute": "aria-expanded",
          "values": {
            "closed": "false",
            "open": "true"
          }
        }
      }
    }
  },
  "motion": {
    "reducedMotion": "respect",
    "transitions": [
      {
        "name": "open",
        "trigger": "openness=closed→open",
        "phase": "enter",
        "properties": [
          "opacity",
          "transform"
        ],
        "duration": "core.motion.duration.short",
        "easing": "core.motion.easing.emphasizedDecelerate"
      },
      {
        "name": "close",
        "trigger": "openness=open→closed",
        "phase": "exit",
        "properties": [
          "opacity",
          "transform"
        ],
        "duration": "core.motion.duration.short",
        "easing": "core.motion.easing.emphasizedAccelerate"
      }
    ]
  },
  "focus": {
    "strategy": "roving",
    "orientation": "vertical",
    "initialFocus": "search",
    "returnFocus": "trigger",
    "wrap": true
  },
  "portal": {
    "enabled": true,
    "defaultTarget": "body",
    "positioning": "anchored",
    "layering": "popover",
    "collision": "flip-shift"
  },
  "dismissal": {
    "triggers": [
      {
        "event": "escape",
        "defaultEnabled": true
      },
      {
        "event": "outsideClick",
        "defaultEnabled": true
      },
      {
        "event": "selection",
        "defaultEnabled": true,
        "description": "After a single-select choice is made, the listbox closes automatically."
      }
    ]
  },
  "slots": {
    "content": {
      "required": false
    },
    "options": {
      "required": false
    },
    "search": {
      "required": false
    },
    "trigger": {
      "required": false
    },
    "root": {
      "required": true,
      "selector": "[data-slot=\"select\"]"
    },
    "option": {
      "required": true,
      "selector": "[data-slot=\"select-option\"]"
    }
  },
  "ssr": {
    "hydrateOn": "interaction"
  },
  "rtl": {
    "flipIcon": false
  },
  "relationships": [
    {
      "from": "trigger",
      "to": "options",
      "attribute": "aria-controls",
      "description": "Trigger controls the options listbox via aria-controls (Select's listbox role lives on the `options` anatomy part)."
    },
    {
      "from": "trigger",
      "to": "options",
      "attribute": "aria-expanded",
      "description": "Trigger reflects whether the options listbox is currently expanded."
    }
  ],
  "a11y": {
    "role": "combobox",
    "apgPattern": "combobox",
    "labeling": [
      "aria-label",
      "aria-expanded",
      "aria-haspopup"
    ],
    "keyboard": [
      {
        "key": "Enter",
        "action": "Open the dropdown or select the focused option.",
        "when": "trigger"
      },
      {
        "key": "Space",
        "action": "Open the dropdown or select the focused option.",
        "when": "trigger"
      },
      {
        "key": "ArrowDown",
        "action": "Move focus to the next option, or open the dropdown if closed.",
        "when": "trigger"
      },
      {
        "key": "ArrowUp",
        "action": "Move focus to the previous option.",
        "when": "content"
      },
      {
        "key": "ArrowDown",
        "action": "Move focus to the next option.",
        "when": "content"
      },
      {
        "key": "Home",
        "action": "Move focus to the first option.",
        "when": "content"
      },
      {
        "key": "End",
        "action": "Move focus to the last option.",
        "when": "content"
      },
      {
        "key": "Enter",
        "action": "Select the focused option and close the dropdown.",
        "when": "option"
      },
      {
        "key": "Escape",
        "action": "Close the dropdown and return focus to the trigger.",
        "when": "content"
      }
    ]
  },
  "a2ui": {
    "category": "form-field",
    "usageHints": [
      "Use when the option list is too long for a radio group (> 5 items)",
      "Enable search for lists with 10+ items",
      "Use multi-select mode with chips for selecting multiple values",
      "Prefer native <select> inside a plain form when JS is unavailable"
    ],
    "children": {
      "allowed": false
    }
  }
}
