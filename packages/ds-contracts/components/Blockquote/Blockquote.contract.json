{
  "$schema": "../../component.contract.schema.json",
  "name": "Blockquote",
  "description": "Styled blockquote for displaying cited passages or testimonials.",
  "layer": "primitive",
  "category": "surface",
  "anatomy": {
    "parts": [
      "root"
    ],
    "dom": {
      "tag": "blockquote",
      "part": "root",
      "children": [
        {
          "tag": "children"
        }
      ]
    }
  },
  "props": {
    "designed": {
      "members": [
        {
          "name": "cite",
          "propType": { "kind": "string" },
          "description": "Citation or source URL of the quote"
        },
        {
          "name": "variant",
          "propType": { "kind": "ref", "to": "BlockquoteVariant" },
          "description": "Visual variant of the blockquote"
        },
        {
          "name": "size",
          "propType": { "kind": "ref", "to": "BlockquoteSize" },
          "description": "Size token"
        }
      ]
    }
  },
  "types": {
    "BlockquoteVariant": {
      "kind": "union",
      "values": [
        "default",
        "bordered",
        "highlighted"
      ]
    },
    "BlockquoteSize": {
      "kind": "union",
      "values": [
        "sm",
        "md",
        "lg"
      ]
    }
  },
  "variants": {
    "variant": [
      "default",
      "bordered",
      "highlighted"
    ],
    "size": [
      "sm",
      "md",
      "lg"
    ]
  },
  "states": {
    "dimensions": {
      "pointer": {
        "category": "interaction",
        "values": [
          "default"
        ],
        "initial": "default",
        "exclusive": true
      }
    }
  },
  "slots": {
    "root": {
      "required": true,
      "selector": "[data-slot=\"blockquote\"]"
    }
  },
  "ssr": {
    "hydrateOn": "none"
  },
  "rtl": {
    "flipIcon": false
  },
  "a11y": {
    "labeling": [],
    "keyboard": []
  },
  "a2ui": {
    "category": "content",
    "usageHints": [
      "Set the cite prop to the URL of the source document (not the visible citation text)",
      "Pair with a figcaption sibling for the attribution text"
    ],
    "children": {
      "allowed": true,
      "slot": "children",
      "accepts": [
        "string",
        "node-ref"
      ]
    }
  }
}
