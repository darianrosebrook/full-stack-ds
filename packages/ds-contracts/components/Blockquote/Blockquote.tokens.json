{
  "box-model.padding-block-start": {
    "resolvesTo": "semantic.surface.size.padding-block",
    "fallback": "16px",
    "layer": "semantic"
  },
  "box-model.padding-block-end": {
    "resolvesTo": "semantic.surface.size.padding-block",
    "fallback": "16px",
    "layer": "semantic"
  },
  "box-model.padding-inline-start": {
    "resolvesTo": "semantic.surface.size.padding-inline",
    "fallback": "16px",
    "layer": "semantic"
  },
  "box-model.padding-inline-end": {
    "resolvesTo": "semantic.surface.size.padding-inline",
    "fallback": "16px",
    "layer": "semantic"
  },
  "box-model.gap": {
    "resolvesTo": "semantic.surface.size.gap",
    "fallback": "12px",
    "layer": "semantic"
  },
  "box-model.min-width": {
    "resolvesTo": "semantic.surface.size.min-width",
    "fallback": "64px",
    "layer": "semantic"
  },
  "blockquote.color.foreground.primary": {
    "resolvesTo": "semantic.color.foreground.secondary",
    "fallback": "#555555",
    "layer": "semantic"
  },
  "blockquote.color.background.default": {
    "resolvesTo": "semantic.color.background.secondary",
    "fallback": "#efefef",
    "layer": "semantic"
  },
  "blockquote.color.border.default": {
    "resolvesTo": "semantic.color.border.accent",
    "fallback": "#d9292b",
    "layer": "semantic"
  },
  "blockquote.typography.fontStyle": {
    "resolvesTo": "semantic.typography.font.style.italic",
    "fallback": "italic",
    "layer": "semantic"
  },
  "blockquote.typography.fontWeight": {
    "resolvesTo": "semantic.typography.font.weight.medium",
    "fallback": "500",
    "layer": "semantic"
  },
  "blockquote.size.padding.default": {
    "resolvesTo": "core.spacing.size.05",
    "fallback": "12px",
    "layer": "core"
  },
  "blockquote.size.padding.sm": {
    "resolvesTo": "core.spacing.size.04",
    "fallback": "8px",
    "layer": "core"
  },
  "blockquote.size.padding.lg": {
    "resolvesTo": "core.spacing.size.07",
    "fallback": "24px",
    "layer": "core"
  },
  "blockquote.size.radius.default": {
    "resolvesTo": "semantic.shape.control.radius.default",
    "fallback": "8px",
    "layer": "semantic"
  },
  "blockquote.size.border.thick": {
    "resolvesTo": "semantic.shape.control.border.focusWidth",
    "fallback": "2px",
    "layer": "semantic"
  },
  "blockquote.size.fontSize.sm": {
    "resolvesTo": "core.typography.ramp.3",
    "fallback": "0.875rem",
    "layer": "core"
  },
  "blockquote.size.fontSize.md": {
    "resolvesTo": "core.typography.ramp.4",
    "fallback": "1rem",
    "layer": "core"
  },
  "blockquote.size.fontSize.lg": {
    "resolvesTo": "core.typography.ramp.5",
    "fallback": "1.125rem",
    "layer": "core"
  }
}
