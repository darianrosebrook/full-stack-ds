{
  "$schema": "../../component.contract.schema.json",
  "name": "Calendar",
  "description": "Interactive calendar grid for selecting a single date or a date range.",
  "layer": "composer",
  "category": "structure",
  "anatomy": {
    "parts": [
      "root",
      "header",
      "nav",
      "grid",
      "cell",
      "day",
      "caption"
    ],
    "details": {
      "root": {
        "tag": "div",
        "description": "Interactive calendar surface that owns month navigation and date selection.",
        "role": "root",
        "aria": {
          "role": "application"
        }
      },
      "header": {
        "tag": "div",
        "description": "Header row containing month navigation controls and the current month caption.",
        "role": "group"
      },
      "nav": {
        "tag": "button",
        "description": "Previous/next month control.",
        "role": "trigger",
        "multiple": true,
        "interactive": true,
        "focusable": true,
        "aria": {
          "attributes": [
            "aria-label"
          ]
        }
      },
      "grid": {
        "tag": "table",
        "description": "Calendar date grid labeled for assistive technology.",
        "role": "group",
        "aria": {
          "role": "grid",
          "attributes": [
            "aria-label"
          ]
        }
      },
      "cell": {
        "tag": "td",
        "description": "Grid cell for one visible calendar day slot.",
        "role": "item",
        "multiple": true,
        "aria": {
          "role": "gridcell"
        }
      },
      "day": {
        "tag": "button",
        "description": "Selectable day button inside a calendar grid cell.",
        "role": "trigger",
        "multiple": true,
        "interactive": true,
        "focusable": true
      },
      "caption": {
        "tag": "span",
        "description": "Visible label for the currently displayed month or range.",
        "role": "label"
      }
    },
    "dom": {
      "tag": "div",
      "part": "root",
      "attrs": {
        "role": "application"
      },
      "children": [
        {
          "tag": "div",
          "part": "header",
          "children": [
            {
              "tag": "button",
              "part": "nav",
              "attrs": {
                "aria-label": "Previous month"
              }
            },
            {
              "tag": "span",
              "part": "caption"
            },
            {
              "tag": "button",
              "part": "nav",
              "attrs": {
                "aria-label": "Next month"
              }
            }
          ]
        },
        {
          "tag": "table",
          "part": "grid",
          "attrs": {
            "role": "grid",
            "aria-label": "Calendar"
          },
          "children": [
            {
              "tag": "tbody",
              "children": [
                {
                  "tag": "tr",
                  "children": [
                    {
                      "tag": "td",
                      "part": "cell",
                      "iterate": {
                        "source": "prop:daysShown",
                        "kind": "count"
                      },
                      "attrs": {
                        "role": "gridcell"
                      },
                      "bindings": {
                        "data-calendar-index": "iter:index"
                      },
                      "children": [
                        {
                          "tag": "button",
                          "part": "day"
                        }
                      ]
                    }
                  ]
                }
              ]
            }
          ]
        }
      ]
    }
  },
  "props": {
    "designed": {
      "members": [
        {
          "name": "value",
          "propType": {
            "kind": "union",
            "of": [
              { "kind": "ref", "to": "Date" },
              { "kind": "array", "items": { "kind": "ref", "to": "Date" } },
              { "kind": "literal", "value": null }
            ]
          },
          "description": "Controlled selected date or range."
        },
        {
          "name": "defaultValue",
          "propType": {
            "kind": "union",
            "of": [
              { "kind": "ref", "to": "Date" },
              { "kind": "array", "items": { "kind": "ref", "to": "Date" } },
              { "kind": "literal", "value": null }
            ]
          },
          "description": "Uncontrolled initial selected date or range."
        },
        {
          "name": "onChange",
          "propType": {
            "kind": "callback",
            "params": [
              {
                "name": "value",
                "type": {
                  "kind": "union",
                  "of": [
                    { "kind": "ref", "to": "Date" },
                    { "kind": "array", "items": { "kind": "ref", "to": "Date" } },
                    { "kind": "literal", "value": null }
                  ]
                }
              }
            ],
            "returns": { "kind": "void" }
          },
          "description": "Called when the selected date changes."
        },
        {
          "name": "mode",
          "propType": { "kind": "ref", "to": "CalendarMode" },
          "description": "Selection mode: single date or date range.",
          "default": "single"
        },
        {
          "name": "disabled",
          "propType": { "kind": "boolean" },
          "description": "Disables all interaction."
        },
        {
          "name": "minDate",
          "propType": { "kind": "ref", "to": "Date" },
          "description": "Earliest selectable date."
        },
        {
          "name": "maxDate",
          "propType": { "kind": "ref", "to": "Date" },
          "description": "Latest selectable date."
        },
        {
          "name": "locale",
          "propType": { "kind": "string" },
          "description": "BCP 47 locale tag for date formatting.",
          "default": "en-US"
        },
        {
          "name": "shouldCloseOnSelect",
          "propType": { "kind": "boolean" },
          "description": "When true, selecting a date closes the popup. Wired to behavior.dismissalTriggers.select.enabledBy.",
          "default": true
        },
        {
          "name": "daysShown",
          "propType": { "kind": "number" },
          "description": "Number of day cells the grid should render. Drives structural count iteration on the cell node; visible date labels and selection state are NOT yet wired (the binding grammar cannot project a Date into a button label inline). A typical month occupies 42 cells (6 weeks x 7 days), which is the recommended default.",
          "default": 42
        }
      ]
    }
  },
  "channels": {
    "value": {
      "description": "Selected date or date range.",
      "value": "value",
      "defaultValue": "defaultValue",
      "onChange": "onChange",
      "valueType": "Date | Date[] | null"
    }
  },
  "types": {
    "CalendarMode": {
      "kind": "union",
      "values": [
        "single",
        "range"
      ]
    }
  },
  "variants": {
    "mode": [
      "single",
      "range"
    ]
  },
  "states": {
    "dimensions": {
      "pointer": {
        "category": "interaction",
        "values": [
          "default",
          "hover"
        ],
        "initial": "default",
        "exclusive": true
      },
      "focus": {
        "category": "interaction",
        "values": [
          "unfocused",
          "focus"
        ],
        "initial": "unfocused",
        "exclusive": true
      },
      "availability": {
        "category": "availability",
        "effect": "restyle",
        "values": [
          "enabled",
          "disabled"
        ],
        "initial": "enabled",
        "exclusive": true,
        "suppresses": {
          "categories": [
            "interaction"
          ]
        }
      },
      "selection": {
        "category": "selection",
        "effect": "restyle",
        "values": [
          "unselected",
          "selected"
        ],
        "initial": "unselected",
        "exclusive": true,
        "a11y": {
          "attribute": "aria-selected",
          "values": {
            "unselected": "false",
            "selected": "true"
          }
        }
      },
      "today": {
        "category": "presentation",
        "effect": "overlay",
        "values": [
          "other",
          "today"
        ],
        "initial": "other",
        "exclusive": true
      },
      "month": {
        "category": "presentation",
        "effect": "restyle",
        "values": [
          "inMonth",
          "outsideMonth"
        ],
        "initial": "inMonth",
        "exclusive": true
      }
    }
  },
  "form": {
    "participates": true,
    "inputType": "date",
    "name": {
      "prop": "name"
    },
    "serialization": {
      "valueType": "string",
      "valueSource": "channel:selection",
      "omitWhen": "empty"
    },
    "validity": {
      "model": "props",
      "ariaAttributes": [
        "aria-invalid",
        "aria-required"
      ]
    },
    "labeling": {
      "strategy": "associated-label",
      "required": true,
      "via": [
        "aria-labelledby",
        "aria-label",
        "wrapping:FormField"
      ]
    }
  },
  "motion": {
    "reducedMotion": "respect",
    "transitions": [
      {
        "name": "open",
        "trigger": "openness=collapsed→expanded",
        "phase": "enter",
        "properties": [
          "opacity",
          "transform"
        ],
        "duration": "calendar.motion.duration",
        "easing": "calendar.motion.easing"
      },
      {
        "name": "close",
        "trigger": "openness=expanded→collapsed",
        "phase": "exit",
        "properties": [
          "opacity",
          "transform"
        ],
        "duration": "calendar.motion.duration",
        "easing": "calendar.motion.easing"
      }
    ]
  },
  "focus": {
    "strategy": "roving",
    "orientation": "both",
    "initialFocus": "today",
    "wrap": false,
    "description": "Arrow keys navigate between dates. Tab moves to prev/next month controls."
  },
  "portal": {
    "enabled": true,
    "defaultTarget": "body",
    "targetProp": "portalId",
    "positioning": "anchored",
    "layering": "popover",
    "collision": "flip-shift"
  },
  "dismissal": {
    "triggers": [
      {
        "event": "escape",
        "defaultEnabled": true,
        "description": "Closes the calendar popup and returns focus to the input."
      },
      {
        "event": "outsideClick",
        "defaultEnabled": true
      },
      {
        "event": "selection",
        "enabledBy": "shouldCloseOnSelect",
        "defaultEnabled": true,
        "description": "Selecting a date closes the popup (controlled by shouldCloseOnSelect)."
      }
    ]
  },
  "slots": {
    "root": {
      "required": true,
      "selector": "[data-slot=\"calendar\"]"
    }
  },
  "ssr": {
    "hydrateOn": "interaction"
  },
  "rtl": {
    "flipIcon": false
  },
  "relationships": [],
  "a11y": {
    "role": "application",
    "apgPattern": null,
    "labeling": [
      "aria-label",
      "aria-labelledby"
    ],
    "keyboard": [
      {
        "key": "ArrowLeft",
        "action": "Move focus to the previous day."
      },
      {
        "key": "ArrowRight",
        "action": "Move focus to the next day."
      },
      {
        "key": "ArrowUp",
        "action": "Move focus to the same day in the previous week."
      },
      {
        "key": "ArrowDown",
        "action": "Move focus to the same day in the next week."
      },
      {
        "key": "PageUp",
        "action": "Move focus to the same day in the previous month."
      },
      {
        "key": "PageDown",
        "action": "Move focus to the same day in the next month."
      },
      {
        "key": "Home",
        "action": "Move focus to the first day of the current week."
      },
      {
        "key": "End",
        "action": "Move focus to the last day of the current week."
      },
      {
        "key": "Enter|Space",
        "action": "Select the focused date."
      }
    ]
  },
  "a2ui": {
    "category": "form-field",
    "usageHints": [
      "Use for explicit date picking; combine with a text input for manual entry",
      "For date ranges, configure mode=\"range\" and supply an array value",
      "Pair with a DatePicker trigger for inline-vs-popup flexibility"
    ],
    "children": {
      "allowed": false
    }
  }
}
