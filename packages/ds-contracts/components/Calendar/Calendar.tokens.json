{
  "root": {
    "calendar.color.background.default": {
      "resolvesTo": "semantic.color.background.secondary",
      "fallback": "#efefef",
      "property": "background-color",
      "layer": "semantic"
    },
    "calendar.color.foreground.primary": {
      "resolvesTo": "semantic.color.foreground.primary",
      "fallback": "#141414",
      "property": "color",
      "layer": "semantic"
    },
    "calendar.color.foreground.secondary": {
      "resolvesTo": "semantic.color.foreground.secondary",
      "fallback": "#555555",
      "property": "color",
      "layer": "semantic"
    },
    "calendar.color.border.default": {
      "resolvesTo": "semantic.color.border.light",
      "fallback": "#fceaea",
      "property": "border-color",
      "layer": "semantic"
    },
    "calendar.color.border.accent": {
      "resolvesTo": "semantic.color.border.accent",
      "fallback": "#d9292b",
      "property": "border-color",
      "layer": "semantic"
    },
    "calendar.size.padding.default": {
      "resolvesTo": "core.spacing.size.07",
      "fallback": "24px",
      "property": "padding",
      "layer": "core"
    },
    "calendar.size.radius.default": {
      "resolvesTo": "core.shape.radius.medium",
      "fallback": "8px",
      "property": "border-radius",
      "layer": "core"
    },
    "calendar.elevation.default": {
      "resolvesTo": "semantic.elevation.default",
      "fallback": "none",
      "layer": "semantic"
    }
  },
  "hover": {
    "calendar.elevation.hover": {
      "resolvesTo": "semantic.elevation.surface.floating",
      "fallback": "0 2px 8px rgba(0,0,0,0.12)",
      "layer": "semantic"
    }
  }
}
