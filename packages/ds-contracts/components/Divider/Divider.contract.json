{
  "$schema": "../../component.contract.schema.json",
  "name": "Divider",
  "description": "Visual separator between content sections. Renders as an hr or div depending on orientation.",
  "layer": "primitive",
  "category": "display",
  "anatomy": {
    "parts": [
      "root"
    ],
    "dom": {
      "tag": "hr",
      "part": "root"
    }
  },
  "props": {
    "styled": {
      "description": "Props for the <Divider> component.",
      "members": [
        {
          "name": "orientation",
          "type": "\"horizontal\" | \"vertical\"",
          "description": "Visual orientation of the divider"
        },
        {
          "name": "decorative",
          "type": "boolean",
          "description": "Semantic role - separator (default) or presentation for purely decorative"
        },
        {
          "name": "thickness",
          "type": "string",
          "description": "Custom thickness/size"
        },
        {
          "name": "title",
          "type": "string",
          "description": "Title attribute on the underlying hr element."
        }
      ]
    }
  },
  "variants": {
    "orientation": [
      "horizontal",
      "vertical"
    ]
  },
  "states": [
    "default"
  ],
  "slots": {
    "root": {
      "required": true,
      "selector": "[data-slot=\"divider\"]"
    }
  },
  "ssr": {
    "hydrateOn": "none"
  },
  "rtl": {
    "flipIcon": false
  },
  "a11y": {
    "role": "separator",
    "labeling": [
      "aria-orientation"
    ],
    "keyboard": []
  },
  "a2ui": {
    "category": "layout",
    "usageHints": [
      "Use orientation=horizontal for horizontal rules; orientation=vertical for column separators",
      "Do not place Divider inside flex-row containers unless you set an explicit height"
    ],
    "children": {
      "allowed": false
    }
  }
}
