{
  "$schema": "../../component.contract.schema.json",
  "name": "Image",
  "description": "Responsive image component with layout and aspect-ratio helpers.",
  "layer": "primitive",
  "category": "display",
  "morphology": "replaced-media",
  "anatomy": {
    "parts": [
      "root",
      "img",
      "placeholder",
      "errorState"
    ],
    "details": {
      "root": {
        "tag": "img",
        "description": "Rendered image element carrying source, alt text, sizing, loading, and responsive hints.",
        "role": "content"
      },
      "img": {
        "description": "Image media payload represented by the root element in the current DOM realization.",
        "role": "content"
      },
      "placeholder": {
        "description": "Optional temporary visual shown while the image is loading.",
        "role": "decoration"
      },
      "errorState": {
        "description": "Fallback visual or source used when the primary image fails to load.",
        "role": "content"
      }
    },
    "dom": {
      "tag": "img",
      "part": "root",
      "bindings": {
        "src": "prop:src",
        "alt": "prop:alt",
        "width": "prop:width",
        "height": "prop:height",
        "loading": "prop:loading",
        "sizes": "prop:sizes"
      }
    }
  },
  "props": {
    "designed": {
      "members": [
        {
          "name": "src",
          "propType": { "kind": "string" },
          "description": "Image source URL."
        },
        {
          "name": "alt",
          "propType": { "kind": "string" },
          "description": "Accessible text describing the image. Use empty string for decorative images.",
          "required": true
        },
        {
          "name": "width",
          "propType": { "kind": "number" },
          "description": "Pixel width."
        },
        {
          "name": "height",
          "propType": { "kind": "number" },
          "description": "Pixel height."
        },
        {
          "name": "aspectRatio",
          "propType": { "kind": "ref", "to": "ImageAspectRatio" },
          "description": "Aspect ratio preset or numeric ratio."
        },
        {
          "name": "objectFit",
          "propType": { "kind": "ref", "to": "ImageObjectFit" },
          "description": "Object fit behavior"
        },
        {
          "name": "objectPosition",
          "propType": { "kind": "string" },
          "description": "Object position CSS value"
        },
        {
          "name": "loading",
          "propType": { "kind": "ref", "to": "ImageLoading" },
          "description": "Native image loading hint"
        },
        {
          "name": "sizes",
          "propType": { "kind": "string" },
          "description": "Native sizes attribute for responsive images"
        },
        {
          "name": "radius",
          "propType": { "kind": "ref", "to": "ImageRadius" },
          "description": "Border radius token"
        },
        {
          "name": "showPlaceholder",
          "propType": { "kind": "boolean" },
          "description": "Whether to show a placeholder while loading"
        },
        {
          "name": "fallbackSrc",
          "propType": { "kind": "string" },
          "description": "Fallback image source on error"
        }
      ]
    }
  },
  "types": {
    "ImageAspectRatio": {
      "kind": "union",
      "values": [
        "square",
        "video",
        "photo",
        "wide",
        "portrait"
      ]
    },
    "ImageObjectFit": {
      "kind": "union",
      "values": [
        "cover",
        "contain",
        "fill",
        "scale-down",
        "none"
      ]
    },
    "ImageLoading": {
      "kind": "union",
      "values": [
        "lazy",
        "eager"
      ]
    },
    "ImageRadius": {
      "kind": "union",
      "values": [
        "none",
        "sm",
        "md",
        "lg",
        "full"
      ]
    }
  },
  "variants": {
    "size": [
      "xs",
      "sm",
      "md",
      "lg",
      "xl",
      "full"
    ],
    "radius": [
      "none",
      "sm",
      "md",
      "lg",
      "full"
    ]
  },
  "states": {
    "dimensions": {
      "pointer": {
        "category": "interaction",
        "values": [
          "default"
        ],
        "initial": "default",
        "exclusive": true
      },
      "validation": {
        "category": "validation",
        "effect": "restyle",
        "values": [
          "valid",
          "error"
        ],
        "initial": "valid",
        "exclusive": true
      },
      "loading": {
        "category": "data",
        "effect": "overlay",
        "values": [
          "idle",
          "loading"
        ],
        "initial": "idle",
        "exclusive": true
      }
    }
  },
  "slots": {
    "root": {
      "required": true,
      "selector": "[data-slot=\"image\"]"
    },
    "img": {
      "required": true,
      "selector": "[data-slot=\"image-img\"]"
    }
  },
  "ssr": {
    "hydrateOn": "interaction"
  },
  "rtl": {
    "flipIcon": false
  },
  "a11y": {
    "role": "img",
    "labeling": [
      "aria-label",
      "alt"
    ],
    "keyboard": []
  },
  "a2ui": {
    "category": "display",
    "usageHints": [
      "Always provide a meaningful alt string; use alt=\"\" for decorative images",
      "Set fill for images that should cover their container; use width/height otherwise",
      "Use priority on above-the-fold images to avoid layout shift"
    ],
    "children": {
      "allowed": false
    }
  }
}
