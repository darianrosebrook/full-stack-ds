{
  "$schema": "../../component.contract.schema.json",
  "name": "Card",
  "description": "Surface container grouping related content with optional header, media, and action areas.",
  "layer": "compound",
  "anatomy": {
    "parts": [
      "root",
      "header",
      "media",
      "content",
      "footer",
      "actions",
      "badge",
      "description",
      "link",
      "note"
    ]
  },
  "props": {
    "styled": {
      "description": "Props for the <Card> component.",
      "members": [
        {
          "name": "interactive",
          "type": "boolean",
          "description": "Enable hover affordances (shadow lift, translate)"
        },
        {
          "name": "status",
          "type": "CardStatus",
          "description": "Visual status variant of the card"
        }
      ]
    }
  },
  "types": {
    "CardStatus": {
      "kind": "union",
      "values": [
        "completed",
        "in-progress",
        "planned",
        "deprecated",
        "category",
        "complexity"
      ]
    }
  },
  "variants": {
    "status": [
      "completed",
      "in-progress",
      "planned",
      "deprecated",
      "category",
      "complexity"
    ]
  },
  "states": [
    "default",
    "hover",
    "focus",
    "active"
  ],
  "slots": {
    "actions": {
      "required": false
    },
    "badge": {
      "required": false
    },
    "content": {
      "required": false
    },
    "description": {
      "required": false
    },
    "footer": {
      "required": false
    },
    "header": {
      "required": false
    },
    "link": {
      "required": false
    },
    "media": {
      "required": false
    },
    "note": {
      "required": false
    },
    "title": {
      "required": false
    },
    "root": {
      "required": true,
      "selector": "[data-slot=\"card\"]"
    }
  },
  "ssr": {
    "hydrateOn": "interaction"
  },
  "rtl": {
    "flipIcon": false
  },
  "a11y": {
    "role": "group",
    "labeling": [
      "aria-label",
      "aria-labelledby"
    ],
    "keyboard": []
  },
  "usage": {
    "example": "<Card variant=\"small\">\n  <CardHeader>\n    <CardTitle>Project Update</CardTitle>\n    <CardDescription>Latest status report</CardDescription>\n  </CardHeader>\n  <CardContent>\n    <p>Everything is on track for the Q2 release.</p>\n  </CardContent>\n  <CardFooter>\n    <Button kind=\"primary\">View Details</Button>\n  </CardFooter>\n</Card>"
  },
  "a2ui": {
    "category": "display",
    "usageHints": [
      "Use Card.Link to make the entire card clickable",
      "Keep Card.Actions to 1\u20132 actions; move secondary actions to an overflow menu",
      "Card.Media expects a fixed-aspect image or media slot"
    ],
    "children": {
      "allowed": true,
      "slot": "children",
      "accepts": [
        "ReactNode"
      ]
    }
  }
}
