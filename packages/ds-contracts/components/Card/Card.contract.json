{
  "$schema": "../../component.contract.schema.json",
  "name": "Card",
  "description": "Surface container grouping related content with optional header, media, and action areas.",
  "layer": "compound",
  "category": "surface",
  "anatomy": {
    "parts": [
      "root",
      "header",
      "media",
      "content",
      "footer",
      "actions",
      "badge",
      "description",
      "link",
      "note"
    ],
    "details": {
      "root": {
        "description": "Surface container that groups related card content and optional affordances.",
        "role": "region",
        "aria": {
          "role": "group",
          "attributes": [
            "aria-label",
            "aria-labelledby"
          ]
        }
      },
      "header": {
        "description": "Introductory area for title, heading, or primary metadata.",
        "role": "label"
      },
      "media": {
        "description": "Optional visual media area, typically an image or illustration associated with the card.",
        "role": "content"
      },
      "content": {
        "description": "Primary body content for the card.",
        "role": "content"
      },
      "footer": {
        "description": "Secondary footer area for supporting metadata or trailing content.",
        "role": "group"
      },
      "actions": {
        "description": "Action group for controls that operate on the card subject.",
        "role": "group"
      },
      "badge": {
        "description": "Compact status, category, or count marker associated with the card.",
        "role": "context"
      },
      "description": {
        "description": "Short supporting copy that explains or summarizes the card subject.",
        "role": "content"
      },
      "link": {
        "description": "Optional navigation affordance that can make the card subject reachable.",
        "role": "trigger",
        "interactive": true,
        "focusable": true
      },
      "note": {
        "description": "Supplementary note or annotation attached to the card.",
        "role": "context"
      }
    }
  },
  "props": {
    "designed": {
      "members": [
        {
          "name": "interactive",
          "propType": { "kind": "boolean" },
          "description": "Enable hover affordances (shadow lift, translate)"
        },
        {
          "name": "status",
          "propType": { "kind": "ref", "to": "CardStatus" },
          "description": "Visual status variant of the card"
        },
        {
          "name": "density",
          "propType": { "kind": "ref", "to": "CardDensity" },
          "description": "Padding and border treatment. Use 'inset' for compact tiles inside a list or grid where the surrounding container provides primary structure.",
          "default": "default"
        }
      ]
    }
  },
  "types": {
    "CardStatus": {
      "kind": "union",
      "values": [
        "completed",
        "in-progress",
        "planned",
        "deprecated",
        "category",
        "complexity"
      ]
    },
    "CardDensity": {
      "kind": "union",
      "values": [
        "default",
        "inset"
      ]
    }
  },
  "variants": {
    "status": [
      "completed",
      "in-progress",
      "planned",
      "deprecated",
      "category",
      "complexity"
    ],
    "density": [
      "default",
      "inset"
    ]
  },
  "states": {
    "dimensions": {
      "pointer": {
        "category": "interaction",
        "values": [
          "default",
          "hover",
          "active"
        ],
        "initial": "default",
        "exclusive": true
      },
      "focus": {
        "category": "interaction",
        "values": [
          "unfocused",
          "focus"
        ],
        "initial": "unfocused",
        "exclusive": true
      },
      "affordance": {
        "category": "interaction",
        "values": [
          "static",
          "interactive"
        ],
        "initial": "static",
        "exclusive": true
      }
    }
  },
  "slots": {
    "actions": {
      "required": false
    },
    "badge": {
      "required": false
    },
    "content": {
      "required": false
    },
    "description": {
      "required": false
    },
    "footer": {
      "required": false
    },
    "header": {
      "required": false
    },
    "link": {
      "required": false
    },
    "media": {
      "required": false
    },
    "note": {
      "required": false
    },
    "title": {
      "required": false
    },
    "root": {
      "required": true,
      "selector": "[data-slot=\"card\"]"
    }
  },
  "ssr": {
    "hydrateOn": "interaction"
  },
  "rtl": {
    "flipIcon": false
  },
  "a11y": {
    "role": "group",
    "labeling": [
      "aria-label",
      "aria-labelledby"
    ],
    "keyboard": []
  },
  "a2ui": {
    "category": "display",
    "usageHints": [
      "Use Card.Link to make the entire card clickable",
      "Keep Card.Actions to 1–2 actions; move secondary actions to an overflow menu",
      "Card.Media expects a fixed-aspect image or media slot"
    ],
    "children": {
      "allowed": true,
      "slot": "children",
      "accepts": [
        "ReactNode"
      ]
    }
  }
}
