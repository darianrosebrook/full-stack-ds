{
  "root": {
    "background-color": {
      "resolvesTo": "card.color.background.default"
    },
    "border-color": {
      "resolvesTo": "card.color.border.default"
    },
    "color": {
      "resolvesTo": "card.color.foreground.primary"
    },
    "padding": {
      "resolvesTo": "card.size.padding.default"
    },
    "border-radius": {
      "resolvesTo": "card.size.radius.default"
    },
    "gap": {
      "resolvesTo": "card.size.gap.default"
    },
    "line-height": {
      "resolvesTo": "card.typography.lineHeight.normal"
    },
    "display": {
      "literal": "flex",
      "platforms": [
        "web"
      ]
    },
    "flex-direction": {
      "literal": "column",
      "platforms": [
        "web"
      ]
    },
    "border-style": {
      "literal": "solid",
      "platforms": [
        "web"
      ]
    },
    "border-width": {
      "literal": "1px",
      "platforms": [
        "web",
        "ios",
        "android"
      ]
    },
    "box-sizing": {
      "literal": "border-box",
      "platforms": [
        "web"
      ]
    },
    "box-shadow": {
      "resolvesTo": "card.elevation.resting"
    },
    "border-inline-start-width": {
      "resolvesTo": "card.size.statusAccent.width"
    },
    "border-inline-start-color": {
      "resolvesTo": "card.color.statusAccent.default"
    },
    "transition-property": {
      "literal": "box-shadow, border-color, background-color",
      "platforms": [
        "web"
      ]
    },
    "transition-duration": {
      "literal": "150ms",
      "platforms": [
        "web"
      ]
    },
    "transition-timing-function": {
      "literal": "cubic-bezier(0.4, 0, 0.2, 1)",
      "platforms": [
        "web"
      ]
    }
  },
  "hover": {
    "background-color": {
      "resolvesTo": "card.color.background.hover"
    },
    "box-shadow": {
      "resolvesTo": "card.elevation.raised"
    }
  },
  "focus": {
    "outline-width": {
      "resolvesTo": "card.focus.ring.width"
    },
    "outline-color": {
      "resolvesTo": "card.color.focus.ring"
    },
    "outline-offset": {
      "resolvesTo": "card.focus.ring.offset"
    },
    "outline-style": {
      "literal": "solid",
      "platforms": [
        "web"
      ]
    }
  },
  "--completed": {
    "card.color.statusAccent.default": {
      "resolvesTo": "semantic.color.border.success",
      "fallback": "#336006"
    }
  },
  "--in-progress": {
    "card.color.statusAccent.default": {
      "resolvesTo": "semantic.color.border.info",
      "fallback": "#0042dc"
    }
  },
  "--planned": {
    "card.color.statusAccent.default": {
      "resolvesTo": "semantic.color.border.subtle",
      "fallback": "#cecece"
    }
  },
  "--deprecated": {
    "card.color.statusAccent.default": {
      "resolvesTo": "semantic.color.border.danger",
      "fallback": "#ae0001"
    }
  },
  "--category": {
    "card.color.statusAccent.default": {
      "resolvesTo": "semantic.color.border.accent",
      "fallback": "#d9292b"
    }
  },
  "--complexity": {
    "card.color.statusAccent.default": {
      "resolvesTo": "semantic.color.border.warning",
      "fallback": "#824500"
    }
  },
  "--inset": {
    "padding": {
      "resolvesTo": "card.size.padding.inset"
    }
  },
  "header": {
    "display": {
      "literal": "flex",
      "platforms": [
        "web"
      ]
    },
    "align-items": {
      "literal": "flex-start",
      "platforms": [
        "web"
      ]
    },
    "justify-content": {
      "literal": "space-between",
      "platforms": [
        "web"
      ]
    },
    "gap": {
      "resolvesTo": "card.size.gap.default"
    },
    "line-height": {
      "resolvesTo": "card.typography.lineHeight.heading"
    },
    "color": {
      "resolvesTo": "card.color.foreground.primary"
    }
  },
  "media": {
    "display": {
      "literal": "block",
      "platforms": [
        "web"
      ]
    },
    "width": {
      "literal": "100%",
      "platforms": [
        "web"
      ]
    },
    "overflow": {
      "literal": "hidden",
      "platforms": [
        "web"
      ]
    },
    "border-radius": {
      "resolvesTo": "card.size.radius.default"
    }
  },
  "content": {
    "display": {
      "literal": "flex",
      "platforms": [
        "web"
      ]
    },
    "flex-direction": {
      "literal": "column",
      "platforms": [
        "web"
      ]
    },
    "gap": {
      "resolvesTo": "card.size.gap.default"
    },
    "flex": {
      "literal": "1 1 auto",
      "platforms": [
        "web"
      ]
    },
    "color": {
      "resolvesTo": "card.color.foreground.primary"
    }
  },
  "description": {
    "margin": {
      "literal": "0",
      "platforms": [
        "web"
      ]
    },
    "card.color.foreground.primary": {
      "resolvesTo": "semantic.color.foreground.secondary",
      "fallback": "#555555"
    }
  },
  "footer": {
    "display": {
      "literal": "flex",
      "platforms": [
        "web"
      ]
    },
    "align-items": {
      "literal": "center",
      "platforms": [
        "web"
      ]
    },
    "justify-content": {
      "literal": "flex-end",
      "platforms": [
        "web"
      ]
    },
    "gap": {
      "resolvesTo": "card.size.gap.default"
    },
    "padding-top": {
      "resolvesTo": "card.size.padding.default"
    },
    "margin-top": {
      "literal": "auto",
      "platforms": [
        "web"
      ]
    },
    "border-top-color": {
      "resolvesTo": "card.color.border.default"
    },
    "border-top-style": {
      "literal": "solid",
      "platforms": [
        "web"
      ]
    },
    "border-top-width": {
      "literal": "1px",
      "platforms": [
        "web",
        "ios",
        "android"
      ]
    }
  },
  "actions": {
    "display": {
      "literal": "flex",
      "platforms": [
        "web"
      ]
    },
    "align-items": {
      "literal": "center",
      "platforms": [
        "web"
      ]
    },
    "gap": {
      "resolvesTo": "card.size.gap.default"
    }
  },
  "badge": {
    "display": {
      "literal": "inline-flex",
      "platforms": [
        "web"
      ]
    },
    "align-items": {
      "literal": "center",
      "platforms": [
        "web"
      ]
    },
    "background-color": {
      "resolvesTo": "card.color.badge.accent.background"
    },
    "color": {
      "resolvesTo": "card.color.badge.accent.foreground"
    },
    "padding": {
      "literal": "2px 8px",
      "platforms": [
        "web"
      ]
    },
    "border-radius": {
      "literal": "9999px",
      "platforms": [
        "web"
      ]
    },
    "font-size": {
      "literal": "0.75em",
      "platforms": [
        "web"
      ]
    },
    "line-height": {
      "literal": "1.4",
      "platforms": [
        "web"
      ]
    }
  },
  "link": {
    "text-decoration": {
      "literal": "none",
      "platforms": [
        "web"
      ]
    },
    "card.color.foreground.primary": {
      "resolvesTo": "semantic.color.foreground.link",
      "fallback": "#d9292b"
    }
  },
  ".card__link:hover": {
    "text-decoration": {
      "literal": "underline",
      "platforms": [
        "web"
      ]
    }
  },
  "note": {
    "font-size": {
      "literal": "0.875em",
      "platforms": [
        "web"
      ]
    },
    "line-height": {
      "resolvesTo": "card.typography.lineHeight.normal"
    },
    "card.color.foreground.primary": {
      "resolvesTo": "semantic.color.foreground.secondary",
      "fallback": "#555555"
    }
  }
}
