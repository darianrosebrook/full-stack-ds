{
  "$schema": "../../component.contract.schema.json",
  "name": "Accordion",
  "description": "Vertically stacked sections that expand/collapse to reveal content. Supports single or multi-panel open modes.",
  "layer": "composer",
  "category": "structure",
  "anatomy": {
    "parts": [
      "root",
      "item",
      "trigger",
      "header",
      "chevron",
      "content",
      "contentInner"
    ],
    "dom": {
      "tag": "div",
      "part": "root",
      "children": [
        {
          "tag": "div",
          "part": "item",
          "children": [
            {
              "tag": "h3",
              "part": "header",
              "children": [
                {
                  "tag": "button",
                  "part": "trigger",
                  "attrs": {
                    "type": "button"
                  },
                  "bindings": {
                    "aria-expanded": "channel:openness.value"
                  },
                  "children": [
                    {
                      "tag": "children"
                    },
                    {
                      "tag": "span",
                      "part": "chevron"
                    }
                  ]
                }
              ]
            },
            {
              "tag": "div",
              "part": "content",
              "children": [
                {
                  "tag": "div",
                  "part": "contentInner",
                  "children": [
                    {
                      "tag": "children"
                    }
                  ]
                }
              ]
            }
          ]
        }
      ]
    }
  },
  "props": {
    "styled": {
      "description": "Props for the <Accordion> component.",
      "members": [
        {
          "name": "type",
          "type": "AccordionType",
          "description": "Whether only one panel can be open at a time (single) or multiple may be open simultaneously (multiple).",
          "default": "single"
        },
        {
          "name": "value",
          "type": "string | string[]",
          "description": "Controlled value. String in single mode; string array in multiple mode."
        },
        {
          "name": "defaultValue",
          "type": "string | string[]",
          "description": "Uncontrolled initial open value."
        },
        {
          "name": "onValueChange",
          "type": "(value: string | string[]) => void",
          "description": "Called when the open panel(s) change."
        },
        {
          "name": "collapsible",
          "type": "boolean",
          "description": "When true in single mode, the open panel may be collapsed by clicking its trigger again.",
          "default": false
        },
        {
          "name": "disabled",
          "type": "boolean",
          "description": "Disables all accordion items."
        }
      ]
    }
  },
  "channels": {
    "openness": {
      "description": "Which panel(s) are expanded. String in single mode, string[] in multiple mode.",
      "value": "value",
      "defaultValue": "defaultValue",
      "onChange": "onValueChange",
      "valueType": "string | string[]"
    }
  },
  "types": {
    "AccordionType": {
      "kind": "union",
      "values": [
        "single",
        "multiple"
      ]
    }
  },
  "variants": {
    "type": [
      "single",
      "multiple"
    ]
  },
  "states": {
    "dimensions": {
      "pointer": {
        "category": "interaction",
        "values": [
          "default",
          "hover"
        ],
        "initial": "default",
        "exclusive": true
      },
      "focus": {
        "category": "interaction",
        "values": [
          "unfocused",
          "focus"
        ],
        "initial": "unfocused",
        "exclusive": true
      },
      "availability": {
        "category": "availability",
        "values": [
          "enabled",
          "disabled"
        ],
        "initial": "enabled",
        "exclusive": true,
        "suppresses": {
          "categories": [
            "interaction"
          ]
        }
      },
      "disclosure": {
        "category": "visibility",
        "values": [
          "closed",
          "open"
        ],
        "initial": "closed",
        "exclusive": true,
        "a11y": {
          "attribute": "aria-expanded",
          "values": {
            "closed": "false",
            "open": "true"
          }
        }
      }
    }
  },
  "motion": {
    "reducedMotion": "respect",
    "reducedMotionStrategy": "Duration set to 0; panels snap between collapsed and expanded states without height animation.",
    "transitions": [
      {
        "name": "expand",
        "trigger": "openness=collapsed→expanded",
        "phase": "enter",
        "properties": [
          "height",
          "opacity"
        ],
        "duration": "accordion.motion.duration",
        "easing": "accordion.motion.easing"
      },
      {
        "name": "collapse",
        "trigger": "openness=expanded→collapsed",
        "phase": "exit",
        "properties": [
          "height",
          "opacity"
        ],
        "duration": "accordion.motion.duration",
        "easing": "accordion.motion.easing"
      }
    ]
  },
  "focus": {
    "strategy": "manual",
    "orientation": "vertical",
    "initialFocus": "trigger",
    "wrap": true,
    "description": "Arrow keys navigate between accordion triggers; Space/Enter toggles the focused panel."
  },
  "portal": {
    "enabled": false
  },
  "dismissal": {
    "triggers": []
  },
  "slots": {
    "content": {
      "required": false,
      "selector": "[data-slot=\"accordion-content\"]"
    },
    "item": {
      "required": false,
      "selector": "[data-slot=\"accordion-item\"]"
    },
    "root": {
      "required": true,
      "selector": "[data-slot=\"accordion\"]"
    },
    "trigger": {
      "required": false,
      "selector": "[data-slot=\"accordion-trigger\"]"
    }
  },
  "ssr": {
    "hydrateOn": "interaction"
  },
  "rtl": {
    "flipIcon": true
  },
  "relationships": [
    {
      "from": "trigger",
      "to": "content",
      "attribute": "aria-controls",
      "description": "Each accordion trigger controls its associated content region."
    },
    {
      "from": "content",
      "to": "trigger",
      "attribute": "aria-labelledby",
      "description": "Each content region is labelled by its corresponding trigger heading."
    }
  ],
  "a11y": {
    "role": "region",
    "apgPattern": "accordion",
    "labeling": [],
    "keyboard": [
      {
        "key": "Enter|Space",
        "action": "Toggle the focused accordion item open or closed.",
        "when": "trigger"
      },
      {
        "key": "ArrowDown",
        "action": "Move focus to the next accordion trigger.",
        "when": "trigger"
      },
      {
        "key": "ArrowUp",
        "action": "Move focus to the previous accordion trigger.",
        "when": "trigger"
      },
      {
        "key": "Home",
        "action": "Move focus to the first accordion trigger.",
        "when": "trigger"
      },
      {
        "key": "End",
        "action": "Move focus to the last accordion trigger.",
        "when": "trigger"
      }
    ]
  },
  "a2ui": {
    "category": "navigation",
    "usageHints": [
      "Use type=\"single\" to allow only one panel open at a time; \"multiple\" allows several",
      "Set collapsible on single mode to allow the open panel to also be closed",
      "Bind value and onValueChange for controlled mode",
      "Avoid deeply nesting accordions — prefer flat structures for better readability"
    ],
    "children": {
      "allowed": true,
      "slot": "children",
      "accepts": [
        "AccordionItem",
        "AccordionTrigger",
        "AccordionContent"
      ]
    }
  }
}
