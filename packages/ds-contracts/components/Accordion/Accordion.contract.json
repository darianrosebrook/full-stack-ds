{
  "$schema": "../../component.contract.schema.json",
  "name": "Accordion",
  "description": "Vertically stacked sections that expand/collapse to reveal content. Supports single or multi-panel open modes.",
  "layer": "composer",
  "anatomy": {
    "parts": [
      "root",
      "item",
      "trigger",
      "header",
      "chevron",
      "content",
      "contentInner"
    ],
    "dom": {
      "tag": "div",
      "part": "root",
      "children": [
        {
          "tag": "div",
          "part": "item",
          "children": [
            {
              "tag": "h3",
              "part": "header",
              "children": [
                {
                  "tag": "button",
                  "part": "trigger",
                  "attrs": {
                    "type": "button"
                  },
                  "bindings": {
                    "aria-expanded": "channel:openness.value"
                  },
                  "children": [
                    {
                      "tag": "children"
                    },
                    {
                      "tag": "span",
                      "part": "chevron"
                    }
                  ]
                }
              ]
            },
            {
              "tag": "div",
              "part": "content",
              "children": [
                {
                  "tag": "div",
                  "part": "contentInner",
                  "children": [
                    {
                      "tag": "children"
                    }
                  ]
                }
              ]
            }
          ]
        }
      ]
    }
  },
  "props": {
    "styled": {
      "description": "Props for the <Accordion> component.",
      "members": [
        {
          "name": "type",
          "type": "AccordionType",
          "description": "Whether only one panel can be open at a time (single) or multiple may be open simultaneously (multiple).",
          "default": "single"
        },
        {
          "name": "value",
          "type": "string | string[]",
          "description": "Controlled value. String in single mode; string array in multiple mode."
        },
        {
          "name": "defaultValue",
          "type": "string | string[]",
          "description": "Uncontrolled initial open value."
        },
        {
          "name": "onValueChange",
          "type": "(value: string | string[]) => void",
          "description": "Called when the open panel(s) change."
        },
        {
          "name": "collapsible",
          "type": "boolean",
          "description": "When true in single mode, the open panel may be collapsed by clicking its trigger again.",
          "default": false
        },
        {
          "name": "disabled",
          "type": "boolean",
          "description": "Disables all accordion items."
        }
      ]
    }
  },
  "channels": {
    "openness": {
      "description": "Which panel(s) are expanded. String in single mode, string[] in multiple mode.",
      "value": "value",
      "defaultValue": "defaultValue",
      "onChange": "onValueChange",
      "valueType": "string | string[]"
    }
  },
  "types": {
    "AccordionType": {
      "kind": "union",
      "values": [
        "single",
        "multiple"
      ]
    }
  },
  "variants": {
    "type": [
      "single",
      "multiple"
    ]
  },
  "states": [
    "default",
    "hover",
    "focus",
    "disabled",
    "open",
    "closed"
  ],
  "tokens": {
    "root": {
      "accordion.color.background.hover": {
        "resolvesTo": "semantic.interaction.background.hover",
        "fallback": "#efefef",
        "property": "background-color",
        "layer": "semantic"
      },
      "accordion.color.text": {
        "resolvesTo": "semantic.color.foreground.primary",
        "fallback": "#141414",
        "property": "color",
        "layer": "semantic"
      },
      "accordion.color.textSecondary": {
        "resolvesTo": "semantic.color.foreground.secondary",
        "fallback": "#555555",
        "property": "color",
        "layer": "semantic"
      },
      "accordion.color.icon": {
        "resolvesTo": "semantic.color.foreground.tertiary",
        "fallback": "#717171",
        "layer": "semantic"
      },
      "accordion.border.width": {
        "resolvesTo": "core.shape.border.width.hairline",
        "fallback": "1px",
        "property": "border-width",
        "layer": "core"
      },
      "accordion.border.color": {
        "resolvesTo": "semantic.color.border.light",
        "fallback": "#fceaea",
        "property": "border-color",
        "layer": "semantic"
      },
      "accordion.border.radius": {
        "resolvesTo": "core.shape.radius.small",
        "fallback": "4px",
        "property": "border-radius",
        "layer": "core"
      },
      "accordion.spacing.gap": {
        "resolvesTo": "core.spacing.size.07",
        "fallback": "24px",
        "property": "gap",
        "layer": "core"
      },
      "accordion.spacing.paddingX": {
        "resolvesTo": "core.spacing.size.00",
        "fallback": "0px",
        "property": "padding",
        "layer": "core"
      },
      "accordion.spacing.paddingY": {
        "resolvesTo": "core.spacing.size.04",
        "fallback": "8px",
        "property": "padding",
        "layer": "core"
      },
      "accordion.text.weight": {
        "resolvesTo": "semantic.typography.font.weight.medium",
        "fallback": "500",
        "property": "font-weight",
        "layer": "semantic"
      },
      "accordion.text.size": {
        "resolvesTo": "semantic.typography.body.02",
        "fallback": "16px",
        "property": "font-size",
        "layer": "semantic"
      },
      "accordion.text.lineHeight": {
        "resolvesTo": "semantic.typography.line.height.normal",
        "fallback": "1.5",
        "property": "line-height",
        "layer": "semantic"
      },
      "accordion.text.sizeContent": {
        "resolvesTo": "semantic.typography.body.03",
        "fallback": "14px",
        "property": "font-size",
        "layer": "semantic"
      },
      "accordion.text.lineHeightContent": {
        "resolvesTo": "semantic.typography.line.height.loose",
        "fallback": "1.8",
        "property": "line-height",
        "layer": "semantic"
      },
      "accordion.icon.size": {
        "resolvesTo": "core.spacing.size.04",
        "fallback": "8px",
        "layer": "core"
      },
      "accordion.focus.width": {
        "resolvesTo": "core.shape.border.width.thick",
        "fallback": "2px",
        "layer": "core"
      },
      "accordion.focus.color": {
        "resolvesTo": "semantic.color.border.accent",
        "fallback": "#d9292b",
        "layer": "semantic"
      },
      "accordion.focus.offset": {
        "resolvesTo": "core.spacing.size.01",
        "fallback": "1px",
        "layer": "core"
      },
      "accordion.opacity.disabled": {
        "resolvesTo": "semantic.interaction.disabled.opacity",
        "fallback": "0.5",
        "property": "opacity",
        "layer": "semantic"
      }
    },
    "hover": {
      "accordion.color.textHover": {
        "resolvesTo": "semantic.interaction.text.hover",
        "fallback": "#555555",
        "property": "color",
        "layer": "semantic"
      }
    }
  },
  "motion": {
    "reducedMotion": "respect",
    "reducedMotionStrategy": "Duration set to 0; panels snap between collapsed and expanded states without height animation.",
    "transitions": [
      {
        "name": "expand",
        "trigger": "openness=collapsed\u2192expanded",
        "phase": "enter",
        "properties": [
          "height",
          "opacity"
        ],
        "duration": "accordion.motion.duration",
        "easing": "accordion.motion.easing"
      },
      {
        "name": "collapse",
        "trigger": "openness=expanded\u2192collapsed",
        "phase": "exit",
        "properties": [
          "height",
          "opacity"
        ],
        "duration": "accordion.motion.duration",
        "easing": "accordion.motion.easing"
      }
    ]
  },
  "focus": {
    "strategy": "manual",
    "orientation": "vertical",
    "initialFocus": "trigger",
    "wrap": true,
    "description": "Arrow keys navigate between accordion triggers; Space/Enter toggles the focused panel."
  },
  "portal": {
    "enabled": false
  },
  "dismissal": {
    "triggers": []
  },
  "slots": {
    "content": {
      "required": false,
      "selector": "[data-slot=\"accordion-content\"]"
    },
    "item": {
      "required": false,
      "selector": "[data-slot=\"accordion-item\"]"
    },
    "root": {
      "required": true,
      "selector": "[data-slot=\"accordion\"]"
    },
    "trigger": {
      "required": false,
      "selector": "[data-slot=\"accordion-trigger\"]"
    }
  },
  "ssr": {
    "hydrateOn": "interaction"
  },
  "rtl": {
    "flipIcon": true
  },
  "relationships": [
    {
      "from": "trigger",
      "to": "content",
      "attribute": "aria-controls",
      "description": "Each accordion trigger controls its associated content region."
    },
    {
      "from": "content",
      "to": "trigger",
      "attribute": "aria-labelledby",
      "description": "Each content region is labelled by its corresponding trigger heading."
    }
  ],
  "a11y": {
    "role": "region",
    "apgPattern": "accordion",
    "labeling": [],
    "keyboard": [
      {
        "key": "Enter|Space",
        "action": "Toggle the focused accordion item open or closed.",
        "when": "trigger"
      },
      {
        "key": "ArrowDown",
        "action": "Move focus to the next accordion trigger.",
        "when": "trigger"
      },
      {
        "key": "ArrowUp",
        "action": "Move focus to the previous accordion trigger.",
        "when": "trigger"
      },
      {
        "key": "Home",
        "action": "Move focus to the first accordion trigger.",
        "when": "trigger"
      },
      {
        "key": "End",
        "action": "Move focus to the last accordion trigger.",
        "when": "trigger"
      }
    ]
  },
  "usage": {
    "example": "<Accordion headingLevel={3} isMultiOpen={false}>\n  <AccordionSection id=\"section-1\">\n    <AccordionHeader>Section 1</AccordionHeader>\n    <AccordionPanel>Content 1</AccordionPanel>\n  </AccordionSection>\n</Accordion>",
    "hookExample": "const accordion = useAccordion({ isMultiOpen: false });\n\nreturn (\n  <div>\n    {sections.map((section, index) => (\n      <div key={section.id}>\n        <button {...accordion.getHeaderProps(section.id, index)}>\n          {section.title}\n        </button>\n        <div {...accordion.getPanelProps(section.id, index)}>\n          {section.content}\n        </div>\n      </div>\n    ))}\n  </div>\n);"
  },
  "a2ui": {
    "category": "navigation",
    "usageHints": [
      "Use type=\"single\" to allow only one panel open at a time; \"multiple\" allows several",
      "Set collapsible on single mode to allow the open panel to also be closed",
      "Bind value and onValueChange for controlled mode",
      "Avoid deeply nesting accordions \u2014 prefer flat structures for better readability"
    ],
    "children": {
      "allowed": true,
      "slot": "children",
      "accepts": [
        "AccordionItem",
        "AccordionTrigger",
        "AccordionContent"
      ]
    }
  }
}
