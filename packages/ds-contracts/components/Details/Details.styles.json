{
  "root": {
    "padding": {
      "resolvesTo": "details.size.padding.default"
    },
    "border-radius": {
      "resolvesTo": "details.size.radius.default"
    },
    "background-color": {
      "resolvesTo": "details.color.background.default"
    },
    "gap": {
      "resolvesTo": "details.spacing.gap.default"
    },
    "line-height": {
      "resolvesTo": "details.typography.lineHeight.body"
    },
    "display": {
      "literal": "block",
      "platforms": [
        "web"
      ]
    },
    "border-style": {
      "literal": "solid",
      "platforms": [
        "web"
      ]
    },
    "border-width": {
      "literal": "1px",
      "platforms": [
        "web",
        "ios",
        "android"
      ]
    },
    "box-sizing": {
      "literal": "border-box",
      "platforms": [
        "web"
      ]
    },
    "border-color": {
      "resolvesTo": "details.color.border.default"
    },
    "color": {
      "resolvesTo": "details.color.foreground.primary"
    }
  },
  "hover": {
    "background-color": {
      "resolvesTo": "details.color.background.hover"
    },
    "border-color": {
      "resolvesTo": "details.color.border.hover"
    }
  },
  "summary": {
    "cursor": {
      "literal": "pointer",
      "platforms": [
        "web"
      ]
    },
    "display": {
      "literal": "flex",
      "platforms": [
        "web"
      ]
    },
    "align-items": {
      "literal": "center",
      "platforms": [
        "web"
      ]
    },
    "gap": {
      "resolvesTo": "details.spacing.gap.default"
    },
    "list-style": {
      "literal": "none",
      "platforms": [
        "web"
      ]
    },
    "padding": {
      "resolvesTo": "details.size.padding.default"
    },
    "color": {
      "resolvesTo": "details.color.foreground.primary"
    },
    "font-weight": {
      "resolvesTo": "details.typography.fontWeight.medium"
    }
  },
  ".details__summary:hover": {
    "details.color.background.default": {
      "resolvesTo": "semantic.color.background.hover",
      "fallback": "#cecece"
    }
  },
  ".details__summary:focus-visible": {
    "outline-width": {
      "resolvesTo": "details.focus.ring.width"
    },
    "outline-color": {
      "resolvesTo": "details.focus.ring.color"
    },
    "outline-offset": {
      "resolvesTo": "details.focus.ring.offset"
    },
    "outline-style": {
      "literal": "solid",
      "platforms": [
        "web"
      ]
    }
  },
  "summaryContent": {
    "display": {
      "literal": "flex",
      "platforms": [
        "web"
      ]
    },
    "align-items": {
      "literal": "center",
      "platforms": [
        "web"
      ]
    },
    "gap": {
      "resolvesTo": "details.spacing.gap.default"
    },
    "flex": {
      "literal": "1 1 auto",
      "platforms": [
        "web"
      ]
    }
  },
  "summaryText": {
    "flex": {
      "literal": "1 1 auto",
      "platforms": [
        "web"
      ]
    },
    "color": {
      "resolvesTo": "details.color.foreground.primary"
    }
  },
  "icon": {
    "display": {
      "literal": "inline-flex",
      "platforms": [
        "web"
      ]
    },
    "flex-shrink": {
      "literal": "0",
      "platforms": [
        "web"
      ]
    },
    "width": {
      "resolvesTo": "details.size.icon"
    },
    "height": {
      "resolvesTo": "details.size.icon"
    },
    "transition": {
      "literal": "transform 200ms ease",
      "platforms": [
        "web"
      ]
    },
    "align-items": {
      "literal": "center",
      "platforms": [
        "web"
      ]
    },
    "justify-content": {
      "literal": "center",
      "platforms": [
        "web"
      ]
    }
  },
  ".details[open] .details__icon": {
    "transform": {
      "literal": "rotate(180deg)",
      "platforms": [
        "web"
      ]
    }
  },
  "content": {
    "display": {
      "literal": "block",
      "platforms": [
        "web"
      ]
    },
    "padding": {
      "resolvesTo": "details.size.padding.default"
    },
    "color": {
      "resolvesTo": "details.color.foreground.primary"
    },
    "line-height": {
      "resolvesTo": "details.typography.lineHeight.body"
    }
  },
  "--compact": {
    "details.size.padding.default": { "resolvesTo": "core.spacing.size.04", "fallback": "8px" },
    "details.typography.lineHeight.body": { "resolvesTo": "core.spacing.size.06", "fallback": "16px" }
  },
  "--inline": {
    "details.size.padding.default": { "resolvesTo": "core.spacing.size.07", "fallback": "24px" },
    "details.color.background.default": { "resolvesTo": "semantic.color.background.secondary", "fallback": "#f5f5f5" },
    "details.color.border.default": { "resolvesTo": "semantic.color.border.subtle", "fallback": "#e0e0e0" }
  },
  ".details--icon-none .details__icon": {
    "display": { "literal": "none", "platforms": ["web"] }
  },
  ".details--icon-right .details__icon": {
    "order": { "literal": "1", "platforms": ["web"] },
    "margin-inline-start": { "literal": "auto", "platforms": ["web"] }
  }
}
