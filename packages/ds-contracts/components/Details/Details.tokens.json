{
  "root": {
    "details.size.padding.default": {
      "resolvesTo": "core.spacing.size.06",
      "fallback": "16px",
      "property": "padding",
      "layer": "core"
    },
    "details.size.radius.default": {
      "resolvesTo": "semantic.shape.control.radius.default",
      "fallback": "8px",
      "property": "border-radius",
      "layer": "semantic"
    },
    "details.size.icon": {
      "resolvesTo": "core.spacing.size.05",
      "fallback": "12px",
      "layer": "core"
    },
    "details.color.background.default": {
      "resolvesTo": "semantic.color.background.primary",
      "fallback": "#ffffff",
      "property": "background-color",
      "layer": "semantic"
    },
    "details.color.foreground.primary": {
      "resolvesTo": "semantic.color.foreground.primary",
      "fallback": "#141414",
      "property": "color",
      "layer": "semantic"
    },
    "details.color.foreground.secondary": {
      "resolvesTo": "semantic.color.foreground.secondary",
      "fallback": "#555555",
      "property": "color",
      "layer": "semantic"
    },
    "details.color.border.default": {
      "resolvesTo": "semantic.color.border.primary",
      "fallback": "#f29495",
      "property": "border-color",
      "layer": "semantic"
    },
    "details.color.border.accent": {
      "resolvesTo": "semantic.color.border.accent",
      "fallback": "#d9292b",
      "property": "border-color",
      "layer": "semantic"
    },
    "details.focus.ring.width": {
      "resolvesTo": "core.shape.border.width.thick",
      "fallback": "2px",
      "layer": "core"
    },
    "details.focus.ring.color": {
      "resolvesTo": "semantic.color.border.accent",
      "fallback": "#d9292b",
      "layer": "semantic"
    },
    "details.focus.ring.offset": {
      "resolvesTo": "core.spacing.size.02",
      "fallback": "2px",
      "layer": "core"
    },
    "details.spacing.gap.default": {
      "resolvesTo": "core.spacing.size.02",
      "fallback": "2px",
      "property": "gap",
      "layer": "core"
    },
    "details.typography.lineHeight.body": {
      "resolvesTo": "semantic.typography.line.height.body",
      "fallback": "1.5",
      "property": "line-height",
      "layer": "semantic"
    },
    "details.typography.fontWeight.medium": {
      "resolvesTo": "semantic.typography.font.weight.medium",
      "fallback": "500",
      "layer": "semantic"
    }
  },
  "hover": {
    "details.color.background.hover": {
      "resolvesTo": "semantic.color.background.hover",
      "fallback": "#cecece",
      "property": "background-color",
      "layer": "semantic"
    },
    "details.color.border.hover": {
      "resolvesTo": "semantic.color.border.bold",
      "fallback": "#8f8f8f",
      "property": "border-color",
      "layer": "semantic"
    }
  }
}
