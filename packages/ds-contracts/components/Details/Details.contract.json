{
  "$schema": "../../component.contract.schema.json",
  "name": "Details",
  "description": "Disclosure widget revealing additional content on demand. Semantically equivalent to <details>/<summary>.",
  "layer": "composer",
  "category": "structure",
  "anatomy": {
    "parts": [
      "root",
      "summary",
      "summaryContent",
      "icon",
      "summaryText",
      "content"
    ],
    "details": {
      "root": {
        "tag": "details",
        "description": "Native disclosure container that owns the open state.",
        "role": "root",
        "collapsibleTo": "native-disclosure"
      },
      "summary": {
        "tag": "summary",
        "description": "Native disclosure trigger that toggles the details content.",
        "role": "trigger",
        "interactive": true,
        "focusable": true
      },
      "summaryContent": {
        "tag": "span",
        "description": "Layout wrapper for summary icon and text.",
        "role": "group"
      },
      "icon": {
        "tag": "span",
        "description": "Optional decorative disclosure indicator.",
        "role": "decoration"
      },
      "summaryText": {
        "tag": "span",
        "description": "Visible summary label for the disclosure trigger.",
        "role": "label"
      },
      "content": {
        "tag": "div",
        "description": "Content region revealed when the disclosure is open.",
        "role": "content"
      }
    },
    "dom": {
      "tag": "details",
      "part": "root",
      "bindings": {
        "open": "channel:open.value"
      },
      "children": [
        {
          "tag": "summary",
          "part": "summary",
          "children": [
            {
              "tag": "span",
              "part": "summaryContent",
              "children": [
                {
                  "tag": "span",
                  "part": "icon"
                },
                {
                  "tag": "span",
                  "part": "summaryText",
                  "content": "prop:summary"
                }
              ]
            }
          ]
        },
        {
          "tag": "div",
          "part": "content",
          "if": "open",
          "children": [
            {
              "tag": "children"
            }
          ]
        }
      ]
    }
  },
  "props": {
    "styled": {
      "description": "Props for the <Details> disclosure component.",
      "members": [
        {
          "name": "summary",
          "type": "string",
          "description": "The summary text displayed in the toggle button.",
          "required": true
        },
        {
          "name": "open",
          "type": "boolean",
          "description": "Controlled open state."
        },
        {
          "name": "defaultOpen",
          "type": "boolean",
          "description": "Default open state for uncontrolled usage."
        },
        {
          "name": "onOpenChange",
          "type": "(open: boolean) => void",
          "description": "Called when open state changes."
        },
        {
          "name": "disabled",
          "type": "boolean",
          "description": "Disabled state."
        },
        {
          "name": "variant",
          "type": "DetailsVariant",
          "description": "Visual variant."
        },
        {
          "name": "icon",
          "type": "DetailsIcon",
          "description": "Icon position or absence."
        }
      ]
    }
  },
  "channels": {
    "open": {
      "value": "open",
      "defaultValue": "defaultOpen",
      "onChange": "onOpenChange",
      "valueType": "boolean",
      "description": "Whether the disclosure is expanded."
    }
  },
  "types": {
    "DetailsVariant": {
      "kind": "union",
      "values": [
        "default",
        "inline",
        "compact"
      ]
    },
    "DetailsIcon": {
      "kind": "union",
      "values": [
        "left",
        "right",
        "none"
      ]
    }
  },
  "variants": {
    "variant": [
      "default",
      "inline",
      "compact"
    ],
    "icon": [
      "left",
      "right",
      "none"
    ]
  },
  "states": {
    "dimensions": {
      "pointer": {
        "category": "interaction",
        "values": [
          "default",
          "hover"
        ],
        "initial": "default",
        "exclusive": true
      },
      "focus": {
        "category": "interaction",
        "values": [
          "unfocused",
          "focus"
        ],
        "initial": "unfocused",
        "exclusive": true
      },
      "availability": {
        "category": "availability",
        "effect": "restyle",
        "values": [
          "enabled",
          "disabled"
        ],
        "initial": "enabled",
        "exclusive": true,
        "suppresses": {
          "categories": [
            "interaction"
          ]
        }
      },
      "disclosure": {
        "category": "visibility",
        "effect": "channel",
        "values": [
          "closed",
          "open"
        ],
        "initial": "closed",
        "exclusive": true,
        "a11y": {
          "attribute": "aria-expanded",
          "values": {
            "closed": "false",
            "open": "true"
          }
        }
      }
    }
  },
  "slots": {
    "compact": {
      "required": false
    },
    "inline": {
      "required": false
    },
    "root": {
      "required": true,
      "selector": "[data-slot=\"details\"]"
    },
    "summary": {
      "required": true,
      "selector": "[data-slot=\"details-summary\"]"
    },
    "content": {
      "required": true,
      "selector": "[data-slot=\"details-content\"]"
    }
  },
  "focus": {
    "strategy": "auto",
    "description": "Native <details>/<summary> focus behavior; no custom roving or trap required."
  },
  "portal": {
    "enabled": false
  },
  "dismissal": {
    "triggers": []
  },
  "relationships": [
    {
      "from": "summary",
      "to": "content",
      "attribute": "aria-controls",
      "description": "Native HTML: <summary> implicitly controls the sibling content via the <details> open attribute."
    }
  ],
  "ssr": {
    "hydrateOn": "interaction"
  },
  "rtl": {
    "flipIcon": true
  },
  "a11y": {
    "role": "group",
    "apgPattern": null,
    "labeling": [
      "aria-label"
    ],
    "keyboard": [
      {
        "key": "Enter",
        "action": "Toggle the disclosure open or closed.",
        "when": "summary"
      },
      {
        "key": "Space",
        "action": "Toggle the disclosure open or closed.",
        "when": "summary"
      }
    ]
  },
  "a2ui": {
    "category": "content",
    "usageHints": [
      "Use for progressive disclosure of non-critical detail",
      "Not for navigation — use Accordion for a multi-section expand/collapse list",
      "The summary is always visible; the content is hidden until expanded"
    ],
    "children": {
      "allowed": true,
      "slot": "children",
      "accepts": [
        "ReactNode"
      ]
    }
  }
}
