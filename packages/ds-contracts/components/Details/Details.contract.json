{
  "$schema": "../../component.contract.schema.json",
  "name": "Details",
  "description": "Disclosure widget revealing additional content on demand. Semantically equivalent to <details>/<summary>.",
  "layer": "composer",
  "anatomy": {
    "parts": [
      "root",
      "summary",
      "summaryContent",
      "icon",
      "summaryText",
      "content"
    ],
    "dom": {
      "tag": "details",
      "part": "root",
      "bindings": {
        "open": "channel:open.value"
      },
      "children": [
        {
          "tag": "summary",
          "part": "summary",
          "children": [
            {
              "tag": "span",
              "part": "summaryContent",
              "children": [
                {
                  "tag": "span",
                  "part": "icon"
                },
                {
                  "tag": "span",
                  "part": "summaryText",
                  "bindings": {
                    "textContent": "prop:summary"
                  }
                }
              ]
            }
          ]
        },
        {
          "tag": "div",
          "part": "content",
          "if": "open",
          "children": [
            {
              "tag": "children"
            }
          ]
        }
      ]
    }
  },
  "props": {
    "styled": {
      "description": "Props for the <Details> disclosure component.",
      "members": [
        {
          "name": "summary",
          "type": "string",
          "description": "The summary text displayed in the toggle button.",
          "required": true
        },
        {
          "name": "open",
          "type": "boolean",
          "description": "Controlled open state."
        },
        {
          "name": "defaultOpen",
          "type": "boolean",
          "description": "Default open state for uncontrolled usage."
        },
        {
          "name": "onOpenChange",
          "type": "(open: boolean) => void",
          "description": "Called when open state changes."
        },
        {
          "name": "disabled",
          "type": "boolean",
          "description": "Disabled state."
        },
        {
          "name": "variant",
          "type": "DetailsVariant",
          "description": "Visual variant."
        },
        {
          "name": "icon",
          "type": "DetailsIcon",
          "description": "Icon position or absence."
        }
      ]
    }
  },
  "channels": {
    "open": {
      "value": "open",
      "defaultValue": "defaultOpen",
      "onChange": "onOpenChange",
      "valueType": "boolean",
      "description": "Whether the disclosure is expanded."
    }
  },
  "types": {
    "DetailsVariant": {
      "kind": "union",
      "values": [
        "default",
        "inline",
        "compact"
      ]
    },
    "DetailsIcon": {
      "kind": "union",
      "values": [
        "left",
        "right",
        "none"
      ]
    }
  },
  "variants": {
    "variant": [
      "default",
      "inline",
      "compact"
    ],
    "icon": [
      "left",
      "right",
      "none"
    ]
  },
  "states": [
    "default",
    "hover",
    "focus",
    "disabled",
    "open",
    "closed"
  ],
  "tokens": {
    "root": {
      "details.size.padding.default": {
        "resolvesTo": "core.spacing.size.06",
        "fallback": "16px",
        "property": "padding",
        "layer": "core"
      },
      "details.size.radius.default": {
        "resolvesTo": "semantic.shape.control.radius.default",
        "fallback": "8px",
        "property": "border-radius",
        "layer": "semantic"
      },
      "details.size.icon": {
        "resolvesTo": "core.spacing.size.05",
        "fallback": "12px",
        "layer": "core"
      },
      "details.color.background.default": {
        "resolvesTo": "semantic.color.background.primary",
        "fallback": "#ffffff",
        "property": "background-color",
        "layer": "semantic"
      },
      "details.color.foreground.primary": {
        "resolvesTo": "semantic.color.foreground.primary",
        "fallback": "#141414",
        "property": "color",
        "layer": "semantic"
      },
      "details.color.foreground.secondary": {
        "resolvesTo": "semantic.color.foreground.secondary",
        "fallback": "#555555",
        "property": "color",
        "layer": "semantic"
      },
      "details.color.border.default": {
        "resolvesTo": "semantic.color.border.primary",
        "fallback": "#f29495",
        "property": "border-color",
        "layer": "semantic"
      },
      "details.color.border.accent": {
        "resolvesTo": "semantic.color.border.accent",
        "fallback": "#d9292b",
        "property": "border-color",
        "layer": "semantic"
      },
      "details.focus.ring.width": {
        "resolvesTo": "core.shape.border.width.thick",
        "fallback": "2px",
        "layer": "core"
      },
      "details.focus.ring.color": {
        "resolvesTo": "semantic.color.border.accent",
        "fallback": "#d9292b",
        "layer": "semantic"
      },
      "details.focus.ring.offset": {
        "resolvesTo": "core.spacing.size.02",
        "fallback": "2px",
        "layer": "core"
      },
      "details.spacing.gap.default": {
        "resolvesTo": "core.spacing.size.02",
        "fallback": "2px",
        "property": "gap",
        "layer": "core"
      },
      "details.typography.lineHeight.body": {
        "resolvesTo": "semantic.typography.line.height.body",
        "fallback": "1.5",
        "property": "line-height",
        "layer": "semantic"
      },
      "details.typography.fontWeight.medium": {
        "resolvesTo": "semantic.typography.font.weight.medium",
        "fallback": "500",
        "layer": "semantic"
      }
    },
    "hover": {
      "details.color.background.hover": {
        "resolvesTo": "semantic.color.background.hover",
        "fallback": "#cecece",
        "property": "background-color",
        "layer": "semantic"
      },
      "details.color.border.hover": {
        "resolvesTo": "semantic.color.border.bold",
        "fallback": "#8f8f8f",
        "property": "border-color",
        "layer": "semantic"
      }
    }
  },
  "slots": {
    "compact": {
      "required": false
    },
    "inline": {
      "required": false
    },
    "root": {
      "required": true,
      "selector": "[data-slot=\"details\"]"
    },
    "summary": {
      "required": true,
      "selector": "[data-slot=\"details-summary\"]"
    },
    "content": {
      "required": true,
      "selector": "[data-slot=\"details-content\"]"
    }
  },
  "focus": {
    "strategy": "auto",
    "description": "Native <details>/<summary> focus behavior; no custom roving or trap required."
  },
  "portal": {
    "enabled": false
  },
  "dismissal": {
    "triggers": []
  },
  "relationships": [
    {
      "from": "summary",
      "to": "content",
      "attribute": "aria-controls",
      "description": "Native HTML: <summary> implicitly controls the sibling content via the <details> open attribute."
    }
  ],
  "ssr": {
    "hydrateOn": "interaction"
  },
  "rtl": {
    "flipIcon": true
  },
  "a11y": {
    "role": "group",
    "apgPattern": null,
    "labeling": [
      "aria-label"
    ],
    "keyboard": [
      {
        "key": "Enter",
        "action": "Toggle the disclosure open or closed.",
        "when": "summary"
      },
      {
        "key": "Space",
        "action": "Toggle the disclosure open or closed.",
        "when": "summary"
      }
    ]
  },
  "a2ui": {
    "category": "content",
    "usageHints": [
      "Use for progressive disclosure of non-critical detail",
      "Not for navigation \u2014 use Accordion for a multi-section expand/collapse list",
      "The summary is always visible; the content is hidden until expanded"
    ],
    "children": {
      "allowed": true,
      "slot": "children",
      "accepts": [
        "ReactNode"
      ]
    }
  }
}
