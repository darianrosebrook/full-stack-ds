{
  "$schema": "../../component.contract.schema.json",
  "name": "Avatar",
  "description": "Circular user or entity representation showing an image, initials, or icon fallback.",
  "layer": "compound",
  "category": "glyph",
  "anatomy": {
    "parts": [
      "root",
      "image",
      "initials",
      "status"
    ],
    "dom": {
      "tag": "div",
      "part": "root",
      "bindings": {
        "aria-label": "prop:name"
      },
      "children": [
        {
          "tag": "img",
          "part": "image",
          "if": "src",
          "bindings": {
            "src": "prop:src",
            "alt": "literal:"
          }
        }
      ]
    }
  },
  "props": {
    "styled": {
      "description": "Props for the <Avatar> component.",
      "members": [
        {
          "name": "src",
          "type": "string",
          "description": "Image source URL. Omit to render initials from `name`."
        },
        {
          "name": "name",
          "type": "string",
          "description": "User/entity name. Used for initials fallback and as the accessible label.",
          "required": true
        },
        {
          "name": "priority",
          "type": "boolean",
          "description": "Mark image as priority for above-the-fold loading."
        }
      ]
    }
  },
  "variants": {
    "size": [
      "small",
      "medium",
      "large",
      "extra-large"
    ]
  },
  "states": [
    "default",
    "focus"
  ],
  "slots": {
    "root": {
      "required": true,
      "selector": "[data-slot=\"avatar\"]"
    },
    "image": {
      "required": false,
      "selector": "[data-slot=\"avatar-image\"]"
    },
    "initials": {
      "required": false,
      "selector": "[data-slot=\"avatar-initials\"]"
    }
  },
  "ssr": {
    "hydrateOn": "none"
  },
  "rtl": {
    "flipIcon": false
  },
  "a11y": {
    "role": "img",
    "labeling": [
      "aria-label"
    ],
    "keyboard": []
  },
  "a2ui": {
    "category": "display",
    "usageHints": [
      "Provide src and alt for image avatars; omit src to render initials from the name prop",
      "Use size to scale the avatar to fit its context (xs through xl)",
      "Always set alt text or a name prop so screen readers have a meaningful label"
    ],
    "children": {
      "allowed": false
    }
  }
}
