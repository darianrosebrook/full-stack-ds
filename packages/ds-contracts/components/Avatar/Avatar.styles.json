{
  "root": {
    "display": {
      "literal": "inline-flex",
      "platforms": [
        "web"
      ]
    },
    "align-items": {
      "literal": "center",
      "platforms": [
        "web"
      ]
    },
    "justify-content": {
      "literal": "center",
      "platforms": [
        "web"
      ]
    },
    "overflow": {
      "literal": "hidden",
      "platforms": [
        "web"
      ]
    },
    "position": {
      "literal": "relative",
      "platforms": [
        "web"
      ]
    },
    "border-radius": {
      "resolvesTo": "avatar.size.radius.default"
    },
    "background-color": {
      "resolvesTo": "avatar.color.background.default"
    },
    "color": {
      "resolvesTo": "avatar.color.foreground.primary"
    },
    "border-color": {
      "resolvesTo": "avatar.color.border.default"
    },
    "border-style": {
      "literal": "solid",
      "platforms": [
        "web"
      ]
    },
    "border-width": {
      "resolvesTo": "avatar.size.border.default"
    },
    "width": {
      "resolvesTo": "avatar.size.default"
    },
    "height": {
      "resolvesTo": "avatar.size.default"
    },
    "font-weight": {
      "resolvesTo": "avatar.typography.fontWeight.medium"
    },
    "font-family": {
      "resolvesTo": "avatar.typography.fontFamily.sans"
    }
  },
  "image": {
    "width": {
      "literal": "100%",
      "platforms": [
        "web"
      ]
    },
    "height": {
      "literal": "100%",
      "platforms": [
        "web"
      ]
    },
    "object-fit": {
      "literal": "cover",
      "platforms": [
        "web"
      ]
    },
    "display": {
      "literal": "block",
      "platforms": [
        "web"
      ]
    }
  },
  "--small": {
    "width": { "resolvesTo": "avatar.size.small" },
    "height": { "resolvesTo": "avatar.size.small" }
  },
  "--medium": {
    "width": { "resolvesTo": "avatar.size.medium" },
    "height": { "resolvesTo": "avatar.size.medium" }
  },
  "--large": {
    "width": { "resolvesTo": "avatar.size.large" },
    "height": { "resolvesTo": "avatar.size.large" }
  },
  "--extra-large": {
    "width": { "resolvesTo": "avatar.size.extra-large" },
    "height": { "resolvesTo": "avatar.size.extra-large" }
  }
}
