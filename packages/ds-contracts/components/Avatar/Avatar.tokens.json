  },
  "avatar.color.background.inverse": {
    "resolvesTo": "semantic.color.background.inverse",
    "fallback": "#141414",
    "layer": "semantic"
  },
  "avatar.color.foreground.primary": {
    "resolvesTo": "semantic.color.foreground.primary",
    "fallback": "#141414",
    "layer": "semantic"
  },
  "avatar.color.border.default": {
    "resolvesTo": "semantic.color.border.light",
    "fallback": "#fceaea",
    "layer": "semantic"
  },
  "avatar.typography.fontWeight.medium": {
    "resolvesTo": "core.typography.weight.medium",
    "fallback": "500",
    "layer": "core"
  },
  "avatar.typography.fontFamily.sans": {
    "resolvesTo": "core.typography.font.family.sans",
    "fallback": "\"Inter\", sans-serif",
    "layer": "core"
  }
