{
  "box-model.padding-block-start": {
    "resolvesTo": "semantic.surface.size.padding-block",
    "fallback": "16px",
    "layer": "semantic"
  },
  "box-model.padding-block-end": {
    "resolvesTo": "semantic.surface.size.padding-block",
    "fallback": "16px",
    "layer": "semantic"
  },
  "box-model.padding-inline-start": {
    "resolvesTo": "semantic.surface.size.padding-inline",
    "fallback": "16px",
    "layer": "semantic"
  },
  "box-model.padding-inline-end": {
    "resolvesTo": "semantic.surface.size.padding-inline",
    "fallback": "16px",
    "layer": "semantic"
  },
  "box-model.gap": {
    "resolvesTo": "semantic.surface.size.gap",
    "fallback": "12px",
    "layer": "semantic"
  },
  "box-model.min-width": {
    "resolvesTo": "semantic.surface.size.min-width",
    "fallback": "64px",
    "layer": "semantic"
  },
  "tooltip.color.background.default": {
    "resolvesTo": "semantic.color.background.inverse",
    "fallback": "#141414",
    "layer": "semantic"
  },
  "tooltip.color.foreground.default": {
    "resolvesTo": "semantic.color.foreground.inverse",
    "fallback": "#fafafa",
    "layer": "semantic"
  },
  "tooltip.color.border.default": {
    "resolvesTo": "semantic.color.border.subtle",
    "fallback": "#cecece",
    "layer": "semantic"
  },
  "tooltip.size.padding.y": {
    "resolvesTo": "core.spacing.size.03",
    "fallback": "4px",
    "layer": "core"
  },
  "tooltip.size.padding.x": {
    "resolvesTo": "core.spacing.size.04",
    "fallback": "8px",
    "layer": "core"
  },
  "tooltip.size.radius.default": {
    "resolvesTo": "core.shape.radius.small",
    "fallback": "4px",
    "layer": "core"
  },
  "tooltip.size.maxWidth": {
    "literal": "200px"
  },
  "tooltip.typography.fontSize": {
    "resolvesTo": "semantic.typography.caption.01",
    "fallback": "14px",
    "layer": "semantic"
  },
  "tooltip.layer.content": {
    "resolvesTo": "core.layer.tooltip",
    "fallback": "1800",
    "layer": "core"
  }
}
