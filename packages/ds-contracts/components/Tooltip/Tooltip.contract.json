{
  "$schema": "../../component.contract.schema.json",
  "name": "Tooltip",
  "description": "Anchored ephemeral presence surface that exposes supplemental information about a trigger element on hover or focus. Composes as <Tooltip><Tooltip.Trigger>...</Tooltip.Trigger><Tooltip.Content>...</Tooltip.Content></Tooltip>; the substrate wires aria-describedby, hover/focus opening, and escape/blur/pointer-leave dismissal.",
  "layer": "composer",
  "category": "surface",
  "anatomy": {
    "parts": [
      "root",
      "trigger",
      "content"
    ],
    "details": {
      "root": {
        "role": "group"
      },
      "trigger": {
        "role": "trigger",
        "interactive": true,
        "focusable": true
      },
      "content": {
        "role": "content",
        "aria": {
          "role": "tooltip"
        }
      }
    }
  },
  "props": {
    "styled": {
      "description": "Props for the <Tooltip> root component.",
      "members": [
        {
          "name": "open",
          "type": "boolean",
          "description": "Controlled visibility."
        },
        {
          "name": "defaultOpen",
          "type": "boolean",
          "description": "Uncontrolled initial visibility."
        },
        {
          "name": "onOpenChange",
          "type": "(open: boolean) => void",
          "description": "Called when visibility changes."
        },
        {
          "name": "placement",
          "type": "TooltipPlacement",
          "description": "Preferred placement. May be overridden by collision detection."
        },
        {
          "name": "disabled",
          "type": "boolean",
          "description": "Suppresses the tooltip entirely; the trigger renders but never opens."
        },
        {
          "name": "closeOnEscape",
          "type": "boolean",
          "description": "When true, Escape closes the tooltip and returns focus is preserved.",
          "default": true
        },
        {
          "name": "closeOnBlur",
          "type": "boolean",
          "description": "When true, blur on the trigger closes the tooltip.",
          "default": true
        }
      ]
    }
  },
  "channels": {
    "open": {
      "value": "open",
      "defaultValue": "defaultOpen",
      "onChange": "onOpenChange",
      "valueType": "boolean",
      "description": "Whether the tooltip is visible."
    }
  },
  "types": {
    "TooltipPlacement": {
      "kind": "union",
      "values": [
        "top",
        "bottom",
        "left",
        "right",
        "auto"
      ]
    }
  },
  "variants": {
    "placement": [
      "top",
      "bottom",
      "left",
      "right",
      "auto"
    ]
  },
  "states": {
    "dimensions": {
      "pointer": {
        "category": "interaction",
        "values": [
          "default",
          "hover"
        ],
        "initial": "default",
        "exclusive": true
      },
      "transition": {
        "category": "motion",
        "effect": "channel",
        "values": [
          "idle",
          "entering",
          "leaving"
        ],
        "initial": "idle",
        "exclusive": true
      }
    }
  },
  "motion": {
    "reducedMotion": "respect",
    "reducedMotionStrategy": "Duration set to 0; tooltip appears/disappears instantly without opacity transition.",
    "transitions": [
      {
        "name": "show",
        "trigger": "visibility=hidden→visible",
        "phase": "enter",
        "properties": [
          "opacity"
        ],
        "duration": "core.motion.duration.short",
        "easing": "core.motion.easing.soft-enter"
      },
      {
        "name": "hide",
        "trigger": "visibility=visible→hidden",
        "phase": "exit",
        "properties": [
          "opacity"
        ],
        "duration": "core.motion.duration.short",
        "easing": "core.motion.easing.soft-exit"
      }
    ]
  },
  "focus": {
    "strategy": "none",
    "description": "Tooltip never takes focus — it is non-interactive. The trigger element retains focus throughout the tooltip's lifecycle."
  },
  "portal": {
    "enabled": true,
    "defaultTarget": "body",
    "positioning": "anchored",
    "layering": "tooltip",
    "collision": "flip-shift"
  },
  "dismissal": {
    "triggers": [
      {
        "event": "escape",
        "enabledBy": "closeOnEscape"
      },
      {
        "event": "blur",
        "enabledBy": "closeOnBlur"
      }
    ]
  },
  "surface": {
    "kind": "tooltip",
    "presence": "ephemeral",
    "modality": "non-blocking",
    "anchor": {
      "part": "trigger",
      "relation": "describedby"
    },
    "content": {
      "part": "content",
      "interactive": false
    },
    "positioning": {
      "strategy": "anchored",
      "placementProp": "placement",
      "collision": "flip-shift"
    },
    "dismissal": [
      "escape",
      "blur",
      "pointer-leave"
    ],
    "openTriggers": [
      "hover",
      "focus"
    ]
  },
  "slots": {
    "root": {
      "required": true,
      "selector": "[data-slot=\"tooltip\"]"
    }
  },
  "ssr": {
    "hydrateOn": "interaction"
  },
  "rtl": {
    "flipIcon": false
  },
  "relationships": [
    {
      "from": "trigger",
      "to": "root",
      "attribute": "aria-describedby",
      "when": "visibility=visible",
      "description": "Trigger's aria-describedby points to the tooltip content's id when visible, providing supplemental screen-reader description."
    }
  ],
  "a11y": {
    "role": "tooltip",
    "apgPattern": "tooltip",
    "labeling": [
      "aria-describedby"
    ],
    "keyboard": [
      {
        "key": "Escape",
        "action": "Dismiss the tooltip without moving focus from the trigger (WCAG 2.1 SC 1.4.13)."
      }
    ]
  },
  "a2ui": {
    "category": "overlay",
    "usageHints": [
      "Wrap any focusable element as the Tooltip trigger child",
      "Keep tooltip content to a single brief phrase — never include interactive elements",
      "Use placement to control which side the tooltip appears on",
      "Tooltip satisfies WCAG 2.1 SC 1.4.13 — it is dismissible via Escape"
    ],
    "children": {
      "allowed": true,
      "slot": "trigger",
      "accepts": [
        "node-ref"
      ]
    }
  }
}
