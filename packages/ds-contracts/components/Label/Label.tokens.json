{
  "box-model.gap": {
    "resolvesTo": "semantic.display.size.gap",
    "fallback": "4px",
    "layer": "semantic"
  },
  "label.color.text.default": {
    "resolvesTo": "semantic.color.foreground.primary",
    "fallback": "#141414",
    "layer": "semantic"
  },
  "label.typo.weight.default": {
    "resolvesTo": "semantic.typography.font.weight.medium",
    "fallback": "500",
    "layer": "semantic"
  },
  "label.typo.lineHeight.default": {
    "resolvesTo": "semantic.typography.line.height.tight",
    "fallback": "1.2",
    "layer": "semantic"
  }
}
