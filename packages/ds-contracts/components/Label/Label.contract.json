{
  "$schema": "../../component.contract.schema.json",
  "name": "Label",
  "description": "Accessible form label associated with a control via htmlFor.",
  "layer": "primitive",
  "category": "display",
  "anatomy": {
    "parts": [
      "root"
    ],
    "dom": {
      "tag": "label",
      "part": "root",
      "bindings": {
        "htmlFor": "prop:htmlFor",
        "form": "prop:form"
      },
      "children": [
        {
          "tag": "children"
        }
      ]
    }
  },
  "props": {
    "designed": {
      "members": [
        {
          "name": "htmlFor",
          "propType": { "kind": "string" },
          "description": "ID of the form control this label is associated with."
        },
        {
          "name": "form",
          "propType": { "kind": "string" },
          "description": "ID of the form this label belongs to."
        }
      ]
    }
  },
  "states": {
    "dimensions": {
      "pointer": {
        "category": "interaction",
        "values": [
          "default"
        ],
        "initial": "default",
        "exclusive": true
      }
    }
  },
  "slots": {
    "root": {
      "required": true,
      "selector": "[data-slot=\"label\"]"
    }
  },
  "ssr": {
    "hydrateOn": "none"
  },
  "rtl": {
    "flipIcon": false
  },
  "a11y": {
    "labeling": [],
    "keyboard": []
  },
  "a2ui": {
    "category": "form-field",
    "usageHints": [
      "Always pair with an input via htmlFor; do not use as decorative text",
      "TextField automatically wires Label to its Input — use Label directly only when composing custom forms"
    ],
    "children": {
      "allowed": true,
      "slot": "children",
      "accepts": [
        "string"
      ]
    }
  }
}
