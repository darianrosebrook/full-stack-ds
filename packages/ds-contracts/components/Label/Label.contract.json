{
  "$schema": "../../component.contract.schema.json",
  "name": "Label",
  "description": "Accessible form label associated with a control via htmlFor.",
  "layer": "primitive",
  "anatomy": {
    "parts": [
      "root"
    ],
    "dom": {
      "tag": "label",
      "part": "root",
      "bindings": {
        "htmlFor": "prop:htmlFor",
        "form": "prop:form"
      },
      "children": [
        {
          "tag": "children"
        }
      ]
    }
  },
  "props": {
    "styled": {
      "description": "Props for the <Label> component.",
      "members": [
        {
          "name": "htmlFor",
          "type": "string",
          "description": "ID of the form control this label is associated with."
        },
        {
          "name": "form",
          "type": "string",
          "description": "ID of the form this label belongs to."
        }
      ]
    }
  },
  "states": [
    "default"
  ],
  "slots": {
    "root": {
      "required": true,
      "selector": "[data-slot=\"label\"]"
    }
  },
  "ssr": {
    "hydrateOn": "none"
  },
  "rtl": {
    "flipIcon": false
  },
  "a11y": {
    "labeling": [],
    "keyboard": []
  },
  "a2ui": {
    "category": "form-field",
    "usageHints": [
      "Always pair with an input via htmlFor; do not use as decorative text",
      "TextField automatically wires Label to its Input \u2014 use Label directly only when composing custom forms"
    ],
    "children": {
      "allowed": true,
      "slot": "children",
      "accepts": [
        "string"
      ]
    }
  }
}
