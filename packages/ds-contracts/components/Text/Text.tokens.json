{
  "box-model.gap": {
    "resolvesTo": "semantic.display.size.gap",
    "fallback": "4px",
    "layer": "semantic"
  },
  "text.color.foreground.primary": {
    "resolvesTo": "semantic.color.foreground.primary",
    "fallback": "#141414",
    "layer": "semantic"
  },
  "text.typography.fontWeight.light": {
    "resolvesTo": "semantic.typography.font.weight.light",
    "fallback": "300",
    "layer": "semantic"
  },
  "text.typography.fontWeight.regular": {
    "resolvesTo": "semantic.typography.font.weight.regular",
    "fallback": "400",
    "layer": "semantic"
  },
  "text.typography.fontWeight.medium": {
    "resolvesTo": "semantic.typography.font.weight.medium",
    "fallback": "500",
    "layer": "semantic"
  },
  "text.typography.fontWeight.bold": {
    "resolvesTo": "semantic.typography.font.weight.bold",
    "fallback": "700",
    "layer": "semantic"
  },
  "text.typography.lineHeight.heading": {
    "resolvesTo": "semantic.typography.line.height.heading",
    "fallback": "1",
    "layer": "semantic"
  },
  "text.typography.lineHeight.body": {
    "resolvesTo": "semantic.typography.line.height.body",
    "fallback": "1.5",
    "layer": "semantic"
  }
}
