{
  "root": {
    "color": {
      "resolvesTo": "text.color.foreground.primary"
    },
    "line-height": {
      "resolvesTo": "text.typography.lineHeight.body"
    },
    "margin": {
      "literal": "0",
      "platforms": [
        "web"
      ]
    }
  },
  "--title": {
    "font-weight": {
      "resolvesTo": "text.typography.fontWeight.bold"
    },
    "line-height": {
      "resolvesTo": "text.typography.lineHeight.heading"
    },
    "color": {
      "resolvesTo": "text.color.foreground.primary"
    }
  },
  "--body": {
    "font-weight": {
      "resolvesTo": "text.typography.fontWeight.regular"
    },
    "line-height": {
      "resolvesTo": "text.typography.lineHeight.body"
    },
    "color": {
      "resolvesTo": "semantic.color.foreground.secondary",
      "fallback": "#555555"
    }
  },
  "error": {
    "color": {
      "resolvesTo": "semantic.color.feedback.foreground.danger.default",
      "fallback": "#d9292b"
    }
  },
  "success": {
    "color": {
      "resolvesTo": "semantic.color.feedback.foreground.success.default",
      "fallback": "#1f8a4c"
    }
  }
}
