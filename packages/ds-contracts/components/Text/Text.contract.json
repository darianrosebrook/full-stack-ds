{
  "$schema": "../../component.contract.schema.json",
  "name": "Text",
  "description": "Polymorphic text element with design-system typography variants and semantic element control.",
  "layer": "primitive",
  "category": "display",
  "anatomy": {
    "parts": [
      "root"
    ],
    "dom": {
      "tag": "p",
      "part": "root"
    }
  },
  "props": {
    "designed": {
      "members": [
        {
          "name": "as",
          "propType": { "kind": "ref", "to": "TextElement" },
          "description": "Element tag to render."
        },
        {
          "name": "variant",
          "propType": { "kind": "ref", "to": "TextVariant" },
          "description": "Typography variant"
        },
        {
          "name": "size",
          "propType": { "kind": "ref", "to": "TextSize" },
          "description": "Type-scale size token"
        },
        {
          "name": "weight",
          "propType": { "kind": "ref", "to": "TextWeight" },
          "description": "Font weight token"
        },
        {
          "name": "align",
          "propType": { "kind": "ref", "to": "TextAlign" },
          "description": "Text alignment"
        },
        {
          "name": "transform",
          "propType": { "kind": "ref", "to": "TextTransform" },
          "description": "CSS text-transform"
        },
        {
          "name": "truncate",
          "propType": { "kind": "boolean" },
          "description": "Single-line truncation with ellipsis."
        }
      ]
    }
  },
  "types": {
    "TextElement": {
      "kind": "union",
      "values": [
        "p",
        "span",
        "div",
        "h1",
        "h2",
        "h3",
        "h4",
        "h5",
        "h6"
      ]
    },
    "TextVariant": {
      "kind": "union",
      "values": [
        "display",
        "headline",
        "title",
        "body",
        "caption",
        "overline",
        "code"
      ]
    },
    "TextSize": {
      "kind": "union",
      "values": [
        "xs",
        "sm",
        "md",
        "lg",
        "xl",
        "2xl",
        "3xl"
      ]
    },
    "TextWeight": {
      "kind": "union",
      "values": [
        "light",
        "normal",
        "medium",
        "semibold",
        "bold"
      ]
    },
    "TextAlign": {
      "kind": "union",
      "values": [
        "left",
        "center",
        "right",
        "justify"
      ]
    },
    "TextTransform": {
      "kind": "union",
      "values": [
        "none",
        "uppercase",
        "lowercase",
        "capitalize"
      ]
    }
  },
  "variants": {
    "variant": [
      "display",
      "headline",
      "title",
      "body",
      "caption",
      "overline",
      "code"
    ],
    "size": [
      "xs",
      "sm",
      "md",
      "lg",
      "xl",
      "2xl",
      "3xl"
    ],
    "weight": [
      "light",
      "normal",
      "medium",
      "semibold",
      "bold"
    ],
    "align": [
      "left",
      "center",
      "right",
      "justify"
    ],
    "transform": [
      "none",
      "uppercase",
      "lowercase",
      "capitalize"
    ]
  },
  "states": {
    "dimensions": {
      "pointer": {
        "category": "interaction",
        "values": [
          "default"
        ],
        "initial": "default",
        "exclusive": true
      },
      "validation": {
        "category": "validation",
        "effect": "restyle",
        "values": [
          "valid",
          "error",
          "success"
        ],
        "initial": "valid",
        "exclusive": true
      }
    }
  },
  "slots": {
    "root": {
      "required": true,
      "selector": "[data-slot=\"text\"]"
    }
  },
  "ssr": {
    "hydrateOn": "interaction"
  },
  "rtl": {
    "flipIcon": false
  },
  "a11y": {
    "labeling": [],
    "keyboard": []
  },
  "a2ui": {
    "category": "display",
    "usageHints": [
      "Use as to control the rendered element (p, span, h1–h6, label, etc.)",
      "Use variant to apply typography scale (body, caption, heading, etc.)",
      "Do not nest block-level Text elements inside inline ones"
    ],
    "children": {
      "allowed": true,
      "slot": "children",
      "accepts": [
        "string",
        "node-ref"
      ]
    }
  }
}
