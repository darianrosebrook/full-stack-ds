{
  "root": {
    "background-color": {
      "resolvesTo": "chip.color.background.default"
    },
    "color": {
      "resolvesTo": "chip.color.foreground.default"
    },
    "border-color": {
      "resolvesTo": "chip.color.border.default"
    },
    "padding": {
      "resolvesTo": "chip.size.padding.vertical"
    },
    "gap": {
      "resolvesTo": "chip.size.gap"
    },
    "border-radius": {
      "resolvesTo": "chip.size.radius"
    },
    "font-size": {
      "resolvesTo": "chip.text.size"
    },
    "font-weight": {
      "resolvesTo": "chip.text.weight"
    },
    "transition-duration": {
      "resolvesTo": "chip.motion.duration.fast"
    }
  },
  "hover": {
    "background-color": {
      "resolvesTo": "chip.color.background.hover"
    }
  },
  "active": {
    "background-color": {
      "resolvesTo": "chip.color.background.active"
    }
  },
  "icon": {
    "display": { "literal": "inline-flex", "platforms": ["web"] },
    "align-items": { "literal": "center", "platforms": ["web"] },
    "flex-shrink": { "literal": "0", "platforms": ["web"] },
    "width": { "literal": "1em", "platforms": ["web"] },
    "height": { "literal": "1em", "platforms": ["web"] },
    "margin-inline-end": { "literal": "2px", "platforms": ["web"] }
  },
  "text": {
    "display": { "literal": "inline-block", "platforms": ["web"] },
    "white-space": { "literal": "nowrap", "platforms": ["web"] },
    "text-overflow": { "literal": "ellipsis", "platforms": ["web"] },
    "overflow": { "literal": "hidden", "platforms": ["web"] },
    "font-size": { "resolvesTo": "chip.text.size" },
    "font-weight": { "resolvesTo": "chip.text.weight" }
  }
}
