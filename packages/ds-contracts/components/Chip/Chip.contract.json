{
  "$schema": "../../component.contract.schema.json",
  "name": "Chip",
  "description": "Compact interactive element for tags, filters, or multi-select choices. Optionally dismissible.",
  "layer": "compound",
  "category": "display",
  "anatomy": {
    "parts": [
      "root",
      "action",
      "icon",
      "text",
      "dismiss"
    ],
    "details": {
      "root": {
        "tag": "span",
        "description": "Non-interactive chip container that groups the action control and the optional dismiss control.",
        "role": "root"
      },
      "action": {
        "componentRef": "fsds.Button",
        "description": "Primary interactive control for the chip; activates the tag, filter, or choice. Realized by-reference as the Button primitive.",
        "role": "trigger",
        "interactive": true,
        "focusable": true,
        "aria": {
          "attributes": [
            "aria-label",
            "aria-expanded",
            "aria-pressed"
          ]
        }
      },
      "icon": {
        "tag": "span",
        "description": "Optional leading glyph for the chip; hidden from assistive technology.",
        "role": "decoration"
      },
      "text": {
        "tag": "span",
        "description": "Visible chip label supplied by children.",
        "role": "label"
      },
      "dismiss": {
        "componentRef": "fsds.Button",
        "description": "Optional control that removes the chip. Realized by-reference as the Button primitive.",
        "role": "trigger",
        "interactive": true,
        "focusable": true,
        "aria": {
          "attributes": [
            "aria-label"
          ]
        }
      }
    },
    "dom": {
      "tag": "span",
      "part": "root",
      "children": [
        {
          "componentRef": "fsds.Button",
          "part": "action",
          "attrs": {
            "variant": "ghost"
          },
          "bindings": {
            "type": "prop:type",
            "disabled": "prop:disabled",
            "ariaLabel": "prop:ariaLabel",
            "ariaExpanded": "prop:ariaExpanded",
            "ariaPressed": "prop:ariaPressed"
          },
          "events": {
            "click": "prop:onClick"
          },
          "children": [
            {
              "tag": "span",
              "part": "icon",
              "attrs": {
                "aria-hidden": "true"
              },
              "if": "icon"
            },
            {
              "tag": "span",
              "part": "text",
              "children": [
                {
                  "tag": "children"
                }
              ]
            }
          ]
        },
        {
          "componentRef": "fsds.Button",
          "part": "dismiss",
          "if": "dismissible",
          "attrs": {
            "type": "button",
            "variant": "ghost"
          },
          "bindings": {
            "disabled": "prop:disabled",
            "ariaLabel": "prop:dismissLabel"
          },
          "events": {
            "click": "prop:onDismiss"
          }
        }
      ]
    }
  },
  "props": {
    "designed": {
      "members": [
        {
          "name": "type",
          "propType": { "kind": "ref", "to": "ChipType" },
          "description": "HTML button type attribute for the action control."
        },
        {
          "name": "variant",
          "propType": { "kind": "ref", "to": "ChipVariant" },
          "description": "Visual variant"
        },
        {
          "name": "size",
          "propType": { "kind": "ref", "to": "ChipSize" },
          "description": "Size token"
        },
        {
          "name": "disabled",
          "propType": { "kind": "boolean" },
          "description": "Disables both the action and dismiss controls."
        },
        {
          "name": "icon",
          "propType": { "kind": "node", "of": "content" },
          "description": "Icon node to render. Omit for text-only chips."
        },
        {
          "name": "title",
          "propType": { "kind": "string" },
          "description": "Title attribute. Use to expose a tooltip-equivalent label."
        },
        {
          "name": "ariaLabel",
          "propType": { "kind": "string" },
          "description": "Accessible label for the action control when content is not descriptive enough on its own."
        },
        {
          "name": "ariaExpanded",
          "propType": { "kind": "boolean" },
          "description": "Sets aria-expanded on the action control for chips that toggle a popover/menu."
        },
        {
          "name": "ariaPressed",
          "propType": { "kind": "boolean" },
          "description": "Sets aria-pressed on the action control for chips used as toggle buttons."
        },
        {
          "name": "onClick",
          "propType": { "kind": "callback", "params": [], "returns": { "kind": "void" } },
          "description": "Handler invoked when the chip action control is activated (click / Enter / Space)."
        },
        {
          "name": "dismissible",
          "propType": { "kind": "boolean" },
          "description": "Whether the chip renders a dismiss control."
        },
        {
          "name": "onDismiss",
          "propType": { "kind": "callback", "params": [], "returns": { "kind": "void" } },
          "description": "Handler invoked when the dismiss control is activated. Required surface for `dismissible`; consumers handle removing the chip."
        },
        {
          "name": "dismissLabel",
          "propType": { "kind": "string" },
          "description": "Accessible label for the dismiss control.",
          "default": "Remove"
        }
      ]
    }
  },
  "types": {
    "ChipType": {
      "kind": "union",
      "values": [
        "button",
        "submit",
        "reset"
      ]
    },
    "ChipVariant": {
      "kind": "union",
      "values": [
        "default",
        "selected",
        "dismissible"
      ]
    },
    "ChipSize": {
      "kind": "union",
      "values": [
        "small",
        "medium",
        "large"
      ]
    }
  },
  "variants": {
    "variant": [
      "default",
      "selected",
      "dismissible"
    ],
    "size": [
      "small",
      "medium",
      "large"
    ]
  },
  "states": {
    "dimensions": {
      "pointer": {
        "category": "interaction",
        "values": [
          "default",
          "hover",
          "active"
        ],
        "initial": "default",
        "exclusive": true
      },
      "focus": {
        "category": "interaction",
        "values": [
          "unfocused",
          "focus"
        ],
        "initial": "unfocused",
        "exclusive": true
      },
      "availability": {
        "category": "availability",
        "effect": "restyle",
        "values": [
          "enabled",
          "disabled"
        ],
        "initial": "enabled",
        "exclusive": true,
        "suppresses": {
          "categories": [
            "interaction"
          ]
        }
      }
    }
  },
  "slots": {
    "root": {
      "required": true,
      "selector": "[data-slot=\"chip\"]"
    },
    "action": {
      "required": true,
      "selector": "[data-slot=\"chip-action\"]"
    },
    "text": {
      "required": false,
      "selector": "[data-slot=\"chip-text\"]"
    },
    "icon": {
      "required": false,
      "selector": "[data-slot=\"chip-icon\"]"
    },
    "dismiss": {
      "required": false,
      "selector": "[data-slot=\"chip-dismiss\"]"
    }
  },
  "ssr": {
    "hydrateOn": "interaction"
  },
  "rtl": {
    "flipIcon": true
  },
  "a11y": {
    "role": "button",
    "labeling": [
      "aria-label",
      "title"
    ],
    "keyboard": [
      {
        "key": "Enter|Space",
        "action": "Activate the chip action (same as click)"
      }
    ]
  },
  "a2ui": {
    "category": "action",
    "usageHints": [
      "Use variant=selected to mark the chip as active in a filter group",
      "Set dismissible with onDismiss to make the chip removable with an X control",
      "The chip action and the dismiss control are separate buttons; clicking the X does not activate the chip"
    ],
    "children": {
      "allowed": true,
      "slot": "children",
      "accepts": [
        "string"
      ]
    }
  }
}
