    "layer": "semantic"
  },
  "chip.focus.ring.style": {
    "resolvesTo": "semantic.focus.ring.style",
    "fallback": "solid",
    "layer": "semantic"
  },
  "chip.focus.ring.offset": {
    "resolvesTo": "semantic.focus.ring.offset",
    "fallback": "2px",
    "layer": "semantic"
  }
