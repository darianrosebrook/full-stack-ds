{
  "$schema": "../../component.contract.schema.json",
  "name": "TextField",
  "description": "Full-featured form field composing a label, input, optional description, and error message with ARIA wiring.",
  "layer": "composer",
  "category": "input",
  "anatomy": {
    "parts": [
      "root",
      "label",
      "field",
      "description",
      "error"
    ],
    "dom": {
      "tag": "div",
      "part": "root",
      "children": [
        {
          "tag": "label",
          "part": "label",
          "if": "label",
          "children": [
            {
              "tag": "children"
            }
          ]
        },
        {
          "tag": "input",
          "part": "field",
          "bindings": {
            "type": "prop:type",
            "value": "channel:value.value",
            "disabled": "prop:disabled",
            "name": "prop:name",
            "required": "prop:required",
            "aria-invalid": "prop:invalid",
            "aria-describedby": "prop:ariaDescribedby"
          },
          "events": {
            "change": "channel:value.onChange"
          }
        },
        {
          "tag": "span",
          "part": "description",
          "if": "description",
          "children": [
            {
              "tag": "children"
            }
          ]
        },
        {
          "tag": "span",
          "part": "error",
          "if": "error",
          "attrs": {
            "role": "alert"
          },
          "children": [
            {
              "tag": "children"
            }
          ]
        }
      ]
    }
  },
  "props": {
    "styled": {
      "description": "Props for the <TextField> component.",
      "members": [
        {
          "name": "label",
          "type": "ReactNode",
          "description": "Visible label rendered above the input."
        },
        {
          "name": "description",
          "type": "ReactNode",
          "description": "Helper text rendered below the input."
        },
        {
          "name": "error",
          "type": "ReactNode",
          "description": "Error message rendered below the input. Setting this also flips the field into invalid state."
        },
        {
          "name": "type",
          "type": "string",
          "description": "HTML input type."
        },
        {
          "name": "value",
          "type": "string",
          "description": "Controlled value."
        },
        {
          "name": "defaultValue",
          "type": "string",
          "description": "Uncontrolled initial value."
        },
        {
          "name": "onChange",
          "type": "(value: string) => void",
          "description": "Called when value changes."
        },
        {
          "name": "invalid",
          "type": "boolean",
          "description": "Applies error styling and sets aria-invalid."
        },
        {
          "name": "disabled",
          "type": "boolean",
          "description": "Prevents interaction."
        },
        {
          "name": "required",
          "type": "boolean",
          "description": "Marks the input as required."
        },
        {
          "name": "name",
          "type": "string",
          "description": "Form name for native submission."
        },
        {
          "name": "ariaDescribedby",
          "type": "string",
          "description": "External description element id appended to aria-describedby."
        }
      ]
    }
  },
  "channels": {
    "value": {
      "value": "value",
      "defaultValue": "defaultValue",
      "onChange": "onChange",
      "valueType": "string",
      "description": "The current text value of the field's input."
    }
  },
  "states": [
    "default",
    "focus",
    "disabled",
    "invalid"
  ],
  "form": {
    "participates": true,
    "inputType": "text",
    "name": {
      "prop": "name"
    },
    "required": {
      "prop": "required",
      "constraintValidation": true
    },
    "serialization": {
      "valueType": "string",
      "valueSource": "prop:value",
      "omitWhen": "never"
    },
    "validity": {
      "model": "hybrid",
      "invalidProp": "invalid",
      "errorMessageProp": "error",
      "errorSurface": "aria-describedby",
      "ariaAttributes": [
        "aria-invalid",
        "aria-required",
        "aria-describedby"
      ]
    },
    "labeling": {
      "strategy": "associated-label",
      "required": true,
      "via": [
        "prop:label",
        "aria-labelledby",
        "aria-label"
      ]
    }
  },
  "focus": {
    "strategy": "auto",
    "initialFocus": "field",
    "description": "Focus moves to the native input (anatomy part `field`) via Tab. Label, description, and error are non-interactive and not in the tab sequence."
  },
  "portal": {
    "enabled": false
  },
  "slots": {
    "root": {
      "required": true,
      "selector": "[data-slot=\"text-field\"]"
    },
    "description": {
      "required": false,
      "selector": "[data-slot=\"text-field-description\"]"
    },
    "error": {
      "required": false,
      "selector": "[data-slot=\"text-field-error\"]"
    }
  },
  "ssr": {
    "hydrateOn": "interaction"
  },
  "rtl": {
    "flipIcon": false
  },
  "relationships": [
    {
      "from": "field",
      "to": "label",
      "attribute": "aria-labelledby",
      "description": "The input's htmlFor/id pair associates it with the label for accessible naming. TextField's `field` anatomy part is the input element."
    },
    {
      "from": "field",
      "to": "description",
      "attribute": "aria-describedby",
      "when": "description=present",
      "description": "When a description is provided, the input references its id via aria-describedby."
    },
    {
      "from": "field",
      "to": "error",
      "attribute": "aria-describedby",
      "when": "validity=invalid",
      "description": "When in an error state, the input's aria-describedby includes the error message element's id."
    }
  ],
  "a11y": {
    "labeling": [
      "aria-label",
      "aria-labelledby",
      "aria-describedby"
    ],
    "keyboard": []
  },
  "a2ui": {
    "category": "form-field",
    "usageHints": [
      "Use label prop to attach a visible label (wired via aria automatically)",
      "Use description for supplemental instructions below the input",
      "Use error to display a validation error message (sets aria-invalid on the input)",
      "Bind value and onChange for controlled inputs; use defaultValue for uncontrolled",
      "Use name for native form submission"
    ],
    "children": {
      "allowed": false
    }
  }
}
