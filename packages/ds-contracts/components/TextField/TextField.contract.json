{
  "$schema": "../../component.contract.schema.json",
  "name": "TextField",
  "description": "Full-featured form field composing a label, input, optional description, and error message with ARIA wiring.",
  "layer": "composer",
  "category": "input",
  "anatomy": {
    "parts": [
      "root",
      "label",
      "field",
      "description",
      "error"
    ],
    "details": {
      "root": {
        "tag": "div",
        "description": "Form-field wrapper that coordinates label, native input, helper text, and error state.",
        "role": "root"
      },
      "label": {
        "tag": "label",
        "description": "Visible label associated with the input field.",
        "role": "label"
      },
      "field": {
        "tag": "input",
        "description": "Native input carrying value, disabled, required, validation, name, and description wiring.",
        "role": "trigger",
        "interactive": true,
        "focusable": true,
        "aria": {
          "attributes": [
            "aria-invalid",
            "aria-describedby"
          ]
        }
      },
      "description": {
        "tag": "span",
        "description": "Optional helper text that describes the expected input.",
        "role": "content"
      },
      "error": {
        "tag": "span",
        "description": "Validation error message announced as an alert when present.",
        "role": "content",
        "aria": {
          "role": "alert"
        }
      }
    },
    "dom": {
      "tag": "div",
      "part": "root",
      "children": [
        {
          "tag": "label",
          "part": "label",
          "children": [
            {
              "tag": "slot",
              "name": "label"
            }
          ]
        },
        {
          "tag": "input",
          "part": "field",
          "bindings": {
            "type": "prop:type",
            "value": "channel:value.value",
            "disabled": "prop:disabled",
            "name": "prop:name",
            "required": "prop:required",
            "aria-invalid": "prop:invalid",
            "aria-describedby": "prop:ariaDescribedby"
          },
          "events": {
            "change": "channel:value.onChange"
          }
        },
        {
          "tag": "span",
          "part": "description",
          "children": [
            {
              "tag": "slot",
              "name": "description"
            }
          ]
        },
        {
          "tag": "span",
          "part": "error",
          "attrs": {
            "role": "alert"
          },
          "children": [
            {
              "tag": "slot",
              "name": "error"
            }
          ]
        }
      ]
    }
  },
  "props": {
    "designed": {
      "members": [
        {
          "name": "type",
          "propType": { "kind": "string" },
          "description": "HTML input type."
        },
        {
          "name": "value",
          "propType": { "kind": "string" },
          "description": "Controlled value."
        },
        {
          "name": "defaultValue",
          "propType": { "kind": "string" },
          "description": "Uncontrolled initial value."
        },
        {
          "name": "onChange",
          "propType": {
            "kind": "callback",
            "params": [{ "name": "value", "type": { "kind": "string" } }],
            "returns": { "kind": "void" }
          },
          "description": "Called when value changes."
        },
        {
          "name": "invalid",
          "propType": { "kind": "boolean" },
          "description": "Applies error styling and sets aria-invalid."
        },
        {
          "name": "disabled",
          "propType": { "kind": "boolean" },
          "description": "Prevents interaction."
        },
        {
          "name": "required",
          "propType": { "kind": "boolean" },
          "description": "Marks the input as required."
        },
        {
          "name": "name",
          "propType": { "kind": "string" },
          "description": "Form name for native submission."
        },
        {
          "name": "ariaDescribedby",
          "propType": { "kind": "string" },
          "description": "External description element id appended to aria-describedby."
        }
      ]
    }
  },
  "channels": {
    "value": {
      "value": "value",
      "defaultValue": "defaultValue",
      "onChange": "onChange",
      "valueType": "string",
      "description": "The current text value of the field's input."
    }
  },
  "states": {
    "dimensions": {
      "pointer": {
        "category": "interaction",
        "values": [
          "default"
        ],
        "initial": "default",
        "exclusive": true
      },
      "focus": {
        "category": "interaction",
        "values": [
          "unfocused",
          "focus"
        ],
        "initial": "unfocused",
        "exclusive": true
      },
      "availability": {
        "category": "availability",
        "effect": "restyle",
        "values": [
          "enabled",
          "disabled"
        ],
        "initial": "enabled",
        "exclusive": true,
        "suppresses": {
          "categories": [
            "interaction"
          ]
        }
      },
      "validation": {
        "category": "validation",
        "effect": "restyle",
        "values": [
          "valid",
          "invalid"
        ],
        "initial": "valid",
        "exclusive": true
      }
    }
  },
  "form": {
    "participates": true,
    "inputType": "text",
    "name": {
      "prop": "name"
    },
    "required": {
      "prop": "required",
      "constraintValidation": true
    },
    "serialization": {
      "valueType": "string",
      "valueSource": "prop:value",
      "omitWhen": "never"
    },
    "validity": {
      "model": "hybrid",
      "invalidProp": "invalid",
      "errorSurface": "aria-describedby",
      "ariaAttributes": [
        "aria-invalid",
        "aria-required",
        "aria-describedby"
      ]
    },
    "labeling": {
      "strategy": "associated-label",
      "required": true,
      "via": [
        "slot:label",
        "aria-labelledby",
        "aria-label"
      ]
    }
  },
  "focus": {
    "strategy": "auto",
    "initialFocus": "field",
    "description": "Focus moves to the native input (anatomy part `field`) via Tab. Label, description, and error are non-interactive and not in the tab sequence."
  },
  "portal": {
    "enabled": false
  },
  "slots": {
    "root": {
      "required": true,
      "selector": "[data-slot=\"text-field\"]"
    },
    "label": {
      "required": false,
      "selector": "[data-slot=\"text-field-label\"]"
    },
    "description": {
      "required": false,
      "selector": "[data-slot=\"text-field-description\"]"
    },
    "error": {
      "required": false,
      "selector": "[data-slot=\"text-field-error\"]"
    }
  },
  "ssr": {
    "hydrateOn": "interaction"
  },
  "rtl": {
    "flipIcon": false
  },
  "relationships": [
    {
      "from": "field",
      "to": "label",
      "attribute": "aria-labelledby",
      "description": "The input's htmlFor/id pair associates it with the label for accessible naming. TextField's `field` anatomy part is the input element."
    },
    {
      "from": "field",
      "to": "description",
      "attribute": "aria-describedby",
      "when": "description=present",
      "description": "When a description is provided, the input references its id via aria-describedby."
    },
    {
      "from": "field",
      "to": "error",
      "attribute": "aria-describedby",
      "when": "validity=invalid",
      "description": "When in an error state, the input's aria-describedby includes the error message element's id."
    }
  ],
  "a11y": {
    "labeling": [
      "aria-label",
      "aria-labelledby",
      "aria-describedby"
    ],
    "keyboard": []
  },
  "a2ui": {
    "category": "form-field",
    "usageHints": [
      "Use label prop to attach a visible label (wired via aria automatically)",
      "Use description for supplemental instructions below the input",
      "Use error to display a validation error message (sets aria-invalid on the input)",
      "Bind value and onChange for controlled inputs; use defaultValue for uncontrolled",
      "Use name for native form submission"
    ],
    "children": {
      "allowed": false
    }
  }
}
