{
  "root": {
    "display": {
      "literal": "flex",
      "platforms": ["web"]
    },
    "flex-direction": {
      "literal": "column",
      "platforms": ["web"]
    },
    "gap": {
      "resolvesTo": "text-field.spacing.gap"
    }
  },
  "label": {
    "display": {
      "literal": "inline-block",
      "platforms": ["web"]
    },
    "font-size": {
      "resolvesTo": "text-field.typography.label.size"
    },
    "font-weight": {
      "resolvesTo": "text-field.typography.label.weight"
    },
    "line-height": {
      "resolvesTo": "text-field.typography.label.line-height"
    },
    "color": {
      "resolvesTo": "text-field.color.input.text"
    }
  },
  "field": {
    "display": {
      "literal": "block",
      "platforms": ["web"]
    },
    "width": {
      "literal": "100%",
      "platforms": ["web"]
    },
    "box-sizing": {
      "literal": "border-box",
      "platforms": ["web"]
    },
    "border-style": {
      "literal": "solid",
      "platforms": ["web"]
    },
    "background-color": {
      "resolvesTo": "text-field.color.input.background"
    },
    "border-color": {
      "resolvesTo": "text-field.color.input.border"
    },
    "border-width": {
      "resolvesTo": "text-field.border.width"
    },
    "border-radius": {
      "resolvesTo": "text-field.border.radius"
    },
    "color": {
      "resolvesTo": "text-field.color.input.text"
    },
    "font-size": {
      "resolvesTo": "text-field.typography.field.size"
    },
    "line-height": {
      "resolvesTo": "text-field.typography.field.line-height"
    },
    "min-height": {
      "resolvesTo": "text-field.field.min-height"
    },
    "padding-block": {
      "resolvesTo": "text-field.field.padding-block"
    },
    "padding-inline": {
      "resolvesTo": "text-field.field.padding-inline"
    },
    "transition-property": {
      "literal": "background-color, border-color, color, outline-color",
      "platforms": ["web"]
    },
    "transition-duration": {
      "resolvesTo": "text-field.motion.duration.fast"
    },
    "transition-timing-function": {
      "resolvesTo": "text-field.motion.easing.standard"
    }
  },
  "description": {
    "display": {
      "literal": "block",
      "platforms": ["web"]
    },
    "font-size": {
      "resolvesTo": "text-field.typography.supporting.size"
    },
    "line-height": {
      "resolvesTo": "text-field.typography.supporting.line-height"
    },
    "color": {
      "resolvesTo": "text-field.color.supporting.text"
    }
  },
  "error": {
    "display": {
      "literal": "block",
      "platforms": ["web"]
    },
    "font-size": {
      "resolvesTo": "text-field.typography.supporting.size"
    },
    "line-height": {
      "resolvesTo": "text-field.typography.supporting.line-height"
    },
    "color": {
      "resolvesTo": "text-field.color.error"
    }
  },
  ".text-field__field::placeholder": {
    "color": {
      "resolvesTo": "text-field.color.input.placeholder"
    }
  },
  ".text-field__field:hover:not(:disabled)": {
    "border-color": {
      "resolvesTo": "text-field.color.input.borderHover"
    }
  },
  ".text-field__field:focus-visible": {
    "border-color": {
      "resolvesTo": "text-field.focus.ring.color"
    },
    "outline-width": {
      "resolvesTo": "text-field.focus.ring.width"
    },
    "outline-color": {
      "resolvesTo": "text-field.focus.ring.color"
    },
    "outline-style": {
      "resolvesTo": "text-field.focus.ring.style"
    },
    "outline-offset": {
      "resolvesTo": "text-field.focus.ring.offset"
    }
  },
  ".text-field--invalid .text-field__field": {
    "border-color": {
      "resolvesTo": "text-field.color.input.borderError"
    }
  },
  ".text-field--invalid .text-field__field:focus-visible": {
    "border-color": {
      "resolvesTo": "text-field.color.input.borderError"
    },
    "outline-color": {
      "resolvesTo": "text-field.color.input.borderError"
    }
  },
  ".text-field__field:disabled": {
    "background-color": {
      "resolvesTo": "text-field.color.input.backgroundDisabled"
    },
    "border-color": {
      "resolvesTo": "text-field.color.input.borderDisabled"
    },
    "color": {
      "resolvesTo": "text-field.color.input.textDisabled"
    },
    "opacity": {
      "resolvesTo": "text-field.opacity.disabled"
    },
    "cursor": {
      "literal": "not-allowed",
      "platforms": ["web"]
    }
  }
}
