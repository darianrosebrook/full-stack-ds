{
  "text-field.spacing.gap": {
    "resolvesTo": "core.spacing.size.04",
    "fallback": "8px",
    "layer": "core"
  },
  "text-field.border.width": {
    "resolvesTo": "core.shape.border.width.hairline",
    "fallback": "1px",
    "layer": "core"
  },
  "text-field.border.radius": {
    "resolvesTo": "core.shape.radius.medium",
    "fallback": "8px",
    "layer": "core"
  },
  "text-field.color.input.text": {
    "resolvesTo": "semantic.color.foreground.primary",
    "fallback": "#141414",
    "layer": "semantic"
  },
  "text-field.color.input.placeholder": {
    "resolvesTo": "semantic.color.foreground.tertiary",
    "fallback": "#717171",
    "layer": "semantic"
  },
  "text-field.color.input.borderError": {
    "resolvesTo": "semantic.color.status.danger",
    "fallback": "#d9292b",
    "layer": "semantic"
  },
  "text-field.color.error": {
    "resolvesTo": "semantic.color.foreground.danger",
    "fallback": "#d9292b",
    "layer": "semantic"
  }
}
