{
  "box-model.gap": {
    "resolvesTo": "semantic.structure.size.gap",
    "fallback": "8px",
    "layer": "semantic"
  },
  "shuttle.color.background.default": {
    "resolvesTo": "semantic.color.background.secondary",
    "fallback": "#efefef",
    "layer": "semantic"
  },
  "shuttle.color.foreground.primary": {
    "resolvesTo": "semantic.color.foreground.primary",
    "fallback": "#141414",
    "layer": "semantic"
  },
  "shuttle.color.foreground.secondary": {
    "resolvesTo": "semantic.color.foreground.secondary",
    "fallback": "#555555",
    "layer": "semantic"
  },
  "shuttle.color.border.default": {
    "resolvesTo": "semantic.color.border.light",
    "fallback": "#fceaea",
    "layer": "semantic"
  },
  "shuttle.color.border.accent": {
    "resolvesTo": "semantic.color.border.accent",
    "fallback": "#d9292b",
    "layer": "semantic"
  },
  "shuttle.size.padding.default": {
    "resolvesTo": "core.spacing.size.07",
    "fallback": "24px",
    "layer": "core"
  },
  "shuttle.size.radius.default": {
    "resolvesTo": "core.shape.radius.medium",
    "fallback": "8px",
    "layer": "core"
  }
}
