{
  "$schema": "./component.contract.schema.json",
  "name": "Popover",
  "description": "Anchored persistent presence surface that exposes interactive content adjacent to a trigger element on click. Composes as <Popover><Popover.Trigger>...</Popover.Trigger><Popover.Content>...</Popover.Content></Popover>; the substrate wires aria-controls/aria-expanded, click toggling, and escape/outside-click/boundary-blur dismissal. Non-modal: does NOT trap focus or render an overlay scrim.",
  "layer": "composer",
  "anatomy": {
    "parts": [
      "root",
      "trigger",
      "content"
    ],
    "details": {
      "root": {
        "role": "group"
      },
      "trigger": {
        "role": "trigger",
        "interactive": true,
        "focusable": true
      },
      "content": {
        "role": "content",
        "interactive": true,
        "focusable": true
      }
    }
  },
  "props": {
    "styled": {
      "description": "Props for the <Popover> root component.",
      "members": [
        {
          "name": "open",
          "type": "boolean",
          "description": "Controlled open state."
        },
        {
          "name": "defaultOpen",
          "type": "boolean",
          "description": "Uncontrolled initial open state."
        },
        {
          "name": "onOpenChange",
          "type": "(open: boolean) => void",
          "description": "Called when open state changes."
        },
        {
          "name": "placement",
          "type": "PopoverPlacement",
          "description": "Preferred placement relative to the trigger. May be overridden by collision detection."
        },
        {
          "name": "disabled",
          "type": "boolean",
          "description": "Suppresses the popover entirely; the trigger renders but never opens."
        },
        {
          "name": "closeOnEscape",
          "type": "boolean",
          "description": "When true, Escape closes the popover and returns focus to the trigger.",
          "default": true
        },
        {
          "name": "closeOnOutsideClick",
          "type": "boolean",
          "description": "When true, a click outside the anchor \u222a content surface closes the popover.",
          "default": true
        },
        {
          "name": "closeOnBlur",
          "type": "boolean",
          "description": "When true, focus leaving the anchor \u222a content surface boundary closes the popover.",
          "default": true
        }
      ]
    }
  },
  "channels": {
    "open": {
      "value": "open",
      "defaultValue": "defaultOpen",
      "onChange": "onOpenChange",
      "valueType": "boolean",
      "description": "Whether the popover content is visible."
    }
  },
  "types": {
    "PopoverPlacement": {
      "kind": "union",
      "values": [
        "top",
        "bottom",
        "left",
        "right",
        "auto"
      ]
    }
  },
  "variants": {
    "placement": [
      "top",
      "bottom",
      "left",
      "right",
      "auto"
    ]
  },
  "states": [
    "default",
    "open",
    "focus",
    "entering",
    "leaving"
  ],
  "tokens": {
    "root": {
      "popover.size.padding.default": {
        "resolvesTo": "core.spacing.size.06",
        "fallback": "16px",
        "property": "padding",
        "layer": "core"
      },
      "popover.size.radius.default": {
        "resolvesTo": "semantic.shape.control.radius.default",
        "fallback": "8px",
        "property": "border-radius",
        "layer": "semantic"
      },
      "popover.size.gap.default": {
        "resolvesTo": "core.spacing.size.04",
        "fallback": "8px",
        "property": "gap",
        "layer": "core"
      },
      "popover.color.background.content": {
        "resolvesTo": "semantic.color.background.secondary",
        "fallback": "#efefef",
        "property": "background-color",
        "layer": "semantic"
      },
      "popover.color.border.accent": {
        "resolvesTo": "semantic.color.border.accent",
        "fallback": "#d9292b",
        "property": "border-color",
        "layer": "semantic"
      },
      "popover.elevation.default": {
        "resolvesTo": "semantic.elevation.default",
        "fallback": "0 2px 8px rgba(0,0,0,0.12)",
        "layer": "semantic"
      }
    }
  },
  "motion": {
    "reducedMotion": "respect",
    "reducedMotionStrategy": "Duration set to 0; popover appears/disappears instantly without animation.",
    "transitions": [
      {
        "name": "open",
        "trigger": "openness=closed\u2192open",
        "phase": "enter",
        "properties": [
          "opacity",
          "transform"
        ],
        "duration": "core.motion.duration.short",
        "easing": "core.motion.easing.emphasizedOut"
      },
      {
        "name": "close",
        "trigger": "openness=open\u2192closed",
        "phase": "exit",
        "properties": [
          "opacity",
          "transform"
        ],
        "duration": "core.motion.duration.short",
        "easing": "core.motion.easing.emphasizedIn"
      }
    ]
  },
  "focus": {
    "strategy": "none",
    "description": "Popover does not trap focus. Focus remains on the trigger or moves into the content if interactive children are present."
  },
  "portal": {
    "enabled": true,
    "defaultTarget": "body",
    "positioning": "anchored",
    "layering": "popover",
    "collision": "flip-shift"
  },
  "dismissal": {
    "triggers": [
      {
        "event": "escape",
        "enabledBy": "closeOnEscape"
      },
      {
        "event": "outsideClick",
        "enabledBy": "closeOnOutsideClick"
      },
      {
        "event": "blur",
        "enabledBy": "closeOnBlur"
      }
    ]
  },
  "surface": {
    "kind": "popover",
    "presence": "persistent",
    "modality": "non-blocking",
    "anchor": {
      "part": "trigger",
      "relation": "controls-expanded"
    },
    "content": {
      "part": "content",
      "interactive": true
    },
    "positioning": {
      "strategy": "anchored",
      "placementProp": "placement",
      "collision": "flip-shift"
    },
    "dismissal": [
      "escape",
      "outside-click",
      "blur"
    ],
    "openTriggers": [
      "click"
    ]
  },
  "slots": {
    "root": {
      "required": true,
      "selector": "[data-slot=\"popover\"]"
    },
    "trigger": {
      "required": true,
      "selector": "[data-slot=\"popover-trigger\"]"
    },
    "content": {
      "required": true,
      "selector": "[data-slot=\"popover-content\"]"
    }
  },
  "ssr": {
    "hydrateOn": "interaction"
  },
  "rtl": {
    "flipIcon": false
  },
  "relationships": [
    {
      "from": "trigger",
      "to": "content",
      "attribute": "aria-controls",
      "when": "openness=open"
    },
    {
      "from": "trigger",
      "to": "content",
      "attribute": "aria-expanded",
      "when": "openness=open",
      "description": "aria-expanded is true when the popover is open, false when closed."
    }
  ],
  "a11y": {
    "role": "group",
    "apgPattern": "disclosure",
    "labeling": [
      "aria-controls",
      "aria-expanded"
    ],
    "keyboard": [
      {
        "key": "Escape",
        "action": "Close the popover and return focus to the trigger (WCAG 2.1 SC 2.1.1)."
      },
      {
        "key": "Enter",
        "action": "Toggle the popover open or closed.",
        "when": "trigger"
      },
      {
        "key": "Space",
        "action": "Toggle the popover open or closed.",
        "when": "trigger"
      }
    ]
  },
  "usage": {
    "example": "<Popover open={open} onOpenChange={setOpen} placement=\"bottom\">\n  <PopoverTrigger>\n    <Button>Open menu</Button>\n  </PopoverTrigger>\n  <PopoverContent>\n    <div>Menu content</div>\n  </PopoverContent>\n</Popover>"
  },
  "a2ui": {
    "category": "overlay",
    "usageHints": [
      "Use for supplemental, non-blocking information that does not require a decision",
      "Popover.Trigger wraps the element that opens the panel; Popover.Content is the floating panel",
      "Bind open and onOpenChange for controlled mode",
      "Prefer Tooltip for simple text-only hints; use Popover when content is interactive"
    ],
    "children": {
      "allowed": true,
      "slot": "children",
      "accepts": [
        "Popover.Trigger",
        "Popover.Content"
      ]
    }
  }
}
