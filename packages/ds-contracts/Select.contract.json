{
  "$schema": "./component.contract.schema.json",
  "name": "Select",
  "description": "Dropdown selector with optional search, single or multi-select, and keyboard navigation. Renders a floating listbox anchored to the trigger.",
  "layer": "composite",
  "anatomy": {
    "parts": ["root", "trigger", "content", "search", "options", "option", "check", "emptyState"],
    "dom": {
      "tag": "div",
      "part": "root",
      "attrs": {
        "role": "combobox",
        "aria-haspopup": "listbox"
      },
      "bindings": {
        "aria-expanded": "channel:open.value",
        "aria-disabled": "prop:disabled"
      },
      "children": [
        {
          "tag": "button",
          "part": "trigger",
          "attrs": {
            "type": "button"
          },
          "bindings": {
            "disabled": "prop:disabled"
          },
          "children": [
            {
              "tag": "span",
              "part": "text"
            }
          ]
        },
        {
          "tag": "div",
          "part": "content",
          "if": "open",
          "attrs": {
            "role": "listbox"
          },
          "children": [
            {
              "tag": "div",
              "part": "search",
              "if": "searchable",
              "children": [
                {
                  "tag": "input",
                  "attrs": {
                    "type": "text"
                  }
                }
              ]
            },
            {
              "tag": "div",
              "part": "options",
              "children": [
                {
                  "tag": "div",
                  "part": "option",
                  "attrs": {
                    "role": "option"
                  }
                }
              ]
            },
            {
              "tag": "div",
              "part": "emptyState",
              "if": "empty"
            }
          ]
        }
      ]
    }
  },
  "variants": {
    "size": ["sm", "md", "lg"],
    "position": ["bottom", "top", "auto"]
  },
  "states": ["default", "hover", "focus", "active", "disabled", "open", "closed", "selected"],
  "a11y": {
    "role": "combobox",
    "labeling": ["aria-label", "aria-expanded", "aria-haspopup"],
    "keyboard": [
      {
        "key": "Enter",
        "action": "Open the dropdown or select the focused option.",
        "when": "trigger"
      },
      {
        "key": "Space",
        "action": "Open the dropdown or select the focused option.",
        "when": "trigger"
      },
      {
        "key": "ArrowDown",
        "action": "Move focus to the next option, or open the dropdown if closed.",
        "when": "trigger"
      },
      {
        "key": "ArrowUp",
        "action": "Move focus to the previous option.",
        "when": "content"
      },
      {
        "key": "ArrowDown",
        "action": "Move focus to the next option.",
        "when": "content"
      },
      {
        "key": "Home",
        "action": "Move focus to the first option.",
        "when": "content"
      },
      {
        "key": "End",
        "action": "Move focus to the last option.",
        "when": "content"
      },
      {
        "key": "Enter",
        "action": "Select the focused option and close the dropdown.",
        "when": "option"
      },
      {
        "key": "Escape",
        "action": "Close the dropdown and return focus to the trigger.",
        "when": "content"
      }
    ]
  },
  "channels": {
    "selection": {
      "value": "value",
      "defaultValue": "defaultValue",
      "onChange": "onChange",
      "valueType": "string | string[]",
      "description": "Currently selected value(s)."
    },
    "open": {
      "value": "open",
      "defaultValue": "defaultOpen",
      "onChange": "onOpenChange",
      "valueType": "boolean",
      "description": "Whether the dropdown is open."
    }
  },
  "portal": {
    "enabled": true,
    "defaultTarget": "body",
    "positioning": "anchored",
    "layering": "popover",
    "collision": "flip-shift"
  },
  "dismissal": {
    "triggers": [
      {
        "event": "escape"
      },
      {
        "event": "outsideClick"
      },
      {
        "event": "selection"
      }
    ]
  },
  "tokens": {
    "root": {
      "select.color.background.default": {
        "resolvesTo": "semantic.color.background.primary",
        "fallback": "#ffffff",
        "property": "background-color",
        "layer": "semantic"
      },
      "select.color.foreground.default": {
        "resolvesTo": "semantic.color.foreground.primary",
        "fallback": "#141414",
        "property": "color",
        "layer": "semantic"
      },
      "select.color.border.default": {
        "resolvesTo": "semantic.color.border.primary",
        "fallback": "#f29495",
        "property": "border-color",
        "layer": "semantic"
      },
      "select.color.icon.default": {
        "resolvesTo": "semantic.color.foreground.secondary",
        "fallback": "#555555",
        "layer": "semantic"
      },
      "select.color.placeholder.default": {
        "resolvesTo": "semantic.color.foreground.placeholder",
        "fallback": "#8f8f8f",
        "layer": "semantic"
      },
      "select.size.padding.default": {
        "resolvesTo": "core.spacing.size.03",
        "fallback": "4px",
        "property": "padding",
        "layer": "core"
      },
      "select.size.radius.default": {
        "resolvesTo": "core.shape.radius.medium",
        "fallback": "8px",
        "property": "border-radius",
        "layer": "core"
      },
      "select.size.border.default": {
        "resolvesTo": "core.shape.border.width.hairline",
        "fallback": "1px",
        "layer": "core"
      },
      "select.size.sm.height": {
        "resolvesTo": "semantic.control.size.sm.height",
        "fallback": "24px",
        "layer": "semantic"
      },
      "select.size.md.height": {
        "resolvesTo": "semantic.control.size.md.height",
        "fallback": "32px",
        "layer": "semantic"
      },
      "select.size.lg.height": {
        "resolvesTo": "semantic.control.size.lg.height",
        "fallback": "48px",
        "layer": "semantic"
      },
      "select.font.size.default": {
        "resolvesTo": "semantic.typography.body.02",
        "fallback": "16px",
        "property": "font-size",
        "layer": "semantic"
      },
      "select.font.lineHeight.default": {
        "resolvesTo": "semantic.typography.line.height.body",
        "fallback": "1.5",
        "property": "line-height",
        "layer": "semantic"
      }
    },
    "hover": {
      "select.color.background.hover": {
        "resolvesTo": "semantic.color.background.hover",
        "fallback": "#cecece",
        "property": "background-color",
        "layer": "semantic"
      },
      "select.color.foreground.hover": {
        "resolvesTo": "semantic.color.foreground.hover",
        "fallback": "#3a3a3a",
        "property": "color",
        "layer": "semantic"
      },
      "select.color.border.hover": {
        "resolvesTo": "semantic.color.border.bold",
        "fallback": "#8f8f8f",
        "property": "border-color",
        "layer": "semantic"
      }
    },
    "disabled": {
      "select.color.background.disabled": {
        "resolvesTo": "semantic.color.background.disabled",
        "fallback": "#cecece",
        "property": "background-color",
        "layer": "semantic"
      },
      "select.color.foreground.disabled": {
        "resolvesTo": "semantic.color.foreground.disabled",
        "fallback": "#aeaeae",
        "property": "color",
        "layer": "semantic"
      },
      "select.color.border.disabled": {
        "resolvesTo": "semantic.color.border.disabled",
        "fallback": "#cecece",
        "property": "border-color",
        "layer": "semantic"
      }
    },
    "open": {
      "select.color.border.isOpen": {
        "resolvesTo": "semantic.color.border.accent",
        "fallback": "#d9292b",
        "property": "border-color",
        "layer": "semantic"
      },
      "select.color.icon.isOpen": {
        "resolvesTo": "semantic.color.foreground.accent",
        "fallback": "#d9292b",
        "layer": "semantic"
      }
    },
    "selected": {
      "select.color.background.selected": {
        "resolvesTo": "semantic.color.background.highlight",
        "fallback": "#f7c1c2",
        "property": "background-color",
        "layer": "semantic"
      },
      "select.color.foreground.selected": {
        "resolvesTo": "semantic.color.foreground.accent",
        "fallback": "#d9292b",
        "property": "color",
        "layer": "semantic"
      }
    }
  },
  "props": {
    "styled": {
      "description": "Props for the <Select> dropdown component.",
      "members": [
        {
          "name": "options",
          "type": "SelectOption[]",
          "description": "Available options.",
          "required": true
        },
        {
          "name": "value",
          "type": "string | string[]",
          "description": "Controlled selected value(s)."
        },
        {
          "name": "defaultValue",
          "type": "string | string[]",
          "description": "Default selected value(s) for uncontrolled usage."
        },
        {
          "name": "onChange",
          "type": "(value: string | string[]) => void",
          "description": "Called when selection changes."
        },
        {
          "name": "open",
          "type": "boolean",
          "description": "Controlled open state."
        },
        {
          "name": "defaultOpen",
          "type": "boolean",
          "description": "Default open state for uncontrolled usage."
        },
        {
          "name": "onOpenChange",
          "type": "(open: boolean) => void",
          "description": "Called when open state changes."
        },
        {
          "name": "multiple",
          "type": "boolean",
          "description": "Allow multiple selections."
        },
        {
          "name": "disabled",
          "type": "boolean",
          "description": "Disabled state."
        },
        {
          "name": "size",
          "type": "SelectSize",
          "description": "Size variant.",
          "default": "md"
        },
        {
          "name": "filterFn",
          "type": "((option: SelectOption, searchTerm: string) => boolean)",
          "description": "Custom filter function for search."
        },
        {
          "name": "searchable",
          "type": "boolean",
          "description": "Whether to render the search input inside the dropdown."
        },
        {
          "name": "empty",
          "type": "boolean",
          "description": "Whether the option list is empty (drives the empty-state slot)."
        }
      ]
    }
  },
  "types": {
    "SelectSize": {
      "kind": "union",
      "values": ["sm", "md", "lg"]
    },
    "SelectOption": {
      "kind": "alias",
      "alias": "{ value: string; label: string; disabled?: boolean }"
    }
  }
}
