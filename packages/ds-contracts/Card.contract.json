{
  "$schema": "./component.contract.schema.json",
  "name": "Card",
  "description": "Surface container grouping related content with optional header, media, and action areas.",
  "layer": "compound",
  "anatomy": {
    "parts": [
      "root",
      "header",
      "media",
      "content",
      "footer",
      "actions",
      "badge",
      "description",
      "link",
      "note"
    ]
  },
  "props": {
    "styled": {
      "description": "Props for the <Card> component.",
      "members": [
        {
          "name": "interactive",
          "type": "boolean",
          "description": "Enable hover affordances (shadow lift, translate)"
        },
        {
          "name": "status",
          "type": "CardStatus",
          "description": "Visual status variant of the card"
        }
      ]
    }
  },
  "types": {
    "CardStatus": {
      "kind": "union",
      "values": [
        "completed",
        "in-progress",
        "planned",
        "deprecated",
        "category",
        "complexity"
      ]
    }
  },
  "variants": {
    "status": [
      "completed",
      "in-progress",
      "planned",
      "deprecated",
      "category",
      "complexity"
    ]
  },
  "states": [
    "default",
    "hover",
    "focus",
    "active"
  ],
  "tokens": {
    "root": {
      "card.color.background.default": {
        "resolvesTo": "semantic.color.background.primary",
        "fallback": "#ffffff",
        "property": "background-color",
        "layer": "semantic"
      },
      "card.color.border.default": {
        "resolvesTo": "semantic.color.border.light",
        "fallback": "#fceaea",
        "property": "border-color",
        "layer": "semantic"
      },
      "card.color.foreground.primary": {
        "resolvesTo": "semantic.color.foreground.primary",
        "fallback": "#141414",
        "property": "color",
        "layer": "semantic"
      },
      "card.color.foreground.secondary": {
        "resolvesTo": "semantic.color.foreground.secondary",
        "fallback": "#555555",
        "property": "color",
        "layer": "semantic"
      },
      "card.color.foreground.link": {
        "resolvesTo": "semantic.color.foreground.link",
        "fallback": "#d9292b",
        "property": "color",
        "layer": "semantic"
      },
      "card.size.padding.default": {
        "resolvesTo": "core.spacing.size.06",
        "fallback": "16px",
        "property": "padding",
        "layer": "core"
      },
      "card.size.radius.default": {
        "resolvesTo": "semantic.shape.control.radius.default",
        "fallback": "8px",
        "property": "border-radius",
        "layer": "semantic"
      },
      "card.size.gap.default": {
        "resolvesTo": "core.spacing.size.03",
        "fallback": "4px",
        "property": "gap",
        "layer": "core"
      },
      "card.typography.lineHeight.heading": {
        "resolvesTo": "semantic.typography.line.height.heading",
        "fallback": "1",
        "property": "line-height",
        "layer": "semantic"
      },
      "card.typography.lineHeight.normal": {
        "resolvesTo": "semantic.typography.line.height.normal",
        "fallback": "1.5",
        "property": "line-height",
        "layer": "semantic"
      }
    },
    "hover": {
      "card.color.background.hover": {
        "resolvesTo": "semantic.color.background.secondary",
        "fallback": "#efefef",
        "property": "background-color",
        "layer": "semantic"
      }
    },
    "badge": {
      "card.color.badge.success.background": {
        "resolvesTo": "semantic.color.background.success.subtle",
        "fallback": "#e4f2e0",
        "property": "background-color",
        "layer": "semantic"
      },
      "card.color.badge.success.foreground": {
        "resolvesTo": "semantic.color.foreground.on.success.subtle",
        "fallback": "#234104",
        "property": "color",
        "layer": "semantic"
      },
      "card.color.badge.warning.background": {
        "resolvesTo": "semantic.color.background.warning.subtle",
        "fallback": "#ffedcc",
        "property": "background-color",
        "layer": "semantic"
      },
      "card.color.badge.warning.foreground": {
        "resolvesTo": "semantic.color.foreground.on.warning.subtle",
        "fallback": "#593000",
        "property": "color",
        "layer": "semantic"
      },
      "card.color.badge.info.background": {
        "resolvesTo": "semantic.color.background.info.subtle",
        "fallback": "#d9f3fe",
        "property": "background-color",
        "layer": "semantic"
      },
      "card.color.badge.info.foreground": {
        "resolvesTo": "semantic.color.foreground.on.info.subtle",
        "fallback": "#002d99",
        "property": "color",
        "layer": "semantic"
      },
      "card.color.badge.error.background": {
        "resolvesTo": "semantic.color.background.danger.subtle",
        "fallback": "#fceaea",
        "property": "background-color",
        "layer": "semantic"
      },
      "card.color.badge.error.foreground": {
        "resolvesTo": "semantic.color.foreground.on.danger.subtle",
        "fallback": "#7b0000",
        "property": "color",
        "layer": "semantic"
      },
      "card.color.badge.neutral.background": {
        "resolvesTo": "semantic.color.background.secondary",
        "fallback": "#efefef",
        "property": "background-color",
        "layer": "semantic"
      },
      "card.color.badge.neutral.foreground": {
        "resolvesTo": "semantic.color.foreground.secondary",
        "fallback": "#555555",
        "property": "color",
        "layer": "semantic"
      },
      "card.color.badge.accent.background": {
        "resolvesTo": "semantic.color.background.accent",
        "fallback": "#d9292b",
        "property": "background-color",
        "layer": "semantic"
      },
      "card.color.badge.accent.foreground": {
        "resolvesTo": "semantic.color.foreground.on.brand",
        "fallback": "#ffffff",
        "property": "color",
        "layer": "semantic"
      }
    }
  },
  "slots": {
    "actions": {
      "required": false
    },
    "badge": {
      "required": false
    },
    "content": {
      "required": false
    },
    "description": {
      "required": false
    },
    "footer": {
      "required": false
    },
    "header": {
      "required": false
    },
    "link": {
      "required": false
    },
    "media": {
      "required": false
    },
    "note": {
      "required": false
    },
    "title": {
      "required": false
    },
    "root": {
      "required": true,
      "selector": "[data-slot=\"card\"]"
    }
  },
  "ssr": {
    "hydrateOn": "interaction"
  },
  "rtl": {
    "flipIcon": false
  },
  "a11y": {
    "role": "group",
    "labeling": [
      "aria-label",
      "aria-labelledby"
    ],
    "keyboard": []
  },
  "usage": {
    "example": "<Card variant=\"small\">\n  <CardHeader>\n    <CardTitle>Project Update</CardTitle>\n    <CardDescription>Latest status report</CardDescription>\n  </CardHeader>\n  <CardContent>\n    <p>Everything is on track for the Q2 release.</p>\n  </CardContent>\n  <CardFooter>\n    <Button kind=\"primary\">View Details</Button>\n  </CardFooter>\n</Card>",
    "hookExample": "// Static card\nconst { getRootProps } = useCard({ variant: 'small' });\n<article {...getRootProps()}>...</article>\n\n// Interactive card \u2014 action area split\nconst { getRootProps, getActionAreaProps } = useCard({ interactive: true, onClick: handleClick });\n<div {...getRootProps()}>\n  <div {...getActionAreaProps()}>content</div>\n  <footer>actions</footer>\n</div>"
  },
  "a2ui": {
    "category": "display",
    "usageHints": [
      "Use Card.Link to make the entire card clickable",
      "Keep Card.Actions to 1\u20132 actions; move secondary actions to an overflow menu",
      "Card.Media expects a fixed-aspect image or media slot"
    ],
    "children": {
      "allowed": true,
      "slot": "children",
      "accepts": [
        "ReactNode"
      ]
    }
  }
}
