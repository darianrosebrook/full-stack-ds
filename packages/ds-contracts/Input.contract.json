{
  "$schema": "./component.contract.schema.json",
  "name": "Input",
  "description": "Native text input with design-system styling. Use inside TextField for label and error support.",
  "layer": "primitive",
  "anatomy": {
    "parts": ["root"],
    "dom": {
      "tag": "input",
      "part": "root",
      "bindings": {
        "value": "channel:value.value",
        "onChange": "channel:value.onChange",
        "disabled": "prop:disabled",
        "aria-invalid": "prop:invalid",
        "type": "prop:type"
      }
    }
  },
  "states": ["default", "hover", "focus", "disabled", "invalid"],
  "a11y": {
    "role": "textbox",
    "labeling": ["aria-label", "aria-labelledby", "aria-invalid"],
    "keyboard": []
  },
  "channels": {
    "value": {
      "value": "value",
      "defaultValue": "defaultValue",
      "onChange": "onChange",
      "valueType": "string",
      "description": "The current text value of the input."
    }
  },
  "tokens": {
    "root": {
      "input.color.bg.default": {
        "resolvesTo": "semantic.color.background.primary",
        "fallback": "#ffffff",
        "property": "background-color",
        "layer": "semantic"
      },
      "input.color.text.default": {
        "resolvesTo": "semantic.color.foreground.primary",
        "fallback": "#141414",
        "property": "color",
        "layer": "semantic"
      },
      "input.color.border.default": {
        "resolvesTo": "semantic.color.border.default",
        "fallback": "#aeaeae",
        "property": "border-color",
        "layer": "semantic"
      },
      "input.size.height.default": {
        "resolvesTo": "semantic.control.size.lg.height",
        "fallback": "48px",
        "property": "min-height",
        "layer": "semantic"
      },
      "input.size.radius.default": {
        "resolvesTo": "core.shape.radius.medium",
        "fallback": "8px",
        "property": "border-radius",
        "layer": "core"
      },
      "input.space.inline.default": {
        "resolvesTo": "core.spacing.size.05",
        "fallback": "12px",
        "property": "padding",
        "layer": "core"
      }
    },
    "focus": {
      "input.color.focus.default": {
        "resolvesTo": "semantic.color.border.focus",
        "fallback": "#d9292b",
        "property": "border-color",
        "layer": "semantic"
      }
    },
    "invalid": {
      "input.color.invalid.default": {
        "resolvesTo": "semantic.color.border.danger",
        "fallback": "#ae0001",
        "property": "border-color",
        "layer": "semantic"
      }
    }
  },
  "props": {
    "styled": {
      "description": "Props for the <Input> component.",
      "members": [
        {
          "name": "type",
          "type": "string",
          "description": "HTML input type (text, email, password, number, search, etc.)."
        },
        {
          "name": "value",
          "type": "string",
          "description": "Controlled value."
        },
        {
          "name": "defaultValue",
          "type": "string",
          "description": "Uncontrolled initial value."
        },
        {
          "name": "onChange",
          "type": "(value: string) => void",
          "description": "Called when value changes."
        },
        {
          "name": "placeholder",
          "type": "string",
          "description": "Placeholder text shown when empty."
        },
        {
          "name": "disabled",
          "type": "boolean",
          "description": "Prevents interaction."
        },
        {
          "name": "invalid",
          "type": "boolean",
          "description": "Applies error styling and sets aria-invalid."
        },
        {
          "name": "required",
          "type": "boolean",
          "description": "Sets the native required attribute."
        },
        {
          "name": "name",
          "type": "string",
          "description": "Form name for native submission."
        }
      ]
    }
  }
}
