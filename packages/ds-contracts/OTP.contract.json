{
  "$schema": "./component.contract.schema.json",
  "name": "OTP",
  "description": "One-time password input composed of individual single-character digit fields.",
  "layer": "composer",
  "anatomy": {
    "parts": [
      "root",
      "group",
      "field",
      "separator"
    ],
    "dom": {
      "tag": "div",
      "part": "root",
      "attrs": {
        "role": "group"
      },
      "bindings": {
        "aria-label": "prop:label",
        "aria-describedby": "literal:otp-error-id"
      },
      "children": [
        {
          "tag": "div",
          "part": "group",
          "children": [
            {
              "tag": "input",
              "part": "field",
              "attrs": {
                "type": "text",
                "inputmode": "numeric",
                "autocomplete": "one-time-code",
                "maxlength": "1"
              },
              "bindings": {
                "disabled": "prop:disabled",
                "aria-readonly": "prop:readOnly"
              }
            }
          ]
        }
      ]
    }
  },
  "variants": {
    "mode": [
      "numeric",
      "alphanumeric"
    ]
  },
  "states": [
    "default",
    "focus",
    "disabled"
  ],
  "a11y": {
    "labeling": [
      "aria-label",
      "aria-describedby",
      "aria-readonly"
    ],
    "keyboard": [
      {
        "key": "0-9",
        "action": "Enter a digit and advance focus to the next field.",
        "when": "field"
      },
      {
        "key": "Backspace",
        "action": "Clear the current field and move focus to the previous field.",
        "when": "field"
      },
      {
        "key": "ArrowLeft",
        "action": "Move focus to the previous OTP field.",
        "when": "field"
      },
      {
        "key": "ArrowRight",
        "action": "Move focus to the next OTP field.",
        "when": "field"
      }
    ]
  },
  "channels": {
    "value": {
      "description": "The full OTP string assembled from individual digit inputs.",
      "value": "value",
      "defaultValue": "defaultValue",
      "onChange": "onChange",
      "valueType": "string"
    }
  },
  "form": {
    "participates": true,
    "inputType": "text",
    "serialization": {
      "valueType": "string",
      "valueSource": "channel:value"
    },
    "validity": {
      "model": "native",
      "errorSurface": "aria-describedby"
    }
  },
  "tokens": {
    "root": {
      "otp.color.background.default": {
        "resolvesTo": "semantic.color.background.secondary",
        "fallback": "#efefef",
        "property": "background-color",
        "layer": "semantic"
      },
      "otp.color.foreground.primary": {
        "resolvesTo": "semantic.color.foreground.primary",
        "fallback": "#141414",
        "property": "color",
        "layer": "semantic"
      },
      "otp.color.foreground.secondary": {
        "resolvesTo": "semantic.color.foreground.secondary",
        "fallback": "#555555",
        "property": "color",
        "layer": "semantic"
      },
      "otp.color.border.default": {
        "resolvesTo": "semantic.color.border.light",
        "fallback": "#fceaea",
        "property": "border-color",
        "layer": "semantic"
      },
      "otp.size.padding.default": {
        "resolvesTo": "core.spacing.size.07",
        "fallback": "24px",
        "property": "padding",
        "layer": "core"
      },
      "otp.size.radius.default": {
        "resolvesTo": "core.shape.radius.medium",
        "fallback": "8px",
        "property": "border-radius",
        "layer": "core"
      }
    },
    "focus": {
      "otp.color.border.accent": {
        "resolvesTo": "semantic.color.border.accent",
        "fallback": "#d9292b",
        "property": "border-color",
        "layer": "semantic"
      }
    }
  },
  "props": {
    "styled": {
      "description": "Props for the <OTP> component.",
      "members": [
        {
          "name": "length",
          "type": "number",
          "description": "Number of individual input fields to render.",
          "default": 6
        },
        {
          "name": "value",
          "type": "string",
          "description": "Controlled OTP value string."
        },
        {
          "name": "defaultValue",
          "type": "string",
          "description": "Uncontrolled initial OTP value."
        },
        {
          "name": "onChange",
          "type": "(value: string) => void",
          "description": "Called when the OTP value changes."
        },
        {
          "name": "onComplete",
          "type": "(value: string) => void",
          "description": "Called when all fields are filled."
        },
        {
          "name": "mode",
          "type": "OTPMode",
          "description": "Whether fields accept only digits or any alphanumeric character.",
          "default": "numeric"
        },
        {
          "name": "disabled",
          "type": "boolean",
          "description": "Disables all input fields."
        },
        {
          "name": "readOnly",
          "type": "boolean",
          "description": "Makes all fields read-only."
        },
        {
          "name": "label",
          "type": "string",
          "description": "Accessible label for the OTP group.",
          "default": "One-time password"
        }
      ]
    }
  },
  "types": {
    "OTPMode": {
      "kind": "union",
      "values": [
        "numeric",
        "alphanumeric"
      ]
    }
  }
}
