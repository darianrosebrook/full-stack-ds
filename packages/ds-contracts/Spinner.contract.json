{
  "$schema": "./component.contract.schema.json",
  "name": "Spinner",
  "description": "Rotating indicator for indeterminate loading states.",
  "layer": "primitive",
  "anatomy": {
    "parts": ["root", "visual"],
    "dom": {
      "tag": "div",
      "part": "root",
      "children": [
        {
          "tag": "span",
          "part": "visual",
          "attrs": {
            "aria-hidden": "true"
          }
        }
      ]
    }
  },
  "variants": {
    "size": ["xs", "sm", "md", "lg"],
    "variant": ["ring", "dots", "bars"],
    "thickness": ["hairline", "regular", "bold"]
  },
  "states": ["default"],
  "a11y": {
    "role": "status",
    "labeling": ["aria-label"],
    "keyboard": []
  },
  "tokens": {
    "root": {
      "spinner.size.xs": {
        "literal": "12px"
      },
      "spinner.size.sm": {
        "literal": "16px"
      },
      "spinner.size.md": {
        "literal": "20px"
      },
      "spinner.size.lg": {
        "literal": "28px"
      },
      "spinner.thickness.hairline": {
        "literal": "2px"
      },
      "spinner.thickness.regular": {
        "literal": "3px"
      },
      "spinner.thickness.bold": {
        "literal": "4px"
      },
      "spinner.color.accent": {
        "resolvesTo": "semantic.color.background.accent",
        "fallback": "#d9292b",
        "layer": "semantic"
      },
      "spinner.color.track": {
        "resolvesTo": "semantic.color.border.subtle",
        "fallback": "#cecece",
        "layer": "semantic"
      },
      "spinner.dots.gap": {
        "resolvesTo": "core.spacing.size.04",
        "fallback": "8px",
        "property": "gap",
        "layer": "core"
      },
      "spinner.anim.duration": {
        "literal": "800ms",
        "property": "transition-duration"
      }
    }
  },
  "props": {
    "styled": {
      "description": "Props for the <Spinner> component.",
      "members": [
        {
          "name": "size",
          "type": "SpinnerSize",
          "description": "Visual size token"
        },
        {
          "name": "variant",
          "type": "SpinnerVariant",
          "description": "Visual variant: ring, dots, or bars"
        },
        {
          "name": "thickness",
          "type": "SpinnerThickness",
          "description": "Stroke thickness token"
        },
        {
          "name": "ariaHidden",
          "type": "boolean",
          "description": "If decorative only, set ariaHidden; else provide label"
        },
        {
          "name": "label",
          "type": "string",
          "description": "Localized label for screen reader users; ignored if ariaHidden"
        },
        {
          "name": "inline",
          "type": "boolean",
          "description": "Inline layout (align with baseline)"
        },
        {
          "name": "showAfterMs",
          "type": "number",
          "description": "Delay before showing (ms) to avoid spinner flash"
        }
      ]
    }
  },
  "types": {
    "SpinnerSize": {
      "kind": "union",
      "values": ["xs", "sm", "md", "lg"]
    },
    "SpinnerVariant": {
      "kind": "union",
      "values": ["ring", "dots", "bars"]
    },
    "SpinnerThickness": {
      "kind": "union",
      "values": ["hairline", "regular", "bold"]
    }
  }
}
