{
  "$schema": "./component.contract.schema.json",
  "name": "AlertNotice",
  "description": "Inline alert message communicating status, errors, warnings, or success. Always visible (not triggered by user interaction).",
  "layer": "compound",
  "anatomy": {
    "parts": [
      "root",
      "icon",
      "body",
      "title",
      "dismiss"
    ]
  },
  "props": {
    "styled": {
      "description": "Props for the <AlertNotice> component.",
      "members": [
        {
          "name": "status",
          "type": "AlertNoticeStatus",
          "description": "Status severity of the alert notice"
        },
        {
          "name": "level",
          "type": "AlertNoticeLevel",
          "description": "Display level affecting layout and emphasis"
        },
        {
          "name": "dismissible",
          "type": "boolean",
          "description": "Whether the alert notice can be dismissed by the user"
        },
        {
          "name": "icon",
          "type": "ReactNode",
          "description": "Optional icon node rendered before the alert content"
        }
      ]
    }
  },
  "types": {
    "AlertNoticeStatus": {
      "kind": "union",
      "values": [
        "info",
        "success",
        "warning",
        "danger",
        "error"
      ]
    },
    "AlertNoticeLevel": {
      "kind": "union",
      "values": [
        "page",
        "section",
        "inline"
      ]
    }
  },
  "variants": {
    "status": [
      "info",
      "success",
      "warning",
      "danger",
      "error"
    ],
    "level": [
      "page",
      "section",
      "inline"
    ]
  },
  "states": [
    "default"
  ],
  "tokens": {
    "root": {
      "alertnotice.color.background.primary": {
        "resolvesTo": "semantic.color.background.primary",
        "fallback": "#ffffff",
        "property": "background-color",
        "layer": "semantic"
      },
      "alertnotice.color.foreground.primary": {
        "resolvesTo": "semantic.color.foreground.primary",
        "fallback": "#141414",
