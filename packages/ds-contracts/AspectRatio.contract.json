{
  "$schema": "./component.contract.schema.json",
  "name": "AspectRatio",
  "description": "Constrains its child to a fixed aspect ratio (e.g. 16:9) regardless of container width.",
  "layer": "primitive",
  "anatomy": {
    "parts": ["root"],
    "dom": {
      "tag": "div",
      "part": "root",
      "children": [{ "tag": "children" }]
    }
  },
  "states": ["default"],
  "a11y": {
    "labeling": [],
    "keyboard": []
  },
  "props": {
    "styled": {
      "description": "Props for the <AspectRatio> component.",
      "members": [
        {
          "name": "ratio",
          "type": "number",
          "description": "Aspect ratio as width/height (e.g., 16/9, 4/3, 1)"
        },
        {
          "name": "preset",
          "type": "AspectRatioPreset",
          "description": "Predefined aspect ratio"
        }
      ]
    }
  },
  "types": {
    "AspectRatioPreset": {
      "kind": "union",
      "values": ["square", "video", "photo", "wide", "portrait"]
    }
  }
}
