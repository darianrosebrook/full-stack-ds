{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "ignoreDeprecations": "6.0",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "isolatedModules": true,
    "types": []
  },
  "include": ["src/**/*.ts", "src/**/*.svelte"],
  "exclude": ["dist", "node_modules"]
}
