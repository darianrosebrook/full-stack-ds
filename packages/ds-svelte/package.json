{
  "name": "@full-stack-ds/svelte",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Svelte 5 implementation of Full Stack DS (Stack component + generated components)",
  "svelte": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "svelte": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./primitives": {
      "types": "./dist/primitives/index.d.ts",
      "svelte": "./dist/primitives/index.js",
      "default": "./dist/primitives/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "typecheck": "svelte-check --tsconfig ./tsconfig.json",
    "test": "vitest run -c vitest.config.ts",
    "test:watch": "vitest -c vitest.config.ts",
    "build": "svelte-package -i src -o dist",
    "build:watch": "svelte-package -i src -o dist -w"
  },
  "peerDependencies": {
    "svelte": ">=5.0.0"
  },
  "devDependencies": {
    "@sveltejs/package": "^2.3.0",
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@testing-library/svelte": "^5.3.1",
    "svelte": "^5.0.0",
    "svelte-check": "^4.0.0",
    "typescript": "^6.0.2",
    "vitest": "^3.2.4",
    "vitest-axe": "^0.1.0"
  }
}
