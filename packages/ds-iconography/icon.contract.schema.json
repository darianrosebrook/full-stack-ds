{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "icon.contract.schema.json",
  "title": "Full-Stack DS Icon Contract",
  "description": "Defines a stable icon identity, metadata, and size-specific governed vector payloads. Emitters lower this contract to target-specific icon artifacts.",
  "type": "object",
  "required": ["name", "namespace", "category", "tags", "variants"],
  "additionalProperties": false,
  "properties": {
    "$schema": {
      "type": "string"
    },
    "schemaVersion": {
      "type": "string",
      "description": "Icon contract schema version. Absent or \"1\" indicates the current scaffold."
    },
    "name": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]*$",
      "description": "Canonical kebab-case icon name, e.g. \"heart\" or \"panel-close\"."
    },
    "displayName": {
      "type": "string"
    },
    "namespace": {
      "type": "string",
      "const": "fsds.icon"
    },
    "description": {
      "type": "string"
    },
    "category": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]*$"
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[a-z0-9][a-z0-9 -]*$"
      },
      "uniqueItems": true
    },
    "aliases": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[a-z][a-z0-9-]*$"
      },
      "uniqueItems": true
    },
    "status": {
      "type": "string",
      "enum": ["draft", "new", "active", "deprecated", "removed"]
    },
    "updatedAt": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "semantics": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "decorativeDefault": { "type": "boolean" },
        "requiresLabelWhenStandalone": { "type": "boolean" }
      }
    },
    "rtl": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "mirrors": { "type": "boolean" },
        "strategy": {
          "type": "string",
          "enum": ["none", "transform", "authored-variant"]
        }
      }
    },
    "variants": {
      "type": "object",
      "minProperties": 1,
      "patternProperties": {
        "^[0-9]+$": {
          "$ref": "#/$defs/sizeVariant"
        }
      },
      "additionalProperties": false
    },
    "relatedIcons": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[a-z][a-z0-9-]*$"
      },
      "uniqueItems": true
    },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "source": { "type": "string" },
        "license": { "type": "string" },
        "notes": { "type": "string" }
      }
    }
  },
  "$defs": {
    "sizeVariant": {
      "type": "object",
      "required": ["name", "width", "height", "viewBox", "paths", "platformNames"],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9-]*-[0-9]+$"
        },
        "description": {
          "type": "string"
        },
        "width": {
          "type": "number",
          "minimum": 1
        },
        "height": {
          "type": "number",
          "minimum": 1
        },
        "viewBox": {
          "type": "string",
          "pattern": "^-?[0-9.]+ -?[0-9.]+ [0-9.]+ [0-9.]+$"
        },
        "paths": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/path"
          }
        },
        "platformNames": {
          "type": "object",
          "required": ["web", "android", "ios"],
          "additionalProperties": false,
          "properties": {
            "web": {
              "type": "string",
              "pattern": "^icon-[a-z0-9-]+-[0-9]+$"
            },
            "android": {
              "type": "string",
              "pattern": "^[a-z][a-z0-9_]*$"
            },
            "ios": {
              "type": "string",
              "pattern": "^[a-z][a-z0-9-]*-[0-9]+$"
            },
            "react": {
              "type": "string"
            },
            "svelte": {
              "type": "string"
            },
            "reactNative": {
              "type": "string"
            },
            "swift": {
              "type": "string"
            },
            "kotlin": {
              "type": "string"
            }
          }
        }
      }
    },
    "path": {
      "type": "object",
      "required": ["d"],
      "additionalProperties": false,
      "properties": {
        "d": {
          "type": "string",
          "minLength": 1
        },
        "fill": {
          "type": "string"
        },
        "stroke": {
          "type": "string"
        },
        "strokeWidth": {
          "type": "number"
        },
        "strokeLineCap": {
          "type": "string",
          "enum": ["butt", "round", "square"]
        },
        "strokeLineJoin": {
          "type": "string",
          "enum": ["arcs", "bevel", "miter", "miter-clip", "round"]
        },
        "strokeDasharray": {
          "type": "string"
        },
        "fillRule": {
          "type": "string",
          "enum": ["nonzero", "evenodd"]
        },
        "clipRule": {
          "type": "string",
          "enum": ["nonzero", "evenodd"]
        }
      }
    }
  }
}

