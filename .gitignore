tmp/

# Codegen emission manifest — per-run record of generated artifacts
# consumed by validate:generated. Per-machine, regenerated on each
# `pnpm run generate`.
packages/ds-codegen/.emission-manifest.json

# Per-contributor ephemeral docs (roadmaps, working notes, in-flight
# thinking). Consumer-facing docs/ is durable reference only; anything
# with authority roadmap/working/ephemeral lives here off-tree. Spec:
# docs/specifications/document_governance.md, "Location" section.
docs/internal/

# Claude runtime state — hooks/ and settings.json are tracked,
# everything else under .claude/ is per-machine.
CLAUDE.md
.claude/logs/
.claude/sessions/
.claude/plans/
.claude/worktrees/
.claude/transcripts/
.claude/cache/

# Codex agent runtime — per-machine agent tooling (hooks, worktrees,
# claim oracle). Not repo source; eslint also ignores .codex/** (see
# eslint.config.js). AGENTS.md is left untracked, not gitignored.
.codex/

# CAWS runtime state — specs and waivers are tracked,
# state/cache/event logs are per-machine.
**/.caws/state/
**/.caws/cache/
**/.caws/events.jsonl

# Local screenshots from DevTools-MCP review sessions
.tmp-review/

# >>> caws gitignore (managed, v2) >>>
# Ephemeral CAWS runtime/local state — never tracked. Authority state
# (.caws/specs/, .caws/policy.yaml, .caws/waivers/) is intentionally NOT
# listed here so it stays versioned. Managed by `caws init`; edits inside
# these markers are overwritten on the next init.
.caws/worktrees/
.caws/worktrees.json
.caws/agents.json
.caws/leases/
.caws/cache/
.caws/sessions/
.caws/state/
.caws/duplication-cache.json
.caws/events.jsonl
.caws/events.jsonl.lock
tmp/guard-strikes-*.json
# <<< caws gitignore <<<
